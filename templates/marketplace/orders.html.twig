{% extends 'base.html.twig' %}

{% block title %}My Orders - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.48), rgba(0, 0, 0, 0.48)), url('{{ asset('adventure/img/g3.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .order-card {
            border: 1px solid #eee;
            border-radius: 10px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 18px;
            margin-bottom: 12px;
        }

        .status-pill {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-confirmed { background: #dcfce7; color: #166534; }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-cancelled { background: #fee2e2; color: #991b1b; }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:14px;">
            <a href="{{ path('app_marketplace_buyer') }}" class="genric-btn default-border">Back To Shop</a>
        </div>
        <h1 class="mb-10">My Orders</h1>
        <p class="mb-0">Track all your marketplace purchases in one place.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}

        {% if factures is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No orders yet</h4>
                <p class="text-muted mb-3">Your purchase history will appear here.</p>
                <a href="{{ path('app_marketplace_buyer') }}" class="primary-btn text-uppercase">Start Shopping</a>
            </div>
        {% else %}
            {% for f in factures %}
                <article class="order-card">
                    <div class="d-flex flex-wrap justify-content-between" style="gap:12px;">
                        <div>
                            <small class="text-muted d-block">Order #{{ f.id_facture }}</small>
                            <h4 class="mb-1">{{ f.total_price|number_format(2) }} TND</h4>
                            <small class="text-muted">{{ f.date_facture|date('d M Y, H:i') }}</small>
                        </div>
                        <div class="text-right">
                            <span class="status-pill status-{{ f.delivery_status }}">
                                {% if f.delivery_status == 'confirmed' %}Confirmed
                                {% elseif f.delivery_status == 'cancelled' %}Cancelled
                                {% else %}Pending{% endif %}
                            </span>
                            <div class="mt-2"><span class="badge badge-light">{{ f.payment_method == 'online' ? 'Online' : 'Cash' }}</span></div>
                        </div>
                    </div>
                    <div class="mt-3 pt-3" style="border-top:1px solid #eee;">
                        <a href="{{ path('app_marketplace_order_detail', {id: f.id_facture}) }}" class="genric-btn info-border small">View Details</a>
                    </div>
                </article>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endblock %}