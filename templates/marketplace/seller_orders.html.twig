{% extends 'base.html.twig' %}
{% block title %}Manage Orders — WanderLust{% endblock %}
{% block content %}
<div class="mp-topnav">
    <div class="mp-topnav-inner">
        <a href="{{ path('app_marketplace_seller') }}" class="mp-nav-btn mp-nav-back">← My Products</a>
        <span style="font-size:16px; font-weight:700; color:white;">📦 Orders Management</span>
        <a href="{{ path('app_marketplace_seller_dashboard') }}" class="mp-nav-btn">📊 Dashboard</a>
    </div>
</div>
<div class="mp-page-content" style="max-width:1000px;">
    {% for msg in app.flashes('success') %}<div class="flash flash-success">{{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="flash flash-error">{{ msg }}</div>{% endfor %}

    {% if orders is empty %}
        <div class="mp-empty">
            <div style="font-size:64px; margin-bottom:16px;">📦</div>
            <h3>No orders yet</h3>
            <p>Orders containing your products will appear here.</p>
        </div>
    {% else %}
        <div style="display:flex; flex-direction:column; gap:16px;">
            {% for order in orders %}
            <div style="background:white; border-radius:16px; border:1px solid var(--gray-200); padding:24px; box-shadow:var(--shadow-sm);">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px;">
                    <div>
                        <div style="font-size:12px; color:var(--gray-400); margin-bottom:4px;">Order #{{ order.id_facture }}</div>
                        <div style="font-weight:700; font-size:16px; color:var(--gray-900); margin-bottom:4px;">
                            👤 {{ order.full_name ?? 'N/A' }}
                            {% if order.city %} · 📍 {{ order.city }}{% endif %}
                            {% if order.phone %} · 📞 {{ order.phone }}{% endif %}
                        </div>
                        <div style="font-size:13px; color:var(--gray-500);">
                            📅 {{ order.date_facture|date('d M Y, H:i') }} ·
                            {{ order.payment_method == 'online' ? '💳 Online' : '💵 Cash' }} ·
                            <strong style="color:#2E7D32;">{{ order.total_price|number_format(2) }} TND</strong>
                        </div>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
                        <span class="mp-status-badge {{ order.delivery_status }}">
                            {% if order.delivery_status == 'confirmed' %}✅ Confirmed
                            {% elseif order.delivery_status == 'cancelled' %}❌ Cancelled
                            {% else %}⏳ Pending{% endif %}
                        </span>
                        {% if order.delivery_status == 'pending' %}
                        <div style="display:flex; gap:8px;">
                            <form method="POST" action="{{ path('app_marketplace_seller_order_confirm', {id: order.id_facture}) }}">
                                <button type="submit" class="mp-btn-primary" style="padding:8px 16px; font-size:12px;">✅ Confirm</button>
                            </form>
                            <form method="POST" action="{{ path('app_marketplace_seller_order_cancel', {id: order.id_facture}) }}"
                                  onsubmit="return confirm('Cancel this order?')">
                                <button type="submit" class="mp-btn-danger" style="padding:8px 16px; font-size:12px;">❌ Cancel</button>
                            </form>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
