{% extends 'base.html.twig' %}
{% block title %}Manage Orders — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-amber-50/60 via-white to-slate-50 px-4 py-8">
<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
        <a href="{{ path('app_marketplace_seller') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">My Products</a>
        <h1 class="text-xl font-heading font-bold text-slate-900">Orders Management</h1>
        <a href="{{ path('app_marketplace_seller_dashboard') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Dashboard</a>
    </div>

    {% for msg in app.flashes('success') %}<div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">{{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800">{{ msg }}</div>{% endfor %}

    {% if orders is empty %}
        <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center">
            <h3 class="text-lg font-heading font-bold text-slate-900">No orders yet</h3>
            <p class="mt-2 text-sm text-slate-600">Orders containing your products will appear here.</p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for order in orders %}
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                        <div class="text-xs text-slate-500">Order #{{ order.id_facture }}</div>
                        <div class="mt-1 text-sm font-semibold text-slate-900">
                            {{ order.full_name ?? 'N/A' }}
                            {% if order.city %} · {{ order.city }}{% endif %}
                            {% if order.phone %} · {{ order.phone }}{% endif %}
                        </div>
                        <div class="mt-1 text-sm text-slate-600">
                            {{ order.date_facture|date('d M Y, H:i') }} ·
                            {{ order.payment_method == 'online' ? 'Online' : 'Cash' }} ·
                            <strong class="text-emerald-700">{{ order.total_price|number_format(2) }} TND</strong>
                        </div>
                    </div>
                    <div class="flex flex-col items-end gap-2">
                        <span class="mp-status-badge {{ order.delivery_status }}">
                            {% if order.delivery_status == 'confirmed' %}✅ Confirmed
                            {% elseif order.delivery_status == 'cancelled' %}❌ Cancelled
                            {% else %}⏳ Pending{% endif %}
                        </span>
                        {% if order.delivery_status == 'pending' %}
                        <div class="flex gap-2">
                            <form method="POST" action="{{ path('app_marketplace_seller_order_confirm', {id: order.id_facture}) }}">
                                <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-2 text-xs font-bold text-white transition-colors hover:bg-emerald-700">Confirm</button>
                            </form>
                            <form method="POST" action="{{ path('app_marketplace_seller_order_cancel', {id: order.id_facture}) }}"
                                  onsubmit="return confirm('Cancel this order?')">
                                <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-xs font-bold text-white transition-colors hover:bg-rose-700">Cancel</button>
                            </form>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
</section>
{% endblock %}
