{% extends 'base.html.twig' %}

{% block title %}Manage Orders - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/g4.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .order-card {
            border: 1px solid #eee;
            border-radius: 10px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 18px;
            margin-bottom: 12px;
        }

        .status-pill {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-confirmed { background: #dcfce7; color: #166534; }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-cancelled { background: #fee2e2; color: #991b1b; }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:14px;">
            <a href="{{ path('app_marketplace_seller') }}" class="genric-btn default-border">My Products</a>
            <a href="{{ path('app_marketplace_seller_dashboard') }}" class="genric-btn info-border">Dashboard</a>
        </div>
        <h1 class="mb-10">Orders Management</h1>
        <p class="mb-0">Process buyer orders that include your products.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        {% if orders is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No orders yet</h4>
                <p class="text-muted mb-0">Orders containing your products will appear here.</p>
            </div>
        {% else %}
            {% for order in orders %}
                <article class="order-card">
                    <div class="d-flex flex-wrap justify-content-between" style="gap:12px;">
                        <div>
                            <small class="text-muted d-block">Order #{{ order.id_facture }}</small>
                            <p class="mb-1"><strong>{{ order.full_name ?? 'N/A' }}</strong>{% if order.city %} · {{ order.city }}{% endif %}{% if order.phone %} · {{ order.phone }}{% endif %}</p>
                            <small class="text-muted">{{ order.date_facture|date('d M Y, H:i') }} · {{ order.payment_method == 'online' ? 'Online' : 'Cash' }} · <strong>{{ order.total_price|number_format(2) }} TND</strong></small>
                        </div>
                        <div class="text-right">
                            <span class="status-pill status-{{ order.delivery_status }}">
                                {% if order.delivery_status == 'confirmed' %}Confirmed
                                {% elseif order.delivery_status == 'cancelled' %}Cancelled
                                {% else %}Pending{% endif %}
                            </span>
                            {% if order.delivery_status == 'pending' %}
                                <div class="mt-2 d-flex" style="gap:8px; justify-content:flex-end;">
                                    <form method="POST" action="{{ path('app_marketplace_seller_order_confirm', {id: order.id_facture}) }}">
                                        <button type="submit" class="genric-btn success small">Confirm</button>
                                    </form>
                                    <form method="POST" action="{{ path('app_marketplace_seller_order_cancel', {id: order.id_facture}) }}" onsubmit="return confirm('Cancel this order?')">
                                        <button type="submit" class="genric-btn danger small">Cancel</button>
                                    </form>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endblock %}