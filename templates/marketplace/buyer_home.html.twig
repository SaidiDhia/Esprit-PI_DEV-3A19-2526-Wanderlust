{% extends 'base.html.twig' %}

{% block title %}Shop - WanderLust Marketplace{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.48), rgba(0, 0, 0, 0.48)), url('{{ asset('adventure/img/slider1.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .market-filter {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.06);
            padding: 18px;
            margin-bottom: 26px;
        }

        .market-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .market-card .thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .market-body {
            padding: 16px;
            flex: 1;
        }

        .market-actions {
            border-top: 1px solid #f0f0f0;
            padding: 14px 16px;
        }

        .type-pill {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .type-rent { background: #fef3c7; color: #92400e; }
        .type-sale { background: #dcfce7; color: #166534; }
        .stock-pill { font-size: 12px; }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Buyer Space</h1>
        <p class="mb-20">Find gear, compare offers, and order in a few clicks.</p>
        <div class="d-flex flex-wrap" style="gap:10px;">
            <a href="{{ path('app_marketplace') }}" class="genric-btn default-border">Marketplace Home</a>
            <a href="{{ path('app_marketplace_orders') }}" class="genric-btn info-border">My Orders</a>
            <a href="{{ path('app_marketplace_cart') }}" class="primary-btn text-uppercase">Cart ({{ cartCount }})</a>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <form method="GET" action="{{ path('app_marketplace_buyer') }}" class="market-filter">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="small text-uppercase">Search</label>
                    <input type="text" name="search" value="{{ search }}" placeholder="Search products" class="form-control">
                </div>
                <div class="col-md-2 mb-3">
                    <label class="small text-uppercase">Category</label>
                    <select name="category" class="form-control">
                        <option value="all">All</option>
                        <option value="camping"  {% if category == 'camping'  %}selected{% endif %}>Camping</option>
                        <option value="hiking"   {% if category == 'hiking'   %}selected{% endif %}>Hiking</option>
                        <option value="beach"    {% if category == 'beach'    %}selected{% endif %}>Beach</option>
                        <option value="nature"   {% if category == 'nature'   %}selected{% endif %}>Nature</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3">
                    <label class="small text-uppercase">Type</label>
                    <select name="type" class="form-control">
                        <option value="all">All</option>
                        <option value="For Sale" {% if type == 'For Sale' %}selected{% endif %}>For Sale</option>
                        <option value="For Rent" {% if type == 'For Rent' %}selected{% endif %}>For Rent</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3">
                    <label class="small text-uppercase">Sort</label>
                    <select name="sort" class="form-control">
                        <option value="">Newest</option>
                        <option value="low" {% if sort == 'low' %}selected{% endif %}>Price Low</option>
                        <option value="high" {% if sort == 'high' %}selected{% endif %}>Price High</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3 d-flex align-items-end" style="gap:8px;">
                    <button type="submit" class="genric-btn primary w-100">Search</button>
                    <a href="{{ path('app_marketplace_buyer') }}" class="genric-btn default w-100 text-center">Reset</a>
                </div>
            </div>
        </form>

        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        {% if products is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No products found</h4>
                <p class="text-muted mb-0">Try another search or clear filters.</p>
            </div>
        {% else %}
            <div class="row">
                {% for p in products %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="market-card w-100">
                            {% if p.image %}
                                <img src="{{ p.image }}" alt="{{ p.title }}" class="thumb" onerror="this.src='https://dummyimage.com/600x420/d1d5db/64748b&text=No+Photo'">
                            {% else %}
                                <img src="{{ asset('adventure/img/g6.jpg') }}" alt="No image" class="thumb">
                            {% endif %}

                            <div class="market-body">
                                <div class="mb-2">
                                    <span class="type-pill {{ p.type == 'For Rent' ? 'type-rent' : 'type-sale' }}">{{ p.type }}</span>
                                </div>
                                <h5 class="mb-1">{{ p.title }}</h5>
                                <small class="text-muted d-block mb-2 text-uppercase">{{ p.category ?: 'General' }}</small>
                                <p class="text-muted mb-2">{{ p.description|slice(0, 95) }}{% if p.description|length > 95 %}...{% endif %}</p>
                                <p class="mb-2"><strong>{{ p.price|number_format(2) }} TND</strong></p>
                                {% if p.available_quantity > 0 %}
                                    <span class="badge badge-success stock-pill">In stock: {{ p.available_quantity }}</span>
                                {% else %}
                                    <span class="badge badge-danger stock-pill">Out of stock</span>
                                {% endif %}
                            </div>

                            <div class="market-actions">
                                <a href="{{ path('app_marketplace_product_details', {id: p.id}) }}" class="genric-btn info-border small">View Details</a>
                                {% if p.available_quantity > 0 %}
                                    <form method="POST" action="{{ path('app_marketplace_cart_add') }}" class="mt-2 d-flex" style="gap:8px;">
                                        <input type="hidden" name="product_id" value="{{ p.id }}">
                                        <input type="number" name="quantity" value="1" min="1" max="{{ p.available_quantity }}" class="form-control" style="max-width:88px;">
                                        <button type="submit" class="genric-btn primary small">Add To Cart</button>
                                    </form>
                                {% else %}
                                    <button type="button" disabled class="genric-btn disable small mt-2">Unavailable</button>
                                {% endif %}
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}