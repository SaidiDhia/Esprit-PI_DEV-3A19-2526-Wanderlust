{% extends 'base.html.twig' %}
{% block title %}Shop — WanderLust Marketplace{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-slate-50 via-white to-sky-50/50 px-4 py-8">
    <div class="mx-auto max-w-7xl space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.26em] text-sky-700">Marketplace</p>
                    <h1 class="mt-2 text-2xl font-heading font-bold text-slate-900 sm:text-3xl">Buyer Space</h1>
                    <p class="mt-2 text-sm text-slate-600">Find gear, compare offers, and order in a few clicks.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="{{ path('app_marketplace') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Home</a>
                    <a href="{{ path('app_marketplace_orders') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">My Orders</a>
                    <a href="{{ path('app_marketplace_cart') }}" class="rounded-xl bg-sky-600 px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-sky-700">Cart ({{ cartCount }})</a>
                </div>
            </div>

            <form method="GET" action="{{ path('app_marketplace_buyer') }}" class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-6">
                <input type="text" name="search" value="{{ search }}" placeholder="Search products" class="xl:col-span-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">

                <select name="category" class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">
                    <option value="all">All categories</option>
                    <option value="camping"  {% if category == 'camping'  %}selected{% endif %}>Camping</option>
                    <option value="hiking"   {% if category == 'hiking'   %}selected{% endif %}>Hiking</option>
                    <option value="beach"    {% if category == 'beach'    %}selected{% endif %}>Beach</option>
                    <option value="nature"   {% if category == 'nature'   %}selected{% endif %}>Nature</option>
                </select>

                <select name="type" class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">
                    <option value="all">All types</option>
                    <option value="For Sale" {% if type == 'For Sale' %}selected{% endif %}>For Sale</option>
                    <option value="For Rent" {% if type == 'For Rent' %}selected{% endif %}>For Rent</option>
                </select>

                <select name="sort" class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">
                    <option value="">Newest</option>
                    <option value="low" {% if sort == 'low' %}selected{% endif %}>Price low to high</option>
                    <option value="high" {% if sort == 'high' %}selected{% endif %}>Price high to low</option>
                </select>

                <div class="flex gap-2">
                    <button type="submit" class="flex-1 rounded-xl bg-slate-900 px-3 py-2 text-sm font-bold text-white transition-colors hover:bg-slate-800">Search</button>
                    <a href="{{ path('app_marketplace_buyer') }}" class="flex-1 rounded-xl border border-slate-300 bg-white px-3 py-2 text-center text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Reset</a>
                </div>
            </form>
        </div>

        {% for msg in app.flashes('success') %}
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800">{{ msg }}</div>
        {% endfor %}

        {% if products is empty %}
            <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center">
                <h3 class="text-lg font-heading font-bold text-slate-900">No products found</h3>
                <p class="mt-2 text-sm text-slate-600">Try another search or clear filters.</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {% for p in products %}
                    <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                        <div class="relative h-52 bg-slate-100">
                            {% if p.image %}
                                <img src="{{ p.image }}" alt="{{ p.title }}" class="h-full w-full object-cover" onerror="this.src='https://dummyimage.com/600x420/d1d5db/64748b&text=No+Photo'">
                            {% else %}
                                <div class="flex h-full items-center justify-center text-sm font-semibold text-slate-400">No image</div>
                            {% endif %}
                            <span class="absolute left-3 top-3 rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider {{ p.type == 'For Rent' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' }}">{{ p.type }}</span>
                        </div>

                        <div class="space-y-3 p-4">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-500">{{ p.category ?: 'General' }}</p>
                                    <h3 class="mt-1 text-lg font-heading font-bold text-slate-900">{{ p.title }}</h3>
                                </div>
                                <p class="text-lg font-heading font-bold text-slate-900">{{ p.price|number_format(2) }} TND</p>
                            </div>
                            <p class="text-sm text-slate-600">{{ p.description|slice(0, 95) }}{% if p.description|length > 95 %}...{% endif %}</p>

                            <div class="flex items-center justify-between border-t border-slate-100 pt-3">
                                {% if p.available_quantity > 0 %}
                                    <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">In stock: {{ p.available_quantity }}</span>
                                {% else %}
                                    <span class="rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700">Out of stock</span>
                                {% endif %}
                                <a href="{{ path('app_marketplace_product_details', {id: p.id}) }}" class="text-sm font-semibold text-sky-700 hover:text-sky-800">View details</a>
                            </div>

                            {% if p.available_quantity > 0 %}
                                <form method="POST" action="{{ path('app_marketplace_cart_add') }}" class="flex gap-2">
                                    <input type="hidden" name="product_id" value="{{ p.id }}">
                                    <input type="number" name="quantity" value="1" min="1" max="{{ p.available_quantity }}" class="w-20 rounded-xl border border-slate-200 bg-slate-50 px-2 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">
                                    <button type="submit" class="flex-1 rounded-xl bg-slate-900 px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-slate-800">Add to cart</button>
                                </form>
                            {% else %}
                                <button type="button" disabled class="w-full cursor-not-allowed rounded-xl bg-slate-200 px-4 py-2 text-sm font-semibold text-slate-500">Unavailable</button>
                            {% endif %}
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% endblock %}
