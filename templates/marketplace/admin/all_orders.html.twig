{% extends 'base.html.twig' %}
{% block title %}All Orders — Admin{% endblock %}
{% block content %}

<div class="admin-topnav">
    <div class="admin-topnav-inner">
        <a href="{{ path('app_marketplace_admin') }}" class="admin-nav-btn">⬅ Admin Home</a>
        <span class="admin-nav-title">🚚 Orders Management — All Users</span>
        <div style="display:flex; gap:10px;">
            <a href="{{ path('app_marketplace_admin_dashboard') }}" class="admin-nav-btn">📊 Dashboard</a>
            <a href="{{ path('app_marketplace_admin_factures') }}" class="admin-nav-btn">🧾 Factures</a>
        </div>
    </div>

    <!-- Filters -->
    <div class="admin-filter-bar">
        <form method="GET" action="{{ path('app_marketplace_admin_orders') }}" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; width:100%;">
            <select name="user_filter" class="admin-select">
                <option value="all">👤 All Buyers</option>
                {% for uid in buyerIds %}
                    <option value="{{ uid }}" {% if userFilter == uid %}selected{% endif %}>{{ uid }}</option>
                {% endfor %}
            </select>
            <select name="status" class="admin-select">
                <option value="all">📋 All Statuses</option>
                <option value="pending"   {% if statusFilter == 'pending'   %}selected{% endif %}>⏳ Pending</option>
                <option value="confirmed" {% if statusFilter == 'confirmed' %}selected{% endif %}>✅ Confirmed</option>
                <option value="cancelled" {% if statusFilter == 'cancelled' %}selected{% endif %}>❌ Cancelled</option>
            </select>
            <button type="submit" class="admin-btn-primary">🔍 Filter</button>
            <a href="{{ path('app_marketplace_admin_orders') }}" class="admin-btn-ghost">🔄 Reset</a>
            <span style="margin-left:auto; color:rgba(255,255,255,0.7); font-size:13px;">
                {{ orders|length }} order{{ orders|length != 1 ? 's' : '' }}
            </span>
        </form>
    </div>
</div>

<div class="admin-page-content">

    {% for msg in app.flashes('success') %}<div class="flash flash-success">{{ msg }}</div>{% endfor %}
    {% for msg in app.flashes('error') %}<div class="flash flash-error">{{ msg }}</div>{% endfor %}

    {% if orders is empty %}
        <div class="mp-empty">
            <div style="font-size:64px; margin-bottom:16px;">🚚</div>
            <h3>No orders found</h3>
            <p>Try adjusting your filters.</p>
        </div>
    {% else %}
        <div style="display:flex; flex-direction:column; gap:16px;">
            {% for order in orders %}
            <div class="admin-order-card">
                <!-- Order Header -->
                <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; margin-bottom:14px;">
                    <div>
                        <div style="display:flex; gap:10px; align-items:center; margin-bottom:4px;">
                            <span style="font-size:12px; color:var(--gray-400);">Order #{{ order.id_facture }}</span>
                            <span style="background:var(--blue-pale); color:var(--blue-primary); font-size:11px; font-weight:700; padding:2px 10px; border-radius:20px;">
                                👤 {{ order.user_id }}
                            </span>
                        </div>
                        <div style="font-family:var(--font-display); font-size:18px; font-weight:700; color:var(--gray-900); margin-bottom:4px;">
                            {{ order.total_price|number_format(2) }} TND
                        </div>
                        <div style="font-size:13px; color:var(--gray-500);">
                            📅 {{ order.date_facture|date('d M Y, H:i') }}
                            · {{ order.payment_method == 'online' ? '💳 Online' : '💵 Cash on Delivery' }}
                            {% if order.full_name %} · 👤 {{ order.full_name }}{% endif %}
                            {% if order.city %} · 📍 {{ order.city }}{% endif %}
                        </div>
                    </div>

                    <!-- Status + Actions -->
                    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:8px;">
                        <span class="mp-status-badge {{ order.delivery_status }}">
                            {% if order.delivery_status == 'confirmed' %}✅ Confirmed
                            {% elseif order.delivery_status == 'cancelled' %}❌ Cancelled
                            {% else %}⏳ Pending{% endif %}
                        </span>
                        <div style="display:flex; gap:8px;">
                            {% if order.delivery_status == 'pending' %}
                                <form method="POST" action="{{ path('app_marketplace_admin_order_confirm', {id: order.id_facture}) }}">
                                    <button type="submit" class="admin-btn-confirm">✅ Confirm</button>
                                </form>
                                <form method="POST" action="{{ path('app_marketplace_admin_order_cancel', {id: order.id_facture}) }}"
                                      onsubmit="return confirm('Cancel order #{{ order.id_facture }}?')">
                                    <button type="submit" class="admin-btn-cancel">❌ Cancel</button>
                                </form>
                            {% elseif order.delivery_status == 'confirmed' %}
                                <form method="POST" action="{{ path('app_marketplace_admin_order_cancel', {id: order.id_facture}) }}"
                                      onsubmit="return confirm('Force-cancel confirmed order #{{ order.id_facture }}? This cannot be undone.')">
                                    <button type="submit" class="admin-btn-cancel" style="font-size:11px; padding:5px 12px;">⚡ Force Cancel</button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <!-- Order Items (collapsible) -->
                {% if order.items is defined and order.items is not empty %}
                <details style="border-top:1px solid var(--gray-100); padding-top:12px;">
                    <summary style="cursor:pointer; font-size:13px; font-weight:600; color:var(--gray-700); list-style:none; display:flex; align-items:center; gap:6px;">
                        📦 {{ order.items|length }} item{{ order.items|length != 1 ? 's' : '' }} — click to expand
                    </summary>
                    <div style="margin-top:10px; display:flex; flex-direction:column; gap:8px;">
                        {% for item in order.items %}
                        <div style="display:flex; gap:12px; align-items:center; padding:8px; background:var(--gray-50); border-radius:8px; font-size:13px;">
                            {% if item.product_image %}
                                <img src="{{ item.product_image }}" style="width:40px; height:40px; object-fit:cover; border-radius:6px;" onerror="this.style.display='none'">
                            {% endif %}
                            <div style="flex:1;">
                                <span style="font-weight:600;">{{ item.product_title }}</span>
                                {% if item.seller_id %}<span style="color:var(--gray-400); font-size:11px; margin-left:6px;">by {{ item.seller_id }}</span>{% endif %}
                            </div>
                            <span style="color:var(--gray-500);">× {{ item.quantity }}</span>
                            <span style="font-weight:700; color:var(--blue-primary);">{{ (item.price * item.quantity)|number_format(2) }} TND</span>
                        </div>
                        {% endfor %}
                    </div>
                </details>
                {% endif %}
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
.admin-order-card {
    background: white; border-radius: 14px;
    border: 1px solid var(--gray-200);
    padding: 20px; box-shadow: var(--shadow-sm);
    transition: all 0.2s;
}
.admin-order-card:hover { box-shadow: var(--shadow-md); border-color: rgba(29,78,216,0.15); }
.admin-btn-confirm {
    background: #059669; color: white;
    border: none; border-radius: 8px;
    padding: 7px 14px; font-size: 12px;
    font-weight: 600; cursor: pointer;
    font-family: var(--font-body);
    transition: all 0.2s;
}
.admin-btn-confirm:hover { background: #047857; transform: translateY(-1px); }
.admin-btn-cancel {
    background: #EF4444; color: white;
    border: none; border-radius: 8px;
    padding: 7px 14px; font-size: 12px;
    font-weight: 600; cursor: pointer;
    font-family: var(--font-body);
    transition: all 0.2s;
}
.admin-btn-cancel:hover { background: #DC2626; transform: translateY(-1px); }
details summary::-webkit-details-marker { display: none; }
</style>
{% endblock %}
