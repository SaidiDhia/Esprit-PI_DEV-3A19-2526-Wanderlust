{% extends 'base.html.twig' %}
{% block title %}Admin Panel — WanderLust{% endblock %}

{% block stylesheets %}
<style>
:root{--blue-primary:#1D4ED8;--blue-light:#3B82F6;--blue-pale:#EFF6FF;--blue-dark:#1e3a8a;--gray-50:#F9FAFB;--gray-100:#F3F4F6;--gray-200:#E5E7EB;--gray-400:#9CA3AF;--gray-500:#6B7280;--gray-700:#374151;--gray-900:#111827;--shadow-sm:0 1px 3px rgba(0,0,0,0.06);--shadow-md:0 4px 16px rgba(0,0,0,0.10);--shadow-lg:0 8px 32px rgba(29,78,216,0.12);--font-display:'Playfair Display',serif;--font-body:'DM Sans',sans-serif;}
/* shared mp classes needed in admin too */
.mp-btn-outline{background:white;color:var(--blue-primary);padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;font-family:var(--font-body);border:1.5px solid var(--blue-primary);cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;}
.mp-btn-outline:hover{background:var(--blue-pale);}
.mp-btn-danger{background:#EF4444;color:white;padding:8px 16px;border-radius:8px;font-size:12px;font-weight:600;font-family:var(--font-body);border:none;cursor:pointer;transition:all 0.2s;}
.mp-btn-danger:hover{background:#DC2626;}
.mp-card-img{position:relative;height:160px;overflow:hidden;background:var(--gray-100);}
.mp-card-img img{width:100%;height:100%;object-fit:cover;}
.mp-card-img-placeholder{display:flex;align-items:center;justify-content:center;height:100%;font-size:48px;}
.mp-type-badge{position:absolute;top:10px;left:10px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.mp-type-badge.sale{background:#E8F5E9;color:#2E7D32;}.mp-type-badge.rent{background:#E3F2FD;color:#1565C0;}
.mp-card-body{padding:14px 16px;flex:1;}.mp-card-category{font-size:11px;color:var(--gray-400);margin-bottom:5px;}
.mp-card-title{font-family:var(--font-display);font-size:15px;font-weight:700;color:var(--gray-900);margin-bottom:6px;line-height:1.3;}
.mp-card-desc{font-size:12px;color:var(--gray-500);line-height:1.5;margin-bottom:8px;}
.mp-card-price{font-family:var(--font-display);font-size:20px;font-weight:800;color:#2E7D32;}
.mp-card-footer{padding:12px 16px;border-top:1px solid var(--gray-100);display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.mp-empty{text-align:center;padding:80px 40px;color:var(--gray-400);}
.mp-empty h3{font-family:var(--font-display);font-size:22px;color:var(--gray-700);margin-bottom:8px;}.mp-empty p{font-size:14px;margin:0;}
.flash{padding:12px 20px;border-radius:10px;font-size:14px;font-weight:500;margin-bottom:12px;}
.flash-success{background:#D1FAE5;color:#065F46;border:1px solid #6EE7B7;}
.flash-error{background:#FEE2E2;color:#991B1B;border:1px solid #FCA5A5;}
.mp-status-badge{padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;display:inline-block;}
.mp-status-badge.confirmed{background:#D1FAE5;color:#065F46;}.mp-status-badge.pending{background:#FEF3C7;color:#92400E;}.mp-status-badge.cancelled{background:#FEE2E2;color:#991B1B;}
.mp-form-card{background:white;border-radius:16px;border:1px solid var(--gray-200);padding:36px;box-shadow:var(--shadow-sm);}
.mp-form-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;padding-bottom:16px;border-bottom:1px solid var(--gray-100);}
.mp-form-header h2{font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--gray-900);margin:0;}
.mp-form-group{margin-bottom:18px;}.mp-form-label{display:block;font-size:13px;font-weight:600;color:var(--gray-700);margin-bottom:7px;}
.mp-form-input{width:100%;padding:11px 14px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:14px;font-family:var(--font-body);color:var(--gray-700);outline:none;transition:border-color 0.2s,box-shadow 0.2s;box-sizing:border-box;}
.mp-form-input:focus{border-color:var(--blue-light);box-shadow:0 0 0 3px rgba(59,130,246,0.12);}
.mp-btn-primary{background:var(--blue-primary);color:white;padding:9px 20px;border-radius:20px;font-size:13px;font-weight:600;font-family:var(--font-body);border:none;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;}
.mp-btn-primary:hover{background:var(--blue-dark);color:white;}
.mp-btn-ghost{background:rgba(255,255,255,0.15);color:white;padding:9px 16px;border-radius:20px;font-size:13px;font-weight:500;font-family:var(--font-body);border:1px solid rgba(255,255,255,0.3);cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;}
/* Admin specific */
.admin-topnav{background:linear-gradient(135deg,#0f2460,#1D4ED8);position:sticky;top:0;z-index:90;box-shadow:0 3px 16px rgba(0,0,0,0.25);border-bottom:2px solid rgba(255,200,0,0.4);}
.admin-topnav-inner{display:flex;align-items:center;justify-content:space-between;padding:13px 24px;gap:12px;}
.admin-nav-title{font-size:15px;font-weight:700;color:white;font-family:var(--font-body);}
.admin-nav-btn{background:rgba(255,255,255,0.12);color:white;text-decoration:none;padding:7px 16px;border-radius:20px;font-size:12px;font-weight:600;font-family:var(--font-body);border:none;cursor:pointer;transition:background 0.2s;white-space:nowrap;display:inline-block;}
.admin-nav-btn:hover{background:rgba(255,255,255,0.25);color:white;}
.admin-btn-orange{background:#FF6F00!important;font-weight:700;}
.admin-btn-orange:hover{background:#E65100!important;}
.admin-filter-bar{display:flex;align-items:center;padding:10px 24px;background:rgba(0,0,0,0.2);gap:10px;flex-wrap:wrap;border-top:1px solid rgba(255,255,255,0.1);}
.admin-input{padding:8px 14px;border-radius:20px;border:none;font-size:13px;font-family:var(--font-body);outline:none;flex:1;}
.admin-select{padding:8px 12px;border-radius:20px;border:none;font-size:13px;font-family:var(--font-body);outline:none;background:white;cursor:pointer;}
.admin-btn-primary{background:#FFB300;color:#1a1a1a;padding:8px 18px;border-radius:20px;font-size:13px;font-weight:700;font-family:var(--font-body);border:none;cursor:pointer;transition:all 0.2s;}
.admin-btn-primary:hover{background:#FF8F00;transform:translateY(-1px);}
.admin-btn-ghost{background:rgba(255,255,255,0.12);color:white;padding:8px 14px;border-radius:20px;font-size:13px;font-weight:500;font-family:var(--font-body);border:1px solid rgba(255,255,255,0.25);cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.2s;}
.admin-btn-ghost:hover{background:rgba(255,255,255,0.25);color:white;}
.admin-page-content{max-width:1300px;margin:0 auto;padding:32px 24px;}
</style>
{% endblock %}

{% block content %}

<div class="admin-page-bg">
    <div class="admin-home-wrap">

        <!-- Admin Badge -->
        <div class="admin-badge">🔐 ADMIN PANEL</div>

        <h1 class="admin-home-title">WanderLust<br><span>Administration</span></h1>
        <p class="admin-home-sub">Full control over products, orders, users & platform stats.</p>

        <!-- Cards -->
        <div class="admin-home-grid">

            <a href="{{ path('app_marketplace_product_management') }}" class="admin-home-card">
                <div class="ahc-icon" style="background:linear-gradient(135deg,#1D4ED8,#7C3AED);">📦</div>
                <div class="ahc-title">Product Management</div>
                <div class="ahc-desc">View, add, edit & delete all products from all sellers. Reassign userId.</div>
                <span class="ahc-arrow">Manage →</span>
            </a>

            <a href="{{ path('app_marketplace_admin_dashboard') }}" class="admin-home-card">
                <div class="ahc-icon" style="background:linear-gradient(135deg,#059669,#10B981);">📊</div>
                <div class="ahc-title">Global Dashboard</div>
                <div class="ahc-desc">Platform-wide stats: revenue, orders, top products — broken down per user.</div>
                <span class="ahc-arrow">View stats →</span>
            </a>

            <a href="{{ path('app_marketplace_admin_orders') }}" class="admin-home-card">
                <div class="ahc-icon" style="background:linear-gradient(135deg,#F59E0B,#EF4444);">🚚</div>
                <div class="ahc-title">Orders Management</div>
                <div class="ahc-desc">See all orders from all buyers. Confirm or cancel any order instantly.</div>
                <span class="ahc-arrow">Manage orders →</span>
            </a>

            <a href="{{ path('app_marketplace_admin_factures') }}" class="admin-home-card">
                <div class="ahc-icon" style="background:linear-gradient(135deg,#8B5CF6,#EC4899);">🧾</div>
                <div class="ahc-title">All Factures</div>
                <div class="ahc-desc">Complete invoice history across all users. Filter by buyer or status.</div>
                <span class="ahc-arrow">View factures →</span>
            </a>

        </div>

        
    </div>
</div>

<style>
.admin-page-bg {
    min-height: calc(100vh - 145px);
    background: linear-gradient(135deg, #0f2460 0%, #1D4ED8 50%, #1565C0 100%);
    display: flex; align-items: center; justify-content: center; padding: 48px 24px;
}
.admin-home-wrap { text-align: center; width: 100%; max-width: 860px; }
.admin-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3);
    color: white; font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
    padding: 6px 18px; border-radius: 30px; margin-bottom: 24px;
}
.admin-home-title {
    font-family: var(--font-display); font-size: clamp(32px,6vw,56px);
    font-weight: 900; color: white; line-height: 1.1; margin-bottom: 12px;
}
.admin-home-title span { color: #93C5FD; font-style: italic; }
.admin-home-sub { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 48px; }

.admin-home-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px;
}
.admin-home-card {
    background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 20px; padding: 28px 20px; text-decoration: none; color: white;
    display: flex; flex-direction: column; align-items: center;
    transition: all 0.3s; backdrop-filter: blur(8px);
}
.admin-home-card:hover {
    background: rgba(255,255,255,0.18); transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3); color: white;
}
.ahc-icon {
    width: 64px; height: 64px; border-radius: 18px;
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; margin-bottom: 14px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}
.ahc-title { font-weight: 700; font-size: 16px; margin-bottom: 8px; }
.ahc-desc { font-size: 12px; opacity: 0.7; line-height: 1.5; flex: 1; margin-bottom: 16px; }
.ahc-arrow { font-size: 12px; font-weight: 700; color: #93C5FD; }
</style>
{% endblock %}
