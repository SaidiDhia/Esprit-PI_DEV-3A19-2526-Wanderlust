{% extends 'base.html.twig' %}
{% block title %}Checkout — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-slate-50 via-white to-sky-50/40 px-4 py-8">
<div class="mx-auto max-w-6xl space-y-6">
    <div class="flex items-center justify-between">
        <a href="{{ path('app_marketplace_cart') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Back to Cart</a>
        <h1 class="text-xl font-heading font-bold text-slate-900">Checkout</h1>
    </div>

    {% for msg in app.flashes('error') %}
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800">{{ msg }}</div>
    {% endfor %}

    <form method="POST" action="{{ path('app_marketplace_checkout_confirm') }}">
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
            <div class="space-y-4">
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h3 class="mb-4 text-lg font-heading font-bold text-slate-900">Delivery Address</h3>
                    <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                        <div class="space-y-1 md:col-span-2"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Full Name</label><input type="text" name="full_name" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Phone</label><input type="tel" name="phone" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Email</label><input type="email" name="email" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1 md:col-span-2"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Address</label><input type="text" name="address" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">City</label><input type="text" name="city" required class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Postal Code</label><input type="text" name="postal_code" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></div>
                        <div class="space-y-1 md:col-span-2"><label class="text-xs font-bold uppercase tracking-wider text-slate-500">Notes</label><textarea name="notes" rows="2" class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm"></textarea></div>
                    </div>
                </div>

                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <h3 class="mb-4 text-lg font-heading font-bold text-slate-900">Payment Method</h3>
                    <label class="mp-payment-option selected" id="opt-cash">
                        <input type="radio" name="payment_method" value="cash" checked onchange="selectPayment(this)">
                        <div>
                            <div style="font-weight:700;">Cash on Delivery</div>
                            <div style="font-size:12px; color:var(--gray-400);">Stock is reserved until order confirmation.</div>
                        </div>
                    </label>
                    <label class="mp-payment-option" id="opt-online" style="margin-top:12px;">
                        <input type="radio" name="payment_method" value="online" onchange="selectPayment(this)">
                        <div>
                            <div style="font-weight:700;">Pay Online</div>
                            <div style="font-size:12px; color:var(--gray-400);">Instant confirmation and stock deduction.</div>
                        </div>
                    </label>
                </div>
            </div>

            <div>
                <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm xl:sticky xl:top-24">
                    <h3 class="mb-4 text-lg font-heading font-bold text-slate-900">Order Summary</h3>
                    <div class="space-y-3">
                        {% for item in cartItems %}
                            <div class="flex items-center gap-3">
                                <div class="h-12 w-12 overflow-hidden rounded-lg bg-slate-100">
                                    {% if item.image %}
                                        <img src="{{ item.image }}" alt="{{ item.product_title }}" class="h-full w-full object-cover" onerror="this.parentNode.innerHTML='No image'">
                                    {% endif %}
                                </div>
                                <div class="flex-1 text-sm">
                                    <p class="font-semibold text-slate-900">{{ item.product_title }}</p>
                                    <p class="text-xs text-slate-500">x {{ item.cart_qty }}</p>
                                </div>
                                <p class="text-sm font-bold text-slate-900">{{ (item.price * item.cart_qty)|number_format(2) }} TND</p>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="mt-5 border-t border-slate-100 pt-4">
                        <div class="mb-4 flex items-center justify-between">
                            <span class="text-sm font-semibold text-slate-700">Total</span>
                            <span class="text-2xl font-heading font-bold text-slate-900">{{ total|number_format(2) }} TND</span>
                        </div>
                        <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-emerald-700">Place Order</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
</section>

{% endblock %}
{% block javascripts %}
<script>
function selectPayment(radio) {
    document.querySelectorAll('.mp-payment-option').forEach(el => el.classList.remove('selected'));
    radio.closest('.mp-payment-option').classList.add('selected');
}
</script>
{% endblock %}
