{% extends 'base.html.twig' %}

{% block title %}{{ product.title }} - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/g2.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .product-panel {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

        .product-image-wrap {
            background: #f7f7f7;
            padding: 20px;
            height: 100%;
        }

        .product-image-wrap img {
            width: 100%;
            height: 100%;
            min-height: 320px;
            object-fit: cover;
            border-radius: 10px;
        }

        .detail-pill {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 11px;
            text-transform: uppercase;
            font-weight: 700;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:14px;">
            <a href="{{ path('app_marketplace_buyer') }}" class="genric-btn default-border">Back To Products</a>
            <a href="{{ path('app_marketplace_cart') }}" class="genric-btn info-border">Cart ({{ cartCount }})</a>
        </div>
        <h1 class="mb-10">{{ product.title }}</h1>
        <p class="mb-0">Detailed product view with inventory-aware purchase flow.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}

        <article class="product-panel">
            <div class="row no-gutters">
                <div class="col-lg-6">
                    <div class="product-image-wrap">
                        {% if product.image %}
                            <img src="{{ product.image }}" alt="{{ product.title }}" onerror="this.src='https://dummyimage.com/800x600/d1d5db/64748b&text=No+Photo'">
                        {% else %}
                            <img src="{{ asset('adventure/img/g5.jpg') }}" alt="No image">
                        {% endif %}
                    </div>
                </div>
                <div class="col-lg-6">
                    <div style="padding:24px;">
                        <div class="mb-3">
                            <span class="detail-pill" style="background: {{ product.type == 'For Rent' ? '#fef3c7' : '#dcfce7' }}; color: {{ product.type == 'For Rent' ? '#92400e' : '#166534' }};">{{ product.type }}</span>
                            <span class="detail-pill" style="background:#f1f5f9; color:#334155;">{{ product.category }}</span>
                        </div>

                        <h3 class="mb-3">{{ product.title }}</h3>
                        <p class="text-muted mb-3">{{ product.description }}</p>

                        <div class="d-flex justify-content-between align-items-center" style="border-top:1px solid #eee; border-bottom:1px solid #eee; padding:14px 0; margin:16px 0;">
                            <h4 class="mb-0">{{ product.price|number_format(2) }} TND</h4>
                            {% if product.available_quantity > 0 %}
                                <span class="badge badge-success">{{ product.available_quantity }} available</span>
                            {% else %}
                                <span class="badge badge-danger">Out of stock</span>
                            {% endif %}
                        </div>

                        {% if product.available_quantity > 0 %}
                            <form method="POST" action="{{ path('app_marketplace_cart_add') }}">
                                <input type="hidden" name="product_id" value="{{ product.id }}">
                                <div class="form-group">
                                    <label>Quantity</label>
                                    <input type="number" name="quantity" value="1" min="1" max="{{ product.available_quantity }}" class="form-control" style="max-width:140px;">
                                </div>
                                <button type="submit" class="primary-btn text-uppercase" style="border:none;">Add To Cart</button>
                            </form>
                        {% else %}
                            <button type="button" class="genric-btn disable" disabled>Unavailable</button>
                        {% endif %}

                        <p class="small text-muted mt-3 mb-0">Listed on {{ product.created_date|date('d M Y') }}</p>
                    </div>
                </div>
            </div>
        </article>
    </div>
</section>
{% endblock %}