{% extends 'base.html.twig' %}
{% block title %}{{ product.title }} — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-sky-50/70 via-white to-white px-4 py-8">
    <div class="mx-auto max-w-6xl space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-2">
            <a href="{{ path('app_marketplace_buyer') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Back to Products</a>
            <a href="{{ path('app_marketplace_cart') }}" class="rounded-xl bg-sky-600 px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-sky-700">Cart ({{ cartCount }})</a>
        </div>

        {% for msg in app.flashes('success') %}
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">{{ msg }}</div>
        {% endfor %}

        <article class="grid grid-cols-1 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm lg:grid-cols-2">
            <div class="min-h-[340px] bg-slate-100 p-6">
                {% if product.image %}
                    <img src="{{ product.image }}" alt="{{ product.title }}" class="h-full w-full rounded-2xl object-cover" onerror="this.src='https://dummyimage.com/800x600/d1d5db/64748b&text=No+Photo'">
                {% else %}
                    <div class="flex h-full min-h-[300px] items-center justify-center rounded-2xl border border-dashed border-slate-300 text-sm font-semibold text-slate-400">No image available</div>
                {% endif %}
            </div>

            <div class="space-y-4 p-6">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider {{ product.type == 'For Rent' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' }}">{{ product.type }}</span>
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-wider text-slate-600">{{ product.category }}</span>
                </div>

                <h1 class="text-2xl font-heading font-bold text-slate-900">{{ product.title }}</h1>
                <p class="text-sm leading-relaxed text-slate-600">{{ product.description }}</p>

                <div class="flex items-center justify-between border-y border-slate-100 py-4">
                    <p class="text-3xl font-heading font-bold text-slate-900">{{ product.price|number_format(2) }} TND</p>
                    {% if product.available_quantity > 0 %}
                        <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">{{ product.available_quantity }} available</span>
                    {% else %}
                        <span class="rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700">Out of stock</span>
                    {% endif %}
                </div>

                {% if product.available_quantity > 0 %}
                    <form method="POST" action="{{ path('app_marketplace_cart_add') }}" class="space-y-3">
                        <input type="hidden" name="product_id" value="{{ product.id }}">
                        <div class="flex items-center gap-3">
                            <label class="text-sm font-semibold text-slate-700">Quantity</label>
                            <input type="number" name="quantity" value="1" min="1" max="{{ product.available_quantity }}" class="w-24 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100">
                        </div>
                        <button type="submit" class="w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-bold text-white transition-colors hover:bg-slate-800">Add to Cart</button>
                    </form>
                {% else %}
                    <button type="button" disabled class="w-full cursor-not-allowed rounded-xl bg-slate-200 px-4 py-3 text-sm font-semibold text-slate-500">Unavailable</button>
                {% endif %}

                <p class="text-xs text-slate-500">Listed on {{ product.created_date|date('d M Y') }}</p>
            </div>
        </article>
    </div>
</section>

{% endblock %}
