{% extends 'base.html.twig' %}

{% block title %}My Cart - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.48), rgba(0, 0, 0, 0.48)), url('{{ asset('adventure/img/g1.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .cart-item {
            border: 1px solid #eee;
            border-radius: 10px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 14px;
            margin-bottom: 12px;
        }

        .cart-thumb {
            width: 84px;
            height: 84px;
            border-radius: 8px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .cart-summary {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 20px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:14px;">
            <a href="{{ path('app_marketplace_buyer') }}" class="genric-btn default-border">Back To Products</a>
        </div>
        <h1 class="mb-10">Shopping Cart</h1>
        <p class="mb-0">Review quantities and proceed to checkout.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        {% if cartItems is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>Your cart is empty</h4>
                <p class="text-muted mb-3">Add products to get started.</p>
                <a href="{{ path('app_marketplace_buyer') }}" class="primary-btn text-uppercase">Browse Products</a>
            </div>
        {% else %}
            {% for item in cartItems %}
                <div class="cart-item d-flex flex-wrap align-items-center" style="gap:12px;">
                    <div>
                        {% if item.image %}
                            <img src="{{ item.image }}" alt="{{ item.product_title }}" class="cart-thumb" onerror="this.src='https://dummyimage.com/600x420/d1d5db/64748b&text=No+Photo'">
                        {% else %}
                            <img src="{{ asset('adventure/img/g6.jpg') }}" alt="No image" class="cart-thumb">
                        {% endif %}
                    </div>

                    <div style="flex:1; min-width:200px;">
                        <h5 class="mb-1">{{ item.product_title }}</h5>
                        <small class="text-muted d-block">{{ item.category }} · {{ item.type }}</small>
                        <strong>{{ item.price|number_format(2) }} TND</strong>
                    </div>

                    <form method="POST" action="{{ path('app_marketplace_cart_update') }}" class="d-flex align-items-center" style="gap:8px;">
                        <input type="hidden" name="product_id" value="{{ item.product_id }}">
                        <input type="number" name="quantity" value="{{ item.cart_qty }}" min="1" max="{{ item.stock }}" class="form-control" style="width:88px;" onchange="this.form.submit()">
                    </form>

                    <div style="min-width:130px; text-align:right;">
                        <small class="text-muted d-block">Subtotal</small>
                        <strong>{{ (item.price * item.cart_qty)|number_format(2) }} TND</strong>
                    </div>

                    <form method="POST" action="{{ path('app_marketplace_cart_remove', {productId: item.product_id}) }}">
                        <button type="submit" class="genric-btn danger-border small">Remove</button>
                    </form>
                </div>
            {% endfor %}

            <div class="cart-summary">
                <div class="d-flex flex-wrap justify-content-between align-items-center" style="gap:12px;">
                    <div>
                        <p class="text-muted mb-1">Total ({{ cartItems|length }} item{{ cartItems|length > 1 ? 's' : '' }})</p>
                        <h3 class="mb-0">{{ total|number_format(2) }} TND</h3>
                    </div>
                    <a href="{{ path('app_marketplace_checkout') }}" class="primary-btn text-uppercase">Proceed To Checkout</a>
                </div>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}