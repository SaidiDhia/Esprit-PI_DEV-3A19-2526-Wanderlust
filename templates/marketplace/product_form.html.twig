{% extends 'base.html.twig' %}

{% block title %}{{ action }} Product - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/slider5.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .form-card {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 22px;
        }

        .preview-wrap {
            border: 1px solid #e5e7eb;
            border-radius: 10px;
            background: #f8fafc;
            padding: 10px;
        }

        .preview-wrap img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-radius: 8px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:14px;">
            <a href="{{ path('app_marketplace_seller') }}" class="genric-btn default-border">Back To Seller</a>
        </div>
        <h1 class="mb-10">{{ action == 'Add' ? 'Add Product' : 'Edit Product' }}</h1>
        <p class="mb-0">Fill in product details and publish it to your seller catalog.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container" style="max-width: 900px;">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        <form method="POST" action="{{ action == 'Add' ? path('app_marketplace_product_add') : path('app_marketplace_product_edit', {id: product.id}) }}" class="form-card">
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label>Title</label>
                    <input type="text" name="title" required placeholder="Sahara Backpack 60L" value="{{ product ? product.title : '' }}" class="form-control">
                </div>

                <div class="col-md-6 mb-3">
                    <label>Type</label>
                    <select name="type" required class="form-control">
                        <option value="For Sale" {{ product and product.type == 'For Sale' ? 'selected' : '' }}>For Sale</option>
                        <option value="For Rent" {{ product and product.type == 'For Rent' ? 'selected' : '' }}>For Rent</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label>Category</label>
                    <select name="category" required class="form-control">
                        <option value="camping" {{ product and product.category == 'camping' ? 'selected' : '' }}>Camping</option>
                        <option value="hiking" {{ product and product.category == 'hiking' ? 'selected' : '' }}>Hiking</option>
                        <option value="beach" {{ product and product.category == 'beach' ? 'selected' : '' }}>Beach</option>
                        <option value="nature" {{ product and product.category == 'nature' ? 'selected' : '' }}>Nature</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label>Price (TND)</label>
                    <input type="number" name="price" required step="0.01" min="0" value="{{ product ? product.price : '' }}" class="form-control">
                </div>
                <div class="col-md-6 mb-3">
                    <label>Quantity</label>
                    <input type="number" name="quantity" required min="0" value="{{ product ? product.quantity : '' }}" class="form-control">
                </div>

                <div class="col-md-12 mb-3">
                    <label>Description</label>
                    <textarea name="description" required rows="4" placeholder="Describe your product..." class="form-control">{{ product ? product.description : '' }}</textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <label>Image URL (optional)</label>
                    <input type="url" name="image" id="imageUrlInput" placeholder="https://..." value="{{ product ? product.image : '' }}" class="form-control">
                </div>

                <div class="col-md-12 mb-3">
                    <div id="imgPreview" class="preview-wrap {{ product and product.image ? '' : 'd-none' }}">
                        <img id="previewImg" src="{{ product ? product.image : '' }}" alt="Product preview" onerror="this.style.display='none'">
                    </div>
                </div>

                <div class="col-md-12 d-flex justify-content-end" style="gap:10px;">
                    <a href="{{ path('app_marketplace_seller') }}" class="genric-btn default-border">Cancel</a>
                    <button type="submit" class="primary-btn text-uppercase" style="border:none;">{{ action == 'Add' ? 'Add Product' : 'Save Changes' }}</button>
                </div>
            </div>
        </form>
    </div>
</section>
{% endblock %}

{% block javascripts %}
<script>
document.getElementById('imageUrlInput')?.addEventListener('input', function() {
    const preview = document.getElementById('imgPreview');
    const img = document.getElementById('previewImg');

    if (!preview || !img) {
        return;
    }

    if (this.value) {
        img.src = this.value;
        preview.classList.remove('d-none');
        img.style.display = 'block';
    } else {
        preview.classList.add('d-none');
    }
});
</script>
{% endblock %}