{% extends 'base.html.twig' %}
{% block title %}Order #{{ facture.id_facture }} — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-slate-50 via-white to-emerald-50/30 px-4 py-8">
<div class="mx-auto max-w-5xl space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-2">
        <a href="{{ path('app_marketplace_orders') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Back to Orders</a>
        <h1 class="text-xl font-heading font-bold text-slate-900">Invoice #{{ facture.id_facture }}</h1>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <h3 class="mb-3 text-base font-heading font-bold text-slate-900">Order Info</h3>
            <div class="space-y-2 text-sm text-slate-700">
                <p><span class="text-slate-500">Order #:</span> <strong>{{ facture.id_facture }}</strong></p>
                <p><span class="text-slate-500">Date:</span> <strong>{{ facture.date_facture|date('d M Y, H:i') }}</strong></p>
                <p><span class="text-slate-500">Payment:</span> <strong>{{ facture.payment_method == 'online' ? 'Online' : 'Cash on Delivery' }}</strong></p>
                <p><span class="text-slate-500">Status:</span> <span class="mp-status-badge {{ facture.delivery_status }}">{% if facture.delivery_status == 'confirmed' %}✅ Confirmed{% elseif facture.delivery_status == 'cancelled' %}❌ Cancelled{% else %}⏳ Pending{% endif %}</span></p>
            </div>
        </div>
        {% if address %}
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <h3 class="mb-3 text-base font-heading font-bold text-slate-900">Delivery Address</h3>
                <div class="space-y-1 text-sm text-slate-700">
                    <p><strong>{{ address.full_name }}</strong></p>
                    <p>{{ address.phone }}</p>
                    <p>{{ address.address }}, {{ address.city }} {{ address.postal_code }}</p>
                    {% if address.notes %}<p class="text-slate-500">{{ address.notes }}</p>{% endif %}
                </div>
            </div>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h3 class="mb-4 text-base font-heading font-bold text-slate-900">Items Ordered</h3>
        <div class="space-y-3">
            {% for item in items %}
                <div class="flex items-center gap-3 border-b border-slate-100 pb-3">
                    <div class="h-14 w-14 overflow-hidden rounded-lg bg-slate-100">
                        {% if item.product_image %}
                            <img src="{{ item.product_image }}" alt="{{ item.product_title }}" class="h-full w-full object-cover" onerror="this.parentNode.innerHTML='No image'">
                        {% endif %}
                    </div>
                    <div class="flex-1">
                        <p class="text-sm font-semibold text-slate-900">{{ item.product_title }}</p>
                        <p class="text-xs text-slate-500">x {{ item.quantity }} · {{ item.price|number_format(2) }} TND each</p>
                    </div>
                    <p class="text-sm font-bold text-sky-700">{{ (item.price * item.quantity)|number_format(2) }} TND</p>
                </div>
            {% endfor %}
        </div>
        <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-3">
            <span class="text-sm font-semibold text-slate-700">Total</span>
            <span class="text-2xl font-heading font-bold text-slate-900">{{ facture.total_price|number_format(2) }} TND</span>
        </div>
    </div>
</div>
</section>
{% endblock %}
