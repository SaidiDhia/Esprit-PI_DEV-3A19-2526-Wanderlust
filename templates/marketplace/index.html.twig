{% extends 'base.html.twig' %}

{% block title %}Marketplace — WanderLust{% endblock %}

{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-br from-sky-100 via-white to-emerald-100 px-4 py-10">
    <div class="mx-auto max-w-6xl">
        <div class="rounded-3xl border border-slate-200 bg-white p-8 text-center shadow-sm">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-sky-700">Marketplace</p>
            <h1 class="mt-3 text-4xl font-heading font-bold text-slate-900">Welcome to WanderLust Commerce</h1>
            <p class="mx-auto mt-3 max-w-2xl text-sm text-slate-600">Browse as buyer or manage as seller with the unified marketplace experience.</p>

            <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                <a href="{{ path('app_marketplace_buyer') }}" class="rounded-xl bg-slate-900 px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-slate-800">Open Buyer Space</a>
                <a href="{{ path('app_marketplace_seller') }}" class="rounded-xl bg-amber-600 px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-amber-700">Open Seller Space</a>
            </div>
        </div>
    </div>
</section>

{% endblock %}
