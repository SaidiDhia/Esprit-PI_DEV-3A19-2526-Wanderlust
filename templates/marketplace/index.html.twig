{% extends 'base.html.twig' %}

{% block title %}Marketplace — WanderLust{% endblock %}

{% block content %}

<div class="page-hero">
    <div class="page-hero-content">
        <span class="page-hero-icon">🛒</span>
        <h1 class="page-hero-title">Marketplace</h1>
        <p class="page-hero-subtitle">Gear up for your next adventure. Shop authentic local crafts, travel essentials, and unique souvenirs.</p>
    </div>
</div>

<div class="page-content">

    <!-- Filter Tabs -->
    <div class="marketplace-filters">
        <button class="filter-btn active">All Products</button>
        <button class="filter-btn">🎒 Travel Gear</button>
        <button class="filter-btn">🎨 Crafts & Art</button>
        <button class="filter-btn">🌿 Local Products</button>
        <button class="filter-btn">📸 Photography</button>
        <button class="filter-btn">👗 Fashion</button>
    </div>

    <!-- Products Grid -->
    <div class="content-grid">

        <div class="card" style="position:relative;">
            <span class="product-badge">SALE</span>
            <div class="card-img" style="background: linear-gradient(135deg,#F59E0B,#EF4444); font-size:52px;">🎒</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★★</span>
                    <span>4.9 · 87 sold</span>
                </div>
                <div class="card-title">Sahara Explorer Backpack</div>
                <p class="card-text">60L waterproof backpack designed for desert treks. Includes solar charging panel and anti-sand zippers.</p>
            </div>
            <div class="card-footer">
                <div>
                    <span class="price">340 TND</span>
                    <span style="font-size:13px; color:var(--gray-400); text-decoration:line-through; margin-left:8px;">420 TND</span>
                </div>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

        <div class="card">
            <div class="card-img" style="background: linear-gradient(135deg,#8B5CF6,#EC4899); font-size:52px;">🏺</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★☆</span>
                    <span>4.6 · 203 sold</span>
                </div>
                <div class="card-title">Handmade Ceramic Tajine Set</div>
                <p class="card-text">Authentic hand-painted Tunisian tajine set. Crafted by artisans in Nabeul. Food-safe glazing, dishwasher safe.</p>
            </div>
            <div class="card-footer">
                <span class="price">185 TND</span>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

        <div class="card" style="position:relative;">
            <span class="product-badge" style="background:#1D4ED8;">NEW</span>
            <div class="card-img" style="background: linear-gradient(135deg,#1D4ED8,#0EA5E9); font-size:52px;">📸</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★★</span>
                    <span>5.0 · 31 sold</span>
                </div>
                <div class="card-title">Desert Landscape Photo Print</div>
                <p class="card-text">Premium fine-art photo print of Tunisian Sahara at sunset. Available in multiple sizes. Signed by photographer.</p>
            </div>
            <div class="card-footer">
                <span class="price">95 TND</span>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

        <div class="card">
            <div class="card-img" style="background: linear-gradient(135deg,#059669,#10B981); font-size:52px;">🌿</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★☆</span>
                    <span>4.7 · 512 sold</span>
                </div>
                <div class="card-title">Organic Tunisian Olive Oil Gift Set</div>
                <p class="card-text">Premium cold-pressed extra virgin olive oil from Cap Bon estates. 3-bottle gift set with tasting notes card.</p>
            </div>
            <div class="card-footer">
                <span class="price">129 TND</span>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

        <div class="card">
            <div class="card-img" style="background: linear-gradient(135deg,#EF4444,#F59E0B); font-size:52px;">🧣</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★★</span>
                    <span>4.8 · 178 sold</span>
                </div>
                <div class="card-title">Handwoven Berber Wool Blanket</div>
                <p class="card-text">Traditional Berber pattern blanket woven by cooperative artisans. 100% natural wool. Each piece is unique.</p>
            </div>
            <div class="card-footer">
                <span class="price">220 TND</span>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

        <div class="card">
            <div class="card-img" style="background: linear-gradient(135deg,#6366F1,#8B5CF6); font-size:52px;">🧭</div>
            <div class="card-body">
                <div class="card-meta">
                    <span class="stars">★★★★☆</span>
                    <span>4.4 · 67 sold</span>
                </div>
                <div class="card-title">Vintage Brass Compass & Map Kit</div>
                <p class="card-text">Collector's edition brass compass with detailed Tunisia topographic map. Perfect for adventurers and collectors.</p>
            </div>
            <div class="card-footer">
                <span class="price">75 TND</span>
                <button class="btn btn-primary">Add to Cart</button>
            </div>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
{% endblock %}
