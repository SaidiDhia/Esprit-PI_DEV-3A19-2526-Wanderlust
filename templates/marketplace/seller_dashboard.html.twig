{% extends 'base.html.twig' %}
{% block title %}Dashboard — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-sky-50/70 via-white to-emerald-50/50 px-4 py-8">
    <div class="mx-auto max-w-6xl space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.26em] text-sky-700">Marketplace</p>
                    <h1 class="mt-2 text-2xl font-heading font-bold text-slate-900">Seller Analytics</h1>
                    <p class="mt-2 text-sm text-slate-600">Track products, orders, and confirmed revenue.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="{{ path('app_marketplace_seller') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">My Products</a>
                    <a href="{{ path('app_marketplace_seller_orders') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Orders</a>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Products</p>
                <p class="mt-2 text-3xl font-heading font-bold text-slate-900">{{ totalProducts }}</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Confirmed Orders</p>
                <p class="mt-2 text-3xl font-heading font-bold text-emerald-700">{{ totalOrders }}</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Pending Orders</p>
                <p class="mt-2 text-3xl font-heading font-bold text-amber-700">{{ pendingOrders }}</p>
            </article>
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Revenue</p>
                <p class="mt-2 text-3xl font-heading font-bold text-sky-700">{{ totalRevenue|number_format(2) }} TND</p>
            </article>
        </div>

        {% if topProducts is not empty %}
            <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="mb-4 flex items-center justify-between">
                    <h3 class="text-lg font-heading font-bold text-slate-900">Top Selling Products</h3>
                    <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Confirmed orders only</span>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full min-w-[720px] border-collapse">
                        <thead>
                        <tr class="border-b border-slate-200 text-left">
                            <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-slate-500">Product</th>
                            <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-slate-500">Sold Units</th>
                            <th class="py-3 text-xs font-bold uppercase tracking-wider text-slate-500">Revenue</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for p in topProducts %}
                            <tr class="border-b border-slate-100 align-top hover:bg-slate-50/70">
                                <td class="py-3 pr-3">
                                    <div class="flex items-center gap-3">
                                        <div class="h-12 w-12 overflow-hidden rounded-lg bg-slate-100">
                                            {% if p.image %}
                                                <img src="{{ p.image }}" alt="{{ p.title }}" class="h-full w-full object-cover" onerror="this.src='https://dummyimage.com/96x96/d1d5db/64748b&text=No+Photo'">
                                            {% endif %}
                                        </div>
                                        <p class="text-sm font-semibold text-slate-900">{{ p.title }}</p>
                                    </div>
                                </td>
                                <td class="py-3 pr-3 text-sm font-semibold text-slate-700">{{ p.sold }}</td>
                                <td class="py-3 text-sm font-bold text-sky-700">{{ p.revenue|number_format(2) }} TND</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center">
                <h3 class="text-lg font-heading font-bold text-slate-900">No sales data yet</h3>
                <p class="mt-2 text-sm text-slate-600">Confirmed orders will appear here automatically.</p>
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
