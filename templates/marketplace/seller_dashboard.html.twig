{% extends 'base.html.twig' %}
{% block title %}Dashboard — WanderLust{% endblock %}
{% block content %}
<div class="mp-topnav">
    <div class="mp-topnav-inner">
        <a href="{{ path('app_marketplace_seller') }}" class="mp-nav-btn mp-nav-back">← My Products</a>
        <span style="font-size:16px; font-weight:700; color:white;">📊 Sales Dashboard</span>
        <a href="{{ path('app_marketplace_seller_orders') }}" class="mp-nav-btn">📦 Orders</a>
    </div>
</div>
<div class="mp-page-content" style="max-width:1000px;">

    <!-- Stats Cards -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:20px; margin-bottom:32px;">
        <div class="mp-stat-card">
            <div class="mp-stat-icon">📦</div>
            <div class="mp-stat-value">{{ totalProducts }}</div>
            <div class="mp-stat-label">My Products</div>
        </div>
        <div class="mp-stat-card" style="background:linear-gradient(135deg,#059669,#10B981);">
            <div class="mp-stat-icon">✅</div>
            <div class="mp-stat-value">{{ totalOrders }}</div>
            <div class="mp-stat-label">Confirmed Orders</div>
        </div>
        <div class="mp-stat-card" style="background:linear-gradient(135deg,#F59E0B,#EF4444);">
            <div class="mp-stat-icon">⏳</div>
            <div class="mp-stat-value">{{ pendingOrders }}</div>
            <div class="mp-stat-label">Pending Orders</div>
        </div>
        <div class="mp-stat-card" style="background:linear-gradient(135deg,#7C3AED,#EC4899);">
            <div class="mp-stat-icon">💰</div>
            <div class="mp-stat-value">{{ totalRevenue|number_format(0) }}</div>
            <div class="mp-stat-label">Revenue (TND)</div>
        </div>
    </div>

    <!-- Top Products -->
    {% if topProducts is not empty %}
    <div style="background:white; border-radius:16px; border:1px solid var(--gray-200); padding:28px; box-shadow:var(--shadow-sm);">
        <h3 style="font-family:var(--font-display); font-size:20px; font-weight:700; margin-bottom:20px; padding-bottom:12px; border-bottom:1px solid var(--gray-100);">🏆 Top Selling Products</h3>
        <div style="display:flex; flex-direction:column; gap:14px;">
            {% for i, p in topProducts %}
            <div style="display:flex; gap:16px; align-items:center; padding:12px; background:var(--gray-50); border-radius:12px;">
                <div style="font-size:20px; font-weight:900; color:var(--blue-primary); min-width:32px; text-align:center;">{{ i+1 }}</div>
                <div style="width:50px; height:50px; border-radius:8px; overflow:hidden; flex-shrink:0; background:var(--gray-100);">
                    {% if p.image %}
                        <img src="{{ p.image }}" style="width:100%; height:100%; object-fit:cover;" onerror="this.parentNode.innerHTML='📦'">
                    {% else %}<div style="display:flex; align-items:center; justify-content:center; height:100%;">📦</div>{% endif %}
                </div>
                <div style="flex:1;"><div style="font-weight:700; color:var(--gray-900);">{{ p.title }}</div></div>
                <div style="text-align:right;">
                    <div style="font-size:18px; font-weight:800; color:#2E7D32;">{{ p.revenue|number_format(2) }} TND</div>
                    <div style="font-size:12px; color:var(--gray-400);">{{ p.sold }} units sold</div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
    {% else %}
    <div class="mp-empty"><div style="font-size:48px; margin-bottom:12px;">📊</div><h3>No sales data yet</h3><p>Confirmed orders will show your stats here.</p></div>
    {% endif %}
</div>
{% endblock %}
