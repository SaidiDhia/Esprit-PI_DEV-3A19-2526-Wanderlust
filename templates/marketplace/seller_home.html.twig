{% extends 'base.html.twig' %}

{% block title %}Seller Dashboard - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/slider4.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .stat-box {
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 10px;
            padding: 16px;
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
        }

        .seller-filter {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.06);
            padding: 18px;
            margin-bottom: 26px;
        }

        .seller-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .seller-card .thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .seller-body { padding: 16px; flex: 1; }
        .seller-actions { border-top: 1px solid #f0f0f0; padding: 14px 16px; }
    </style>
{% endblock %}

{% block content %}
{% set totalProducts = products|length %}
{% set totalStock = 0 %}
{% set totalReserved = 0 %}
{% for product in products %}
    {% set totalStock = totalStock + (product.quantity ?? 0) %}
    {% set totalReserved = totalReserved + (product.reserved_quantity ?? 0) %}
{% endfor %}
{% set totalAvailable = totalStock - totalReserved %}

<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Seller Space</h1>
        <p class="mb-20">Manage products, inventory, and orders from one workspace.</p>
        <div class="d-flex flex-wrap" style="gap:10px; margin-bottom:20px;">
            <a href="{{ path('app_marketplace') }}" class="genric-btn default-border">Marketplace Home</a>
            <a href="{{ path('app_marketplace_seller_orders') }}" class="genric-btn info-border">Orders</a>
            <a href="{{ path('app_marketplace_seller_dashboard') }}" class="genric-btn success-border">Stats</a>
            <a href="{{ path('app_marketplace_product_add') }}" class="primary-btn text-uppercase">Add Product</a>
        </div>

        <div class="row">
            <div class="col-md-4"><div class="stat-box"><small>Products</small><h4 class="text-white mb-0">{{ totalProducts }}</h4></div></div>
            <div class="col-md-4"><div class="stat-box"><small>Available</small><h4 class="text-white mb-0">{{ totalAvailable > 0 ? totalAvailable : 0 }}</h4></div></div>
            <div class="col-md-4"><div class="stat-box"><small>Reserved</small><h4 class="text-white mb-0">{{ totalReserved }}</h4></div></div>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <form method="GET" action="{{ path('app_marketplace_seller') }}" class="seller-filter">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="small text-uppercase">Search</label>
                    <input type="text" name="search" value="{{ search }}" placeholder="Search my products" class="form-control">
                </div>
                <div class="col-md-3 mb-3">
                    <label class="small text-uppercase">Category</label>
                    <select name="category" class="form-control">
                        <option value="all">All</option>
                        <option value="camping" {% if category == 'camping' %}selected{% endif %}>Camping</option>
                        <option value="hiking" {% if category == 'hiking' %}selected{% endif %}>Hiking</option>
                        <option value="beach" {% if category == 'beach' %}selected{% endif %}>Beach</option>
                        <option value="nature" {% if category == 'nature' %}selected{% endif %}>Nature</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <label class="small text-uppercase">Type</label>
                    <select name="type" class="form-control">
                        <option value="all">All</option>
                        <option value="For Sale" {% if type == 'For Sale' %}selected{% endif %}>For Sale</option>
                        <option value="For Rent" {% if type == 'For Rent' %}selected{% endif %}>For Rent</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3 d-flex align-items-end" style="gap:8px;">
                    <button type="submit" class="genric-btn primary w-100">Search</button>
                    <a href="{{ path('app_marketplace_seller') }}" class="genric-btn default w-100 text-center">Reset</a>
                </div>
            </div>
        </form>

        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        {% if products is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No products yet</h4>
                <p class="text-muted mb-3">Create your first listing to start selling.</p>
                <a href="{{ path('app_marketplace_product_add') }}" class="primary-btn text-uppercase">Add Product</a>
            </div>
        {% else %}
            <div class="row">
                {% for p in products %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="seller-card w-100">
                            {% if p.image %}
                                <img src="{{ p.image }}" alt="{{ p.title }}" class="thumb" onerror="this.src='https://dummyimage.com/600x420/d1d5db/64748b&text=No+Photo'">
                            {% else %}
                                <img src="{{ asset('adventure/img/g4.jpg') }}" alt="No image" class="thumb">
                            {% endif %}

                            <div class="seller-body">
                                <h5 class="mb-1">{{ p.title }}</h5>
                                <small class="text-muted d-block mb-2 text-uppercase">{{ p.category ?: 'General' }} · {{ p.type }}</small>
                                <p class="text-muted mb-2">{{ p.description|slice(0, 90) }}{% if p.description|length > 90 %}...{% endif %}</p>
                                <p class="mb-1"><strong>{{ p.price|number_format(2) }} TND</strong></p>
                                <small class="text-muted">Stock: {{ p.quantity }} | Reserved: {{ p.reserved_quantity ?? 0 }} | Available: {{ p.available_quantity }}</small>
                            </div>

                            <div class="seller-actions d-flex" style="gap:8px;">
                                <a href="{{ path('app_marketplace_product_edit', {id: p.id}) }}" class="genric-btn warning-border small">Edit</a>
                                <form method="POST" action="{{ path('app_marketplace_product_delete', {id: p.id}) }}" onsubmit="return confirm('Delete this product?')" style="display:inline;">
                                    <button type="submit" class="genric-btn danger-border small">Delete</button>
                                </form>
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}