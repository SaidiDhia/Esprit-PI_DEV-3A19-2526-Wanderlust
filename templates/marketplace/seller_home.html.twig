{% extends 'base.html.twig' %}
{% block title %}Seller Dashboard — WanderLust{% endblock %}
{% block content %}
{% set totalProducts = products|length %}
{% set totalStock = 0 %}
{% set totalReserved = 0 %}
{% for product in products %}
    {% set totalStock = totalStock + (product.quantity ?? 0) %}
    {% set totalReserved = totalReserved + (product.reserved_quantity ?? 0) %}
{% endfor %}
{% set totalAvailable = totalStock - totalReserved %}

<section class="min-h-[calc(100vh-64px)] bg-gradient-to-b from-amber-50/60 via-white to-emerald-50/60 px-4 py-8">
    <div class="mx-auto max-w-7xl space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.26em] text-amber-700">Marketplace</p>
                    <h1 class="mt-2 text-2xl font-heading font-bold text-slate-900 sm:text-3xl">Seller Space</h1>
                    <p class="mt-2 text-sm text-slate-600">Manage products, inventory, and orders from a single workspace.</p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="{{ path('app_marketplace') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Home</a>
                    <a href="{{ path('app_marketplace_seller_orders') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Orders</a>
                    <a href="{{ path('app_marketplace_seller_dashboard') }}" class="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Stats</a>
                    <a href="{{ path('app_marketplace_product_add') }}" class="rounded-xl bg-amber-600 px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-amber-700">Add Product</a>
                </div>
            </div>

            <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Products</p>
                    <p class="mt-1 text-2xl font-heading font-bold text-slate-900">{{ totalProducts }}</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">In Stock</p>
                    <p class="mt-1 text-2xl font-heading font-bold text-emerald-700">{{ totalAvailable > 0 ? totalAvailable : 0 }}</p>
                </div>
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Reserved</p>
                    <p class="mt-1 text-2xl font-heading font-bold text-amber-700">{{ totalReserved }}</p>
                </div>
            </div>

            <form method="GET" action="{{ path('app_marketplace_seller') }}" class="mt-6 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
                <input type="text" name="search" value="{{ search }}" placeholder="Search my products" class="xl:col-span-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100">
                <select name="category" class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100">
                    <option value="all">All categories</option>
                    <option value="camping" {% if category == 'camping' %}selected{% endif %}>Camping</option>
                    <option value="hiking" {% if category == 'hiking' %}selected{% endif %}>Hiking</option>
                    <option value="beach" {% if category == 'beach' %}selected{% endif %}>Beach</option>
                    <option value="nature" {% if category == 'nature' %}selected{% endif %}>Nature</option>
                </select>
                <select name="type" class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100">
                    <option value="all">All types</option>
                    <option value="For Sale" {% if type == 'For Sale' %}selected{% endif %}>For Sale</option>
                    <option value="For Rent" {% if type == 'For Rent' %}selected{% endif %}>For Rent</option>
                </select>
                <div class="flex gap-2">
                    <button type="submit" class="flex-1 rounded-xl bg-slate-900 px-3 py-2 text-sm font-bold text-white transition-colors hover:bg-slate-800">Search</button>
                    <a href="{{ path('app_marketplace_seller') }}" class="flex-1 rounded-xl border border-slate-300 bg-white px-3 py-2 text-center text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Reset</a>
                </div>
            </form>
        </div>

        {% for msg in app.flashes('success') %}
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800">{{ msg }}</div>
        {% endfor %}

        {% if products is empty %}
            <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center">
                <h3 class="text-lg font-heading font-bold text-slate-900">No products yet</h3>
                <p class="mt-2 text-sm text-slate-600">Create your first listing to start selling.</p>
                <a href="{{ path('app_marketplace_product_add') }}" class="mt-4 inline-flex rounded-xl bg-amber-600 px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-amber-700">Add Product</a>
            </div>
        {% else %}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                {% for p in products %}
                    <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
                        <div class="relative h-52 bg-slate-100">
                            {% if p.image %}
                                <img src="{{ p.image }}" alt="{{ p.title }}" class="h-full w-full object-cover" onerror="this.src='https://dummyimage.com/600x420/d1d5db/64748b&text=No+Photo'">
                            {% else %}
                                <div class="flex h-full items-center justify-center text-sm font-semibold text-slate-400">No image</div>
                            {% endif %}
                            <span class="absolute left-3 top-3 rounded-full px-3 py-1 text-[11px] font-bold uppercase tracking-wider {{ p.type == 'For Rent' ? 'bg-amber-100 text-amber-800' : 'bg-emerald-100 text-emerald-800' }}">{{ p.type }}</span>
                        </div>

                        <div class="space-y-3 p-4">
                            <div class="flex items-start justify-between gap-3">
                                <div>
                                    <p class="text-[11px] font-bold uppercase tracking-wider text-slate-500">{{ p.category ?: 'General' }}</p>
                                    <h3 class="mt-1 text-lg font-heading font-bold text-slate-900">{{ p.title }}</h3>
                                </div>
                                <p class="text-lg font-heading font-bold text-slate-900">{{ p.price|number_format(2) }} TND</p>
                            </div>

                            <p class="text-sm text-slate-600">{{ p.description|slice(0, 90) }}{% if p.description|length > 90 %}...{% endif %}</p>

                            <div class="grid grid-cols-3 gap-2 rounded-xl bg-slate-50 p-3 text-center">
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Stock</p>
                                    <p class="mt-1 text-sm font-bold text-slate-900">{{ p.quantity }}</p>
                                </div>
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Reserved</p>
                                    <p class="mt-1 text-sm font-bold text-amber-700">{{ p.reserved_quantity ?? 0 }}</p>
                                </div>
                                <div>
                                    <p class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Available</p>
                                    <p class="mt-1 text-sm font-bold text-emerald-700">{{ p.available_quantity }}</p>
                                </div>
                            </div>

                            <div class="flex gap-2 pt-1">
                                <a href="{{ path('app_marketplace_product_edit', {id: p.id}) }}" class="flex-1 rounded-xl border border-slate-300 bg-white px-3 py-2 text-center text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-50">Edit</a>
                                <form method="POST" action="{{ path('app_marketplace_product_delete', {id: p.id}) }}" onsubmit="return confirm('Delete this product?')" class="flex-1">
                                    <button type="submit" class="w-full rounded-xl bg-rose-600 px-3 py-2 text-sm font-bold text-white transition-colors hover:bg-rose-700">Delete</button>
                                </form>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% endblock %}
