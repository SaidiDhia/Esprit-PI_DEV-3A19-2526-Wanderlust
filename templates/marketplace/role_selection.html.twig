{% extends 'base.html.twig' %}
{% block title %}Marketplace — WanderLust{% endblock %}
{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-gradient-to-br from-sky-100 via-white to-emerald-100 px-4 py-10">
    <div class="mx-auto max-w-5xl space-y-8 text-center">
        <div>
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-sky-700">Marketplace</p>
            <h1 class="mt-3 text-4xl font-heading font-bold text-slate-900 sm:text-5xl">WanderLust</h1>
            <p class="mt-2 text-sm text-slate-600">Choose your mode and continue your adventure commerce flow.</p>
        </div>

        {% for msg in app.flashes('success') %}
            <div class="mx-auto max-w-2xl rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="mx-auto max-w-2xl rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-800">{{ msg }}</div>
        {% endfor %}

        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <a href="{{ path('app_marketplace_buyer') }}" class="group rounded-3xl border border-slate-200 bg-white p-8 text-left shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Buyer</p>
                <h2 class="mt-2 text-2xl font-heading font-bold text-slate-900">I want to buy</h2>
                <p class="mt-3 text-sm text-slate-600">Browse products, compare offers, add to cart, and track orders.</p>
                <span class="mt-4 inline-flex rounded-xl bg-slate-900 px-4 py-2 text-sm font-bold text-white transition-colors group-hover:bg-slate-800">Enter Buyer Space</span>
            </a>

            <a href="{{ path('app_marketplace_seller') }}" class="group rounded-3xl border border-slate-200 bg-white p-8 text-left shadow-sm transition hover:-translate-y-1 hover:shadow-md">
                <p class="text-xs font-bold uppercase tracking-wider text-slate-500">Seller</p>
                <h2 class="mt-2 text-2xl font-heading font-bold text-slate-900">I want to sell</h2>
                <p class="mt-3 text-sm text-slate-600">Manage inventory, process orders, and monitor your dashboard.</p>
                <span class="mt-4 inline-flex rounded-xl bg-amber-600 px-4 py-2 text-sm font-bold text-white transition-colors group-hover:bg-amber-700">Enter Seller Space</span>
            </a>
        </div>
    </div>
</section>
{% endblock %}
