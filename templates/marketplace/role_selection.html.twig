{% extends 'base.html.twig' %}
{% block title %}Marketplace — WanderLust{% endblock %}
{% block content %}

<div style="min-height:calc(100vh - 145px); background:#F0F4F8; display:flex; align-items:center; justify-content:center; padding:40px;">
    <div style="text-align:center; width:100%; max-width:700px;">

        <!-- Logo / Title -->
        <div style="margin-bottom:40px;">
            <div style="font-size:52px; margin-bottom:10px;">🌿</div>
            <h1 style="font-family:var(--font-display); font-size:42px; font-weight:900; color:var(--blue-primary); margin:0 0 8px;">WanderLust</h1>
            <p style="font-size:16px; color:var(--gray-400); margin:0;">Outdoor Marketplace</p>
        </div>

        <h2 style="font-size:22px; font-weight:700; color:var(--gray-700); margin-bottom:40px;">Who are you today?</h2>

        <!-- Flash messages -->
        {% for msg in app.flashes('success') %}
            <div class="flash flash-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="flash flash-error">{{ msg }}</div>
        {% endfor %}

        <!-- Role Cards -->
        <div style="display:flex; gap:40px; justify-content:center; flex-wrap:wrap;">

            <!-- BUYER -->
            <a href="{{ path('app_marketplace_buyer') }}" class="role-card">
                <div style="font-size:52px; margin-bottom:12px;">🛍️</div>
                <div style="font-size:20px; font-weight:700; color:var(--blue-primary); margin-bottom:8px;">I want to BUY</div>
                <p style="font-size:13px; color:var(--gray-400); line-height:1.5; margin-bottom:20px;">Browse products, add to cart,<br>track your orders</p>
                <span class="btn btn-primary" style="border-radius:30px; padding:10px 28px;">Enter as Buyer →</span>
            </a>

            <!-- SELLER -->
            <a href="{{ path('app_marketplace_seller') }}" class="role-card">
                <div style="font-size:52px; margin-bottom:12px;">🏪</div>
                <div style="font-size:20px; font-weight:700; color:var(--blue-primary); margin-bottom:8px;">I want to SELL</div>
                <p style="font-size:13px; color:var(--gray-400); line-height:1.5; margin-bottom:20px;">Manage products, orders,<br>view your dashboard</p>
                <span class="btn btn-primary" style="border-radius:30px; padding:10px 28px;">Enter as Seller →</span>
            </a>

        </div>
    </div>
</div>

<style>
.role-card {
    display:flex; flex-direction:column; align-items:center;
    width:240px; padding:32px 20px;
    background:white; border-radius:20px;
    border:2px solid var(--blue-primary);
    text-decoration:none;
    box-shadow:0 4px 20px rgba(0,0,0,0.08);
    transition:all 0.25s;
}
.role-card:hover {
    transform:translateY(-6px);
    box-shadow:0 12px 32px rgba(29,78,216,0.2);
    background:var(--blue-pale);
}
</style>
{% endblock %}
