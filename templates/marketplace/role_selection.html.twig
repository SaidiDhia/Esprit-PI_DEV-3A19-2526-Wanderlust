{% extends 'base.html.twig' %}

{% block title %}Marketplace - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/slider2.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .role-card {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 28px;
            height: 100%;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Marketplace</h1>
        <p class="mb-20">Choose your mode and continue your commerce adventure.</p>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for msg in app.flashes('success') %}
            <div class="alert alert-success">{{ msg }}</div>
        {% endfor %}
        {% for msg in app.flashes('error') %}
            <div class="alert alert-danger">{{ msg }}</div>
        {% endfor %}

        <div class="row">
            <div class="col-md-6 d-flex">
                <div class="role-card w-100">
                    <p class="text-uppercase small text-muted mb-2">Buyer</p>
                    <h3 class="mb-3">I Want To Buy</h3>
                    <p class="text-muted mb-4">Browse products, compare offers, add to cart, and track your orders.</p>
                    <a href="{{ path('app_marketplace_buyer') }}" class="primary-btn text-uppercase">Enter Buyer Space</a>
                </div>
            </div>
            <div class="col-md-6 d-flex">
                <div class="role-card w-100">
                    <p class="text-uppercase small text-muted mb-2">Seller</p>
                    <h3 class="mb-3">I Want To Sell</h3>
                    <p class="text-muted mb-4">Manage inventory, process orders, and monitor seller performance.</p>
                    <a href="{{ path('app_marketplace_seller') }}" class="genric-btn warning-border">Enter Seller Space</a>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}