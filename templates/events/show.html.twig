    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-top: 1px solid #dee2e6;
}

.ad-card {
    background: white;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    padding: 2rem;
    transition: all 0.3s ease;
    border: 1px solid #e9ecef;
}

.ad-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
}

.ad-header {
    margin-bottom: 2rem;
}

.ad-header h4 {
    color: #495057;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.ad-header p {
    color: #6c757d;
}

.ad-item {
    background: rgba(102, 126, 234, 0.05);
    border: 2px solid rgba(102, 126, 234, 0.1);
    border-radius: 15px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    height: 100%;
}

.ad-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.15);
    border-color: rgba(102, 126, 234, 0.2);
}

.ad-logo {
    margin-bottom: 1rem;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.ad-logo i {
    font-size: 2rem;
}

.ad-item h6 {
    color: #495057;
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.ad-item p {
    color: #6c757d;
    margin-bottom: 1rem;
    font-size: 0.9rem;
}

.ad-disclaimer {
    background: rgba(108, 117, 125, 0.05);
    border-top: 1px solid #dee2e6;
    border-radius: 10px;
    padding: 1rem;
    margin-top: 2rem;
}

.ad-disclaimer p {
    color: #6c757d;
    font-size: 0.8rem;
    line-height: 1.4;
}
</style>
{% endblock %}
