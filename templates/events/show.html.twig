{% extends 'base.html.twig' %}

{% block title %}Détails Événement - {{ event.lieu }}{% endblock %}

{% block stylesheets %}
{{ parent() }}

<!-- Open Graph Meta Tags -->
<meta property="og:title" content="{{ event.lieu }} - Wanderlust" />
<meta property="og:type" content="website" />
<meta property="og:url" content="{{ app.request.uri }}" />
{% if event.images|length > 0 %}
<meta property="og:image" content="{{ absolute_url(asset('uploads/events/' ~ event.images|first.imagePath)) }}" />
{% endif %}
<meta property="og:description" content="Découvrez cet événement exceptionnel organisé par {{ event.organisateur }}. Ne ratez pas ça !" />

<style>
    .module-hero {
        background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('{{ event.images|length > 0 ? asset("uploads/events/" ~ event.images|first.imagePath) : asset("adventure/img/slider2.jpg") }}') center center/cover no-repeat;
        padding: 140px 0 100px;
        color: #fff;
        margin-bottom: 50px;
    }
    .module-hero h1, .module-hero p { color: #fff; }
    
    .show-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        padding: 2.5rem;
        margin-bottom: 30px;
    }

    .carousel-container {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        height: 450px;
        background: #f7f7f7;
    }
    
    .carousel-track {
        display: flex;
        transition: transform 0.5s ease-in-out;
        height: 100%;
    }
    
    .carousel-slide {
        min-width: 100%;
        height: 100%;
    }
    
    .carousel-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .carousel-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255,255,255,0.8);
        border: none;
        width: 40px; height: 40px;
        border-radius: 50%;
        z-index: 10;
        cursor: pointer;
    }
    .carousel-prev { left: 15px; }
    .carousel-next { right: 15px; }
    
    .carousel-indicators {
        position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%);
        display: flex; gap: 8px; z-index: 10;
    }
    .indicator {
        width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.5); border: none;
    }
    .indicator.active { background: #fff; }

    .info-list { list-style: none; padding: 0; margin: 0; }
    .info-list li {
        display: flex; justify-content: space-between; align-items: center;
        padding: 12px 0; border-bottom: 1px solid #f0f0f0;
    }
    .info-list li:last-child { border-bottom: none; }
    .info-list i { color: #f6214b; margin-right: 8px; width: 20px; text-align: center; }

    .btn-reserve {
        background: #f6214b;
        color: #fff;
        padding: 15px 30px;
        border-radius: 30px;
        font-weight: 600;
        text-transform: uppercase;
        display: block;
        text-align: center;
        transition: all 0.3s;
        margin-top: 20px;
    }
    .btn-reserve:hover { background: #d81b40; color: #fff; }

    /* Auto-discount styles */
    .price-block-show { display: inline-flex; align-items: center; gap: 8px; }
    .price-original-show { text-decoration: line-through; color: #9ca3af; font-size: 0.95rem; }
    .price-discounted-show { font-size: 1.4rem; font-weight: 800; color: #dc2626; }
    .price-normal-show { font-size: 1.2rem; font-weight: 700; color: #1a3a5c; }
    .discount-badge-show {
        background: linear-gradient(135deg, #dc2626, #f97316); color: #fff;
        font-size: 0.75rem; font-weight: 700; padding: 3px 8px; border-radius: 20px;
    }
    .promo-hint {
        background: #fff7ed; border: 1px solid #fdba74; border-radius: 8px;
        padding: 8px 12px; font-size: 0.85rem; color: #92400e; margin-top: 10px; display: none;
    }
</style>
{% endblock %}

{% block content %}
<!-- Hero Section -->
<section class="module-hero">
    <div class="container">
        <h1>{{ event.lieu }}</h1>
        <p class="mb-0">Organisé par {{ event.organisateur }}</p>
    </div>
</section>

<!-- Content -->
<section class="section-gap pt-0">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <!-- Carousel -->
                {% if event.images is not empty %}
                    <div class="show-card p-0 mb-4">
                        <div class="carousel-container">
                            <button class="carousel-nav carousel-prev" onclick="changeSlide(-1)"><i class="fa fa-chevron-left"></i></button>
                            <button class="carousel-nav carousel-next" onclick="changeSlide(1)"><i class="fa fa-chevron-right"></i></button>
                            <div class="carousel-track" id="carousel-track">
                                {% for image in event.images %}
                                    <div class="carousel-slide" data-index="{{ loop.index0 }}">
                                        <img src="{{ asset('uploads/events/' ~ image.imagePath) }}" alt="{{ event.lieu }}" onclick="openLightbox('{{ asset('uploads/events/' ~ image.imagePath) }}')">
                                    </div>
                                {% endfor %}
                            </div>
                            <div class="carousel-indicators">
                                {% for image in event.images %}
                                    <button class="indicator" onclick="goToSlide({{ loop.index0 }})" data-index="{{ loop.index0 }}"></button>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                {% endif %}

                <!-- Description & Activities -->
                <div class="show-card">
                    <h3 class="mb-4">À propos de l'événement</h3>
                    
                    {% if event.materielsNecessaires %}
                    <h5 class="mt-4"><i class="fa fa-shopping-bag text-danger me-2"></i>Matériels nécessaires</h5>
                    <p>{{ event.materielsNecessaires }}</p>
                    {% endif %}

                    {% if event.video %}
                    <h5 class="mt-4"><i class="fa fa-video-camera text-danger me-2"></i>Vidéo de présentation</h5>
                    <a href="{{ event.video }}" target="_blank" class="genric-btn danger circle"><i class="fa fa-play me-2"></i>Voir la vidéo</a>
                    {% endif %}

                    {% if event.activities|length > 0 %}
                    <h4 class="mt-5 mb-4">Activités incluses</h4>
                    <div class="row">
                        {% for activity in event.activities %}
                            <div class="col-md-6 mb-3">
                                <div class="border rounded p-3 d-flex align-items-center">
                                    <div class="flex-shrink-0 me-3">
                                        {% if activity.image %}
                                            <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.titre }}" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;">
                                        {% else %}
                                            <div class="bg-light rounded d-flex justify-content-center align-items-center" style="width: 60px; height: 60px;">
                                                <i class="fa fa-image text-muted"></i>
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <h6 class="mb-1">{{ activity.titre }}</h6>
                                        <small class="text-muted"><i class="fa fa-tag me-1"></i>{{ activity.categorie.value }}</small>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="col-lg-4">
                <div class="show-card">
                    <h4 class="mb-4">Détails</h4>
                    <ul class="info-list">
                        <li>
                            <span><i class="fa fa-calendar"></i> Date de début</span>
                            <strong>{{ event.dateDebut ? event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</strong>
                        </li>
                        <li>
                            <span><i class="fa fa-flag-checkered"></i> Date de fin</span>
                            <strong>{{ event.dateFin ? event.dateFin|date('d/m/Y H:i') : 'N/A' }}</strong>
                        </li>
                        <li>
                            <span><i class="fa fa-phone"></i> Contact</span>
                            <strong>{{ event.telephone }}</strong>
                        </li>
                        <li>
                            <span><i class="fa fa-envelope"></i> Email</span>
                            <strong>{{ event.email }}</strong>
                        </li>
                        <li>
                            <span><i class="fa fa-users"></i> Disponibilité</span>
                            <strong>{{ event.placesDisponibles }} / {{ event.capaciteMax }} places</strong>
                        </li>
                    </ul>

                    <div class="mt-4 p-3 bg-light rounded text-center">
                        <span class="text-muted d-block mb-1">Prix par personne</span>
                        <div class="price-block-show justify-content-center"
                             id="show-price-block"
                             data-prix="{{ event.prix }}"
                             data-places="{{ event.placesDisponibles }}"
                             data-capacite="{{ event.capaciteMax }}"
                             data-debut="{{ event.dateDebut ? event.dateDebut|date('Y-m-d') : '' }}"
                             data-status="{{ event.status.value }}">
                            <span class="price-normal-show">{{ event.prix }} TND</span>
                        </div>
                        <div class="promo-hint" id="show-promo-hint"></div>
                    </div>

                    {% set eventDate = event.getDateDebut() %}
                    {% set now = "now"|date("Y-m-d H:i:s") %}
                    
                    {% if event.placesDisponibles > 0 and eventDate > now %}
                        {% if app.user %}
                            <a href="{{ path('app_reservations_new', {'event_id': event.id}) }}" class="btn-reserve mt-4">
                                Réserver maintenant
                            </a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn-reserve mt-4" style="background: #333;">
                                Connectez-vous pour réserver
                            </a>
                        {% endif %}
                    {% else %}
                        <div class="alert alert-warning mt-4 text-center mb-0">
                            <strong><i class="fa fa-exclamation-circle"></i> Complet ou terminé</strong>
                        </div>
                    {% endif %}

                    <hr class="mt-4 mb-4">
                    
                    <!-- Share Section -->
                    <div class="text-center">
                        <h6 class="text-muted mb-3"><i class="fa fa-share-alt me-2"></i>Partager cet événement</h6>
                        <div class="d-flex justify-content-center mb-2" style="gap: 10px;">
                            <button class="btn btn-primary share-btn rounded-circle" data-network="facebook" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center;" title="Partager sur Facebook"><i class="fa fa-facebook-f"></i></button>
                            <button class="btn btn-info share-btn rounded-circle" data-network="twitter" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; color:white; background-color: #1da1f2; border-color: #1da1f2;" title="Partager sur X (Twitter)"><i class="fa fa-twitter"></i></button>
                            <button class="btn btn-success share-btn rounded-circle" data-network="whatsapp" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center; background-color: #25d366; border-color: #25d366;" title="Envoyer sur WhatsApp"><i class="fa fa-whatsapp"></i></button>
                            <button class="btn btn-secondary share-btn rounded-circle" data-network="copy" style="width:40px; height:40px; padding:0; display:flex; align-items:center; justify-content:center;" title="Copier le lien"><i class="fa fa-link"></i></button>
                        </div>
                        <small class="text-muted"><span id="share-count-display">{{ event.shareCount|default(0) }}</span> partages</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Lightbox -->
<div id="lightbox" onclick="closeLightbox()" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.9);z-index:9999;align-items:center;justify-content:center;">
    <img id="lightbox-img" src="" style="max-width:90%;max-height:90%;border-radius:15px;box-shadow:0 20px 60px rgba(0,0,0,0.5);">
</div>

<script>
    // Carousel JavaScript
    let currentSlide = 0;
    const totalSlides = {{ event.images|length }};

    function changeSlide(direction) {
        if(totalSlides <= 1) return;
        const track = document.getElementById('carousel-track');
        currentSlide += direction;
        if (currentSlide < 0) currentSlide = 0;
        if (currentSlide >= totalSlides) currentSlide = totalSlides - 1;
        track.style.transform = `translateX(-${currentSlide * 100}%)`;
        updateIndicators();
    }

    function goToSlide(index) {
        if(totalSlides <= 1) return;
        currentSlide = index;
        const track = document.getElementById('carousel-track');
        track.style.transform = `translateX(-${index * 100}%)`;
        updateIndicators();
    }

    function updateIndicators() {
        const indicators = document.querySelectorAll('.indicator');
        indicators.forEach((indicator, index) => {
            if (index === currentSlide) indicator.classList.add('active');
            else indicator.classList.remove('active');
        });
    }

    function openLightbox(src) {
        document.getElementById('lightbox').style.display = 'flex';
        document.getElementById('lightbox-img').src = src;
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        document.getElementById('lightbox').style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    updateIndicators();

    // Discount logic
    (function () {
        function calcAutoDiscount(places, capacite, dateDebutStr, statut) {
            if (statut !== 'accepte') return 0;
            if (!dateDebutStr) return 0;
            const daysLeft = (new Date(dateDebutStr) - new Date()) / 86400000;
            if (daysLeft < 0) return 0;
            if (!capacite || capacite <= 0 || places <= 0) return 0;
            if (daysLeft > 30) return 0;
            const occupancyRate = (capacite - places) / capacite;
            if (occupancyRate < 0.70) return 0;

            const occDiscount  = ((occupancyRate - 0.70) / 0.30) * 0.15;
            const timeDiscount = ((30 - daysLeft) / 30) * 0.15;
            return Math.min(Math.round((occDiscount + timeDiscount) * 100) / 100, 0.30);
        }

        document.addEventListener('DOMContentLoaded', function () {
            const block = document.getElementById('show-price-block');
            const hint = document.getElementById('show-promo-hint');
            if (!block) return;

            const prix = parseFloat(block.dataset.prix);
            const places = parseInt(block.dataset.places, 10);
            const capacite = parseInt(block.dataset.capacite, 10);
            const debut = block.dataset.debut || '';
            const statut = block.dataset.status || '';

            const discount = calcAutoDiscount(places, capacite, debut, statut);

            if (discount >= 0.05) {
                const pct = Math.round(discount * 100);
                const prixReduit = (prix * (1 - discount)).toFixed(2);
                
                block.innerHTML = `
                    <span class="price-original-show">${prix.toFixed(2)} TND</span>
                    <span class="price-discounted-show">${prixReduit} TND</span>
                    <span class="discount-badge-show">-${pct}%</span>
                `;

                const reasons = [];
                const occ = Math.round((capacite - places) / capacite * 100);
                if (occ >= 70) reasons.push(`${occ}% réservé`);
                const dLeft = Math.round((new Date(debut) - new Date()) / 86400000);
                if (dLeft >= 0 && dLeft <= 30) reasons.push(`J-${dLeft}`);

                if (hint && reasons.length > 0) {
                    hint.style.display = 'block';
                    hint.innerHTML = `🔥 Offre spéciale — ${reasons.join(' · ')}`;
                }
            } else {
                block.innerHTML = `<span class="price-normal-show">${prix.toFixed(2)} TND</span>`;
            }
        });

        // Logique de partage & AJAX
        const shareBtns = document.querySelectorAll('.share-btn');
        const shareCountDisplay = document.getElementById('share-count-display');
        const shareUrlInput = "{{ url('app_events_show', {'id': event.id}) }}";
        const shareText = "Découvrez cet événement incroyable : {{ event.lieu }} !";

        shareBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                const network = this.dataset.network;
                let finalUrl = '';

                if (network === 'facebook') {
                    finalUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrlInput)}`;
                } else if (network === 'twitter') {
                    finalUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrlInput)}&text=${encodeURIComponent(shareText)}`;
                } else if (network === 'whatsapp') {
                    finalUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(shareText + ' ' + shareUrlInput)}`;
                } else if (network === 'copy') {
                    navigator.clipboard.writeText(shareUrlInput).then(() => alert("Lien copié dans le presse-papier !"));
                }

                // Ouvrir le popup si URL existe (pas pour COPY)
                if (finalUrl !== '') {
                    window.open(finalUrl, '_blank', 'width=600,height=400');
                }

                // Incrémenter en base de données de manière asynchrone (AJAX)
                fetch("{{ path('app_events_share', {'id': event.id}) }}", {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        shareCountDisplay.textContent = data.count; // Met à jour le compteur en temps réel !
                    }
                })
                .catch(err => console.error('Erreur incrémentation partage:', err));
            });
        });
    })();
</script>
{% include '_chatbot.html.twig' with { chatContext: 'events' } %}
{% endblock %}