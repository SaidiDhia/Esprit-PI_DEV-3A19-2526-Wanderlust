<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Fiche evenement #{{ event.id }}</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            color: #0f172a;
            margin: 28px;
        }

        .header {
            border-bottom: 2px solid #2563eb;
            padding-bottom: 12px;
            margin-bottom: 18px;
        }

        .brand {
            font-size: 24px;
            font-weight: 700;
            color: #1d4ed8;
        }

        .muted {
            color: #64748b;
        }

        .title {
            margin-top: 18px;
            font-size: 18px;
            font-weight: 700;
        }

        .meta-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 14px;
        }

        .meta-table td {
            padding: 7px 0;
            vertical-align: top;
        }

        .label {
            color: #475569;
            width: 180px;
            font-weight: 600;
        }

        .status {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            background: #dcfce7;
            color: #166534;
            font-weight: 700;
            font-size: 11px;
            text-transform: uppercase;
        }

        .activities {
            margin-top: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 10px 12px;
        }

        .activities ul {
            margin: 8px 0 0;
            padding-left: 18px;
        }

        .footer {
            margin-top: 24px;
            border-top: 1px solid #cbd5e1;
            padding-top: 10px;
            font-size: 11px;
            color: #64748b;
        }
    </style>
</head>
<body>
<div class="header">
    <div class="brand">Wanderlust</div>
    <div class="muted">Fiche detaillee evenement</div>
</div>

<div class="title">Evenement #{{ event.id }}</div>

<table class="meta-table">
    <tr>
        <td class="label">Lieu</td>
        <td>{{ event.lieu ?: 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Date debut</td>
        <td>{{ event.dateDebut ? event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Date fin</td>
        <td>{{ event.dateFin ? event.dateFin|date('d/m/Y H:i') : 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Date limite inscription</td>
        <td>{{ event.dateLimiteInscription ? event.dateLimiteInscription|date('d/m/Y H:i') : 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Prix</td>
        <td>{{ event.prix|number_format(2, '.', ' ') }} TND</td>
    </tr>
    <tr>
        <td class="label">Capacite max</td>
        <td>{{ event.capaciteMax }}</td>
    </tr>
    <tr>
        <td class="label">Places disponibles</td>
        <td>{{ event.placesDisponibles }}</td>
    </tr>
    <tr>
        <td class="label">Organisateur</td>
        <td>{{ event.organisateur ?: 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Telephone</td>
        <td>{{ event.telephone ?: 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Email</td>
        <td>{{ event.email ?: 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Materiels necessaires</td>
        <td>{{ event.materielsNecessaires ?: 'N/A' }}</td>
    </tr>
    <tr>
        <td class="label">Statut</td>
        <td><span class="status">{{ event.status.value }}</span></td>
    </tr>
</table>

<div class="activities">
    <strong>Activites associees</strong>
    {% if event.activities|length > 0 %}
        <ul>
            {% for activity in event.activities %}
                <li>{{ activity.titre }}</li>
            {% endfor %}
        </ul>
    {% else %}
        <div class="muted">Aucune activite associee.</div>
    {% endif %}
</div>

<div class="footer">
    Document genere automatiquement le {{ "now"|date('d/m/Y H:i') }}.
</div>
</body>
</html>
