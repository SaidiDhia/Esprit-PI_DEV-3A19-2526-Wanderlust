{% extends 'base.html.twig' %}

{% block title %}Modifier un événement{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {# Leaflet CSS pour la carte #}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/hero-bg.jpg') }}') center/cover no-repeat;
            color: #fff;
            padding: 120px 0 80px;
            margin-bottom: 40px;
        }

        /*  Layout général  */
        .event-form-wrapper { max-width: 1100px; margin: 0 auto 60px; padding: 0 15px; }
        .form-section { background: #fff; border-radius: 12px; padding: 1.5rem 2rem; margin-bottom: 1.5rem; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .form-section h2 { font-size: 1rem; font-weight: 600; color: #000; margin-bottom: 1.25rem; padding-bottom: .5rem; border-bottom: 1px solid #e5e7eb; }
        
        /* Text color - all black for clarity */
        .form-section, .form-control, .form-group label, .form-check-label {
            color: #000 !important;
        }
        
        h1, h2, h3, h4, h5, h6 {
            color: #000 !important;
        }

        /*  Styles pour le nouveau système d'activités  */
        .activities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1rem; }
        .activity-card { display: flex; align-items: center; background: #f8f9fa; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem; position: relative; }
        .activity-card img { width: 40px; height: 40px; object-fit: cover; border-radius: 6px; margin-right: 0.75rem; }
        .activity-card-content { flex: 1; }
        .activity-card-title { font-weight: 600; font-size: 0.9rem; color: #374151; }
        .activity-card-desc { font-size: 0.8rem; color: #6b7280; margin-top: 0.2rem; }
        .activity-card-remove { position: absolute; top: 0.5rem; right: 0.5rem; background: #ef4444; color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; font-size: 0.7rem; }
        .btn-add-activity, .btn-add-images { background: #3b82f6; color: white; border: none; border-radius: 8px; padding: 0.75rem 1rem; cursor: pointer; font-size: 0.9rem; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; transition: background 0.2s; }
        .btn-add-activity:hover, .btn-add-images:hover { background: #2563eb; }
        .btn-add-images { margin-top: 0.8rem; }

        /* Styles pour la modale */
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); display: none; align-items: center; justify-content: center; z-index: 1000; }
        .modal { background: white; border-radius: 12px; max-width: 800px; max-height: 80vh; width: 90%; overflow: hidden; }
        .modal-header { padding: 1.5rem; border-bottom: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
        .modal-title { font-size: 1.2rem; font-weight: 600; }
        .modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #6b7280; }
        .modal-body { padding: 1.5rem; max-height: 60vh; overflow-y: auto; }
        .modal-activities { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
        .modal-activity { border: 2px solid #e5e7eb; border-radius: 10px; padding: 1rem; cursor: pointer; transition: all 0.2s; }
        .modal-activity:hover { border-color: #3b82f6; }
        .modal-activity.selected { border-color: #3b82f6; background: #eff6ff; }
        .modal-activity-checkbox { margin-bottom: 0.5rem; }
        .modal-activity-title { font-weight: 600; margin-bottom: 0.5rem; }
        .modal-activity-desc { font-size: 0.85rem; color: #6b7280; }
        .modal-footer { padding: 1.5rem; border-top: 1px solid #e5e7eb; display: flex; justify-content: space-between; align-items: center; }
        .modal-count { color: #6b7280; font-size: 0.9rem; }
        .modal-buttons { display: flex; gap: 1rem; }
        .modal-btn { padding: 0.5rem 1rem; border: none; border-radius: 6px; cursor: pointer; font-size: 0.9rem; }
        .modal-btn-cancel { background: #e5e7eb; color: #374151; }
        .modal-btn-confirm { background: #3b82f6; color: white; }
        .modal-btn:hover { opacity: 0.9; }

        /*  Map  */
        #event-map { height: 300px; border-radius: 10px; margin-top: .75rem; z-index: 1; }

        /*  Dates côte à côte  */
        .dates-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        @media(max-width: 600px) { .dates-row { grid-template-columns: 1fr; } }

        /*  Upload images  */
        .images-drop-zone { border: 2px dashed #d1d5db; border-radius: 10px; padding: 1.5rem; text-align: center; cursor: pointer; transition: border-color .2s; }
        .images-drop-zone:hover { border-color: #3b82f6; }
        .images-preview { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .75rem; }
        .images-preview img { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid #e5e7eb; }

        /*  Champs généraux  */
        .form-control { width: 100%; padding: .6rem .85rem; border: 1px solid #d1d5db; border-radius: 8px; font-size: .95rem; transition: border-color .2s; }
        .form-control:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
        .form-group { margin-bottom: 1.1rem; }
        .form-group label { display: block; font-size: .875rem; font-weight: 500; color: #374151; margin-bottom: .35rem; }
        .form-group .hint { font-size: .78rem; color: #9ca3af; margin-top: .25rem; }
        .form-check { display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 0.75rem; }
        .form-check-input { margin-top: 0.25rem; width: 1rem; height: 1rem; accent-color: #3b82f6; }
        .form-check-label { color: #374151; line-height: 1.4; }

        /*  Bouton submit  */
        .btn-submit { background: #3b82f6; color: #fff; padding: .75rem 2rem; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; width: 100%; transition: background .2s; }
        .btn-submit:hover { background: #2563eb; }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-2">Modifier l'événement</h1>
        <p class="mb-0">Mettez a jour les informations de votre evenement.</p>
    </div>
</section>

<div class="event-form-wrapper">
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    {{ form_errors(form) }}

    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data', 'id': 'event-form'}}) }}

        {# Section activités avec interface moderne de sélection par modale #}
        <div class="form-section">
            <h2>Activités associées</h2>
            <div class="form-group">
                <button type="button" class="btn-add-activity" id="openActivitiesModal">
                     Ajouter des activités
                </button>
                <div id="selected-activities" class="activities-grid mt-3"></div>
                <div id="selectedActivitiesInputs"></div>
            </div>
        </div>

        <div id="activitiesModal" class="modal-overlay" aria-hidden="true">
            <div class="modal" role="dialog" aria-modal="true" aria-labelledby="activitiesModalTitle">
                <div class="modal-header">
                    <div class="modal-title" id="activitiesModalTitle">Sélectionner des activités</div>
                    <button class="modal-close" id="closeModalBtn" type="button">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="text" id="searchActivities" class="form-control mb-3" placeholder="Rechercher une activite...">
                    <div class="modal-activities" id="modalActivitiesList"></div>
                </div>
                <div class="modal-footer">
                    <span class="modal-count" id="selectedCount">0 activité(s) sélectionnée(s)</span>
                    <div class="modal-buttons">
                        <button class="modal-btn modal-btn-cancel" id="cancelModalBtn" type="button">Annuler</button>
                        <button class="modal-btn modal-btn-confirm" id="confirmModalBtn" type="button">Confirmer</button>
                    </div>
                </div>
            </div>
        </div>

        {#  1. Lieu + Map  #}
        <div class="form-section">
            <h2>Lieu</h2>
            <div class="form-group">
                {{ form_label(form.lieu) }}
                {{ form_widget(form.lieu, {'attr': {'class': 'form-control lieu-input'}}) }}
                {{ form_errors(form.lieu) }}
                <p class="hint">Tapez l'adresse  la carte se positionnera automatiquement.</p>
            </div>
            {{ form_widget(form.latitude) }}
            {{ form_widget(form.longitude) }}
            <div id="event-map"></div>
        </div>

        {#  3. Dates  #}
        <div class="form-section">
            <h2>Dates et horaires</h2>
            <div class="dates-row">
                <div class="form-group">
                    {{ form_label(form.dateDebut) }}
                    {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateDebut) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dateFin) }}
                    {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateFin) }}
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.dateLimiteInscription) }}
                {{ form_widget(form.dateLimiteInscription, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.dateLimiteInscription) }}
            </div>
        </div>

        {#  4. Infos pratiques  #}
        <div class="form-section">
            <h2>Informations pratiques</h2>
            <div class="dates-row">
                <div class="form-group">
                    {{ form_label(form.prix) }}
                    {{ form_widget(form.prix, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.prix) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.capaciteMax) }}
                    {{ form_widget(form.capaciteMax, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.capaciteMax) }}
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.organisateur) }}
                {{ form_widget(form.organisateur, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.organisateur) }}
            </div>
            <div class="dates-row">
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>
            </div>
        </div>

        {#  5. Médias  #}
        <div class="form-section">
            <h2>Médias</h2>
            <div class="form-group">
                {{ form_label(form.imagesFiles) }}
                <div class="images-drop-zone" onclick="document.getElementById('{{ form.imagesFiles.vars.id }}').click()">
                    <svg width="32" height="32" fill="none" stroke="#9ca3af" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 16l4-4 4 4 4-6 4 6"/><rect x="3" y="3" width="18" height="18" rx="3"/></svg>
                    <p style="color:#6b7280;margin:.5rem 0 0;">Cliquez ou glissez vos images ici</p>
                    <small style="color:#9ca3af;">JPG, PNG, WEBP  max 5 Mo par image</small>
                </div>
                
                {{ form_widget(form.imagesFiles, {'attr': {'class': 'form-control', 'style': 'display:none'}}) }}
                <div class="images-preview" id="images-preview"></div>
                {{ form_errors(form.imagesFiles) }}
                <div class="mt-2">
                    <small class="text-muted">Conseil : Vous pouvez sélectionner plusieurs images en même temps</small>
                </div>
            </div>
            <div class="form-group">
                {{ form_label(form.video) }}
                {{ form_widget(form.video, {'attr': {'class': 'form-control'}}) }}
                <p class="hint">Lien YouTube, Vimeo... (optionnel)</p>
                {{ form_errors(form.video) }}
            </div>
        </div>

        {#  6. Matériels  #}
        <div class="form-section">
            <h2>Matériels nécessaires</h2>
            <div class="form-group">
                {{ form_widget(form.materielsNecessaires, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.materielsNecessaires) }}
            </div>
        </div>

        {#  7. Règles et conditions  #}
        <div class="form-section">
            <h2>Règles et conditions</h2>
            <div class="form-group">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="condition_security" name="event_conditions[]" value="security"{% if selectedConditions is defined and 'security' in selectedConditions %} checked{% endif %}>
                    <label class="form-check-label" for="condition_security">Je m'engage à respecter les normes de sécurité</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="condition_qualified" name="event_conditions[]" value="qualified"{% if selectedConditions is defined and 'qualified' in selectedConditions %} checked{% endif %}>
                    <label class="form-check-label" for="condition_qualified">Je confirme être qualifié pour encadrer cet évènement</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="condition_verification" name="event_conditions[]" value="verification"{% if selectedConditions is defined and 'verification' in selectedConditions %} checked{% endif %}>
                    <label class="form-check-label" for="condition_verification">J'accepte que Wanderlust vérifie les informations fournies</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="condition_risks" name="event_conditions[]" value="risks"{% if selectedConditions is defined and 'risks' in selectedConditions %} checked{% endif %}>
                    <label class="form-check-label" for="condition_risks">Je m'engage à informer les participants de tous les risques</label>
                </div>
            </div>
        </div>

        <button type="submit" class="btn-submit">Enregistrer les modifications</button>

        {{ form_row(form._token) }}

    {{ form_end(form, {'render_rest': false}) }}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    // Carte Leaflet
    function initMap() {
        const map = L.map('event-map').setView([36.8065, 10.1815], 7);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: ' OpenStreetMap'
        }).addTo(map);

        let marker = null;

        function placeMarker(lat, lng) {
            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map);
            map.setView([lat, lng], 13);
            const latInput = document.querySelector('input[name*="latitude"]');
            const lngInput = document.querySelector('input[name*="longitude"]');
            if (latInput) latInput.value = lat;
            if (lngInput) lngInput.value = lng;
        }

        map.on('click', e => placeMarker(e.latlng.lat, e.latlng.lng));

        const lieuInput = document.querySelector('.lieu-input');
        if (lieuInput) {
            let geocodeTimer = null;
            lieuInput.addEventListener('input', function () {
                clearTimeout(geocodeTimer);
                const q = this.value.trim();
                if (q.length < 4) return;
                geocodeTimer = setTimeout(async () => {
                    try {
                        const res  = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q)}&limit=1`);
                        const data = await res.json();
                        if (data.length) placeMarker(parseFloat(data[0].lat), parseFloat(data[0].lon));
                    } catch (err) { console.error('Geocoding:', err); }
                }, 600);
            });
        }
    }

    let selectedActivities = [];
    let allActivities = [];

    try {
        allActivities = [
            {% for activity in activities %}
                {
                    id: {{ activity.id }},
                    titre: {{ activity.titre|json_encode|raw }},
                    categorie: {{ activity.categorie ? activity.categorie.value|json_encode|raw : '""' }},
                    description: {{ activity.description ? activity.description|slice(0, 100)|json_encode|raw : '""' }}
                }{% if not loop.last %},{% endif %}
            {% endfor %}
        ];
    } catch(e) {
        console.error('Erreur chargement activités:', e);
        allActivities = [];
    }

    const selectedDefaultIds = {% if selectedActivitiesIds is defined and selectedActivitiesIds is iterable %}{{ selectedActivitiesIds|json_encode|raw }}{% else %}[]{% endif %};
    selectedActivities = allActivities.filter(activity => selectedDefaultIds.includes(activity.id) || selectedDefaultIds.includes(String(activity.id)));

    function updateActivitiesInput() {
        const wrapper = document.getElementById('selectedActivitiesInputs');
        if (!wrapper) return;
        wrapper.innerHTML = '';

        selectedActivities.forEach(activity => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'event_activities[]';
            input.value = activity.id;
            wrapper.appendChild(input);
        });
    }

    function renderSelectedActivities() {
        const container = document.getElementById('selected-activities');
        if (!container) return;
        
        container.innerHTML = '';
        
        if (selectedActivities.length === 0) {
            container.innerHTML = '<p class="text-muted">Aucune activité sélectionnée</p>';
            updateActivitiesInput();
            return;
        }

        selectedActivities.forEach(activity => {
            const card = document.createElement('div');
            card.className = 'activity-card';
            card.innerHTML = `
                <div class="activity-card-content">
                    <div class="activity-card-title">${escapeHtml(activity.titre)}</div>
                    <div class="activity-card-desc">${escapeHtml(activity.categorie || activity.description || '')}</div>
                </div>
                <button class="activity-card-remove" type="button" data-id="${activity.id}">x</button>
            `;
            card.querySelector('.activity-card-remove').onclick = () => {
                selectedActivities = selectedActivities.filter(a => a.id !== activity.id);
                renderSelectedActivities();
            };
            container.appendChild(card);
        });
        
        updateActivitiesInput();
    }

    function escapeHtml(text) {
        if (!text) return '';
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function renderModalActivities(searchTerm = '') {
        const container = document.getElementById('modalActivitiesList');
        if (!container) return;

        if (!allActivities.length) {
            container.innerHTML = `<div class="modal-activity" style="border-style:dashed; text-align:center;">Aucune activité disponible. <a href="{{ path('app_activities_new') }}">Créer une activité</a></div>`;
            document.getElementById('selectedCount').innerText = `${selectedActivities.length} activité(s) sélectionnée(s)`;
            return;
        }

        const normalizedSearch = searchTerm.toLowerCase().trim();
        const filtered = allActivities.filter(activity => {
            if (!normalizedSearch) return true;
            return activity.titre.toLowerCase().includes(normalizedSearch)
                || (activity.categorie && activity.categorie.toLowerCase().includes(normalizedSearch))
                || (activity.description && activity.description.toLowerCase().includes(normalizedSearch));
        });

        container.innerHTML = '';
        if (filtered.length === 0) {
            container.innerHTML = `<div class="modal-activity" style="border-style:dashed; text-align:center;">Aucune activité ne correspond à votre recherche.</div>`;
            document.getElementById('selectedCount').innerText = `${selectedActivities.length} activité(s) sélectionnée(s)`;
            return;
        }

        filtered.forEach(activity => {
            const isSelected = selectedActivities.some(a => a.id === activity.id);
            const item = document.createElement('div');
            item.className = 'modal-activity' + (isSelected ? ' selected' : '');
            item.innerHTML = `
                <div class="modal-activity-checkbox">
                    <input type="checkbox" ${isSelected ? 'checked' : ''} value="${activity.id}" />
                </div>
                <div class="modal-activity-title">${activity.titre}</div>
                <div class="modal-activity-desc">${activity.categorie || activity.description || ''}</div>
            `;
            item.onclick = (e) => {
                const checkbox = item.querySelector('input');
                if (e.target !== checkbox) {
                    checkbox.checked = !checkbox.checked;
                }
                if (checkbox.checked) {
                    if (!selectedActivities.some(a => a.id === activity.id)) {
                        selectedActivities.push(activity);
                    }
                } else {
                    selectedActivities = selectedActivities.filter(a => a.id !== activity.id);
                }
                renderModalActivities(searchTerm);
            };
            container.appendChild(item);
        });

        document.getElementById('selectedCount').innerText = `${selectedActivities.length} activité(s) sélectionnée(s)`;
    }

    function openModal() {
        renderModalActivities('');
        document.getElementById('activitiesModal').style.display = 'flex';
        document.getElementById('activitiesModal').setAttribute('aria-hidden', 'false');
        document.getElementById('searchActivities').focus();
    }

    function closeModal() {
        const activeElement = document.activeElement;
        if (activeElement && activeElement.blur) {
            activeElement.blur();
        }
        document.getElementById('activitiesModal').style.display = 'none';
        document.getElementById('activitiesModal').setAttribute('aria-hidden', 'true');
    }

    document.addEventListener('DOMContentLoaded', function () {
        renderSelectedActivities();
        initMap();

        const openActivitiesModal = document.getElementById('openActivitiesModal');
        const closeModalBtn = document.getElementById('closeModalBtn');
        const cancelModalBtn = document.getElementById('cancelModalBtn');
        const confirmModalBtn = document.getElementById('confirmModalBtn');
        const searchActivities = document.getElementById('searchActivities');
        const activitiesModal = document.getElementById('activitiesModal');

        if (openActivitiesModal) openActivitiesModal.onclick = openModal;
        if (closeModalBtn) closeModalBtn.onclick = closeModal;
        if (cancelModalBtn) cancelModalBtn.onclick = closeModal;
        if (confirmModalBtn) confirmModalBtn.onclick = () => {
            renderSelectedActivities();
            closeModal();
        };
        if (searchActivities) searchActivities.oninput = (e) => renderModalActivities(e.target.value);
        if (activitiesModal) activitiesModal.onclick = (e) => {
            if (e.target === activitiesModal) {
                renderSelectedActivities();
                closeModal();
            }
        };

        const eventForm = document.getElementById('event-form');
        if (eventForm) {
            eventForm.addEventListener('submit', function () {
                updateActivitiesInput();
            });
        }

        const imageInput = document.getElementById('{{ form.imagesFiles.vars.id }}');
        const preview = document.getElementById('images-preview');
        let selectedImageFiles = [];

        function refreshImageInput() {
            if (!imageInput) return;
            const dt = new DataTransfer();
            selectedImageFiles.forEach(file => dt.items.add(file));
            imageInput.files = dt.files;
        }

        function renderImagePreview() {
            if (!preview) return;
            preview.innerHTML = '';
            selectedImageFiles.forEach((file, index) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const container = document.createElement('div');
                    container.style.cssText = `
                        position: relative;
                        display: inline-block;
                        margin: 5px;
                        border: 1px solid #e5e7eb;
                        border-radius: 8px;
                        overflow: hidden;
                    `;

                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = `
                        width: 80px;
                        height: 80px;
                        object-fit: cover;
                        display: block;
                    `;

                    const deleteBtn = document.createElement('button');
                    deleteBtn.innerHTML = '';
                    deleteBtn.style.cssText = `
                        position: absolute;
                        top: 5px;
                        right: 5px;
                        background: #ef4444;
                        color: white;
                        border: none;
                        border-radius: 50%;
                        width: 20px;
                        height: 20px;
                        cursor: pointer;
                        font-size: 12px;
                        z-index: 10;
                    `;
                    deleteBtn.onclick = function() {
                        selectedImageFiles.splice(index, 1);
                        refreshImageInput();
                        renderImagePreview();
                    };

                    container.appendChild(img);
                    container.appendChild(deleteBtn);
                    preview.appendChild(container);
                };
                reader.readAsDataURL(file);
            });
        }

        function addSelectedFiles(files) {
            Array.from(files).forEach(file => {
                const exists = selectedImageFiles.some(existing => existing.name === file.name && existing.size === file.size && existing.lastModified === file.lastModified);
                if (!exists) {
                    selectedImageFiles.push(file);
                }
            });
            refreshImageInput();
            renderImagePreview();
        }

        if (imageInput) {
            imageInput.addEventListener('change', function () {
                addSelectedFiles(this.files);
            });
        }
    });
    </script>
{% endblock %}