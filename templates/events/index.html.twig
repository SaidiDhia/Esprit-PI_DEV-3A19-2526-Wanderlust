{% extends 'base.html.twig' %}

{% block title %}Events{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('{{ asset('adventure/img/slider2.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .event-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .event-card .thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .event-body {
            padding: 18px;
            flex: 1;
        }

        .event-meta {
            font-size: 13px;
            color: #777;
            margin-bottom: 6px;
        }

        .event-actions {
            border-top: 1px solid #f0f0f0;
            padding: 14px 18px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .status-pill {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .status-available { background: #dcfce7; color: #166534; }
        .status-full { background: #fee2e2; color: #991b1b; }
        .status-ended { background: #e5e7eb; color: #374151; }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="module-page-title mb-10">Events</h1>
        <p class="mb-20">Discover and manage travel events with the Adventure theme.</p>
        {% if app.user %}
            <a href="{{ path('app_events_new') }}" class="primary-btn text-uppercase">Create Event</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="primary-btn text-uppercase">Login To Create</a>
        {% endif %}
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% if events is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No events available</h4>
                <p class="text-muted mb-3">Be the first to publish one.</p>
                {% if app.user %}
                    <a href="{{ path('app_events_new') }}" class="primary-btn text-uppercase">Create Event</a>
                {% endif %}
            </div>
        {% else %}
            <div class="row">
                {% for event in events %}
                    {% set canManage = app.user and event.createdBy and event.createdBy.id == app.user.id %}
                    {% set now = "now"|date("Y-m-d H:i:s") %}
                    {% set eventDate = event.dateDebut ? event.dateDebut|date("Y-m-d H:i:s") : null %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="event-card w-100">
                            {% if event.images and event.images|length > 0 %}
                                {% set firstImage = event.images|first %}
                                <img class="thumb" src="{{ asset('uploads/events/' ~ firstImage.imagePath) }}" alt="{{ event.lieu }}">
                            {% else %}
                                <img class="thumb" src="{{ asset('adventure/img/g5.jpg') }}" alt="Event placeholder">
                            {% endif %}

                            <div class="event-body">
                                {% if canManage %}
                                    {% if event.placesDisponibles > 0 and eventDate and eventDate > now %}
                                        <span class="status-pill status-available">Available</span>
                                    {% elseif event.placesDisponibles <= 0 %}
                                        <span class="status-pill status-full">Full</span>
                                    {% else %}
                                        <span class="status-pill status-ended">Ended</span>
                                    {% endif %}
                                {% endif %}

                                <h5 class="mb-2">{{ event.lieu }}</h5>
                                <div class="event-meta"><i class="fa fa-calendar"></i> {{ event.dateDebut ? event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</div>
                                <div class="event-meta"><i class="fa fa-user"></i> {{ event.organisateur }}</div>
                                <div class="event-meta"><i class="fa fa-ticket"></i> {{ event.placesDisponibles }}/{{ event.capaciteMax }} places</div>
                                <p class="mb-0 mt-2"><strong>{{ event.prix }} TND</strong></p>
                            </div>

                            <div class="event-actions">
                                <a href="{{ path('app_events_show', {'id': event.id}) }}" class="genric-btn info-border small">View</a>
                                {% if canManage %}
                                    <a href="{{ path('app_events_edit', {'id': event.id}) }}" class="genric-btn warning-border small">Edit</a>
                                    <form method="post" action="{{ path('app_events_delete', {'id': event.id}) }}" onsubmit="return confirm('Delete this event?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
                                        <button type="submit" class="genric-btn danger-border small">Delete</button>
                                    </form>
                                {% endif %}
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
