{% extends 'base.html.twig' %}

{% block title %}Créer une nouvelle activité{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .module-hero {
        position: relative;
        color: #fff;
        padding: 120px 0 80px;
        margin-bottom: 40px;
        overflow: hidden;
    }

    .module-hero h1,
    .module-hero h2,
    .module-hero h3,
    .module-hero h4,
    .module-hero h5,
    .module-hero h6,
    .module-hero p {
        color: #fff !important;
        text-shadow: 0 2px 4px rgba(0, 0, 0, 0.7);
    }

    .adventure-btn {
        font-size: 14px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease 0s;
        border-radius: 25px;
        padding: 10px 20px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border: 2px solid transparent;
        text-decoration: none;
        display: inline-block;
    }

    .adventure-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.3);
        background: linear-gradient(135deg, #5587ea 0%, #3f72df 100%);
        color: #fff;
    }

    .adventure-btn.primary-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .adventure-btn.default-border {
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
    }

    .adventure-btn.info {
        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        color: #fff;
        box-shadow: 0 4px 15px rgba(79, 172, 254, 0.3);
    }

    .module-hero .video-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
    }

    .module-hero .video-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, 
            rgba(0, 0, 0, 0.6) 0%, 
            rgba(0, 0, 0, 0.4) 100%);
        z-index: 0;
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 1;
    }

    .surface-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
        padding: 24px;
        margin-bottom: 24px;
        transition: all 0.3s ease 0s;
    }

    .surface-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.12);
    }

    .enhance-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 8px 16px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 14px rgba(102, 126, 234, 0.35);
    }

    .enhance-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }

    .enhance-btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    .enhance-spinner {
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .enhance-message {
        margin-top: 8px;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: 0.82rem;
        display: none;
    }

    .enhance-message.success {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #34d399;
    }

    .enhance-message.error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #f87171;
    }

    /* Image Upload Modern */
    .image-upload-modern {
        border: 3px dashed #dee2e6;
        border-radius: 20px;
        padding: 3rem;
        text-align: center;
        transition: all 0.3s ease;
        cursor: pointer;
        background: #f8f9fa;
        position: relative;
        overflow: hidden;
    }

    .image-upload-modern::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .image-upload-modern:hover {
        border-color: #667eea;
        background: rgba(102, 126, 234, 0.05);
        transform: translateY(-2px);
    }

    .image-upload-modern:hover::before {
        opacity: 0.05;
    }

    .upload-icon-modern {
        font-size: 4rem;
        color: #adb5bd;
        margin-bottom: 1.5rem;
        transition: all 0.3s ease;
    }

    .image-upload-modern:hover .upload-icon-modern {
        color: #667eea;
        transform: translateY(-5px) scale(1.1);
    }

    .spinner-border {
        border: 2px solid #667eea;
        border-top-color: transparent;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        animation: spin 1s linear infinite;
    }
</style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <video class="video-background" autoplay muted loop playsinline>
        <source src="{{ asset('adventure/video/letsDiscover.mp4') }}" type="video/mp4">
        Votre navigateur ne supporte pas les vidéos HTML5.
    </video>
    
    <div class="video-overlay"></div>
    
    <div class="hero-content">
        <div class="container text-center">
            <h2 class="mb-2">Créer une nouvelle activité</h2>
            <p class="mb-0">Remplissez le formulaire ci-dessous pour ajouter une activité</p>
        </div>
    </div>
</section>

<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="surface-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-group">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.titre) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 5, 'id': 'activity_description'}}) }}
                {{ form_errors(form.description) }}
                
                <div style="margin-top: 10px;">
                    <button type="button" id="btnEnhanceDesc" class="enhance-btn" onclick="enhanceDescription()">
                        <span id="enhanceDescIcon">✨</span>
                        <span id="enhanceDescText">Améliorer avec l'IA</span>
                    </button>
                    <div id="enhanceDescMsg" class="enhance-message"></div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.categorie) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.categorie) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type_activite) }}
                        {{ form_widget(form.type_activite, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.type_activite) }}
                    </div>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.ageMinimum) }}
                {{ form_widget(form.ageMinimum, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.ageMinimum) }}
            </div>

            <div class="form-group">
                {{ form_label(form.image) }}
                {{ form_widget(form.image, {'attr': {'class': 'd-none', 'id': 'activity_image', 'accept': 'image/* '}}) }}
                {{ form_errors(form.image) }}
                
                <!-- Zone d'upload moderne -->
                <div class="image-upload-modern" id="imageUploadArea" style="cursor:pointer;">
                    <i class="fas fa-cloud-upload-alt upload-icon-modern"></i>
                    <h6 class="mb-2">Cliquez ou glissez-déposez une image</h6>
                    <p class="text-muted small mb-0">JPG, PNG ou GIF (Max 5MB)</p>
                </div>

                <!-- Preview + Modération Result -->
                <div id="imagePreview" class="mt-3" style="display: none;">
                    <div class="d-flex align-items-start gap-3 flex-wrap">
                        <!-- Miniature -->
                        <div class="position-relative d-inline-block">
                            <img id="previewImg" src="" alt="Preview" class="rounded-3 shadow-sm"
                                 style="max-width: 180px; max-height: 140px; object-fit: cover; border: 2px solid #dee2e6;">
                            <button type="button" id="removeImage"
                                    class="btn btn-danger btn-sm rounded-circle position-absolute top-0 end-0 translate-middle"
                                    style="width:26px;height:26px;padding:0;font-size:0.7rem;">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>

                        <!-- Badge de modération -->
                        <div id="moderationResult" style="display:none; min-width:220px;">
                            <!-- Chargement -->
                            <div id="modLoading" style="display:none;" class="d-flex align-items-center gap-2 text-muted">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <span style="font-size:0.85rem;">Analyse IA en cours…</span>
                            </div>

                            <!-- Résultat Safe -->
                            <div id="modSafe" style="display:none;
                                 background:linear-gradient(135deg,#d1fae5,#a7f3d0);
                                 border:1.5px solid #34d399; border-radius:14px; padding:14px 16px;">
                                <div style="font-weight:700; color:#065f46; font-size:0.95rem; margin-bottom:4px;">
                                    ✅ Image approuvée
                                </div>
                                <div style="font-size:0.78rem; color:#047857;" id="modSafeReason"></div>
                                <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;" id="modSafeBadges"></div>
                            </div>

                            <!-- Résultat Unsafe -->
                            <div id="modUnsafe" style="display:none;
                                 background:linear-gradient(135deg,#fee2e2,#fecaca);
                                 border:1.5px solid #f87171; border-radius:14px; padding:14px 16px;">
                                <div style="font-weight:700; color:#991b1b; font-size:0.95rem; margin-bottom:4px;">
                                    🚫 Image refusée
                                </div>
                                <div style="font-size:0.78rem; color:#b91c1c;" id="modUnsafeReason"></div>
                                <div style="margin-top:8px; display:flex; gap:6px; flex-wrap:wrap;" id="modUnsafeBadges"></div>
                                <div style="margin-top:10px; font-size:0.78rem; color:#7f1d1d; font-weight:600;">
                                    ⚠️ Cette image ne peut pas être utilisée sur Wanderlust.
                                </div>
                            </div>

                            <!-- Erreur API -->
                            <div id="modError" style="display:none;
                                 background:#f8f9fa; border:1.5px solid #dee2e6;
                                 border-radius:14px; padding:12px 16px;
                                 font-size:0.8rem; color:#6c757d;">
                                ⚠️ Analyse indisponible — la soumission reste possible.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <div>
                    <a href="{{ path('app_activities_index') }}" class="adventure-btn default-border">Retour</a>
                </div>
                <div>
                    <button type="submit" class="adventure-btn primary-btn text-uppercase">Créer</button>
                </div>
            </div>

        {{ form_end(form) }}
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const categorieSelect = document.querySelector('select[name="activities[categorie]"]');
    const typeSelect = document.querySelector('select[name="activities[type_activite]"]');
    
    if (categorieSelect && typeSelect) {
        categorieSelect.addEventListener('change', function() {
            let selectedCategorie = this.value;
            console.log('Catégorie sélectionnée:', selectedCategorie);
            
            loadTypesByCategorie(selectedCategorie);
        });
        
        if (categorieSelect.value) {
            let selectedCategorie = categorieSelect.value;
            console.log('Catégorie sélectionnée:', selectedCategorie);
            
            loadTypesByCategorie(selectedCategorie);
        }
    }
    
    function loadTypesByCategorie(categorie) {
        if (!categorie) {
            typeSelect.innerHTML = '<option value="">Choisir d\'abord une catégorie</option>';
            typeSelect.disabled = true;
            return;
        }
        
        try {
            typeSelect.innerHTML = '<option value="">Chargement...</option>';
            typeSelect.disabled = true;
            
            const typesByCategorie = {
                'desert': [
                    {nom: 'Quad et buggy 🏎️', valeur: 'Quad et buggy'},
                    {nom: 'Trekking dans les dunes 🥾', valeur: 'Trekking dans les dunes'},
                    {nom: 'Moto cross désert 🏍️', valeur: 'Moto cross désert'},
                    {nom: 'Balade à dos de dromadaire 🐪', valeur: 'Balade à dos de dromadaire'},
                    {nom: 'Nuit en campement saharien 🏕️', valeur: 'Nuit en campement saharien'},
                    {nom: 'Observation des étoiles ⭐', valeur: 'Observation des étoiles'}
                ],
                'Mer': [
                    {nom: 'Jet ski 🏄‍♂️', valeur: 'Jet ski'},
                    {nom: 'Parachute ascensionnel 🪂', valeur: 'Parachute ascensionnel'},
                    {nom: 'Paddle 🛶', valeur: 'Paddle'},
                    {nom: 'Kayak 🛶', valeur: 'Kayak'},
                    {nom: 'Planche à voile ⛵', valeur: 'Planche à voile'},
                    {nom: 'Plongée sous-marine 🤿', valeur: 'Plongée sous-marine'},
                    {nom: 'Snorkeling 🤽', valeur: 'Snorkeling'},
                    {nom: 'Sortie en bateau ⛵', valeur: 'Sortie en bateau'},
                    {nom: 'Pêche touristique 🎣', valeur: 'Pêche touristique'}
                ],
                'Aérien': [
                    {nom: 'Parachutisme 🪂', valeur: 'Parachutisme'},
                    {nom: 'Parapente 🪂', valeur: 'Parapente'},
                    {nom: 'ULM (Ultra léger motorisé) 🪂', valeur: 'ULM (Ultra léger motorisé)'},
                    {nom: 'Montgolfière (occasionnellement dans le sud) 🎈', valeur: 'Montgolfière (occasionnellement dans le sud)'},
                    {nom: 'Parachute ascensionnel (mer) 🪂', valeur: 'Parachute ascensionnel (mer)'}
                ],
                'nature': [
                    {nom: 'Randonnée en forêt 🥾', valeur: 'Randonnée en forêt'},
                    {nom: 'Escalade 🧗', valeur: 'Escalade'},
                    {nom: 'Camping 🏕️', valeur: 'Camping'},
                    {nom: 'VTT 🚵', valeur: 'VTT'},
                    {nom: 'Spéléologie ⛰️', valeur: 'Spéléologie'},
                    {nom: 'Nuit en campement 🏕️', valeur: 'Nuit en campement'}
                ],
                'Culture': [
                    {nom: 'Visite des ksour de Tataouine 🏛️', valeur: 'Visite des ksour de Tataouine'},
                    {nom: 'Décors de films à Tozeur 🎬', valeur: 'Décors de films à Tozeur'},
                    {nom: 'Visite archéologique 🏺', valeur: 'Visite archéologique'},
                    {nom: 'Festivals 🎉', valeur: 'Festivals'},
                    {nom: 'Tourisme historique 📚', valeur: 'Tourisme historique'},
                    {nom: 'Photographie 📷', valeur: 'Photographie'}
                ]
            };
            
            const types = typesByCategorie[categorie] || [];
            
            if (types.length === 0) {
                throw new Error('Aucun type disponible pour cette catégorie');
            }
            
            typeSelect.innerHTML = '<option value="">Choisir un type</option>';
            
            types.forEach(type => {
                const option = document.createElement('option');
                option.value = type.valeur;
                option.textContent = type.nom;
                typeSelect.appendChild(option);
            });
            
            typeSelect.disabled = false;
        } catch (error) {
            console.error('Erreur lors du chargement des types:', error);
            typeSelect.innerHTML = '<option value="">Erreur au chargement</option>';
            typeSelect.disabled = true;
        }
    }
});

async function enhanceDescription() {
    const btn = document.getElementById('btnEnhanceDesc');
    const icon = document.getElementById('enhanceDescIcon');
    const text = document.getElementById('enhanceDescText');
    const msg = document.getElementById('enhanceDescMsg');
    
    // Trouver le champ description avec plusieurs sélecteurs possibles
    const descArea = document.getElementById('activity_description') || 
                     document.querySelector('textarea[name*="description"]') ||
                     document.querySelector('textarea[id*="description"]') ||
                     document.querySelector('#activities_description') ||
                     document.querySelector('textarea.form-control');
    
    const titre = document.querySelector('[id*="titre"]')?.value?.trim() || '';
    const type = document.querySelector('[id*="type"]')?.value?.trim() || '';
    const catEl = document.querySelector('[id*="categorie"]');
    const categorie = catEl?.options[catEl?.selectedIndex]?.text?.trim() || catEl?.value?.trim() || '';
    
    // Vérifier si le champ description a été trouvé
    if (!descArea) {
        console.error('Champ description non trouvé!');
        msg.style.display = 'block';
        msg.className = 'enhance-message error';
        msg.textContent = '❌ Erreur: Champ description introuvable';
        return;
    }
    
    if (!titre) {
        msg.style.display = 'block';
        msg.className = 'enhance-message error';
        msg.textContent = '⚠️ Veuillez remplir le titre de l\'activité.';
        return;
    }
    
    btn.disabled = true;
    icon.innerHTML = '<span class="enhance-spinner"></span>';
    text.textContent = 'Génération en cours…';
    msg.style.display = 'none';
    
    try {
        const res = await fetch('/api/ai/activity-description', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({ titre, type_activite: type, categorie })
        });

        const responseText = await res.text();
        let data = {};

        try {
            data = responseText ? JSON.parse(responseText) : {};
        } catch (parseError) {
            if (responseText.trim().startsWith('<')) {
                throw new Error('Le serveur a renvoyé une page HTML au lieu de JSON (session expirée ou erreur serveur). Rechargez la page et reconnectez-vous.');
            }

            throw new Error('Réponse serveur invalide (JSON attendu).');
        }

        if (!res.ok) {
            throw new Error(data.error || `Erreur HTTP ${res.status}`);
        }
        
        if (data.description) {
            descArea.value = data.description;
            msg.style.display = 'block';
            msg.className = 'enhance-message success';
            msg.textContent = '✅ Description améliorée avec succès !';
        } else {
            throw new Error('Aucune description générée');
        }
    } catch (error) {
        msg.style.display = 'block';
        msg.className = 'enhance-message error';
        msg.textContent = '❌ Erreur lors de la génération: ' + error.message;
    } finally {
        btn.disabled = false;
        icon.innerHTML = '✨';
        text.textContent = 'Améliorer avec l\'IA';
    }
}

// Gestionnaire de changement d'image avec modération IA
const imageInput = document.querySelector('input[type="file"]');
const imageUploadArea = document.getElementById('imageUploadArea');
const imagePreview = document.getElementById('imagePreview');
const previewImg = document.getElementById('previewImg');
const removeImageBtn = document.getElementById('removeImage');

if (imageUploadArea && imageInput) {
    imageUploadArea.addEventListener('click', () => imageInput.click());
    
    imageUploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        imageUploadArea.style.borderColor = '#667eea';
        imageUploadArea.style.background = 'rgba(102, 126, 234, 0.05)';
    });
    
    imageUploadArea.addEventListener('dragleave', () => {
        imageUploadArea.style.borderColor = '#dee2e6';
        imageUploadArea.style.background = '#f8f9fa';
    });
    
    imageUploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        imageUploadArea.style.borderColor = '#dee2e6';
        imageUploadArea.style.background = '#f8f9fa';
        const files = e.dataTransfer.files;
        if (files.length > 0) {
            imageInput.files = files;
            previewAndModerate(files[0]);
        }
    });
    
    imageInput.addEventListener('change', function() {
        if (this.files.length > 0) {
            previewAndModerate(this.files[0]);
        } else {
            resetImageUI();
        }
    });
}

function resetImageUI() {
    const modResult = document.getElementById('moderationResult');
    const modLoading = document.getElementById('modLoading');
    const modSafe = document.getElementById('modSafe');
    const modUnsafe = document.getElementById('modUnsafe');
    const modError = document.getElementById('modError');

    if (modResult) modResult.style.display = 'none';
    if (modLoading) modLoading.style.display = 'none';
    if (modSafe) modSafe.style.display = 'none';
    if (modUnsafe) modUnsafe.style.display = 'none';
    if (modError) modError.style.display = 'none';
    
    if (imagePreview) imagePreview.style.display = 'none';
    if (imageUploadArea) imageUploadArea.style.display = 'block';
}

async function previewAndModerate(file) {
    // 1. Afficher la miniature immédiatement
    const reader = new FileReader();
    reader.onload = async function(e) {
        if (previewImg) {
            previewImg.src = e.target.result;
            previewImg.style.border = '2px solid #dee2e6';
        }
        if (imagePreview) imagePreview.style.display = 'flex';
        if (imageUploadArea) imageUploadArea.style.display = 'none';

        // 2. Afficher le spinner de modération
        const modResult = document.getElementById('moderationResult');
        const modLoading = document.getElementById('modLoading');
        const modSafe = document.getElementById('modSafe');
        const modUnsafe = document.getElementById('modUnsafe');
        const modError = document.getElementById('modError');

        if (modResult) modResult.style.display = 'block';
        if (modLoading) modLoading.style.display = 'flex';
        if (modSafe) modSafe.style.display = 'none';
        if (modUnsafe) modUnsafe.style.display = 'none';
        if (modError) modError.style.display = 'none';

        // 3. Appel API modération
        try {
            const formData = new FormData();
            formData.append('image', file);

            const resp = await fetch('/api/ai/moderate-image', {
                method: 'POST',
                body: formData,
            });
            const responseText = await resp.text();
            let data = {};

            try {
                data = responseText ? JSON.parse(responseText) : {};
            } catch (parseError) {
                if (responseText.trim().startsWith('<')) {
                    throw new Error('Le serveur a renvoye une page HTML au lieu de JSON.');
                }

                throw new Error('Reponse JSON invalide du service de moderation.');
            }

            if (!resp.ok) {
                throw new Error(data.error || `Erreur HTTP ${resp.status}`);
            }

            if (modLoading) modLoading.style.display = 'none';

            const status = data.status || (data.safe ? 'safe' : 'unsafe');

            if (status === 'safe') {
                // ✅ Image approuvée - avec les badges !!
                if (previewImg) previewImg.style.border = '2.5px solid #34d399';
                if (modSafe) {
                    modSafe.style.display = 'block';
                    
                    const badges = [];
                    if (data.suitableForKids) badges.push({label: '👶 Kids friendly', bg: '#d1fae5', color: '#065f46'});
                    if (!data.violent) badges.push({label: '✋ Non violent', bg: '#d1fae5', color: '#065f46'});
                    if (!data.adultContent) badges.push({label: '✅ Contenu sûr', bg: '#d1fae5', color: '#065f46'});
                    if (data.confidence) badges.push({label: `${data.confidence}% confiance`, bg: '#f3f4f6', color: '#374151'});

                    let badgesHtml = badges.map(b => 
                        `<span style="background:${b.bg}; color:${b.color}; padding: 6px 12px; border-radius: 50px; font-size: 0.8rem; font-weight: 700;">${b.label}</span>`
                    ).join('');

                    modSafe.innerHTML = `
                        <div style="font-weight: 800; color: #065f46; font-size: 1.1rem; margin-bottom: 6px; display: flex; align-items: center; gap: 8px;">
                            <div style="background: #34d399; color: white; border-radius: 4px; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.9rem;">✓</div> 
                            Image approuvée
                        </div>
                        <div style="font-size: 0.9rem; color: #047857; margin-bottom: 12px;">Analyse partielle effectuée.</div>
                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                            ${badgesHtml}
                        </div>
                    `;
                    
                    modSafe.style.background = '#bbf7d0'; // Light green matching image 2
                    modSafe.style.border = '1.5px solid #34d399';
                    modSafe.style.borderRadius = '16px';
                    modSafe.style.padding = '16px 20px';
                }
                
                // Masquer tous les autres éléments
                if (modUnsafe) modUnsafe.style.display = 'none';
                if (modError) modError.style.display = 'none';
                if (modLoading) modLoading.style.display = 'none';

            } else if (status === 'unsafe') {
                // 🚫 Image refusée
                if (previewImg) previewImg.style.border = '2.5px solid #f87171';
                if (modUnsafe) {
                    modUnsafe.style.display = 'block';
                    
                    const badges = [];
                    if (data.violent) badges.push({label: '⚠️ Violence', bg: '#fee2e2', color: '#991b1b'});
                    if (data.adultContent) badges.push({label: '🔞 Adulte', bg: '#fee2e2', color: '#991b1b'});
                    if (!data.suitableForKids) badges.push({label: '🚫 Non adapté', bg: '#fee2e2', color: '#991b1b'});
                    if (data.confidence) badges.push({label: `${data.confidence}% confiance`, bg: '#f3f4f6', color: '#374151'});

                    let badgesHtml = badges.map(b => 
                        `<span style="background:${b.bg}; color:${b.color}; padding: 6px 12px; border-radius: 50px; font-size: 0.8rem; font-weight: 700;">${b.label}</span>`
                    ).join('');

                    modUnsafe.innerHTML = `
                        <div style="font-weight: 800; color: #991b1b; font-size: 1.1rem; margin-bottom: 6px; display: flex; align-items: center; gap: 8px;">
                            <div style="background: #f87171; color: white; border-radius: 4px; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.9rem;">!</div> 
                            Image refusée
                        </div>
                        <div style="font-size: 0.9rem; color: #b91c1c; margin-bottom: 12px;">Contenu inapproprié détecté.</div>
                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                            ${badgesHtml}
                        </div>
                    `;
                    
                    modUnsafe.style.background = '#fecaca';
                    modUnsafe.style.border = '1.5px solid #f87171';
                    modUnsafe.style.borderRadius = '16px';
                    modUnsafe.style.padding = '16px 20px';
                }
                
                // Masquer tous les autres éléments
                if (modSafe) modSafe.style.display = 'none';
                if (modError) modError.style.display = 'none';
                if (modLoading) modLoading.style.display = 'none';

            } else if (status === 'quota') {
                // ⏳ Quota dépassé
                if (previewImg) previewImg.style.border = '2.5px solid #94a3b8';
                if (modError) {
                    modError.style.display = 'block';
                    modError.style.background = '#fef3c7';
                    modError.style.border = '1.5px solid #f59e0b';
                    modError.style.color = '#92400e';
                    modError.innerHTML = `⏳ <strong>Quota API dépassé.</strong><br>
                        Réessayez dans 1 minute, puis rechoisissez votre image.
                        <br><button type="button" onclick="document.getElementById('removeImage').click()"
                            style="margin-top:8px;background:#f59e0b;color:#fff;border:none;
                            border-radius:20px;padding:5px 14px;font-size:0.78rem;cursor:pointer;">
                            🔄 Changer d'image
                        </button>`;
                }
                
                // Masquer tous les autres éléments
                if (modSafe) modSafe.style.display = 'none';
                if (modUnsafe) modUnsafe.style.display = 'none';
                if (modLoading) modLoading.style.display = 'none';

            } else if (status === 'unavailable') {
                // ⚠️ Service externe indisponible (ex: clé API non autorisée)
                if (previewImg) previewImg.style.border = '2.5px solid #94a3b8';
                if (modError) {
                    modError.style.display = 'block';
                    modError.style.background = '#eff6ff';
                    modError.style.border = '1.5px solid #60a5fa';
                    modError.style.color = '#1e3a8a';
                    modError.innerHTML = `⚠️ <strong>Analyse IA indisponible.</strong><br>
                        ${data.reason || 'Le service de moderation est temporairement indisponible.'}<br>
                        Vous pouvez continuer, mais l'image sera a verifier manuellement.`;
                }

                if (modSafe) modSafe.style.display = 'none';
                if (modUnsafe) modUnsafe.style.display = 'none';
                if (modLoading) modLoading.style.display = 'none';

            } else {
                // ❌ Erreur API
                if (previewImg) previewImg.style.border = '2.5px solid #94a3b8';
                if (modError) {
                    modError.style.display = 'block';
                    modError.style.background = '#f1f5f9';
                    modError.style.border = '1.5px solid #94a3b8';
                    modError.style.color = '#475569';
                    modError.innerHTML = `❌ <strong>Analyse impossible.</strong><br>
                        ${data.reason || 'Service temporairement indisponible.'}
                        <br><button type="button" onclick="document.getElementById('removeImage').click()"
                            style="margin-top:8px;background:#64748b;color:#fff;border:none;
                            border-radius:20px;padding:5px 14px;font-size:0.78rem;cursor:pointer;">
                            🔄 Changer d'image
                        </button>`;
                }
                
                // Masquer tous les autres éléments
                if (modSafe) modSafe.style.display = 'none';
                if (modUnsafe) modUnsafe.style.display = 'none';
                if (modLoading) modLoading.style.display = 'none';
            }

        } catch (err) {
            if (modLoading) modLoading.style.display = 'none';
            // Erreur réseau → BLOQUER et informer
            if (modError) {
                modError.style.display = 'block';
                modError.innerHTML = `❌ Connexion à l'API impossible. Vérifiez le serveur Symfony.<br>
                    <small>${err.message}</small>`;
            }
            
            // Masquer tous les autres éléments en cas d'erreur
            if (modSafe) modSafe.style.display = 'none';
            if (modUnsafe) modUnsafe.style.display = 'none';
            if (modLoading) modLoading.style.display = 'none';
        }

    };
    reader.readAsDataURL(file);
}

if (removeImageBtn) {
    removeImageBtn.addEventListener('click', function() {
        imageInput.value = '';
        resetImageUI();
    });
}

</script>
{% endblock %}
