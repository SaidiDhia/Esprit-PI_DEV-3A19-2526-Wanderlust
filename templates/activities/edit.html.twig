{% extends 'base.html.twig' %}

{% block title %}Modifier l'activite{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .module-hero {
        background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)),
                    url('{{ asset('adventure/img/banner-bg.jpg') }}') center/cover no-repeat;
        color: #fff;
        padding: 120px 0 80px;
        margin-bottom: 40px;
    }

    .surface-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
        padding: 24px;
        margin-bottom: 24px;
    }

    .current-image {
        margin-bottom: 20px;
    }

    .current-image img {
        max-width: 220px;
        max-height: 160px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e6e6e6;
    }
</style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container text-center">
        <h2 class="mb-2">Modifier l'activite</h2>
        <p class="mb-0">Mettez a jour les informations de l'activite</p>
    </div>
</section>

<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <div class="surface-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-group">
                {{ form_label(form.titre) }}
                {{ form_widget(form.titre, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.titre) }}
            </div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                {{ form_errors(form.description) }}
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.categorie) }}
                        {{ form_widget(form.categorie, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.categorie) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.type_activite) }}
                        {{ form_widget(form.type_activite, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.type_activite) }}
                    </div>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.ageMinimum) }}
                {{ form_widget(form.ageMinimum, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.ageMinimum) }}
            </div>

            {% if activity.image %}
                <div class="current-image">
                    <label class="d-block"><strong>Image actuelle</strong></label>
                    <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="Image actuelle">
                </div>
            {% endif %}

            <div class="form-group">
                {{ form_label(form.image) }}
                {{ form_widget(form.image, {'attr': {'class': 'form-control-file'}}) }}
                {{ form_errors(form.image) }}
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <div>
                    <a href="{{ path('app_activities_index') }}" class="genric-btn default-border">Retour</a>
                    <a href="{{ path('app_activities_show', {'id': activity.id}) }}" class="genric-btn info ml-2">Voir</a>
                </div>
                <button type="submit" class="primary-btn text-uppercase">Enregistrer</button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
