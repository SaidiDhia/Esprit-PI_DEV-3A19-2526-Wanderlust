{% extends 'base.html.twig' %}

{% block title %}Activities{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            position: relative;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
            overflow: hidden;
        }

        .module-hero h1,
        .module-hero h2,
        .module-hero h3,
        .module-hero h4,
        .module-hero h5,
        .module-hero h6,
        .module-hero p {
            color: #fff !important;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.7);
        }

        .video-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -1;
        }

        .video-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, 
                rgba(0, 0, 0, 0.6) 0%, 
                rgba(0, 0, 0, 0.4) 100%);
            z-index: 0;
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .activity-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .activity-card .thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .activity-body {
            padding: 18px;
            flex: 1;
        }

        .activity-actions {
            border-top: 1px solid #f0f0f0;
            padding: 14px 18px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .status-pill {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .status-en_attente { background: #fef3c7; color: #92400e; }
        .status-accepte { background: #dcfce7; color: #166534; }
        .status-refuse { background: #fee2e2; color: #991b1b; }

        .pagination .page-item .page-link {
            color: #222;
        }

        .pagination .page-item.active .page-link {
            background: #f6214b;
            border-color: #f6214b;
            color: #fff;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <!-- Video Background -->
    <video class="video-background" autoplay muted loop playsinline>
        <source src="{{ asset('adventure/video/letsDiscover.mp4') }}" type="video/mp4">
        Votre navigateur ne supporte pas les vidéos HTML5.
    </video>
    
    <!-- Video Overlay -->
    <div class="video-overlay"></div>
    
    <div class="hero-content">
        <div class="container">
            <h1 class="mb-10">Activities</h1>
            <p class="mb-20">La Tunisie, c’est l’aventure à chaque pas : dunes du Sahara, plages secrètes, montagnes sauvages et trésors antiques. Entre randonnées, sports nautiques et nuits étoilées dans le désert, chaque activité vous promet une expérience unique. Venez vivre l’authenticité et l’émotion. 🌍✨</p>
        {% if app.user %}
            <a href="{{ path('app_activities_new') }}" class="primary-btn text-uppercase">Create Activity</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="primary-btn text-uppercase">Login To Create</a>
        {% endif %}
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% if activities is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No activities available</h4>
                <p class="text-muted mb-3">Publish your first activity to get started.</p>
            </div>
        {% else %}
            <div class="row">
                {% for activity in activities %}
                    {% set canManage = app.user and activity.createdBy and activity.createdBy.id == app.user.id %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="activity-card w-100">
                            {% if activity.image %}
                                <img class="thumb" src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.titre }}">
                            {% else %}
                                <img class="thumb" src="{{ asset('adventure/img/g6.jpg') }}" alt="Activity placeholder">
                            {% endif %}

                            <div class="activity-body">
                                {% if canManage and activity.status %}
                                    <span class="status-pill status-{{ activity.status.value }}">{{ activity.status.value|replace({'_': ' '})|title }}</span>
                                {% endif %}
                                <h5 class="mb-2">{{ activity.titre }}</h5>
                                <p class="text-muted mb-2">{{ activity.description|striptags|slice(0, 120) }}{% if activity.description|length > 120 %}...{% endif %}</p>
                                {% if activity.categorie %}
                                    <small><i class="fa fa-tag"></i> {{ activity.categorie.value }}</small>
                                {% endif %}
                            </div>

                            <div class="activity-actions">
                                <a href="{{ path('app_activities_show', {'id': activity.id}) }}" class="genric-btn info-border small">View</a>
                                {% if canManage %}
                                    <a href="{{ path('app_activities_edit', {'id': activity.id}) }}" class="genric-btn warning-border small">Edit</a>
                                    <form method="post" action="{{ path('app_activities_delete', {'id': activity.id}) }}" onsubmit="return confirm('Delete this activity?');" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activity.id) }}">
                                        <button type="submit" class="genric-btn danger-border small">Delete</button>
                                    </form>
                                {% endif %}
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>

            <div class="d-flex justify-content-center mt-5">
                {{ knp_pagination_render(activities) }}
            </div>
        {% endif %}
    </div>
</section>

{% include '_chatbot.html.twig' with { chatContext: 'activities' } %}
{% endblock %}
