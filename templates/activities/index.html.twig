                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmActivityDeletion(activityId, activityTitle) {
    const confirmation = confirm(
        '⚠️ CONFIRMATION DE SUPPRESSION ⚠️\n\n' +
        'Êtes-vous sûr de vouloir supprimer l\'activité #' + activityId + ' : ' + activityTitle + ' ?\n\n' +
        'Cette action est IRRÉVERSIBLE et :\n' +
        '• Supprimera définitivement l\'activité\n' +
        '• Retirera l\'activité de tous les événements associés\n' +
        '• Effacera toutes les données associées\n\n' +
        'Cliquez sur OK pour confirmer ou Annuler pour garder l\'activité.'
    );
    
    return confirmation;
}
</script>
{% endblock %}
