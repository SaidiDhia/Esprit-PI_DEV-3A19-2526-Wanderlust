                </div>
                <div class="flex items-center justify-between border-t border-border pt-4">
                    <p class="text-foreground font-bold text-xl">45 TND</p>
                    <a href="#" class="bg-primary hover:bg-primary/90 text-white text-sm font-bold px-6 py-2 rounded-lg transition-all">Book Now</a>
                </div>
            </div>
        </div>
    {% endfor %}

        <!-- Activity 3 -->
        <div class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-56 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-amber-500/20 to-red-500/20 flex items-center justify-center text-6xl">🍽️</div>
