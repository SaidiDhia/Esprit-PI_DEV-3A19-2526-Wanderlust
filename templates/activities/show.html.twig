{% extends 'base.html.twig' %}

{% block title %}{{ activity.titre }} - Détails de l'activité{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .module-hero {
        position: relative;
        padding: 140px 0 100px;
        color: #fff;
        margin-bottom: 50px;
        overflow: hidden;
    }
    .video-background {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: -1;
    }
    .video-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.5) 100%);
        z-index: 0;
        pointer-events: none;
    }
    .hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .show-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        padding: 2.5rem;
        margin-bottom: 30px;
    }
    
    .activity-main-img {
        width: 100%;
        height: 450px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }
    
    .placeholder-img {
        width: 100%;
        height: 450px;
        border-radius: 12px;
        background: #f7f7f7;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        color: #a0a0a0;
        margin-bottom: 2rem;
    }

    .info-list { list-style: none; padding: 0; margin: 0; }
    .info-list li {
        display: flex; justify-content: space-between; align-items: center;
        padding: 15px 0; border-bottom: 1px solid #f0f0f0;
    }
    .info-list li:last-child { border-bottom: none; }
    .info-list i { color: #f6214b; margin-right: 12px; width: 24px; text-align: center; font-size: 1.2rem; }
    
    .category-badge {
        background: #1a3a5c;
        color: #fff;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }
</style>
{% endblock %}

{% block content %}

<!-- Hero Section avec Vidéo -->
<section class="module-hero">
    <video class="video-background" autoplay muted loop playsinline>
        <source src="{{ asset('adventure/video/letsDiscover.mp4') }}" type="video/mp4">
    </video>
    <div class="video-overlay"></div>
    
    <div class="hero-content">
        <div class="container">
            <h1 class="text-white mb-2">{{ activity.titre }}</h1>
            <p class="text-white opacity-75 mb-0">Découvrez tous les détails de cette activité incontournable</p>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        
        <!-- Flash messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success d-flex align-items-center mb-4"><i class="fa fa-check-circle me-2"></i> {{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger d-flex align-items-center mb-4"><i class="fa fa-exclamation-circle me-2"></i> {{ message }}</div>
        {% endfor %}

        <div class="row">
            <!-- Colonne Image & Description -->
            <div class="col-lg-8">
                <div class="show-card p-4">
                    {% if activity.image %}
                        <img src="{{ asset('uploads/activities/' ~ activity.image) }}" alt="{{ activity.titre }}" class="activity-main-img">
                    {% else %}
                        <div class="placeholder-img">
                            <i class="fa fa-image fa-4x mb-3"></i>
                            <h4>Aucune image disponible</h4>
                        </div>
                    {% endif %}

                    <h3 class="mb-4">Description</h3>
                    <p class="text-muted" style="line-height: 1.8;">
                        {{ activity.description|nl2br }}
                    </p>
                </div>
            </div>

            <!-- Colonne Informations -->
            <div class="col-lg-4">
                <div class="show-card">
                    <h4 class="mb-4">Détails <i class="fa fa-info-circle ms-2" style="color: #ccc;"></i></h4>
                    
                    {% set categoryLabel = activity.categorie is not null ? activity.categorie.getLabel() : 'Non classé' %}
                    {% set typeLabel = activity.typeActivite ?: 'Non défini' %}
                    
                    <ul class="info-list">
                        <li>
                            <div class="d-flex align-items-center">
                                <i class="fa fa-layer-group"></i> 
                                <span class="text-muted fw-bold">Catégorie</span>
                            </div>
                            <span class="category-badge">{{ categoryLabel }}</span>
                        </li>
                        <li>
                            <div class="d-flex align-items-center">
                                <i class="fa fa-tag"></i> 
                                <span class="text-muted fw-bold">Type</span>
                            </div>
                            <strong>{{ typeLabel }}</strong>
                        </li>
                        {% if activity.ageMinimum %}
                        <li>
                            <div class="d-flex align-items-center">
                                <i class="fa fa-child"></i> 
                                <span class="text-muted fw-bold">Âge minimum</span>
                            </div>
                            <strong>{{ activity.ageMinimum }} ans +</strong>
                        </li>
                        {% endif %}
                    </ul>

                    <div class="mt-5 text-center">
                        <a href="{{ path('app_activities_index') }}" class="genric-btn default circle w-100">
                            <i class="fa fa-arrow-left me-2"></i> Retour aux activités
                        </a>
                    </div>
                    
                    {% if app.user and activity.createdBy and activity.createdBy.id == app.user.id %}
                        <div class="mt-3 text-center">
                            <a href="{{ path('app_activities_edit', {'id': activity.id}) }}" class="genric-btn warning circle w-100 mb-2">
                                <i class="fa fa-edit me-2"></i> Modifier
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
            
        </div>
    </div>
</section>

{% include '_chatbot.html.twig' with { chatContext: 'activities' } %}
{% endblock %}