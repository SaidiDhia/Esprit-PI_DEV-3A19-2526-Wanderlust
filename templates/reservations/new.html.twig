{% extends 'base.html.twig' %}

{% block title %}Réserver — {{ event.lieu }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .module-hero {
        background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('{{ event.images|length > 0 ? asset("uploads/events/" ~ event.images|first.imagePath) : asset("adventure/img/slider2.jpg") }}') center center/cover no-repeat;
        padding: 140px 0 80px;
        color: #fff;
        margin-bottom: 50px;
        text-align: center;
    }
    .module-hero h1, .module-hero p { color: #fff; }

    .res-wrapper { max-width: 800px; margin: 0 auto; padding: 0 15px 60px; }

    .show-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        padding: 2.5rem;
        margin-bottom: 25px;
    }
    
    .show-card h4 {
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 12px;
        margin-bottom: 25px;
        font-weight: 700;
        display: flex; align-items: center; gap: 10px;
        color: #1a3a5c;
    }

    .event-recap {
        display: flex; align-items: center; gap: 20px;
        background: #fdfdfd; border: 1px solid #ebebeb;
        padding: 20px; border-radius: 10px;
    }
    .recap-icon {
        width: 60px; height: 60px; background: #f6214b; color: #fff;
        border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 24px;
    }
    .recap-info h3 { font-size: 1.2rem; font-weight: 700; margin: 0 0 5px; color: #1a3a5c; }
    .recap-info p { margin: 0; color: #6b7280; font-size: 0.9rem; }
    
    .recap-price { margin-left: auto; text-align: right; }
    .price-normal-show { font-size: 1.5rem; font-weight: 800; color: #1a3a5c; }
    .price-discounted-show { font-size: 1.5rem; font-weight: 900; color: #dc2626; }
    .price-original-show { text-decoration: line-through; color: #9ca3af; font-size: 0.9rem; display: block; }
    .discount-badge-show {
        background: linear-gradient(135deg, #dc2626, #f97316); color: #fff;
        font-size: 0.75rem; font-weight: 700; padding: 3px 8px; border-radius: 20px;
    }

    .form-group label { font-weight: 600; color: #1a3a5c; margin-bottom: 8px; }
    .form-control { border-radius: 8px; padding: 12px 15px; border: 1px solid #e2e8f0; }
    .form-control:focus { border-color: #f6214b; box-shadow: 0 0 0 3px rgba(246, 33, 75, 0.1); }

    .counter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .counter-box {
        border: 1px solid #e2e8f0; border-radius: 10px; padding: 15px;
        display: flex; justify-content: space-between; align-items: center;
        background: #f8fafc;
    }
    .counter-label { font-weight: 600; color: #1a3a5c; }
    .counter-label small { display: block; color: #64748b; font-weight: 400; font-size: 0.8rem; }
    
    .counter-controls { display: flex; align-items: center; gap: 10px; }
    .btn-counter {
        width: 35px; height: 35px; border-radius: 50%; border: none;
        background: #e2e8f0; color: #1a3a5c; font-weight: bold; font-size: 18px;
        display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s;
    }
    .btn-counter:hover { background: #cbd5e1; }
    .counter-value { font-size: 1.2rem; font-weight: 700; color: #f6214b; width: 30px; text-align: center; }

    .total-box {
        background: #1a3a5c; color: #fff; border-radius: 10px; padding: 25px;
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 15px; box-shadow: 0 5px 15px rgba(26,58,92,0.2);
    }
    .total-left span { display: block; opacity: 0.8; font-size: 0.9rem; }
    .total-price { font-size: 2.2rem; font-weight: 800; color: #4ade80; }

    .btn-submit {
        background: #f6214b; color: #fff; padding: 18px; width: 100%;
        border: none; border-radius: 10px; font-weight: 700; font-size: 1.1rem;
        cursor: pointer; transition: 0.3s; margin-top: 25px; box-shadow: 0 5px 15px rgba(246, 33, 75, 0.3);
    }
    .btn-submit:hover { background: #d81b40; transform: translateY(-2px); }

    .flash-error { background: #fee2e2; color: #991b1b; padding: 15px; border-radius: 10px; margin-bottom: 20px; font-weight: 600; }
</style>
{% endblock %}

{% block content %}

<section class="module-hero">
    <div class="container">
        <h1 class="mb-2"><i class="fa fa-ticket me-3"></i>Réservation</h1>
        <p class="mb-0">Confirmez vos places pour cet événement exceptionnel</p>
    </div>
</section>

<div class="res-wrapper">
    {% for msg in app.flashes('error') %}
        <div class="flash-error"><i class="fa fa-exclamation-triangle me-2"></i> {{ msg }}</div>
    {% endfor %}

    <!-- Recap de l'événement -->
    <div class="show-card event-recap mb-4">
        <div class="recap-icon"><i class="fa fa-map-marker"></i></div>
        <div class="recap-info">
            <h3>{{ event.lieu }}</h3>
            <p><i class="fa fa-calendar me-2"></i>{{ event.dateDebut|date('d/m/Y H:i') }}</p>
            <p><i class="fa fa-users me-2"></i>{{ event.placesDisponibles }} places disponibles</p>
        </div>
        <div class="recap-price text-end" id="recap-price-block">
            <!-- Price loaded via JS -->
            <div class="price-normal-show">{{ event.prix }} TND</div>
        </div>
    </div>

    {{ form_start(form, {'attr': {'id': 'res-form', 'novalidate': 'novalidate'}}) }}

        <!-- Infos perso -->
        <div class="show-card">
            <h4><i class="fa fa-user"></i> Informations personnelles</h4>
            
            <div class="form-group mb-4">
                {{ form_label(form.nomComplet) }}
                {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Jean Dupont'}}) }}
                {{ form_errors(form.nomComplet) }}
            </div>

            <div class="row mb-4">
                <div class="col-md-6 form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'votre.email@example.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="col-md-6 form-group mt-3 mt-md-0">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': '+216 XX XXX XXX'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.demandesSpeciales, 'Demandes spéciales (optionnel)') }}
                {{ form_widget(form.demandesSpeciales, {'attr': {'class': 'form-control', 'placeholder': 'Régimes alimentaires, besoins spécifiques...', 'rows': '3'}}) }}
                {{ form_errors(form.demandesSpeciales) }}
            </div>
        </div>

        <!-- Participants & Total -->
        <div class="show-card">
            <h4><i class="fa fa-users"></i> Participants</h4>

            <div class="counter-grid">
                <div class="counter-box">
                    <div class="counter-label">Adultes <small>18 ans et plus</small></div>
                    <div class="counter-controls">
                        <button type="button" class="btn-counter" onclick="decrement('adultes')">−</button>
                        <span class="counter-value" id="val-adultes">1</span>
                        <button type="button" class="btn-counter" onclick="increment('adultes', {{ event.placesDisponibles }})">+</button>
                    </div>
                </div>

                <div class="counter-box">
                    <div class="counter-label">Enfants <small>Moins de 18 ans</small></div>
                    <div class="counter-controls">
                        <button type="button" class="btn-counter" onclick="decrement('enfants')">−</button>
                        <span class="counter-value" id="val-enfants">0</span>
                        <button type="button" class="btn-counter" onclick="increment('enfants', {{ event.placesDisponibles }})">+</button>
                    </div>
                </div>
            </div>

            <!-- Hidden Inputs that Symfony reads -->
            <div style="display:none;">
                {{ form_widget(form.nombreAdultes, {'id': 'input-adultes', 'attr': {'class': 'form-control'}}) }}
                {{ form_widget(form.nombreEnfants, {'id': 'input-enfants', 'attr': {'class': 'form-control'}}) }}
            </div>
            
            <div class="text-danger mt-2">
                {{ form_errors(form.nombreAdultes) }}
                {{ form_errors(form.nombreEnfants) }}
            </div>

            <!-- Dynamic Total Block -->
            <div class="total-box mt-5">
                <div class="total-left">
                    <span style="font-size:1.1rem; font-weight: 700; opacity:1">Total à régler</span>
                    <span id="total-detail">1 personne</span>
                </div>
                <div class="total-right">
                    <div class="total-price" id="total-amount">0.00 TND</div>
                </div>
            </div>

            <button type="submit" class="btn-submit">Confirmer la réservation <i class="fa fa-arrow-right ms-2"></i></button>
            <div class="text-center mt-4">
                <a href="{{ path('app_events_show', {'id': event.id}) }}" class="text-muted text-decoration-none"><i class="fa fa-arrow-left me-2"></i>Retour à l'événement</a>
            </div>
        </div>
    {{ form_end(form) }}
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    const BasePrix = parseFloat('{{ event.prix }}');
    const Places   = parseInt('{{ event.placesDisponibles }}', 10);
    const Capacite = parseInt('{{ event.capaciteMax }}', 10);
    const DateDeb  = '{{ event.dateDebut ? event.dateDebut|date('Y-m-d') : '' }}';
    const Statut   = '{{ event.status.value }}';
    
    let CurrentPrix = BasePrix;

    // ----- Logique de Réduction Intelligente -----
    function calcAutoDiscount(places, capacite, dateDebutStr, statut) {
        if (statut !== 'accepte') return 0;
        if (!dateDebutStr) return 0;
        const daysLeft = (new Date(dateDebutStr) - new Date()) / 86400000;
        if (daysLeft < 0) return 0;
        if (!capacite || capacite <= 0 || places <= 0) return 0;
        if (daysLeft > 30) return 0;
        const occupancyRate = (capacite - places) / capacite;
        if (occupancyRate < 0.70) return 0;

        const occDiscount  = ((occupancyRate - 0.70) / 0.30) * 0.15;
        const timeDiscount = ((30 - daysLeft) / 30) * 0.15;
        return Math.min(Math.round((occDiscount + timeDiscount) * 100) / 100, 0.30);
    }

    // Calculer le prix remisé (ce qui paiera le client final si éligible)
    document.addEventListener('DOMContentLoaded', function() {
        const discount = calcAutoDiscount(Places, Capacite, DateDeb, Statut);
        const recapBlock = document.getElementById('recap-price-block');
        
        if (discount >= 0.05) {
            const pct = Math.round(discount * 100);
            CurrentPrix = BasePrix * (1 - discount);
            
            if (recapBlock) {
                recapBlock.innerHTML = `
                    <span class="price-original-show">${BasePrix.toFixed(2)} TND</span>
                    <span class="price-discounted-show">${CurrentPrix.toFixed(2)} TND</span>
                    <span class="discount-badge-show">-${pct}% de réduction AI !</span>
                    <small class="d-block text-muted">par personne</small>
                `;
            }
        } else {
            if (recapBlock) {
                recapBlock.innerHTML = `
                    <span class="price-normal-show">${BasePrix.toFixed(2)} TND</span>
                    <small class="d-block text-muted">par personne</small>
                `;
            }
        }

        // Initialize counters and total
        const adultesInput = document.getElementById('input-adultes');
        const enfantsInput = document.getElementById('input-enfants');
        if (adultesInput && !adultesInput.value) adultesInput.value = 1;
        if (enfantsInput && !enfantsInput.value) enfantsInput.value = 0;
        
        updateTotal();
    });

    // ----- Compteurs -----
    function getAdultes() { return parseInt(document.getElementById('val-adultes').textContent) || 0; }
    function getEnfants() { return parseInt(document.getElementById('val-enfants').textContent) || 0; }

    function increment(type, max) {
        if (getAdultes() + getEnfants() >= max) return;
        
        const el = document.getElementById('val-' + type);
        const input = document.getElementById('input-' + type);
        
        if (el && input) {
            const val = parseInt(el.textContent) + 1;
            el.textContent = val;
            input.value = val;
            updateTotal();
        }
    }

    function decrement(type) {
        const el = document.getElementById('val-' + type);
        const input = document.getElementById('input-' + type);
        if (!el || !input) return;
        
        let val = parseInt(el.textContent) - 1;
        if (type === 'adultes' && val === 0 && getEnfants() === 0) return; // Forcer min 1 participant
        if (val < 0) return;

        el.textContent = val;
        input.value = val;
        updateTotal();
    }

    function updateTotal() {
        const total = getAdultes() + getEnfants();
        const montant = (CurrentPrix * total).toFixed(2);
        
        const totalAmount = document.getElementById('total-amount');
        const totalDetail = document.getElementById('total-detail');
        
        if (totalAmount) totalAmount.textContent = montant + ' TND';
        if (totalDetail) totalDetail.textContent = `${total} personne${total > 1 ? 's' : ''}`;
    }
</script>
{% endblock %}