{% extends 'base.html.twig' %}

{% block title %}Réserver — {{ event.lieu }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --primary-color: #667eea;
        --primary-dark: #5a67d8;
        --secondary-color: #764ba2;
        --success-color: #28a745;
        --danger-color: #dc3545;
        --warning-color: #ffc107;
        --border-radius: 16px;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
        --shadow-md: 0 8px 24px rgba(0,0,0,0.12);
        --shadow-lg: 0 16px 40px rgba(0,0,0,0.15);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body { 
        background: #fffcf5; 
        font-family: 'DM Sans', sans-serif;
        color: #0f0e17;
    }

    /* Section Header */
    .res-hero {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        padding: 4rem 0 2rem;
        text-align: center;
        color: white;
        margin-bottom: 2.5rem;
        position: relative;
        overflow: hidden;
    }

    .res-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.1)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
        background-size: cover;
        opacity: 0.3;
    }

    .res-hero h1 { 
        font-family: 'Syne', sans-serif; 
        font-size: 2rem; 
        font-weight: 800; 
        margin-bottom: .4rem; 
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }
    
    .res-hero p  { 
        opacity: .6; 
        font-size: .95rem; 
    }

    .res-wrapper { 
        max-width: 780px; 
        margin: 0 auto; 
        padding: 0 1.5rem 4rem; 
    }

    /* Event recap */
    .event-recap {
        background: white;
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: var(--shadow-sm);
    }

    .recap-icon {
        width: 48px; 
        height: 48px;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        border-radius: 12px;
        display: flex; 
        align-items: center; 
        justify-content: center;
    }

    .recap-icon i {
        font-size: 1.25rem;
        color: white;
    }

    .recap-content h3 {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: #0f0e17;
        margin-bottom: 0.25rem;
    }

    .recap-content p {
        color: #6b6b80;
        font-size: 0.9rem;
        margin-bottom: 0;
    }

    .recap-info h3 { 
        font-family: 'Syne', sans-serif; 
        font-size: 1rem; 
        font-weight: 700; 
        margin: 0 0 .2rem; 
    }
    
    .recap-info p  { 
        color: var(--mid); 
        font-size: .82rem; 
        margin: 0; 
    }

    .recap-price {
        margin-left: auto; 
        text-align: right; 
        flex-shrink: 0;
    }

    .recap-price .price { 
        font-family: 'Syne', sans-serif; 
        font-size: 1.5rem; 
        font-weight: 800; 
        color: var(--primary-color); 
    }
    
    .recap-price small  { 
        color: var(--mid); 
        font-size: .75rem; 
        display: block; 
    }

    /* Form Card */
    .form-card {
        background: white;
        border: 1px solid var(--line);
        border-radius: var(--border-radius);
        padding: 1.75rem 2rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .form-header {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
    }

    .form-body {
        padding: 2rem;
    }

    /* Form Groups */
    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: #0f0e17;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-group .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        font-size: 0.95rem;
        transition: var(--transition);
        background: white;
    }

    .form-group .form-control:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    /* Counter Section */
    .counter-group {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .counter-item {
        flex: 1;
        background: white;
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        padding: 1rem;
        text-align: center;
    }

    .counter-label {
        font-weight: 600;
        color: #6b6b80;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .counter-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .counter-btn {
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        font-size: 1rem;
        cursor: pointer;
        transition: var(--transition);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .counter-btn:hover {
        transform: scale(1.1);
        box-shadow: var(--shadow-md);
    }

    .counter-value {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary-color);
        min-width: 40px;
    }

    /* Total Section */
    .total-section {
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .total-amount {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }

    .total-detail {
        color: #6b6b80;
        font-size: 0.9rem;
    }

    /* Buttons */
    .btn-submit {
        background: #209cd1;
        color: white;
        border: none;
        padding: 1rem 2rem;
        border-radius: var(--border-radius);
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: var(--transition);
        width: 100%;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
    }

    .btn-submit:disabled {
        background: #e4e1d8;
        color: #6b6b80;
        cursor: not-allowed;
        transform: none;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .res-hero {
            padding: 3rem 0 1.5rem;
        }
        
        .res-hero h1 {
            font-size: 1.75rem;
        }
        
        .res-wrapper {
            padding: 0 1rem 2rem;
        }
        
        .event-recap {
            flex-direction: column;
            text-align: center;
        }
        
        .counter-group {
            flex-direction: column;
            gap: 1rem;
        }
    }

    /* ── Form card ── */
    .form-card {
        background: white;
        border: 1px solid var(--line);
        border-radius: var(--border-radius);
        border-radius: 16px;
        padding: 1.75rem 2rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .form-section-title {
        font-family: 'Syne', sans-serif;
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--accent);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .form-section-title::after { content:''; flex:1; height:1px; background:var(--line); margin-left:.4rem; }

    .form-group { margin-bottom: 1.1rem; }
    .form-group label { display:block; font-size:.84rem; font-weight:500; color:var(--ink); margin-bottom:.4rem; }

    .form-control {
        width: 100%;
        padding: .7rem 1rem;
        border: 1.5px solid var(--line);
        border-radius: 10px;
        font-size: .92rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
        background: var(--paper);
        transition: border-color .2s, box-shadow .2s;
        outline: none;
    }
    .form-control:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(232,87,42,.1); }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media(max-width:600px) { .two-col { grid-template-columns: 1fr; } }

    /* ── Compteurs adultes/enfants ── */
    .counter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
    @media(max-width:500px) { .counter-grid { grid-template-columns: 1fr; } }

    .counter-box {
        border: 1.5px solid var(--line);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--paper);
        transition: border-color .2s;
    }
    .counter-box:focus-within { border-color: var(--accent); }

    .counter-label { font-size: .88rem; font-weight: 500; color: var(--ink); }
    .counter-label small { display:block; color:var(--mid); font-size:.74rem; font-weight:400; margin-top:.1rem; }

    .counter-controls { display: flex; align-items: center; gap: .5rem; }

    .counter-btn {
        width: 30px; height: 30px;
        border-radius: 50%;
        border: 1.5px solid var(--line);
        background: white;
        color: var(--ink);
        font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all .2s; line-height: 1;
        flex-shrink: 0;
    }
    .counter-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(232,87,42,.05); }

    .counter-value {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem; font-weight: 700;
        min-width: 28px; text-align: center;
    }

    /* ── Résumé total ── */
    .total-summary {
        background: linear-gradient(135deg, #0f0e17 0%, #2d2b3d 100%);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
    }

    .total-left .label  { font-size: .82rem; opacity: .6; margin-bottom: .15rem; }
    .total-left .detail { font-size: .8rem; opacity: .5; }
    .total-amount { font-family: 'Syne',sans-serif; font-size: 2rem; font-weight: 800; }

    /* ── Bouton submit ── */
    .btn-submit {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        border: none;
        border-radius: 12px;
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: .04em;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(102, 126, 234, 0.35);
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        text-decoration: none;
    }
    .btn-submit:hover { background: linear-gradient(135deg, var(--primary-dark), var(--secondary-color)); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5); }

    .btn-back {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        color: var(--mid); font-size: .88rem; text-decoration: none;
        margin-top: .75rem; transition: color .2s;
    }
    .btn-back:hover { color: var(--ink); }

    .flash-error {
        background: #fee2e2; color: #991b1b;
        padding: .9rem 1.1rem; border-radius: 10px;
        margin-bottom: 1.25rem; font-size: .88rem;
        display: flex; align-items: center; gap: .5rem;
    }
</style>
{% endblock %}

{% block content %}

<div class="res-hero">
    <div class="container">
        <h1><i class="fas fa-calendar-check me-2"></i>Réserver un événement</h1>
        <p>Complétez le formulaire pour confirmer votre réservation</p>
    </div>
</div>

<div class="res-wrapper">

    {# Flash messages #}
    {% for msg in app.flashes('error') %}
        <div class="flash-error">
            <i class="fas fa-exclamation-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {# Récap event #}
    <div class="event-recap">
        <div class="recap-icon"><i class="fas fa-map-marker-alt"></i></div>
        <div class="recap-info">
            <h3>{{ event.lieu }}</h3>
            <p>
                <i class="fas fa-calendar me-1"></i>{{ event.dateDebut|date('d/m/Y à H:i') }}
                &nbsp;·&nbsp;
                <i class="fas fa-users me-1"></i>{{ event.placesDisponibles }} place(s) dispo
            </p>
        </div>
        <div class="recap-price">
            <div class="price">{{ event.prix }} TND</div>
            <small>par personne</small>
        </div>
    </div>

    {{ form_start(form, {'attr': {'id': 'res-form', 'novalidate': 'novalidate'}}) }}

        {# Informations personnelles #}
        <div class="form-card">
            <div class="form-section-title">
                <i class="fas fa-user"></i> Informations personnelles
            </div>

            <div class="form-group">
                {{ form_label(form.nomComplet) }}
                {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nomComplet) }}
            </div>

            <div class="two-col">
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
            </div>

            {# Demandes spéciales #}
            <div class="form-group">
                {{ form_label(form.demandesSpeciales, 'Demandes spéciales (optionnel)') }}
                {{ form_widget(form.demandesSpeciales, {'attr': {'class': 'form-control', 'placeholder': 'Indiquez ici vos demandes spéciales...'}}) }}
                {{ form_errors(form.demandesSpeciales) }}
            </div>
        </div>

        {# Participants #}
        <div class="form-card">
            <div class="form-section-title">
                <i class="fas fa-users"></i> Participants
            </div>

            {# Compteurs visuels #}
            <div class="counter-grid">
                <div class="counter-box">
                    <div class="counter-label">
                        Adultes
                        <small>18 ans et plus</small>
                    </div>
                    <div class="counter-controls">
                        <button type="button" class="counter-btn" onclick="decrement('adultes')">−</button>
                        <span class="counter-value" id="val-adultes">1</span>
                        <button type="button" class="counter-btn" onclick="increment('adultes', {{ event.placesDisponibles }})">+</button>
                    </div>
                    {{ form_widget(form.nombreAdultes, {
                        'id': 'input-adultes',
                        'attr': {
                            'class': 'form-control',
                            'style': 'display:none'
                        }
                    }) }}
                </div>

                <div class="counter-box">
                    <div class="counter-label">
                        Enfants
                        <small>Moins de 18 ans</small>
                    </div>
                    <div class="counter-controls">
                        <button type="button" class="counter-btn" onclick="decrement('enfants')">−</button>
                        <span class="counter-value" id="val-enfants">0</span>
                        <button type="button" class="counter-btn" onclick="increment('enfants', {{ event.placesDisponibles }})">+</button>
                    </div>
                    {{ form_widget(form.nombreEnfants, {
                        'id': 'input-enfants',
                        'attr': {
                            'class': 'form-control',
                            'style': 'display:none'
                        }
                    }) }}
                </div>
            </div>

            {{ form_errors(form.nombreAdultes) }}
            {{ form_errors(form.nombreEnfants) }}

        </div>

        <button type="submit" class="btn-submit">
            <i class="fas fa-check-circle"></i> Confirmer la réservation
        </button>

        <a href="{{ path('app_events_show', {'id': event.id}) }}" class="btn-back">
            <i class="fas fa-arrow-left"></i> Retour à l'événement
        </a>

    {{ form_end(form) }}
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const PRIX_UNIT  = parseFloat('{{ event.prix }}');
const MAX_PLACES = parseInt('{{ event.placesDisponibles }}');

function getAdultes() { 
    const el = document.getElementById('val-adultes');
    return el ? parseInt(el.textContent) || 0 : 0; 
}

function getEnfants() { 
    const el = document.getElementById('val-enfants');
    return el ? parseInt(el.textContent) || 0 : 0; 
}

function increment(type, max) {
    console.log('increment called with type:', type);
    
    if (getAdultes() + getEnfants() >= max) {
        console.log('max reached');
        return;
    }
    
    const el = document.getElementById('val-' + type);
    const input = document.getElementById('input-' + type);
    
    console.log('el:', el);
    console.log('input:', input);
    
    if (el && input) {
        const val = parseInt(el.textContent) + 1;
        console.log('new val:', val);
        el.textContent = val;
        input.value = val;
        updateTotal();
    } else {
        console.log('elements not found');
    }
}

function decrement(type) {
    const el = document.getElementById('val-' + type);
    const input = document.getElementById('input-' + type);
    
    console.log('el:', el);
    console.log('input:', input);
    
    if (!el || !input) {
        console.log('elements not found');
        return;
    }
    
    let val = parseInt(el.textContent) - 1;
    
    if (type === 'adultes' && val === 0 && getEnfants() === 0) return;
    if (val < 0) return;

    console.log('new val:', val);
    el.textContent = val;
    input.value = val;
    updateTotal();
}

function updateTotal() {
    const total = getAdultes() + getEnfants();
    const montant = (PRIX_UNIT * total).toFixed(2);
    
    // Mettre à jour seulement si les éléments existent
    const totalAmount = document.getElementById('total-amount');
    const totalDetail = document.getElementById('total-detail');
    
    if (totalAmount) {
        totalAmount.textContent = montant + ' TND';
    }
    
    if (totalDetail) {
        totalDetail.textContent = `${total} personne${total > 1 ? 's' : ''} × ${PRIX_UNIT} TND`;
    }
}

// Init
document.addEventListener('DOMContentLoaded', function() {
    const adultesInput = document.getElementById('input-adultes');
    const enfantsInput = document.getElementById('input-enfants');
    
    if (adultesInput) adultesInput.value = 1;
    if (enfantsInput) enfantsInput.value = 0;
    
    updateTotal();
});
</script>
{% endblock %}