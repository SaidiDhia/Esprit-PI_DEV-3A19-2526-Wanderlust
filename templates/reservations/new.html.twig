{% extends 'base.html.twig' %}

{% block title %}Réserver — {{ event.lieu }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --accent: #e8572a;
        --ink:    #0f0e17;
        --mid:    #6b6b80;
        --line:   #e4e1d8;
        --paper:  #fffcf5;
    }

    body { background: var(--paper); font-family: 'DM Sans', sans-serif; }

    /* ── Hero ── */
    .res-hero {
        background: linear-gradient(135deg, #0f0e17 0%, #2d2b3d 100%);
        padding: 3rem 0 2rem;
        text-align: center;
        color: white;
        margin-bottom: 2.5rem;
    }
    .res-hero h1 { font-family: 'Syne', sans-serif; font-size: 2rem; font-weight: 800; margin-bottom: .4rem; }
    .res-hero p  { opacity: .6; font-size: .95rem; }

    .res-wrapper { max-width: 780px; margin: 0 auto; padding: 0 1.5rem 4rem; }

    /* ── Event recap ── */
    .event-recap {
        background: white;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .recap-icon {
        width: 48px; height: 48px;
        background: linear-gradient(135deg, var(--accent), #f7a278);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 1.2rem; flex-shrink: 0;
    }

    .recap-info h3 { font-family: 'Syne',sans-serif; font-size: 1rem; font-weight: 700; margin: 0 0 .2rem; }
    .recap-info p  { color: var(--mid); font-size: .82rem; margin: 0; }

    .recap-price {
        margin-left: auto; text-align: right; flex-shrink: 0;
    }
    .recap-price .price { font-family: 'Syne',sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--accent); }
    .recap-price small  { color: var(--mid); font-size: .75rem; display: block; }

    /* ── Form card ── */
    .form-card {
        background: white;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 1.75rem 2rem;
        margin-bottom: 1.25rem;
        box-shadow: 0 2px 10px rgba(0,0,0,.04);
    }

    .form-section-title {
        font-family: 'Syne', sans-serif;
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--accent);
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .form-section-title::after { content:''; flex:1; height:1px; background:var(--line); margin-left:.4rem; }

    .form-group { margin-bottom: 1.1rem; }
    .form-group label { display:block; font-size:.84rem; font-weight:500; color:var(--ink); margin-bottom:.4rem; }

    .form-control {
        width: 100%;
        padding: .7rem 1rem;
        border: 1.5px solid var(--line);
        border-radius: 10px;
        font-size: .92rem;
        font-family: 'DM Sans', sans-serif;
        color: var(--ink);
        background: var(--paper);
        transition: border-color .2s, box-shadow .2s;
        outline: none;
    }
    .form-control:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(232,87,42,.1); }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media(max-width:600px) { .two-col { grid-template-columns: 1fr; } }

    /* ── Compteurs adultes/enfants ── */
    .counter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }
    @media(max-width:500px) { .counter-grid { grid-template-columns: 1fr; } }

    .counter-box {
        border: 1.5px solid var(--line);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--paper);
        transition: border-color .2s;
    }
    .counter-box:focus-within { border-color: var(--accent); }

    .counter-label { font-size: .88rem; font-weight: 500; color: var(--ink); }
    .counter-label small { display:block; color:var(--mid); font-size:.74rem; font-weight:400; margin-top:.1rem; }

    .counter-controls { display: flex; align-items: center; gap: .5rem; }

    .counter-btn {
        width: 30px; height: 30px;
        border-radius: 50%;
        border: 1.5px solid var(--line);
        background: white;
        color: var(--ink);
        font-size: 1.1rem;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all .2s; line-height: 1;
        flex-shrink: 0;
    }
    .counter-btn:hover { border-color: var(--accent); color: var(--accent); background: rgba(232,87,42,.05); }

    .counter-value {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem; font-weight: 700;
        min-width: 28px; text-align: center;
    }

    /* ── Résumé total ── */
    .total-summary {
        background: linear-gradient(135deg, #0f0e17 0%, #2d2b3d 100%);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
    }

    .total-left .label  { font-size: .82rem; opacity: .6; margin-bottom: .15rem; }
    .total-left .detail { font-size: .8rem; opacity: .5; }
    .total-amount { font-family: 'Syne',sans-serif; font-size: 2rem; font-weight: 800; }

    /* ── Bouton submit ── */
    .btn-submit {
        width: 100%;
        padding: 1rem;
        background: var(--accent);
        color: white;
        border: none;
        border-radius: 12px;
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: .04em;
        cursor: pointer;
        transition: all .2s;
        box-shadow: 0 4px 14px rgba(232,87,42,.3);
        margin-top: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        text-decoration: none;
    }
    .btn-submit:hover { background: #d14820; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(232,87,42,.4); }

    .btn-back {
        display: flex; align-items: center; justify-content: center; gap: .5rem;
        color: var(--mid); font-size: .88rem; text-decoration: none;
        margin-top: .75rem; transition: color .2s;
    }
    .btn-back:hover { color: var(--ink); }

    .flash-error {
        background: #fee2e2; color: #991b1b;
        padding: .9rem 1.1rem; border-radius: 10px;
        margin-bottom: 1.25rem; font-size: .88rem;
        display: flex; align-items: center; gap: .5rem;
    }
</style>
{% endblock %}

{% block content %}

<div class="res-hero">
    <div class="container">
        <h1><i class="fas fa-calendar-check me-2"></i>Réserver un événement</h1>
        <p>Complétez le formulaire pour confirmer votre réservation</p>
    </div>
</div>

<div class="res-wrapper">

    {# Flash messages #}
    {% for msg in app.flashes('error') %}
        <div class="flash-error">
            <i class="fas fa-exclamation-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {# Récap event #}
    <div class="event-recap">
        <div class="recap-icon"><i class="fas fa-map-marker-alt"></i></div>
        <div class="recap-info">
            <h3>{{ event.lieu }}</h3>
            <p>
                <i class="fas fa-calendar me-1"></i>{{ event.dateDebut|date('d/m/Y à H:i') }}
                &nbsp;·&nbsp;
                <i class="fas fa-users me-1"></i>{{ event.placesDisponibles }} place(s) dispo
            </p>
        </div>
        <div class="recap-price">
            <div class="price">{{ event.prix }} TND</div>
            <small>par personne</small>
        </div>
    </div>

    {{ form_start(form, {'attr': {'id': 'res-form', 'novalidate': 'novalidate'}}) }}

        {# Informations personnelles #}
        <div class="form-card">
            <div class="form-section-title">
                <i class="fas fa-user"></i> Informations personnelles
            </div>

            <div class="form-group">
                {{ form_label(form.nomComplet) }}
                {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nomComplet) }}
            </div>

            <div class="two-col">
                <div class="form-group">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
            </div>
        </div>

        {# Participants #}
        <div class="form-card">
            <div class="form-section-title">
                <i class="fas fa-users"></i> Participants
            </div>

            {# Compteurs visuels #}
            <div class="counter-grid">
                <div class="counter-box">
                    <div class="counter-label">
                        Adultes
                        <small>18 ans et plus</small>
                    </div>
                    <div class="counter-controls">
                        <button type="button" class="counter-btn" onclick="decrement('adultes')">−</button>
                        <span class="counter-value" id="val-adultes">1</span>
                        <button type="button" class="counter-btn" onclick="increment('adultes', {{ event.placesDisponibles }})">+</button>
                    </div>
                    {{ form_widget(form.nombreAdultes, {'attr': {
                        'id': 'input-adultes',
                        'style': 'display:none',
                        'class': 'form-control'
                    }}) }}
                </div>

                <div class="counter-box">
                    <div class="counter-label">
                        Enfants
                        <small>Moins de 18 ans</small>
                    </div>
                    <div class="counter-controls">
                        <button type="button" class="counter-btn" onclick="decrement('enfants')">−</button>
                        <span class="counter-value" id="val-enfants">0</span>
                        <button type="button" class="counter-btn" onclick="increment('enfants', {{ event.placesDisponibles }})">+</button>
                    </div>
                    {{ form_widget(form.nombreEnfants, {'attr': {
                        'id': 'input-enfants',
                        'style': 'display:none',
                        'class': 'form-control'
                    }}) }}
                </div>
            </div>

            {{ form_errors(form.nombreAdultes) }}
            {{ form_errors(form.nombreEnfants) }}

            {# Résumé total #}
            <div class="total-summary">
                <div class="total-left">
                    <div class="label">Montant total</div>
                    <div class="detail" id="total-detail">
                        1 personne × {{ event.prix }} TND
                    </div>
                </div>
                <div class="total-amount" id="total-amount">
                    {{ event.prix }} TND
                </div>
            </div>
        </div>

        {# Demandes spéciales #}
        <div class="form-card">
            <div class="form-section-title">
                <i class="fas fa-comment-dots"></i> Demandes spéciales
                <span style="font-size:.75rem;color:var(--mid);font-weight:400;
                             text-transform:none;letter-spacing:0;margin-left:.25rem;">
                    — optionnel
                </span>
            </div>
            <div class="form-group" style="margin:0;">
                {{ form_widget(form.demandesSpeciales, {'attr': {'class': 'form-control'}}) }}
            </div>
        </div>

        <button type="submit" class="btn-submit">
            <i class="fas fa-check-circle"></i> Confirmer la réservation
        </button>

        <a href="{{ path('app_events_show', {'id': event.id}) }}" class="btn-back">
            <i class="fas fa-arrow-left"></i> Retour à l'événement
        </a>

    {{ form_end(form) }}
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const PRIX_UNIT  = parseFloat('{{ event.prix }}');
const MAX_PLACES = parseInt('{{ event.placesDisponibles }}');

function getAdultes() { return parseInt(document.getElementById('val-adultes').textContent) || 0; }
function getEnfants() { return parseInt(document.getElementById('val-enfants').textContent) || 0; }

function increment(type, max) {
    if (getAdultes() + getEnfants() >= max) return;
    const el    = document.getElementById('val-' + type);
    const input = document.getElementById('input-' + type);
    const val   = parseInt(el.textContent) + 1;
    el.textContent = val;
    input.value    = val;
    updateTotal();
}

function decrement(type) {
    const el    = document.getElementById('val-' + type);
    const input = document.getElementById('input-' + type);
    let   val   = parseInt(el.textContent) - 1;

    // Empêcher adultes < 0 ; empêcher total < 1
    if (val < 0) return;
    if (type === 'adultes' && val === 0 && getEnfants() === 0) return;

    el.textContent = val;
    input.value    = val;
    updateTotal();
}

function updateTotal() {
    const total   = getAdultes() + getEnfants();
    const montant = (PRIX_UNIT * total).toFixed(2);
    document.getElementById('total-amount').textContent = montant + ' TND';
    document.getElementById('total-detail').textContent =
        `${total} personne${total > 1 ? 's' : ''} × ${PRIX_UNIT} TND`;
}

// Init
document.getElementById('input-adultes').value = 1;
document.getElementById('input-enfants').value = 0;
updateTotal();
</script>
{% endblock %}