{% extends 'base.html.twig' %}

{% block title %}Modifier Réservation{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

    :root {
        --primary-color: #667eea;
        --primary-dark: #5a67d8;
        --secondary-color: #764ba2;
        --success-color: #28a745;
        --danger-color: #dc3545;
        --warning-color: #ffc107;
        --border-radius: 16px;
        --shadow-sm: 0 2px 8px rgba(0,0,0,0.1);
        --shadow-md: 0 8px 24px rgba(0,0,0,0.12);
        --shadow-lg: 0 16px 40px rgba(0,0,0,0.15);
        --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    body { 
        background: #fffcf5; 
        font-family: 'DM Sans', sans-serif;
        color: #0f0e17;
    }

    /* Section Header */
    .edit-hero {
        background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
        padding: 4rem 0 2rem;
        text-align: center;
        color: white;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }

    .edit-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320"><path fill="rgba(255,255,255,0.1)" d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,154.7C960,171,1056,181,1152,165.3C1248,149,1344,107,1392,85.3L1440,64L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path></svg>') no-repeat bottom;
        background-size: cover;
        opacity: 0.3;
    }

    .edit-hero h1 { 
        font-family: 'Syne', sans-serif; 
        font-size: 2.5rem; 
        font-weight: 800; 
        margin-bottom: .5rem; 
        text-shadow: 0 2px 4px rgba(0,0,0,0.3);
    }
    
    .edit-hero p  { 
        opacity: .8; 
        font-size: 1.1rem; 
    }

    .container { 
        max-width: 800px; 
        margin: 0 auto; 
        padding: 0 2rem; 
    }

    /* Edit Card */
    .edit-card {
        background: white;
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        box-shadow: var(--shadow-md);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
        color: white;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
    }

    .reservation-id {
        background: rgba(255,255,255,0.2);
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .card-body {
        padding: 2rem;
    }

    .form-section {
    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: #0f0e17;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-group .form-control {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e4e1d8;
        border-radius: var(--border-radius);
        font-size: 0.95rem;
        transition: var(--transition);
        background: white;
    }

    .form-group .form-control:focus {
        outline: none;
        border-color: var(--primary-color);
        box-shadow: 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-section {
        margin-bottom: 2rem;
    }
    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--primary-color);
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    @media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }

    .counter-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .counter-box {
        border: 1.5px solid var(--primary-color);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        text-align: center;
        background: white;
    }
    .counter-label {
        font-weight: 600;
        color: #0f0e17;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }
    .counter-value {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.5rem;
    }

    .help-text {
        font-size: 0.875rem;
        color: var(--mid);
        margin-top: 0.25rem;
    }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }
    .btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-primary {
        background: var(--accent);
        color: white;
    }
    .btn-primary:hover {
        background: #d14820;
        transform: translateY(-1px);
    }
    .btn-secondary {
        background: var(--paper);
        color: var(--ink);
        border: 1px solid var(--line);
    }
    .btn-secondary:hover {
        background: var(--mid);
        color: white;
    }

    .event-info {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 2rem;
    }
    .event-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.5rem;
    }
    .event-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .event-detail {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--ink);
        font-size: 0.9rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="edit-hero">
    <div class="container">
        <h1><i class="fas fa-edit me-3"></i>Modifier la réservation</h1>
        <p>Mettez à jour les informations de réservation</p>
    </div>
</div>

<div class="container">
    <!-- Informations événement -->
    {% if reservation.event %}
    <div class="event-info">
        <h3 class="event-title">
            <i class="fas fa-calendar-alt me-2"></i>Événement associé
        </h3>
        <div class="event-details">
            <div class="event-detail">
                <i class="fas fa-map-marker-alt"></i>
                <span>{{ reservation.event.lieu }}</span>
            </div>
            <div class="event-detail">
                <i class="fas fa-clock"></i>
                <span>{{ reservation.event.dateDebut|date('d/m/Y H:i') }}</span>
            </div>
            <div class="event-detail">
                <i class="fas fa-tag"></i>
                <span>{{ reservation.event.prix }} TND / personne</span>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="edit-card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-user-edit me-2"></i>Informations réservation
            </h3>
            <span class="reservation-id">#{{ reservation.id }}</span>
        </div>
        
        <div class="card-body">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <!-- Informations personnelles -->
                <div class="form-section">
                    <h4 class="section-title">
                        <i class="fas fa-user"></i>Informations personnelles
                    </h4>
                    
                    <div class="form-group">
                        {{ form_label(form.nomComplet, 'Nom complet') }}
                        {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nomComplet) }}
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            {{ form_label(form.email, 'Email') }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div class="form-group">
                            {{ form_label(form.telephone, 'Téléphone') }}
                            {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.telephone) }}
                            <small class="help-text">Optionnel</small>
                        </div>
                    </div>
                </div>

                <!-- Participants -->
                <div class="form-section">
                    <h4 class="section-title">
                        <i class="fas fa-users"></i>Participants
                    </h4>
                    
                    <div class="counter-container">
                        <div class="counter-box">
                            <div class="counter-label">Adultes</div>
                            <div class="counter-value">{{ reservation.nombreAdultes }}</div>
                            {{ form_widget(form.nombreAdultes, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nombreAdultes) }}
                        </div>
                        <div class="counter-box">
                            <div class="counter-label">Enfants</div>
                            <div class="counter-value">{{ reservation.nombreEnfants }}</div>
                            {{ form_widget(form.nombreEnfants, {'attr': {'class': 'form-control'}}) }}
                            {{ form_errors(form.nombreEnfants) }}
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <div class="counter-label">Total personnes</div>
                        <div class="counter-value">{{ reservation.nombreAdultes + reservation.nombreEnfants }}</div>
                    </div>
                </div>

                <!-- Demandes spéciales -->
                <div class="form-section">
                    <h4 class="section-title">
                        <i class="fas fa-comment-dots"></i>Demandes spéciales
                    </h4>
                    
                    <div class="form-group">
                        {{ form_widget(form.demandesSpeciales, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                        {{ form_errors(form.demandesSpeciales) }}
                        <small class="help-text">Optionnel - Indiquez vos besoins particuliers</small>
                    </div>
                </div>

                <!-- Actions -->
                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_reservations_show', {'id': reservation.id}) }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Annuler
                    </a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
                    {{ form_label(form.statut, 'Statut', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.statut, {'attr': {'class': 'text-danger'}}) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(form.montant_paye, 'Montant payé (€)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.montant_paye, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.montant_paye, {'attr': {'class': 'text-danger'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(form.methode_paiement, 'Méthode de paiement', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.methode_paiement, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.methode_paiement, {'attr': {'class': 'text-danger'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(form.date_paiement, 'Date de paiement', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.date_paiement, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.date_paiement, {'attr': {'class': 'text-danger'}}) }}
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.email_client, 'Email du client', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.email_client, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.email_client, {'attr': {'class': 'text-danger'}}) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.telephone_client, 'Téléphone du client', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.telephone_client, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.telephone_client, {'attr': {'class': 'text-danger'}}) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.notes, 'Notes', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'rows': 3}}) }}
                {{ form_errors(form.notes, {'attr': {'class': 'text-danger'}}) }}
                <small class="form-text text-muted">Notes additionnelles sur la réservation (optionnel)</small>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('app_reservations_show', {'id': reservation.id}) }}" class="btn btn-info ms-2">
                    <i class="fas fa-eye"></i> Voir
                </a>
                <a href="{{ path('app_reservations_index') }}" class="btn btn-secondary ms-2">
                    <i class="fas fa-arrow-left"></i> Retour à la liste
                </a>
            </div>

            {{ form_end(form) }}
        </div>
        
        <div class="col-md-2">
            <div class="card">
                <div class="card-header">
                    <h5>Informations actuelles</h5>
                </div>
                <div class="card-body">
                    <p><strong>ID:</strong> {{ reservation.id }}</p>
                    <p><strong>Date de création:</strong> {{ reservation.dateCreation ? reservation.dateCreation|date('d/m/Y H:i') : '' }}</p>
                    
                    <p><strong>Statut actuel:</strong></p>
                    {% if reservation.statut == 'confirmee' %}
                        <span class="badge bg-success">Confirmée</span>
                    {% elseif reservation.statut == 'en_attente' %}
                        <span class="badge bg-warning">En attente</span>
                    {% elseif reservation.statut == 'annulee' %}
                        <span class="badge bg-danger">Annulée</span>
                    {% else %}
                        <span class="badge bg-info">Terminée</span>
                    {% endif %}
                    
                    <p class="mt-3"><strong>Paiement:</strong></p>
                    {% if reservation.isPayeComplet %}
                        <span class="badge bg-success">Payé</span>
                    {% else %}
                        <span class="badge bg-warning">En cours</span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}