{% extends 'base.html.twig' %}

{% block title %}Modifier reservation{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .page-hero {
        background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)),
                    url('{{ asset('adventure/img/banner-bg.jpg') }}') center/cover no-repeat;
        color: #fff;
        padding: 70px 0;
        margin-bottom: 40px;
    }

    .surface-card {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
        padding: 24px;
        margin-bottom: 24px;
    }

    .event-info {
        background: #f8f9fa;
        border: 1px solid #ececec;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .counter-box {
        border: 1px solid #ececec;
        border-radius: 8px;
        padding: 14px;
        text-align: center;
        margin-bottom: 10px;
    }
</style>
{% endblock %}

{% block content %}
<section class="page-hero">
    <div class="container text-center">
        <h2 class="mb-2">Modifier reservation #{{ reservation.id }}</h2>
        <p class="mb-0">Mettez a jour les informations de reservation</p>
    </div>
</section>

<div class="container">
    {% if reservation.event %}
        <div class="event-info">
            <h5 class="mb-2">Evenement associe</h5>
            <p class="mb-1"><strong>Lieu:</strong> {{ reservation.event.lieu }}</p>
            <p class="mb-1"><strong>Date:</strong> {{ reservation.event.dateDebut|date('d/m/Y H:i') }}</p>
            <p class="mb-0"><strong>Prix:</strong> {{ reservation.event.prix }} TND / personne</p>
        </div>
    {% endif %}

    <div class="surface-card">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <h5 class="mb-3">Informations personnelles</h5>
            <div class="form-group">
                {{ form_label(form.nomComplet) }}
                {{ form_widget(form.nomComplet, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.nomComplet) }}
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.email) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.email) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        {{ form_label(form.telephone) }}
                        {{ form_widget(form.telephone, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.telephone) }}
                    </div>
                </div>
            </div>

            <h5 class="mb-3 mt-4">Participants</h5>
            <div class="row">
                <div class="col-md-6">
                    <div class="counter-box">
                        <label class="d-block"><strong>Adultes</strong></label>
                        {{ form_widget(form.nombreAdultes, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nombreAdultes) }}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="counter-box">
                        <label class="d-block"><strong>Enfants</strong></label>
                        {{ form_widget(form.nombreEnfants, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.nombreEnfants) }}
                    </div>
                </div>
            </div>

            <h5 class="mb-3 mt-4">Demandes speciales</h5>
            <div class="form-group">
                {{ form_widget(form.demandesSpeciales, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                {{ form_errors(form.demandesSpeciales) }}
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <a href="{{ path('app_reservations_show', {'id': reservation.id}) }}" class="genric-btn default-border">Annuler</a>
                <button type="submit" class="primary-btn text-uppercase">Enregistrer</button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
