{% extends 'base.html.twig' %}

{% block title %}Détails Réservation{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    :root {
        --accent: #e8572a;
        --ink:    #0f0e17;
        --mid:    #6b6b80;
        --line:   #e4e1d8;
        --paper:  #fffcf5;
    }

    body { background: var(--paper); font-family: 'DM Sans', sans-serif; }

    .show-hero {
        background: linear-gradient(135deg, #0f0e17 0%, #2d2b3d 100%);
        padding: 3rem 0 2rem;
        text-align: center;
        color: white;
        margin-bottom: 3rem;
    }
    .show-hero h1 { font-family: 'Syne', sans-serif; font-size: 2.5rem; font-weight: 800; margin-bottom: .5rem; }
    .show-hero p  { opacity: .8; font-size: 1.1rem; }

    .container { max-width: 1000px; margin: 0 auto; padding: 0 2rem; }

    .detail-card {
        background: white;
        border: 1px solid var(--line);
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,.08);
        margin-bottom: 2rem;
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, var(--accent), #f7a278);
        color: white;
        padding: 1.5rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .card-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.3rem;
        font-weight: 700;
        margin: 0;
    }
    .status-badge {
        padding: 0.5rem 1.2rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .status-en_attente { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
    .status-confirmee { background: rgba(16, 185, 129, 0.2); color: #10b981; }
    .status-annulee { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
    .status-terminee { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }

    .card-body {
        padding: 2rem;
    }

    .info-section {
        margin-bottom: 2rem;
    }
    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--line);
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .info-item {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1.5rem;
    }
    .info-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--mid);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }
    .info-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--ink);
        margin: 0;
    }

    .participants {
        display: flex;
        gap: 1rem;
        margin-top: 0.5rem;
    }
    .participant-badge {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        font-weight: 600;
    }
    .adultes { color: var(--accent); }
    .enfants { color: var(--mid); }

    .price-tag {
        background: linear-gradient(135deg, var(--accent), #f7a278);
        color: white;
        padding: 1rem 1.5rem;
        border-radius: 12px;
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        margin-top: 1rem;
        display: inline-block;
    }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }
    .btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-primary {
        background: var(--accent);
        color: white;
    }
    .btn-primary:hover {
        background: #d14820;
        transform: translateY(-1px);
    }
    .btn-secondary {
        background: var(--paper);
        color: var(--ink);
        border: 1px solid var(--line);
    }
    .btn-secondary:hover {
        background: var(--mid);
        color: white;
    }

    .special-requests {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1rem;
    }
    .special-requests h5 {
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 1rem;
    }
    .special-requests p {
        color: var(--ink);
        line-height: 1.6;
        margin: 0;
    }
    .no-requests {
        color: var(--mid);
        font-style: italic;
    }
</style>
{% endblock %}

{% block content %}
<div class="show-hero">
    <div class="container">
        <h1><i class="fas fa-ticket-alt me-3"></i>Détails Réservation</h1>
        <p>Consultez toutes les informations de votre réservation</p>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col-md-8">
            <div class="detail-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-calendar-check me-2"></i>
                        Réservation #{{ reservation.id }}
                    </h3>
                    <span class="status-badge status-{{ reservation.statut }}">
                        {{ reservation.statut|replace({'_': ' '})|title }}
                    </span>
                </div>

                <div class="card-body">
                    <!-- Événement -->
                    <div class="info-section">
                        <h4 class="section-title">
                            <i class="fas fa-calendar-alt me-2"></i>Événement
                        </h4>
                        <div class="info-grid">
                            <div class="info-item">
                                <div class="info-label">Lieu</div>
                                <div class="info-value">{{ reservation.event ? reservation.event.lieu : 'N/A' }}</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">Date événement</div>
                                <div class="info-value">{{ reservation.event ? reservation.event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">Places disponibles</div>
                                <div class="info-value">{{ reservation.event ? reservation.event.placesDisponibles : 'N/A' }}</div>
                            </div>
                        </div>
                    </div>

                    <!-- Client -->
                    <div class="info-section">
                        <h4 class="section-title">
                            <i class="fas fa-user me-2"></i>Informations client
                        </h4>
                        <div class="info-grid">
                            <div class="info-item">
                                <div class="info-label">Nom complet</div>
                                <div class="info-value">{{ reservation.nomComplet }}</div>
                            </div>
                            <div class="info-item">
                                <div class="info-label">Email</div>
                                <div class="info-value">{{ reservation.email }}</div>
                            </div>
                            {% if reservation.telephone %}
                            <div class="info-item">
                                <div class="info-label">Téléphone</div>
                                <div class="info-value">{{ reservation.telephone }}</div>
                            </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Participants -->
                    <div class="info-section">
                        <h4 class="section-title">
                            <i class="fas fa-users me-2"></i>Participants
                        </h4>
                        <div class="info-item">
                            <div class="info-label">Nombre total de personnes</div>
                            <div class="info-value">{{ reservation.nombrePersonnes }}</div>
                          
                            <div class="participants">
                                {% if reservation.nombreAdultes > 0 %}
                                <span class="participant-badge adultes">
                                    {{ reservation.nombreAdultes }} adulte{{ reservation.nombreAdultes > 1 ? 's' : '' }}
                                </span>
                                {% endif %}
                                {% if reservation.nombreEnfants > 0 %}
                                <span class="participant-badge enfants">
                                    {{ reservation.nombreEnfants }} enfant{{ reservation.nombreEnfants > 1 ? 's' : '' }}
                                </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <!-- Prix -->
                    <div class="info-section">
                        <h4 class="section-title">
                            <i class="fas fa-money-bill-wave me-2"></i>Prix
                        </h4>
                        <div class="price-tag">
                            {{ reservation.prixTotal }} TND
                        </div>
                    </div>

                    <!-- Demandes spéciales -->
                    {% if reservation.demandesSpeciales %}
                    <div class="special-requests">
                        <h5><i class="fas fa-comment-dots me-2"></i>Demandes spéciales</h5>
                        <p>{{ reservation.demandesSpeciales }}</p>
                    </div>
                    {% endif %}

                    <!-- Actions -->
                    <div class="actions">
                        <div class="btn-group" role="group">
                           
                            <a href="{{ path('app_reservations_index') }}" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}