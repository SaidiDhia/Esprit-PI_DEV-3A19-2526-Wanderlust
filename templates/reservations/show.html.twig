{% extends 'base.html.twig' %}

{% block title %}Details Reservation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.52), rgba(0, 0, 0, 0.52)), url('{{ asset('adventure/img/banner-bg.jpg') }}') center/cover no-repeat;
            color: #fff;
            padding: 120px 0 80px;
            margin-bottom: 40px;
        }

        .reservation-card {
            border: 1px solid #ececec;
            border-radius: 14px;
            background: #fff;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            margin-bottom: 60px;
        }

        .reservation-head {
            padding: 20px 24px;
            border-bottom: 1px solid #eee;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .reservation-body {
            padding: 24px;
        }

        .badge-status {
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            display: inline-flex;
            align-items: center;
        }

        .status-en_attente { background: #fff4cf; color: #8a6d00; }
        .status-confirmee { background: #d7f7e4; color: #10663b; }
        .status-annulee { background: #ffe0e0; color: #a01b1b; }

        .details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 14px;
            margin-bottom: 20px;
        }

        .detail-item {
            border: 1px solid #efefef;
            border-radius: 10px;
            padding: 14px;
            background: #fafafa;
        }

        .detail-item .label {
            color: #7b7b7b;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .06em;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .detail-item .value {
            color: #1e1e1e;
            font-size: 16px;
            font-weight: 700;
            margin: 0;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 12px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-2">Reservation #{{ reservation.id }}</h1>
        <p class="mb-0">Consultez toutes les informations de votre reservation.</p>
    </div>
</section>

<div class="container">
    <article class="reservation-card">
        <div class="reservation-head">
            <h3 class="mb-0">Details de la reservation</h3>
            <span class="badge-status status-{{ reservation.statut }}">{{ reservation.statut|replace({'_': ' '})|title }}</span>
        </div>

        <div class="reservation-body">
            <h4 class="section-title">Evenement</h4>
            <div class="details-grid">
                <div class="detail-item">
                    <p class="label">Lieu</p>
                    <p class="value">{{ reservation.event ? reservation.event.lieu : 'N/A' }}</p>
                </div>
                <div class="detail-item">
                    <p class="label">Date evenement</p>
                    <p class="value">{{ reservation.event ? reservation.event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</p>
                </div>
                <div class="detail-item">
                    <p class="label">Places disponibles</p>
                    <p class="value">{{ reservation.event ? reservation.event.placesDisponibles : 'N/A' }}</p>
                </div>
            </div>

            <h4 class="section-title">Informations client</h4>
            <div class="details-grid">
                <div class="detail-item">
                    <p class="label">Nom complet</p>
                    <p class="value">{{ reservation.nomComplet }}</p>
                </div>
                <div class="detail-item">
                    <p class="label">Email</p>
                    <p class="value">{{ reservation.email }}</p>
                </div>
                {% if reservation.telephone %}
                    <div class="detail-item">
                        <p class="label">Telephone</p>
                        <p class="value">{{ reservation.telephone }}</p>
                    </div>
                {% endif %}
            </div>

            <h4 class="section-title">Participants</h4>
            <div class="details-grid">
                <div class="detail-item">
                    <p class="label">Nombre total</p>
                    <p class="value">{{ reservation.nombrePersonnes }}</p>
                </div>
                <div class="detail-item">
                    <p class="label">Adultes</p>
                    <p class="value">{{ reservation.nombreAdultes }}</p>
                </div>
                <div class="detail-item">
                    <p class="label">Enfants</p>
                    <p class="value">{{ reservation.nombreEnfants }}</p>
                </div>
            </div>

            <h4 class="section-title">Prix</h4>
            <div class="details-grid">
                <div class="detail-item">
                    <p class="label">Total</p>
                    <p class="value">{{ reservation.prixTotal }} TND</p>
                </div>
            </div>

            {% if reservation.demandesSpeciales %}
                <h4 class="section-title">Demandes speciales</h4>
                <div class="detail-item" style="margin-bottom: 20px;">
                    <p class="value" style="font-size: 15px; font-weight: 500;">{{ reservation.demandesSpeciales }}</p>
                </div>
            {% endif %}

            <a href="{{ path('app_reservations_index') }}" class="genric-btn default-border">Retour a la liste</a>
        </div>
    </article>
</div>
{% endblock %}
