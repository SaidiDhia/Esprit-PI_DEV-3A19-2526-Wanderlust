{% extends 'base.html.twig' %}

{% block title %}Réservations — WanderLust{% endblock %}

{% block styles %}
{{ parent() }}
<style>
    .reservations-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 4rem 0;
        text-align: center;
        margin-bottom: 2rem;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .stats-card {
        background: white;
        border-radius: 15px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .stat-item {
        text-align: center;
        padding: 1.5rem;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        color: #667eea;
        margin-bottom: 0.5rem;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 600;
    }

    .reservation-card {
        background: white;
        border-radius: 20px;
        padding: 2rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid #e9ecef;
        position: relative;
        overflow: hidden;
    }

    .reservation-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px 20px 0 0;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .reservation-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 48px rgba(102, 126, 234, 0.15);
    }

    .reservation-card:hover::before {
        height: 6px;
    }

    .reservation-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #f8f9fa;
        position: relative;
    }

    .reservation-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1a2029;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .reservation-title::before {
        content: '';
        width: 8px;
        height: 8px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 50%;
        margin-right: 0.5rem;
    }

    .reservation-meta {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .meta-item:hover {
        background: #e9ecef;
        transform: translateY(-2px);
    }

    .meta-label {
        color: #6c757d;
        font-weight: 600;
        font-size: 0.85rem;
        min-width: 80px;
    }

    .meta-value {
        color: #1a2029;
        font-weight: 700;
        font-size: 0.95rem;
    }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 25px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        overflow: hidden;
    }

    .status-badge::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
    }

    .status-en_attente { 
        background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
        color: #856404; 
        box-shadow: 0 4px 20px rgba(255, 193, 7, 0.25);
    }

    .status-confirmee { 
        background: linear-gradient(135deg, #198754 0%, #157347 100%);
        color: #ffffff; 
        box-shadow: 0 4px 20px rgba(25, 135, 84, 0.25);
    }

    .status-annulee { 
        background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
        color: #ffffff; 
        box-shadow: 0 4px 20px rgba(220, 38, 38, 0.25);
    }

    .action-buttons {
        display: flex;
        gap: 0.75rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    .btn-modern {
        padding: 0.875rem 1.75rem;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        position: relative;
        overflow: hidden;
    }

    .btn-modern::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.1);
        transition: all 0.3s ease;
        border-radius: 12px;
    }

    .btn-primary-modern { 
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white; 
        box-shadow: 0 4px 20px rgba(102, 126, 234, 0.3);
    }

    .btn-primary-modern:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary-modern { 
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white; 
        box-shadow: 0 4px 20px rgba(108, 117, 125, 0.3);
    }

    .btn-secondary-modern:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(108, 117, 125, 0.4);
    }

    .btn-danger-modern { 
        background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
        color: white; 
        box-shadow: 0 4px 20px rgba(220, 38, 38, 0.3);
    }

    .btn-danger-modern:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(220, 38, 38, 0.4);
    }

    .btn-modern i {
        font-size: 0.9rem;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 2rem;
        color: #6c757d;
    }

    .empty-state i {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .reservation-meta {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .action-buttons {
            flex-direction: column;
        }
    }
</style>
{% endblock %}

{% block content %}
<!-- Hero Section -->
<section class="reservations-hero">
    <div class="container text-center">
        <h1 class="hero-title mb-3">
            🎫 Gestion des Réservations
        </h1>
        <p class="text-white-50">Consultez et gérez toutes les réservations</p>
    </div>
</section>

<!-- Main Content -->
<section class="container mb-5">
    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <!-- Statistics -->
    <div class="stats-card">
        <div class="row">
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number">{{ reservations|length }}</div>
                    <div class="stat-label">Total Réservations</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number" id="confirmed-count">0</div>
                    <div class="stat-label">Confirmées</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number" id="pending-count">0</div>
                    <div class="stat-label">En attente</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number" id="cancelled-count">0</div>
                    <div class="stat-label">Annulées</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reservations List -->
    {% if reservations is empty %}
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <h3>Aucune réservation trouvée</h3>
            <p>Commencez par créer une nouvelle réservation pour gérer vos événements.</p>
            <div class="action-buttons">
                <a href="{{ path('app_reservations_new') }}" class="btn-modern btn-primary-modern">
                    <i class="fas fa-plus me-2"></i> Nouvelle Réservation
                </a>
                <a href="{{ path('app_events_index') }}" class="btn-modern btn-secondary-modern">
                    <i class="fas fa-calendar me-2"></i> Voir les Événements
                </a>
            </div>
        </div>
    {% else %}
        <div class="row">
            {% for reservation in reservations %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="reservation-card">
                        <div class="reservation-header">
                            <h5 class="reservation-title">
                                Réservation #{{ reservation.id }}
                            </h5>
                            <span class="status-badge status-{{ reservation.statut }}">
                                {{ reservation.statut|replace({'_': ' '})|title }}
                            </span>
                        </div>
                        <div class="reservation-meta">
                            <div class="meta-item">
                                <span class="meta-label">Événement:</span>
                                <span class="meta-value">{{ reservation.event ? reservation.event.lieu : 'N/A' }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Date:</span>
                                <span class="meta-value">{{ reservation.event ? reservation.event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Client:</span>
                                <span class="meta-value">{{ reservation.nomComplet }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Participants:</span>
                                <span class="meta-value">{{ reservation.nombrePersonnes }}</span>
                            </div>
                            <div class="meta-item">
                                <span class="meta-label">Total:</span>
                                <span class="meta-value">{{ reservation.prixTotal }} TND</span>
                            </div>
                        </div>
                        <div class="action-buttons">
                            <a href="{{ path('app_reservations_show', {'id': reservation.id}) }}" class="btn-modern btn-primary-modern">
                                <i class="fas fa-eye me-2"></i> Voir
                            </a>
                            <a href="{{ path('app_reservations_edit', {'id': reservation.id}) }}" class="btn-modern btn-warning-modern">
                                <i class="fas fa-edit me-2"></i> Modifier
                            </a>
                            <form method="post" action="{{ path('app_reservations_delete', {'id': reservation.id}) }}" 
                                  onsubmit="return confirmDeleteReservation({{ reservation.id }});" 
                                  class="w-100">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                <button type="submit" class="btn-modern btn-danger-modern" title="Supprimer">
                                    <i class="fas fa-trash me-2"></i>SUPPRIMER
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</section>

<!-- Statistics Script -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Calculer les statistiques
    const confirmedCount = document.querySelectorAll('.status-confirmee').length;
    const pendingCount = document.querySelectorAll('.status-en_attente').length;
    const cancelledCount = document.querySelectorAll('.status-annulee').length;
    
    document.getElementById('confirmed-count').textContent = confirmedCount;
    document.getElementById('pending-count').textContent = pendingCount;
    document.getElementById('cancelled-count').textContent = cancelledCount;
});
</script>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmDeleteReservation(reservationId) {
    const confirmation = confirm(
        '⚠️ CONFIRMATION DE SUPPRESSION ⚠️\n\n' +
        'Êtes-vous sûr de vouloir supprimer la réservation #' + reservationId + ' ?\n\n' +
        'Cette action est IRRÉVERSIBLE et :\n' +
        '• Supprimera définitivement la réservation\n' +
        '• Libérera les places réservées\n' +
        '• Effacera toutes les données associées\n\n' +
        'Cliquez sur OK pour confirmer ou Annuler pour garder la réservation.'
    );
    
    return confirmation;
}
</script>
{% endblock %}
