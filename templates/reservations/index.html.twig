{% extends 'base.html.twig' %}

{% block title %}Réservations - Wanderlust{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .reservations-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 0 0 60px 60px;
        padding: 3rem 0;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
    }

    .reservations-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
        animation: float 10s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(30px, -20px) rotate(10deg); }
    }

    .hero-title {
        font-size: 3rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .reservation-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        overflow: hidden;
        background: white;
    }

    .reservation-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 60px rgba(0,0,0,0.15);
    }

    .reservation-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .reservation-body {
        padding: 1.5rem;
    }

    .badge-modern {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-success-modern {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
    }

    .badge-warning-modern {
        background: linear-gradient(135deg, #ffc107, #fd7e14);
        color: white;
    }

    .badge-danger-modern {
        background: linear-gradient(135deg, #dc3545, #e83e8c);
        color: white;
    }

    .badge-info-modern {
        background: linear-gradient(135deg, #17a2b8, #6f42c1);
        color: white;
    }

    .btn-modern {
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 15px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
    }

    .btn-primary-modern {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
    }

    .btn-primary-modern:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .btn-info-modern {
        background: linear-gradient(135deg, #17a2b8, #6f42c1);
        color: white;
    }

    .btn-warning-modern {
        background: linear-gradient(135deg, #ffc107, #fd7e14);
        color: white;
    }

    .btn-danger-modern {
        background: linear-gradient(135deg, #dc3545, #e83e8c);
        color: white;
    }

    .btn-success-modern {
        background: linear-gradient(135deg, #28a745, #20c997);
        color: white;
    }

    .progress-modern {
        height: 8px;
        border-radius: 10px;
        background: #e9ecef;
        overflow: hidden;
    }

    .progress-bar-modern {
        border-radius: 10px;
        transition: width 0.6s ease;
    }

    .progress-bar-success {
        background: linear-gradient(90deg, #28a745, #20c997);
    }

    .progress-bar-warning {
        background: linear-gradient(90deg, #ffc107, #fd7e14);
    }

    .reservation-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .reservation-meta i {
        color: #667eea;
        width: 16px;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #6c757d;
    }

    .empty-state i {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 1rem;
    }

    .stats-card {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        border-radius: 15px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        border: none;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
    }

    .stat-item {
        text-align: center;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #667eea, #764ba2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stat-label {
        color: #6c757d;
        font-size: 0.9rem;
        font-weight: 600;
    }
</style>
{% endblock %}

{% block content %}
<!-- Hero Section -->
<section class="reservations-hero">
    <div class="container text-center">
        <h1 class="hero-title mb-3">
            🎫 Gestion des Réservations
        </h1>
        <p class="text-white-50">Consultez et gérez toutes les réservations</p>
    </div>
</section>

<!-- Main Content -->
<section class="container mb-5">
    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <!-- Statistics -->
    <div class="stats-card">
        <div class="row">
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number">{{ reservations|length }}</div>
                    <div class="stat-label">Total Réservations</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number">
                        {% set confirmed = 0 %}
                        {% for reservation in reservations %}
                            {% if reservation.statut == 'confirmee' %}
                                {% set confirmed = confirmed + 1 %}
                            {% endif %}
                        {% endfor %}
                        {{ confirmed }}
                    </div>
                    <div class="stat-label">Confirmées</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number">
                        {% set pending = 0 %}
                        {% for reservation in reservations %}
                            {% if reservation.statut == 'en_attente' %}
                                {% set pending = pending + 1 %}
                            {% endif %}
                        {% endfor %}
                        {{ pending }}
                    </div>
                    <div class="stat-label">En attente</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-item">
                    <div class="stat-number">
                        {% set cancelled = 0 %}
                        {% for reservation in reservations %}
                            {% if reservation.statut == 'annulee' %}
                                {% set cancelled = cancelled + 1 %}
                            {% endif %}
                        {% endfor %}
                        {{ cancelled }}
                    </div>
                    <div class="stat-label">Annulées</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title">
            <i class="fas fa-list me-2"></i>Liste des Réservations
        </h2>
        <div class="btn-group">
            <a href="{{ path('app_events_index') }}" class="btn-modern btn-primary-modern">
                <i class="fas fa-plus me-2"></i>Nouvelle Réservation
            </a>
        </div>
    </div>

    <!-- Reservations Grid -->
    <div class="row">
        {% if reservations is empty %}
            <div class="col-12">
                <div class="empty-state">
                    <i class="fas fa-calendar-times"></i>
                    <h3>Aucune réservation trouvée</h3>
                    <p class="text-muted">Commencez par créer votre première réservation</p>
                    <a href="{{ path('app_events_index') }}" class="btn-modern btn-primary-modern mt-3">
                        <i class="fas fa-plus me-2"></i>Voir les Événements
                    </a>
                </div>
            </div>
        {% else %}
            {% for reservation in reservations %}
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="reservation-card h-100">
                        <!-- Header -->
                        <div class="reservation-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold">
                                        <i class="fas fa-ticket-alt me-2"></i>Réservation #{{ reservation.id }}
                                    </h6>
                                    <small class="text-muted">
                                        <i class="fas fa-calendar me-1"></i>
                                        {{ reservation.dateCreation ? reservation.dateCreation|date('d/m/Y H:i') : '' }}
                                    </small>
                                </div>
                                <div>
                                    {% if reservation.statut == 'confirmee' %}
                                        <span class="badge-modern badge-success-modern">
                                            <i class="fas fa-check-circle me-1"></i>Confirmée
                                        </span>
                                    {% elseif reservation.statut == 'en_attente' %}
                                        <span class="badge-modern badge-warning-modern">
                                            <i class="fas fa-clock me-1"></i>En attente
                                        </span>
                                    {% elseif reservation.statut == 'annulee' %}
                                        <span class="badge-modern badge-danger-modern">
                                            <i class="fas fa-times-circle me-1"></i>Annulée
                                        </span>
                                    {% else %}
                                        <span class="badge-modern badge-info-modern">
                                            <i class="fas fa-check-double me-1"></i>Terminée
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <!-- Body -->
                        <div class="reservation-body">
                            <!-- Event Info -->
                            {% if reservation.event %}
                                <div class="reservation-meta">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>{{ reservation.event.lieu }}</span>
                                </div>
                                <div class="reservation-meta">
                                    <i class="fas fa-calendar-alt"></i>
                                    <span>{{ reservation.event.dateDebut ? reservation.event.dateDebut|date('d/m/Y H:i') : '' }}</span>
                                </div>
                            {% endif %}

                            <!-- Client Info -->
                            <div class="reservation-meta">
                                <i class="fas fa-user"></i>
                                <span>{{ reservation.nomComplet }}</span>
                            </div>
                            {% if reservation.email %}
                                <div class="reservation-meta">
                                    <i class="fas fa-envelope"></i>
                                    <span>{{ reservation.email }}</span>
                                </div>
                            {% endif %}
                            {% if reservation.telephone %}
                                <div class="reservation-meta">
                                    <i class="fas fa-phone"></i>
                                    <span>{{ reservation.telephone }}</span>
                                </div>
                            {% endif %}

                            <!-- Reservation Details -->
                            <div class="reservation-meta">
                                <i class="fas fa-users"></i>
                                <span>{{ reservation.nombrePersonnes }} personne(s)</span>
                            </div>
                            <div class="reservation-meta">
                                <i class="fas fa-euro-sign"></i>
                                <span><strong>{{ reservation.prixTotal }} €</strong></span>
                            </div>

                            <!-- Special Requests -->
                            {% if reservation.demandesSpeciales %}
                                <div class="mt-3">
                                    <small class="text-muted">
                                        <i class="fas fa-comment-dots me-1"></i>
                                        {{ reservation.demandesSpeciales|slice(0, 50) }}{% if reservation.demandesSpeciales|length > 50 %}...{% endif %}
                                    </small>
                                </div>
                            {% endif %}
                        </div>

                        <!-- Footer Actions -->
                        <div class="p-3 border-top">
                            <form method="post" action="{{ path('app_reservations_delete', {'id': reservation.id}) }}" 
                                  onsubmit="return confirmDeleteReservation({{ reservation.id }});" 
                                  class="w-100">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                <button type="submit" class="btn-modern btn-danger-modern w-100 py-2 fw-bold" title="Supprimer">
                                    <i class="fas fa-trash me-2"></i>SUPPRIMER
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</section>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function confirmDeleteReservation(reservationId) {
    // Créer une alerte de confirmation plus détaillée
    const confirmation = confirm(
        '⚠️ CONFIRMATION DE SUPPRESSION ⚠️\n\n' +
        'Êtes-vous sûr de vouloir supprimer la réservation #' + reservationId + ' ?\n\n' +
        'Cette action est IRRÉVERSIBLE et :\n' +
        '• Supprimera définitivement la réservation\n' +
        '• Libérera les places réservées\n' +
        '• Effacera toutes les données associées\n\n' +
        'Cliquez sur OK pour confirmer ou Annuler pour garder la réservation.'
    );
    
    return confirmation;
}
</script>
{% endblock %}
