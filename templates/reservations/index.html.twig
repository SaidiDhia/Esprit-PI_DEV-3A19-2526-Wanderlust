{% extends 'base.html.twig' %}

{% block title %}Reservations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.42)), url('{{ asset('adventure/img/video-bg.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .reservation-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 24px;
        }

        .reservation-body {
            padding: 20px;
        }

        .status-pill {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
        }

        .status-en_attente { background: #fef3c7; color: #92400e; }
        .status-confirmee { background: #dcfce7; color: #166534; }
        .status-annulee { background: #fee2e2; color: #991b1b; }

        .meta-line { margin-bottom: 7px; color: #666; }
        .meta-line i { width: 18px; }

        .reservation-actions {
            border-top: 1px solid #f0f0f0;
            padding: 12px 20px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">My Reservations</h1>
        <p class="mb-20">Track your confirmed, pending, and cancelled reservations.</p>
        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase">Browse Events</a>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {% if reservations is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No reservations found</h4>
                <p class="text-muted mb-3">You have not booked an event yet.</p>
                <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase">Explore Events</a>
            </div>
        {% else %}
            <div class="row">
                {% for reservation in reservations %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="reservation-card w-100">
                            <div class="reservation-body">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0">Reservation #{{ reservation.id }}</h5>
                                    <span class="status-pill status-{{ reservation.statut }}">{{ reservation.statut|replace({'_': ' '})|title }}</span>
                                </div>

                                <div class="meta-line"><i class="fa fa-map-marker"></i> {{ reservation.event ? reservation.event.lieu : 'N/A' }}</div>
                                <div class="meta-line"><i class="fa fa-calendar"></i> {{ reservation.event and reservation.event.dateDebut ? reservation.event.dateDebut|date('d/m/Y H:i') : 'N/A' }}</div>
                                <div class="meta-line"><i class="fa fa-users"></i> {{ reservation.nombrePersonnes }} participants</div>
                                <div class="meta-line"><i class="fa fa-money"></i> <strong>{{ reservation.prixTotal }} TND</strong></div>
                            </div>

                            <div class="reservation-actions">
                                <a href="{{ path('app_reservations_show', {'id': reservation.id}) }}" class="genric-btn info-border small">View</a>
                                


                                <form method="post" action="{{ path('app_reservations_delete', {'id': reservation.id}) }}" onsubmit="return confirm('Delete this reservation?');" style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                    <button type="submit" class="genric-btn danger-border small">Delete</button>
                                </form>
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

{% include '_chatbot.html.twig' with { chatContext: 'reservations' } %}
{% endblock %}
