{% extends 'base.html.twig' %}

{% block title %}{{ conversation.name }} - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
    <style>
        .messaging-topbar {
            background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('{{ asset('adventure/img/slider1.jpg') }}') center center/cover no-repeat;
            border-bottom: 1px solid rgba(148, 163, 184, 0.35);
            margin-top: -96px;
            padding: 112px 0 14px;
            margin-bottom: 10px;
        }

        .messaging-topbar h1 {
            margin-bottom: 4px;
            color: #f8fafc;
            font-size: clamp(1.9rem, 3.6vw, 2.6rem);
            line-height: 1.08;
            text-shadow: 0 10px 28px rgba(15, 23, 42, 0.35);
        }

        .messaging-topbar p {
            margin-bottom: 0;
            color: rgba(241, 245, 249, 0.9);
            font-size: 15px;
        }

        .messaging-topbar .back-link {
            color: #e2e8f0;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .messaging-topbar .back-link:hover {
            color: #ffffff;
        }

        .conversation-wrap {
            max-width: 1020px;
            margin: 0 auto;
        }

        .conversation-toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 8px;
        }

        .conversation-toolbar .btn {
            padding: 10px 18px;
            font-weight: 600;
            border-radius: 999px;
        }

        .conversation-search {
            margin-bottom: 8px;
        }

        .conversation-search-form {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .conversation-search-input {
            flex: 1;
            padding: 11px 16px;
            border: 1px solid #d2dbe7;
            border-radius: 999px;
            outline: none;
            background: #ffffff;
        }

        .conversation-search-input:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
        }

        .conversation-chat-shell {
            border-radius: 22px;
            overflow: hidden;
            border: 1px solid #d6e0ea;
            box-shadow: 0 22px 48px rgba(15, 23, 42, 0.14);
            background: #fff;
            min-height: 390px;
            height: calc(100dvh - 312px);
            max-height: 540px;
        }

        .message-item .msg-action-wrapper {
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s ease;
        }

        .message-item:hover .msg-action-wrapper {
            opacity: 1;
            pointer-events: auto;
        }

        .message-track {
            display: flex;
            align-items: flex-start;
            gap: 6px;
        }

        .message-track.own {
            flex-direction: row-reverse;
        }

        #messagesContainer {
            height: auto;
            max-height: none;
            min-height: 0;
            overflow-y: auto;
            scroll-behavior: smooth;
            background:
                radial-gradient(circle at 14% 12%, rgba(191, 219, 254, 0.34), transparent 32%),
                radial-gradient(circle at 82% 88%, rgba(254, 215, 170, 0.25), transparent 30%),
                #f8fbff;
                flex: 1;
        }

            .conversation-page {
                margin-bottom: 26px;
            }

        @media (max-width: 768px) {
            .conversation-chat-shell {
                min-height: 68vh;
                height: auto;
                max-height: none;
            }

            #messagesContainer {
                min-height: 260px;
            }

            .message-item .msg-action-wrapper {
                opacity: 1;
                pointer-events: auto;
            }
        }

        .chat-file-row {
            border-top: 1px solid #e2e8f0;
            background: #f8fafc;
            padding: 12px 16px 16px;
        }

        .message-item .msg-bubble-content {
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.11);
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, 0.2);
        }

        .msg-warning-popup {
            position: fixed;
            left: 50%;
            bottom: 32px;
            transform: translateX(-50%) translateY(16px);
            opacity: 0;
            pointer-events: none;
            z-index: 1400;
            background: #111827;
            color: #ffffff;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 12px;
            padding: 11px 14px;
            box-shadow: 0 14px 32px rgba(15, 23, 42, 0.38);
            display: inline-flex;
            align-items: center;
            gap: 9px;
            font-size: 14px;
            font-weight: 600;
            transition: opacity .2s ease, transform .2s ease;
        }

        .msg-warning-popup.is-visible {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        .ai-result-pre {
            white-space: pre-wrap;
            line-height: 1.5;
            color: #0f172a;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 12px;
            margin: 0;
            max-height: 320px;
            overflow: auto;
            font-size: 14px;
        }

        .translate-language-select {
            width: 100%;
            min-height: 44px;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            background: #ffffff;
            color: #0f172a;
            padding: 8px 10px;
        }

        .emoji-suggestion-bar {
            margin-bottom: 10px;
            padding: 8px 12px;
            background: #f0f8f0;
            border: 1px solid #d4ead4;
            border-radius: 24px;
            display: none;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .emoji-suggestion-btn {
            background: #e0e0e0;
            border: none;
            border-radius: 20px;
            padding: 4px 12px;
            cursor: pointer;
            min-width: 42px;
            font-size: 16px;
            line-height: 1.2;
        }

        .emoji-suggestion-btn:hover {
            background: #d5d5d5;
        }

        .chat-file-picker {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            background: #ffffff;
            color: #0f172a;
            cursor: pointer;
            padding: 8px 10px;
            min-height: 42px;
            min-width: 46px;
            font-weight: 600;
            white-space: nowrap;
        }

        .chat-file-picker:hover {
            background: #f8fafc;
        }

        .chat-file-name {
            flex: 1;
            font-size: 13px;
            color: #64748b;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            background: #ffffff;
            padding: 10px 12px;
            min-height: 42px;
            display: inline-flex;
            align-items: center;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        @media (max-width: 640px) {
            .conversation-search-form {
                flex-wrap: wrap;
            }

            .conversation-search-form .btn {
                width: 100%;
            }
        }
    </style>
{% endblock %}

{% block content %}
<section class="messaging-topbar">
    <div class="container">
        <a href="{{ path('app_messaging') }}" class="back-link">← Back to conversations</a>
        <h1>{{ conversation.name ?: 'Conversation #' ~ conversation.id }}</h1>
        <p>{{ conversation.type }} chat</p>
    </div>
</section>

<div class="container conversation-wrap conversation-page">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">✅ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">⚠️ {{ message }}</div>
    {% endfor %}

    <!-- Manage Members Button (for GROUP conversations) -->
    {% if conversation.type == 'GROUP' %}
        <div class="conversation-toolbar">
            <a href="{{ path('messaging_conversation_participants', {id: conversation.id}) }}" class="btn btn-outline msg-btn-action" style="border: 2px solid #cbd5e1; color: #0f172a; background: #f8fafc; display: inline-flex; align-items: center; gap: 8px;">👥 Manage Members</a>
            <a href="{{ path('messaging_export', {id: conversation.id}) }}" class="btn msg-btn-export" style="border: 2px solid #2554d9; color: #ffffff; background: linear-gradient(135deg, #2554d9 0%, #1e40af 100%); display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(37, 84, 217, 0.25);">📥 Export Chat</a>
            <button type="button" onclick="summarizeConversation()" class="btn" style="border: 2px solid #0f766e; color: #ffffff; background: #0f766e; display: inline-flex; align-items: center; gap: 8px;">📋 Summarize Chat</button>
            {% if currentUserRole == 'CREATOR' %}
                <form method="POST" action="{{ path('messaging_conversation_delete', {id: conversation.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this conversation and all messages? This action cannot be undone.');">
                    <button type="submit" class="btn" style="border: 2px solid #dc2626; color: #ffffff; background: #dc2626; display: inline-flex; align-items: center; gap: 8px;">🗑️ Delete Conversation</button>
                </form>
            {% endif %}
        </div>
    {% else %}
        <div class="conversation-toolbar">
            <a href="{{ path('messaging_export', {id: conversation.id}) }}" class="btn msg-btn-export" style="border: 2px solid #2554d9; color: #ffffff; background: linear-gradient(135deg, #2554d9 0%, #1e40af 100%); display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(37, 84, 217, 0.25);">📥 Export Chat</a>
            <button type="button" onclick="summarizeConversation()" class="btn" style="border: 2px solid #0f766e; color: #ffffff; background: #0f766e; display: inline-flex; align-items: center; gap: 8px;">📋 Summarize Chat</button>
            {% if currentUserRole == 'CREATOR' %}
                <form method="POST" action="{{ path('messaging_conversation_delete', {id: conversation.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this conversation and all messages? This action cannot be undone.');">
                    <button type="submit" class="btn" style="border: 2px solid #dc2626; color: #ffffff; background: #dc2626; display: inline-flex; align-items: center; gap: 8px;">🗑️ Delete Conversation</button>
                </form>
            {% endif %}
        </div>
    {% endif %}

    <!-- Search Bar -->
    <div class="conversation-search">
        <form method="GET" action="{{ path('messaging_search', {id: conversation.id}) }}" class="conversation-search-form">
            <input type="text" name="q" placeholder="🔍 Search messages, senders, or files..."
                   value="{{ app.request.query.get('q') }}" class="conversation-search-input">
            <button type="submit" class="btn btn-primary" style="border-radius: 999px;">Search</button>
            {% if app.request.query.get('q') %}
                <a href="{{ path('messaging_conversation_show', {id: conversation.id}) }}" class="btn btn-outline" style="border-radius: 999px;">Clear</a>
            {% endif %}
        </form>
    </div>

    <!-- Chat Wrapper -->
    <div class="conversation-chat-shell" style="display: flex; flex-direction: column; height: 100%;">
    <!-- Messages Area -->
    <div id="messagesContainer" style="background: white; border-radius: 0; border: none; flex: 1; overflow-y: auto; padding: 24px;">
    {% if messages|length == 0 %}
        <div style="text-align: center; padding: 60px; color: var(--gray-400);">
            <div style="font-size: 48px; margin-bottom: 16px;">💬</div>
            <p>No messages yet. Start the conversation!</p>
        </div>
    {% else %}
        {% for msg in messages %}
            {% set isOwn = msg.sender_id == currentUserId %}
            <div id="msg-{{ msg.id }}" class="message-item" style="margin-bottom: 20px; display: flex; align-items: flex-start; gap: 0; justify-content: {% if msg.sender_id == currentUserId %}flex-end{% else %}flex-start{% endif %};">
                <!-- Message bubble and button grouped together -->
                <div class="message-track {% if isOwn %}own{% endif %}">
                    <!-- Message bubble -->
                    <div style="flex-shrink: 0;">
                        <div class="msg-bubble-content {% if msg.sender_id == currentUserId %}msg-bubble-own{% else %}msg-bubble-other{% endif %}" style="transition: all 0.3s ease;">
                            <div class="msg-bubble-info">
                                <span>{{ msg.sender_name ?: 'User ' ~ msg.sender_id|slice(0,8) }} • {{ msg.created_at|time_diff }}</span>
                            </div>
                            <div id="message-content-{{ msg.id }}" style="margin-top: 6px; word-wrap: break-word; word-break: break-word;">
                                {% if msg.message_type == 'IMAGE' %}
                                    <div style="margin-top: 8px;">
                                        {% set uploadFilename = msg.file_url|split('/')|last %}
                                        <img src="{{ asset('uploads/' ~ uploadFilename) }}"
                                             alt="{{ msg.file_name ?: 'Image' }}"
                                             style="max-width: 200px; max-height: 200px; border-radius: 8px; cursor: pointer;"
                                             onclick="window.open('{{ asset('uploads/' ~ uploadFilename) }}', '_blank')">
                                    </div>
                                {% elseif msg.message_type == 'VIDEO' %}
                                    🎥 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit; text-decoration: underline;">Play Video</a>
                                {% elseif msg.message_type == 'AUDIO' %}
                                    🎵 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit; text-decoration: underline;">Play Audio</a>
                                {% elseif msg.message_type == 'FILE' %}
                                    📎 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit; text-decoration: underline;">{{ msg.file_name ?: 'Download File' }}</a>
                                {% else %}
                                    {% set msgLines = msg.content|split('\n') %}
                                    {% set hasReplyMarker = msgLines[0] starts with '**Replying to' %}

                                    {% if hasReplyMarker %}
                                        {% set fullContent = msg.content %}
                                        {% set doubleNewline = '\n\n' %}
                                        {% set parts = fullContent|split(doubleNewline, 2) %}
                                        {% set headerPart = parts[0] %}
                                        {% set replyPart = parts[1] ?? '' %}

                                        {% set senderName = headerPart|replace({'**Replying to ': '', ':**': ''}) %}

                                        {% set quotedMsg = msg.content|split('\n> ')|slice(1, 1)|join('') %}
                                        {% if quotedMsg %}
                                            {% set quotedMsgTrimmed = quotedMsg|split('\n\n')|first %}
                                            <div style="font-size: 12px; color: #ffffff; margin-bottom: 8px; font-style: italic; opacity: 0.85;">
                                                ↩️ {{ senderName }}
                                            </div>
                                        {% endif %}

                                        {{ replyPart|trim|nl2br }}
                                    {% else %}
                                        {{ msg.content|nl2br }}
                                    {% endif %}
                                {% endif %}
                            </div>
                            {% if msg.edited_at %}
                                <div style="font-size: 9px; opacity: 0.5; margin-top: 6px; font-style: italic;">edited</div>
                            {% endif %}

                            <div id="reactions-{{ msg.id }}" style="display: flex; gap: 4px; flex-wrap: wrap; margin-top: 8px; align-items: center;">
                                {% set reactionsData = get_message_reactions(msg.id) %}
                                {% for reactionData in reactionsData %}
                                    <span onclick="toggleReaction({{ msg.id }}, '{{ reactionData.reaction }}')"
                                          style="background: #e8e8e8; border-radius: 30px; padding: 2px 8px; font-size: 12px; cursor: pointer; display: inline-flex; align-items: center; gap: 4px; transition: all 0.2s ease; user-select: none;">
                                        {{ reactionData.reaction }} <span style="font-size: 10px; color: #666;">{{ reactionData.count }}</span>
                                    </span>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <!-- Action menu (now placed after bubble for non-own messages) -->
                    <div class="msg-action-wrapper" onclick="event.stopPropagation()" style="margin-top: 2px; flex-shrink: 0; position: relative;">
                        <!-- Reaction trigger button with picker -->
                        <button class="msg-menu-trigger" type="button" onclick="toggleReactionPicker({{ msg.id }})" style="font-size: 18px;">😊</button>
                        
                        <!-- Reaction picker popup (hidden by default) -->
                        <div id="reaction-picker-{{ msg.id }}" style="display: none; position: absolute; bottom: 110%; left: 50%; transform: translateX(-50%); z-index: 1000; background: white; border-radius: 30px; padding: 8px 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); flex-direction: row; gap: 4px;">
                            <button onclick="addReaction({{ msg.id }}, '👍')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">👍</button>
                            <button onclick="addReaction({{ msg.id }}, '❤️')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">❤️</button>
                            <button onclick="addReaction({{ msg.id }}, '😂')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">😂</button>
                            <button onclick="addReaction({{ msg.id }}, '😮')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">😮</button>
                            <button onclick="addReaction({{ msg.id }}, '😢')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">😢</button>
                            <button onclick="addReaction({{ msg.id }}, '😡')" class="reaction-popup-btn" style="font-size: 18px; background: none; border: none; cursor: pointer; padding: 4px 6px;">😡</button>
                        </div>
                        
                        <!-- 3 dot menu button -->
                        <button class="msg-menu-trigger" type="button" onclick="toggleMessageMenu(event, {{ msg.id }})" title="Message options">⋯</button>
                        
                        <!-- Dropdown menu -->
                        <div id="menu-{{ msg.id }}" class="msg-dropdown-menu">
                            <button class="msg-dropdown-item" onclick="openReplyModal({{ msg.id }}, '{{ msg.content|e('js') }}', '{{ msg.sender_name|e('js') }}')">
                                <span>↩️</span> Reply
                            </button>
                            <button class="msg-dropdown-item" onclick="openForwardModal({{ msg.id }}, '{{ msg.content|e('js') }}')">
                                <span>↗️</span> Forward
                            </button>
                            <button class="msg-dropdown-item" onclick="translateMessage({{ msg.id }})">
                                <span>🌐</span> Translate
                            </button>
                            <button class="msg-dropdown-item" onclick="summarizeMessage({{ msg.id }})">
                                <span>📋</span> Summarize
                            </button>
                            {% if msg.sender_id == currentUserId %}
                                <div class="msg-dropdown-divider"></div>
                                <button class="msg-dropdown-item" onclick="editMessage({{ msg.id }}, '{{ msg.content|e('js') }}')">
                                    <span>✏️</span> Edit
                                </button>
                                <div class="msg-dropdown-divider"></div>
                                <form method="POST" action="{{ path('messaging_message_delete', {id: msg.id}) }}" style="display: contents;" onsubmit="return confirm('Delete this message? This action cannot be undone.')">
                                    <button type="submit" class="msg-dropdown-item danger">
                                        <span>🗑️</span> Delete
                                    </button>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    {% endif %}
    </div>
    {% if messages.getTotalItemCount() > 20 %}
        <div style="padding: 10px 24px; border-top: 1px solid #e8e8e8; background: white;">
            {{ knp_pagination_render(messages) }}
        </div>
    {% endif %}
    <!-- Input Area Wrapper -->
    <div style="padding: 16px 24px; border-top: 1px solid #e8e8e8; background: white;">
        <div id="emojiSuggestionBar" class="emoji-suggestion-bar">
            <span>💡 Suggestions:</span>
            <button type="button" id="emoji1" class="emoji-suggestion-btn emoji-suggestion"></button>
            <button type="button" id="emoji2" class="emoji-suggestion-btn emoji-suggestion"></button>
            <button type="button" id="emoji3" class="emoji-suggestion-btn emoji-suggestion"></button>
        </div>

        <!-- Message Input -->
        <form method="POST" action="{{ path('messaging_message_send') }}" id="sendMessageForm" class="msg-input-group" style="margin-bottom: 12px;" novalidate>
            <input type="hidden" name="conversation_id" value="{{ conversation.id }}">
            <input type="text" name="content" id="sendMessageContent" placeholder="💬 Type your message..." class="msg-input">
            <button type="button" id="smartReplyBtn" class="msg-btn msg-btn-secondary">🤖 Smart Reply</button>
            <button type="submit" class="msg-btn msg-btn-primary" style="background: #2554d9; border-color: #2554d9;">Send</button>
        </form>
        
        <!-- File Upload -->
        <form method="POST" action="{{ path('messaging_message_upload') }}" enctype="multipart/form-data" class="msg-input-group chat-file-row">
            <input type="hidden" name="conversation_id" value="{{ conversation.id }}">
            <input type="file" id="chatFileInput" name="file" style="display: none;">
            <label for="chatFileInput" class="chat-file-picker" title="Choose file" aria-label="Choose file">
                <span style="font-size: 22px; line-height: 1;">📎</span>
            </label>
            <span id="chatFileName" class="chat-file-name">No file chosen</span>
            <button type="submit" class="msg-btn msg-btn-secondary">📎 Upload</button>
        </form>
    </div>
    </div>

<!-- Edit Message Modal (hidden by default) -->
<div id="editModal" class="msg-modal-backdrop" onclick="if(event.target === this) closeEditModal()">
    <div class="msg-modal">
        <div class="msg-modal-head">
            <h3 class="msg-modal-title">✏️ Edit Message</h3>
        </div>
        <div class="msg-modal-body">
            <textarea id="editContent" class="msg-textarea" placeholder="Edit your message..." rows="4"></textarea>
        </div>
        <div class="msg-modal-actions">
            <button onclick="closeEditModal()" class="msg-btn msg-btn-secondary msg-btn-sm">Cancel</button>
            <button onclick="submitEdit()" class="msg-btn msg-btn-primary msg-btn-sm">Save Changes</button>
        </div>
        <form id="editForm" method="POST" style="display: none;">
            <input type="hidden" name="content" id="editFormContent">
        </form>
    </div>
</div>

<!-- Forward Modal -->
<div id="forwardModal" class="msg-modal-backdrop" onclick="if(event.target === this) closeForwardModal()">
    <div class="msg-modal">
        <div class="msg-modal-head">
            <h3 class="msg-modal-title">↗️ Forward Message</h3>
        </div>
        <div class="msg-modal-body">
            <div class="msg-reply-quote">
                <div class="msg-reply-quote-content" id="forwardPreview"></div>
            </div>
            <label style="display: block; font-weight: 600; margin-bottom: 8px; font-size: 13px; color: var(--gray-900);">Select Conversation:</label>
            <div style="position: relative;">
                <input type="text" id="forwardConversationSearch" class="msg-input" placeholder="🔍 Search or type conversation name..." style="font-size: 14px; padding: 10px 12px;" oninput="filterConversations()">
                <div id="forwardConversationDropdown" style="position: absolute; top: 100%; left: 0; right: 0; background: white; border: 1px solid #e2e8f0; border-top: none; border-radius: 0 0 8px 8px; max-height: 200px; overflow-y: auto; display: none; z-index: 1000; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                    {% for conv in conversations %}
                        <div class="forward-conv-option" data-id="{{ conv.id }}" data-name="{{ conv.name ?: 'Conversation #' ~ conv.id }}" style="padding: 12px 14px; border-bottom: 1px solid #f0f0f0; cursor: pointer; transition: all 0.2s; font-size: 14px; user-select: none; color: #0f172a;">
                            {{ conv.name ?: 'Conversation #' ~ conv.id }}
                        </div>
                    {% endfor %}
                </div>
                <input type="hidden" id="forwardConversation" name="forwardConversation">
            </div>
        </div>
        <div class="msg-modal-actions">
            <button onclick="closeForwardModal()" class="msg-btn msg-btn-secondary msg-btn-sm">Cancel</button>
            <button onclick="submitForward()" class="msg-btn msg-btn-primary msg-btn-sm">Forward</button>
        </div>
        <form id="forwardForm" method="POST" style="display: none;">
            <input type="hidden" name="message_id" id="forwardMessageId">
            <input type="hidden" name="target_conversation_id" id="forwardTargetId">
        </form>
    </div>
</div>

<!-- Reply Modal -->
<div id="replyModal" class="msg-modal-backdrop" onclick="if(event.target === this) closeReplyModal()">
    <div class="msg-modal">
        <div class="msg-modal-head">
            <h3 class="msg-modal-title">↩️ Reply to Message</h3>
        </div>
        <div class="msg-modal-body">
            <label style="display: block; font-weight: 600; margin-bottom: 10px; font-size: 12px; color: var(--msg-muted); text-transform: uppercase; letter-spacing: 0.5px;">Original Message:</label>
            <div class="msg-reply-quote">
                <div class="msg-reply-quote-sender" id="replySender"></div>
                <div class="msg-reply-quote-content" id="replyContent"></div>
            </div>
            <label style="display: block; font-weight: 600; margin-bottom: 10px; font-size: 12px; color: var(--msg-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 16px;">Your Reply:</label>
            <textarea id="replyInput" class="msg-textarea" placeholder="Type your reply..." rows="4"></textarea>
        </div>
        <div class="msg-modal-actions">
            <button onclick="closeReplyModal()" class="msg-btn msg-btn-secondary msg-btn-sm">Cancel</button>
            <button id="replySubmitBtn" onclick="submitReply()" class="msg-btn msg-btn-primary msg-btn-sm">Send Reply</button>
        </div>
        <form id="replyForm" method="POST" action="{{ path('messaging_message_reply') }}" style="display: none;">
            <input type="hidden" name="conversation_id" value="{{ conversation.id }}">
            <input type="hidden" name="reply_to_id" id="replyToId">
            <input type="hidden" name="content" id="replyFormContent">
        </form>
    </div>
</div>

<div id="aiResultModal" class="msg-modal-backdrop" onclick="if(event.target === this) closeAiResultModal()">
    <div class="msg-modal">
        <div class="msg-modal-head">
            <h3 id="aiResultTitle" class="msg-modal-title">📋 AI Result</h3>
        </div>
        <div class="msg-modal-body">
            <pre id="aiResultBody" class="ai-result-pre"></pre>
        </div>
        <div class="msg-modal-actions">
            <button type="button" onclick="closeAiResultModal()" class="msg-btn msg-btn-primary msg-btn-sm">Close</button>
        </div>
    </div>
</div>

<div id="translateLanguageModal" class="msg-modal-backdrop" onclick="if(event.target === this) closeTranslateLanguageModal()">
    <div class="msg-modal">
        <div class="msg-modal-head">
            <h3 class="msg-modal-title">🌐 Translate Message</h3>
        </div>
        <div class="msg-modal-body">
            <label for="translateLanguageSelect" style="display:block; font-weight:600; margin-bottom:8px; color:#0f172a;">Choose target language:</label>
            <select id="translateLanguageSelect" class="translate-language-select">
                <option value="English">English</option>
                <option value="French">French</option>
                <option value="Spanish">Spanish</option>
                <option value="German">German</option>
                <option value="Italian">Italian</option>
                <option value="Arabic">Arabic</option>
                <option value="Chinese">Chinese</option>
                <option value="Japanese">Japanese</option>
            </select>
        </div>
        <div class="msg-modal-actions">
            <button type="button" onclick="closeTranslateLanguageModal()" class="msg-btn msg-btn-secondary msg-btn-sm">Cancel</button>
            <button type="button" onclick="submitTranslateLanguage()" class="msg-btn msg-btn-primary msg-btn-sm">Translate</button>
        </div>
    </div>
</div>

<div id="emptyMessagePopup" class="msg-warning-popup" role="alert" aria-live="assertive" aria-hidden="true">
    <span>⚠️</span>
    <span>Please write something before sending.</span>
</div>


<script>
    let currentMessageId = null;
    let forwardMessageId = null;
    let replyToId = null;
    let activeMenuId = null;
    let emptyPopupTimer = null;
    let translateTargetMessageId = null;
    let suggestionTimeout = null;

    function escapeCountryText(value) {
        return String(value ?? '').replace(/\s+/g, ' ').trim();
    }

    function showWarningPopup(messageText) {
        const popup = document.getElementById('emptyMessagePopup');
        if (!popup) {
            return;
        }

        const textNode = popup.querySelector('span:last-child');
        if (textNode) {
            textNode.textContent = messageText;
        }

        popup.classList.add('is-visible');
        popup.setAttribute('aria-hidden', 'false');

        if (emptyPopupTimer !== null) {
            clearTimeout(emptyPopupTimer);
        }

        emptyPopupTimer = window.setTimeout(function() {
            popup.classList.remove('is-visible');
            popup.setAttribute('aria-hidden', 'true');
            emptyPopupTimer = null;
        }, 2200);
    }

    function openAiResultModal(title, content) {
        const modal = document.getElementById('aiResultModal');
        const titleNode = document.getElementById('aiResultTitle');
        const bodyNode = document.getElementById('aiResultBody');

        if (!modal || !titleNode || !bodyNode) {
            return;
        }

        titleNode.textContent = title;
        bodyNode.textContent = content;
        modal.classList.add('active');
    }

    function closeAiResultModal() {
        const modal = document.getElementById('aiResultModal');
        if (modal) {
            modal.classList.remove('active');
        }
    }

    function closeTranslateLanguageModal() {
        const modal = document.getElementById('translateLanguageModal');
        if (modal) {
            modal.classList.remove('active');
        }
        translateTargetMessageId = null;
    }

    function submitTranslateLanguage() {
        if (translateTargetMessageId === null) {
            closeTranslateLanguageModal();
            return;
        }

        const select = document.getElementById('translateLanguageSelect');
        const language = select ? String(select.value || 'English') : 'English';

        fetch('{{ path('messaging_message_translate', {id: 0}) }}'.replace('0', String(translateTargetMessageId)), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'language=' + encodeURIComponent(language),
        })
            .then(function(response) {
                return response.json();
            })
            .then(function(data) {
                if (data.translation) {
                    openAiResultModal('🌐 Translation (' + language + ')', data.translation);
                } else {
                    showWarningPopup(data.error || 'Unable to translate this message.');
                }
            })
            .catch(function() {
                showWarningPopup('Unable to translate this message.');
            })
            .finally(function() {
                closeTranslateLanguageModal();
            });
    }

    function summarizeConversation() {
        fetch('{{ path('messaging_conversation_summarize', {id: conversation.id}) }}')
            .then(function(response) {
                return response.json();
            })
            .then(function(data) {
                if (data.summary) {
                    openAiResultModal('📋 Conversation Summary', data.summary);
                } else {
                    showWarningPopup(data.error || 'Unable to summarize this conversation right now.');
                }
            })
            .catch(function() {
                showWarningPopup('Unable to summarize this conversation right now.');
            });
    }

    function summarizeMessage(messageId) {
        fetch('{{ path('messaging_message_summarize', {id: 0}) }}'.replace('0', String(messageId)))
            .then(function(response) {
                return response.json();
            })
            .then(function(data) {
                if (data.summary) {
                    openAiResultModal('📋 Message Summary', data.summary);
                } else {
                    showWarningPopup(data.error || 'Unable to summarize this message.');
                }
            })
            .catch(function() {
                showWarningPopup('Unable to summarize this message.');
            });
    }

    function translateMessage(messageId) {
        closeAllMenus();
        translateTargetMessageId = messageId;

        const select = document.getElementById('translateLanguageSelect');
        if (select && !select.value) {
            select.value = 'English';
        }

        const modal = document.getElementById('translateLanguageModal');
        if (modal) {
            modal.classList.add('active');
        }
    }
    
    // Filter conversations in forward modal
    function filterConversations() {
        const searchInput = document.getElementById('forwardConversationSearch');
        const query = searchInput.value.toLowerCase();
        const options = document.querySelectorAll('.forward-conv-option');
        const dropdown = document.getElementById('forwardConversationDropdown');
        
        let visibleCount = 0;
        options.forEach(option => {
            const name = option.getAttribute('data-name').toLowerCase();
            if (name.includes(query) || query === '') {
                option.style.display = 'block';
                visibleCount++;
            } else {
                option.style.display = 'none';
            }
        });
        
        if (query.length > 0 && visibleCount > 0) {
            dropdown.style.display = 'block';
        } else if (query.length === 0) {
            dropdown.style.display = 'block';
        } else {
            dropdown.style.display = 'none';
        }
    }
    
    // Select conversation from dropdown
    function selectConversation(element) {
        const id = element.getAttribute('data-id');
        const name = element.getAttribute('data-name');
        document.getElementById('forwardConversationSearch').value = name;
        document.getElementById('forwardConversation').value = id;
        document.getElementById('forwardConversationDropdown').style.display = 'none';
        console.log('Selected conversation:', id, name);
    }
    
    // Show dropdown when input is focused
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('forwardConversationSearch');
        const dropdown = document.getElementById('forwardConversationDropdown');
        const sendForm = document.getElementById('sendMessageForm');
        const sendContentInput = document.getElementById('sendMessageContent');
        const sendButton = sendForm ? sendForm.querySelector('button[type="submit"]') : null;
        const smartReplyBtn = document.getElementById('smartReplyBtn');
        const chatFileInput = document.getElementById('chatFileInput');
        const chatFileName = document.getElementById('chatFileName');
        const emojiBar = document.getElementById('emojiSuggestionBar');
        const emojiButtons = [
            document.getElementById('emoji1'),
            document.getElementById('emoji2'),
            document.getElementById('emoji3'),
        ];

        if (chatFileInput && chatFileName) {
            chatFileInput.addEventListener('change', function() {
                if (chatFileInput.files && chatFileInput.files.length > 0) {
                    chatFileName.textContent = chatFileInput.files[0].name;
                } else {
                    chatFileName.textContent = 'No file chosen';
                }
            });
        }

        function hideEmojiBar() {
            if (emojiBar) {
                emojiBar.style.display = 'none';
            }
            emojiButtons.forEach(function(btn) {
                if (btn) {
                    btn.textContent = '';
                    btn.style.display = 'none';
                }
            });
        }

        if (sendContentInput) {
            sendContentInput.addEventListener('input', function() {
                const text = sendContentInput.value.trim();

                if (suggestionTimeout !== null) {
                    clearTimeout(suggestionTimeout);
                }

                if (text.length < 10) {
                    hideEmojiBar();
                    return;
                }

                suggestionTimeout = window.setTimeout(function() {
                    fetch('{{ path('messaging_suggest_emojis') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'text=' + encodeURIComponent(text),
                    })
                        .then(function(response) {
                            return response.json();
                        })
                        .then(function(data) {
                            const emojis = Array.isArray(data.emojis) ? data.emojis.slice(0, 3) : [];
                            if (emojis.length === 0) {
                                hideEmojiBar();
                                return;
                            }

                            emojiButtons.forEach(function(btn, index) {
                                if (!btn) {
                                    return;
                                }

                                const emoji = emojis[index] || '';
                                btn.textContent = emoji;
                                btn.style.display = emoji !== '' ? 'inline-flex' : 'none';
                            });

                            if (emojiBar) {
                                emojiBar.style.display = 'flex';
                            }
                        })
                        .catch(function() {
                            hideEmojiBar();
                        });
                }, 1000);
            });
        }

        document.querySelectorAll('.emoji-suggestion').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const emoji = (btn.textContent || '').trim();
                if (!emoji || !sendContentInput) {
                    return;
                }

                const current = sendContentInput.value.trim();
                sendContentInput.value = (current !== '' ? current + ' ' : '') + emoji + ' ';
                sendContentInput.focus();
                hideEmojiBar();
            });
        });

        if (sendForm && sendContentInput) {
            sendForm.addEventListener('submit', function(event) {
                const normalized = sendContentInput.value.trim();
                sendContentInput.value = normalized;

                if (normalized === '') {
                    event.preventDefault();
                    showWarningPopup('Please write something before sending.');
                    sendContentInput.focus();
                    return;
                }

                const countryMatch = normalized.match(/^\/country\s+(.+)$/i);
                if (countryMatch) {
                    event.preventDefault();

                    const requestedCountry = countryMatch[1].trim();
                    if (requestedCountry === '') {
                        showWarningPopup('Use /country followed by a country name.');
                        sendContentInput.focus();
                        return;
                    }

                    if (sendButton) {
                        sendButton.disabled = true;
                        sendButton.textContent = 'Loading...';
                    }

                    fetch(`/messaging/country/${encodeURIComponent(requestedCountry)}`)
                        .then(function(response) {
                            return response.json().then(function(data) {
                                return { ok: response.ok, data: data };
                            });
                        })
                        .then(function(result) {
                            if (!result.ok || result.data.error) {
                                const errorText = escapeCountryText(result.data.error || 'Country not found.');
                                showWarningPopup(errorText);
                                sendContentInput.focus();
                                return;
                            }

                            const data = result.data;
                            const countryTitle = `${escapeCountryText(data.flagEmoji || '🌍')} ${escapeCountryText(data.name || requestedCountry)}`;
                            const formatted = [
                                countryTitle,
                                `🏛️ Capital: ${escapeCountryText(data.capital || 'N/A')}`,
                                `👥 Population: ${escapeCountryText(data.population || 'N/A')}`,
                                `💰 Currency: ${escapeCountryText(data.currency || 'N/A')} (${escapeCountryText(data.currencyCode || 'N/A')})`,
                                `🗣️ Language: ${escapeCountryText(data.language || 'N/A')}`,
                                `🌍 Region: ${escapeCountryText(data.region || 'N/A')}`,
                            ];

                            if (data.flagPng) {
                                formatted.push(`🏳️ Flag: ${escapeCountryText(data.flagPng)}`);
                            }

                            sendContentInput.value = formatted.join('\n');
                            sendForm.submit();
                        })
                        .catch(function() {
                            showWarningPopup('Country service is unavailable right now.');
                            sendContentInput.focus();
                        })
                        .finally(function() {
                            if (sendButton) {
                                sendButton.disabled = false;
                                sendButton.textContent = 'Send';
                            }
                        });
                }
            });
        }

        if (smartReplyBtn && sendContentInput) {
            smartReplyBtn.addEventListener('click', function() {
                smartReplyBtn.disabled = true;
                smartReplyBtn.textContent = '⏳ Thinking...';

                fetch('{{ path('messaging_smart_reply', {id: conversation.id}) }}')
                    .then(function(response) {
                        return response.json();
                    })
                    .then(function(data) {
                        if (data.suggestion) {
                            sendContentInput.value = data.suggestion;
                            sendContentInput.focus();
                        } else {
                            showWarningPopup(data.error || 'Could not generate a smart reply.');
                        }
                    })
                    .catch(function() {
                        showWarningPopup('Could not generate a smart reply.');
                    })
                    .finally(function() {
                        smartReplyBtn.disabled = false;
                        smartReplyBtn.textContent = '🤖 Smart Reply';
                    });
            });
        }
        
        if (searchInput) {
            searchInput.addEventListener('focus', function() {
                dropdown.style.display = 'block';
            });
            
            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
                    dropdown.style.display = 'none';
                }
            });
            
            // Allow clicking inside dropdown without closing
            dropdown.addEventListener('mousedown', function(e) {
                e.preventDefault();
                if (e.target.classList.contains('forward-conv-option')) {
                    selectConversation(e.target);
                }
            });
        }
    });

    function scrollToLatestMessage() {
        const container = document.getElementById('messagesContainer');
        if (container) {
            requestAnimationFrame(() => {
                container.scrollTop = container.scrollHeight;
            });

            // Highlight the last message (newly sent reply)
            const messages = container.querySelectorAll('.message-item');
            if (messages.length > 0) {
                const lastMsg = messages[messages.length - 1];
                const bubble = lastMsg.querySelector('.msg-bubble-content');
                if (bubble) {
                    bubble.classList.add('reply-highlight');
                    setTimeout(() => {
                        bubble.classList.remove('reply-highlight');
                    }, 4000);
                }
            }
        }
    }

    // Auto-scroll to last message when opening conversation
    document.addEventListener('DOMContentLoaded', scrollToLatestMessage);
    window.addEventListener('load', scrollToLatestMessage);

    window.addEventListener('load', function() {
        setTimeout(scrollToLatestMessage, 120);
    });

    // Highlight message if URL has hash
    window.addEventListener('load', function() {
        const hash = window.location.hash;
        if (hash.startsWith('#msg-')) {
            const messageId = hash.substring(5);
            highlightMessage(messageId);
        }
    });

    function highlightMessage(messageId) {
        const msgElement = document.getElementById('msg-' + messageId);
        if (msgElement) {
            msgElement.style.backgroundColor = '#FFEB3B';
            msgElement.style.padding = '8px';
            msgElement.style.borderRadius = '8px';
            msgElement.style.animation = 'pulse 2s ease-in-out';

            // Scroll to the message
            msgElement.scrollIntoView({ behavior: 'smooth', block: 'center' });

            // Remove highlight after 3 seconds
            setTimeout(() => {
                msgElement.style.backgroundColor = '';
                msgElement.style.padding = '';
            }, 3000);
        }
    }

    // Add pulse animation
    const style = document.createElement('style');
    style.textContent = `
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 235, 59, 0.7); }
            50% { box-shadow: 0 0 0 10px rgba(255, 235, 59, 0); }
        }
    `;
    document.head.appendChild(style);

    // Toggle message menu
    function toggleMessageMenu(event, messageId) {
        event.stopPropagation();
        const menu = document.getElementById('menu-' + messageId);
        
        if (activeMenuId !== null && activeMenuId !== messageId) {
            const activeMenu = document.getElementById('menu-' + activeMenuId);
            if (activeMenu) {
                activeMenu.classList.remove('active');
            }
        }
        
        menu.classList.toggle('active');
        activeMenuId = menu.classList.contains('active') ? messageId : null;
    }

    // Close all menus when clicking outside
    document.addEventListener('click', function(event) {
        if (activeMenuId !== null) {
            const activeMenu = document.getElementById('menu-' + activeMenuId);
            if (activeMenu && !activeMenu.contains(event.target)) {
                activeMenu.classList.remove('active');
                activeMenuId = null;
            }
        }
    });

    function editMessage(id, content) {
        closeAllMenus();
        currentMessageId = id;
        document.getElementById('editContent').value = content;
        document.getElementById('editModal').classList.add('active');
    }

    function closeEditModal() {
        document.getElementById('editModal').classList.remove('active');
        currentMessageId = null;
    }

    function submitEdit() {
        if (currentMessageId) {
            const newContent = document.getElementById('editContent').value.trim();
            if (!newContent) {
                alert('Message cannot be empty');
                return;
            }
            const form = document.getElementById('editForm');
            form.action = '{{ path("messaging_message_edit", {id: 0}) }}'.replace('0', currentMessageId);
            document.getElementById('editFormContent').value = newContent;
            form.submit();
        }
    }

    // Forward functionality
    function openForwardModal(id, content) {
        closeAllMenus();
        forwardMessageId = id;
        const preview = content.length > 150 ? content.substring(0, 150) + '...' : content;
        document.getElementById('forwardPreview').innerText = preview;
        document.getElementById('forwardModal').classList.add('active');
    }

    function closeForwardModal() {
        document.getElementById('forwardModal').classList.remove('active');
        forwardMessageId = null;
    }

    function submitForward() {
        const targetId = document.getElementById('forwardConversation').value;
        if (!targetId) {
            alert('Please select a conversation');
            return;
        }

        const form = document.getElementById('forwardForm');
        form.action = '{{ path("messaging_message_forward") }}';
        document.getElementById('forwardMessageId').value = forwardMessageId;
        document.getElementById('forwardTargetId').value = targetId;
        form.submit();
    }

    // Reply functionality
    function openReplyModal(id, content, senderName) {
        closeAllMenus();
        replyToId = id;
        const displayName = (senderName || 'User').trim();
        document.getElementById('replySender').textContent = displayName;
        
        // Format content for display
        let preview = content;
        if (preview.length > 250) {
            preview = preview.substring(0, 250) + '...';
        }
        
        // Handle if content starts with quote (from reply chain)
        if (preview.startsWith('> ')) {
            preview = preview.split('\n').filter(l => l.startsWith('> ')).slice(0, 3).map(l => l.replace(/^> /, '')).join('\n');
            if (preview.length > 150) {
                preview = preview.substring(0, 150) + '...';
            }
        }
        
        document.getElementById('replyContent').textContent = preview;
        document.getElementById('replyModal').classList.add('active');
        document.getElementById('replyInput').focus();
    }

    function closeReplyModal() {
        document.getElementById('replyModal').classList.remove('active');
        replyToId = null;
        document.getElementById('replyInput').value = '';
    }

    function submitReply() {
        const replyText = document.getElementById('replyInput').value.trim();
        if (!replyText) {
            alert('Please enter a reply');
            return;
        }

        const form = document.getElementById('replyForm');
        document.getElementById('replyToId').value = replyToId;
        document.getElementById('replyFormContent').value = replyText;
        
        // Add visual feedback before submitting
        const submitBtn = document.getElementById('replySubmitBtn');
        if (submitBtn) {
            submitBtn.textContent = '⏳ Sending...';
            submitBtn.disabled = true;
        }
        
        setTimeout(() => {
            form.submit();
        }, 300);
    }

    function closeAllMenus() {
        if (activeMenuId !== null) {
            const menu = document.getElementById('menu-' + activeMenuId);
            if (menu) {
                menu.classList.remove('active');
            }
            activeMenuId = null;
        }
    }

    // Make reply quotes clickable to scroll to original message
    function initializeReplyQuotes() {
        const replyQuotes = document.querySelectorAll('[data-reply-to-id]');
        replyQuotes.forEach(quote => {
            quote.style.cursor = 'pointer';
            quote.addEventListener('click', function() {
                const replyToId = this.getAttribute('data-reply-to-id');
                const originalMsg = document.getElementById('msg-' + replyToId);
                if (originalMsg) {
                    const bubble = originalMsg.querySelector('.msg-bubble-content');
                    bubble.classList.add('reply-highlight');
                    originalMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    setTimeout(() => {
                        bubble.classList.remove('reply-highlight');
                    }, 3000);
                }
            });
        });
    }

    window.addEventListener('load', initializeReplyQuotes);

    // Close modals when clicking on backdrop
    document.getElementById('editModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeEditModal();
        }
    });

    document.getElementById('forwardModal')?.addEventListener('click', function(e) {
        if (e.target === this) closeForwardModal();
    });

    document.getElementById('replyModal')?.addEventListener('click', function(e) {
        if (e.target === this) closeReplyModal();
    });

    document.getElementById('aiResultModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeAiResultModal();
        }
    });

    document.getElementById('translateLanguageModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeTranslateLanguageModal();
        }
    });

    // Keyboard shortcuts
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeEditModal();
            closeForwardModal();
            closeReplyModal();
            closeAiResultModal();
            closeTranslateLanguageModal();
            closeAllMenus();
        }
    });

    // Reaction system
    let activePicker = null;

    // Toggle reaction on/off (for clicking existing badge)
    function toggleReaction(messageId, reaction) {
        console.log('🔄 Toggling reaction:', reaction, 'for message:', messageId);
        fetch('{{ path('messaging_message_react', {id: 0}) }}'.replace('0', messageId), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'reaction=' + encodeURIComponent(reaction)
        })
        .then(response => {
            console.log('📨 Response status:', response.status);
            if (response.redirected) {
                window.location.href = response.url;
            } else {
                return response.json();
            }
        })
        .then(data => {
            if (data) {
                console.log('✅ Reaction toggled, reloading page...');
                location.reload();
            }
        })
        .catch(error => console.error('Error:', error));
    }

    // Add new reaction (from picker)
    function addReaction(messageId, reaction) {
        console.log('➕ Adding reaction:', reaction, 'to message:', messageId);
        fetch('{{ path('messaging_message_react', {id: 0}) }}'.replace('0', messageId), {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: 'reaction=' + encodeURIComponent(reaction)
        })
        .then(response => {
            console.log('📨 Response status:', response.status);
            if (response.redirected) {
                window.location.href = response.url;
            } else {
                return response.json();
            }
        })
        .then(data => {
            if (data) {
                console.log('✅ Reaction added, reloading page...');
                location.reload();
            }
        })
        .catch(error => console.error('Error:', error));
    }

    // Toggle reaction picker visibility
    function toggleReactionPicker(messageId) {
        const picker = document.getElementById('reaction-picker-' + messageId);
        
        // Close other pickers
        if (activePicker && activePicker !== picker) {
            activePicker.style.display = 'none';
        }
        
        // Toggle current picker
        if (picker.style.display === 'none' || picker.style.display === '') {
            picker.style.display = 'flex';
            activePicker = picker;
        } else {
            picker.style.display = 'none';
            activePicker = null;
        }
    }

    // Close picker when clicking outside
    document.addEventListener('click', function(event) {
        if (activePicker && !event.target.closest('#' + activePicker.id) && !event.target.closest('button[onclick*="toggleReactionPicker"]')) {
            activePicker.style.display = 'none';
            activePicker = null;
        }
    });
</script>
{% endblock %}