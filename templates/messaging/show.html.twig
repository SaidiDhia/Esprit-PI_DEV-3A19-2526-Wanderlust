{% extends 'base.html.twig' %}

{% block title %}{{ conversation.name }} - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
{% endblock %}

{% block content %}
<div class="msg-page">
<div class="page-hero" style="background:  linear-gradient(180deg, #2144b8 0%, #1d49cf 58%, #1e4ed8 100%); color: #ffffff; border-bottom: 1px solid rgba(255,255,255,0.14); padding: 92px 40px 84px; text-align: center;">
    <div class="page-hero-content">
        <a href="{{ path('app_messaging') }}" style="color: var(--gray-700); text-decoration: none; display: inline-block; margin-bottom: 16px;">← Back to conversations</a>
        <h1 class="page-hero-title msg-hero-title">{{ conversation.name ?: 'Conversation #' ~ conversation.id }}</h1>
        <p class="page-hero-subtitle">{{ conversation.type }} chat</p>
    </div>
</div>

<div class="page-content msg-fade-in">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Manage Members Button (for GROUP conversations) -->
    {% if conversation.type == 'GROUP' %}
        <div style="margin-bottom: 20px;">
            <a href="{{ path('messaging_conversation_participants', {id: conversation.id}) }}" class="msg-btn msg-btn-secondary">👥 Manage Members</a>
        </div>
    {% endif %}
    
    <!-- Messages Area -->
<div class="msg-card msg-card-hover" style="min-height: 400px; max-height: 500px; overflow-y: auto; padding: 20px; margin-bottom: 20px;">
    {% if messages is empty %}
        <div style="text-align: center; padding: 60px; color: var(--gray-400);">
            <div style="font-size: 48px; margin-bottom: 16px;">💬</div>
            <p>No messages yet. Start the conversation!</p>
        </div>
    {% else %}
        {% for msg in messages %}
            <div class="msg-fade-in" style="margin-bottom: 16px; display: flex; justify-content: {% if msg.sender_id == currentUserId %}flex-end{% else %}flex-start{% endif %};">
                <div class="msg-bubble" style="max-width: 70%; background: {% if msg.sender_id == currentUserId %}var(--msg-primary){% else %}var(--gray-100){% endif %}; color: {% if msg.sender_id == currentUserId %}white{% else %}var(--gray-900){% endif %}; border-radius: 16px; padding: 10px 16px; box-shadow: {% if msg.sender_id == currentUserId %}0 14px 24px rgba(14, 165, 233, 0.16){% else %}0 8px 16px rgba(15, 23, 42, 0.04){% endif %};">
                    <div style="font-size: 11px; opacity: 0.85; margin-bottom: 4px; display: flex; justify-content: space-between; align-items: center; font-family: 'Plus Jakarta Sans', sans-serif;">
                        <span>{{ msg.sender_name ?: 'User ' ~ msg.sender_id|slice(0,8) }} • {{ msg.created_at|date('H:i') }}</span>
                        
                        {% if msg.sender_id == currentUserId %}
                            <div style="display: flex; gap: 8px; margin-left: 12px;">
                                <!-- Edit Button -->
                                <button onclick="editMessage({{ msg.id }}, '{{ msg.content|e('js') }}')" 
                                        style="background: none; border: none; color: inherit; cursor: pointer; font-size: 12px; opacity: 0.7;"
                                        title="Edit">✏️</button>
                                <!-- Delete Button -->
                                <form method="POST" action="{{ path('messaging_message_delete', {id: msg.id}) }}" 
                                      style="display: inline; margin: 0; padding: 0;"
                                      onsubmit="return confirm('Delete this message?')">
                                    <button type="submit" style="background: none; border: none; color: inherit; cursor: pointer; font-size: 12px; opacity: 0.7;" title="Delete">🗑️</button>
                                </form>
                            </div>
                        {% endif %}
                    </div>
                    <div id="message-content-{{ msg.id }}">
                        {% if msg.message_type == 'IMAGE' %}
                            📷 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit;">{{ msg.file_name ?: 'Image' }}</a>
                        {% elseif msg.message_type == 'VIDEO' %}
                            🎥 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit;">{{ msg.file_name ?: 'Video' }}</a>
                        {% elseif msg.message_type == 'AUDIO' %}
                            🎵 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit;">{{ msg.file_name ?: 'Audio' }}</a>
                        {% elseif msg.message_type == 'FILE' %}
                            📎 <a href="{{ path('serve_upload', {filename: msg.file_url|split('/')|last}) }}" target="_blank" style="color: inherit;">{{ msg.file_name ?: 'File' }}</a>
                        {% else %}
                            {{ msg.content }}
                        {% endif %}
                    </div>
                    {% if msg.edited_at %}
                        <div style="font-size: 9px; opacity: 0.5; margin-top: 4px;">edited</div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>

<!-- Edit Message Modal (hidden by default) -->
<div id="editModal" class="msg-modal-backdrop">
    <div class="msg-modal msg-pop-in">
        <div class="msg-modal-head">
            <h3 class="msg-modal-title">Edit Message</h3>
        </div>
        <div class="msg-modal-body">
            <textarea id="editContent" class="msg-textarea" rows="3" style="font-family: inherit;"></textarea>
        </div>
        <div class="msg-modal-actions">
            <button onclick="closeEditModal()" class="msg-btn msg-btn-secondary">Cancel</button>
            <button onclick="submitEdit()" class="msg-btn msg-btn-primary">Save</button>
        </div>
        <form id="editForm" method="POST" style="display: none;">
            <input type="hidden" name="content" id="editFormContent">
        </form>
    </div>
</div>

<script>
    let currentMessageId = null;
    
    function editMessage(id, content) {
        currentMessageId = id;
        document.getElementById('editContent').value = content;
        document.getElementById('editModal').style.display = 'flex';
    }
    
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        currentMessageId = null;
    }
    
    function submitEdit() {
        if (currentMessageId) {
            const newContent = document.getElementById('editContent').value;
            const form = document.getElementById('editForm');
            form.action = '{{ path("messaging_message_edit", {id: 0}) }}'.replace('0', currentMessageId);
            document.getElementById('editFormContent').value = newContent;
            form.submit();
        }
    }
    
    // Close modal when clicking outside
    document.getElementById('editModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closeEditModal();
        }
    });
</script>
    
    <!-- Message Input -->
    <form id="messageComposer" method="POST" action="{{ path('messaging_message_send') }}" class="msg-card msg-card-hover" style="display: flex; gap: 12px; margin-bottom: 12px; padding: 14px; align-items: center;">
        <input type="hidden" name="conversation_id" value="{{ conversation.id }}">
        <input type="text" name="content" class="msg-input" placeholder="Type your message..." style="flex: 1; border-radius: 24px;" required>
        <button type="submit" class="msg-btn msg-btn-primary" style="border-radius: 24px; min-width: 110px;">Send</button>
    </form>
    
    <!-- File Upload -->
    <form method="POST" action="{{ path('messaging_message_upload') }}" enctype="multipart/form-data" class="msg-card msg-card-hover msg-fade-in" style="display: flex; gap: 12px; padding: 14px; align-items: center;">
        <input type="hidden" name="conversation_id" value="{{ conversation.id }}">
        <input type="file" name="file" required class="msg-input" style="flex: 1; padding: 8px;">
        <button type="submit" class="msg-btn msg-btn-secondary">📎 Upload</button>
    </form>
    <p style="margin-top: 8px; font-size: 12px; color: var(--gray-500);">Max upload size: 2 MB (server limit).</p>
</div>
</div>
<script>
    const messageComposer = document.getElementById('messageComposer');
    messageComposer?.addEventListener('submit', function() {
        const submitButton = this.querySelector('button[type="submit"]');
        if (submitButton) {
            submitButton.textContent = 'Sending...';
            submitButton.disabled = true;
        }
    });
</script>
{% endblock %}