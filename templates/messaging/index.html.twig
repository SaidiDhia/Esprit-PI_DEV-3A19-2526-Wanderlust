{% extends 'base.html.twig' %}

{% block title %}Messaging - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('{{ asset('adventure/img/slider1.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .msg-toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .msg-search {
            margin-bottom: 24px;
        }

        .msg-search form {
            display: flex;
            gap: 10px;
        }

        .msg-search input {
            flex: 1;
            border: 1px solid #e5e7eb;
            border-radius: 999px;
            padding: 10px 16px;
            outline: none;
        }

        .conversation-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 12px;
            padding: 16px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 14px;
        }

        .conversation-card.pinned {
            border-left: 4px solid #f59e0b;
        }

        .conversation-meta {
            font-size: 12px;
            color: #777;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .conversation-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .conversation-actions .genric-btn {
            margin: 0;
        }

        .msg-section-title {
            margin: 24px 0 14px;
        }

        .archive-wrap {
            opacity: 0.78;
        }

        .msg-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1100;
            align-items: center;
            justify-content: center;
        }

        .msg-modal-card {
            background: #fff;
            border-radius: 16px;
            padding: 24px;
            width: 420px;
            max-width: 92%;
            box-shadow: 0 12px 36px rgba(0, 0, 0, 0.24);
        }

        .msg-modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            margin-top: 14px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Messaging</h1>
        <p class="mb-20">Connect with fellow adventurers using the same WanderLust style.</p>
        <a href="{{ path('messaging_conversation_new') }}" class="primary-btn text-uppercase">Start New Conversation</a>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <div class="msg-toolbar">
            <h2 class="mb-0">Your Conversations</h2>
            <a href="{{ path('messaging_conversation_new') }}" class="genric-btn primary">+ New Conversation</a>
        </div>

        <div class="msg-search">
            <form method="GET" action="">
                <input type="text" name="search" placeholder="Search conversations..." value="{{ app.request.query.get('search') }}">
                <button type="submit" class="genric-btn primary circle">Search</button>
                {% if app.request.query.get('search') %}
                    <a href="{{ path('app_messaging') }}" class="genric-btn default circle">Clear</a>
                {% endif %}
            </form>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <h4 class="msg-section-title">Active</h4>
        {% if conversations is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h5>No active conversations</h5>
                <p class="text-muted mb-3">Start a new one to begin chatting.</p>
                <a href="{{ path('messaging_conversation_new') }}" class="primary-btn text-uppercase">New Conversation</a>
            </div>
        {% else %}
            {% for conv in conversations %}
                <article class="conversation-card{% if conv.is_pinned %} pinned{% endif %}">
                    <div>
                        <h5 class="mb-1">
                            {{ conv.name ?: 'Conversation #' ~ conv.id }}
                            {% if conv.is_pinned %} 📌{% endif %}
                        </h5>
                        <div class="conversation-meta">{{ conv.type }}</div>
                    </div>

                    <div class="conversation-actions">
                        <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="genric-btn info-border small">Open</a>

                        <form method="POST" action="{{ path('messaging_conversation_pin', {id: conv.id}) }}" style="display:inline;">
                            <button type="submit" class="genric-btn default-border small">{{ conv.is_pinned ? 'Unpin' : 'Pin' }}</button>
                        </form>

                        <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display:inline;">
                            <button type="submit" class="genric-btn default-border small">Archive</button>
                        </form>

                        <button onclick="renameConversation({{ conv.id }}, '{{ conv.name|e('js') }}')" class="genric-btn warning-border small">Rename</button>

                        {% if conv.user_role == 'CREATOR' %}
                            <form method="POST" id="deleteForm_{{ conv.id }}" action="{{ path('messaging_conversation_delete', {id: conv.id}) }}" style="display:none;"></form>
                            <button type="button" class="genric-btn danger-border small" onclick="prepareDeleteConversation({{ conv.id }})">Delete</button>
                        {% endif %}
                    </div>
                </article>
            {% endfor %}
        {% endif %}

        {% if archivedConversations is not empty %}
            <h4 class="msg-section-title">Archived</h4>
            <div class="archive-wrap">
                {% for conv in archivedConversations %}
                    <article class="conversation-card">
                        <div>
                            <h5 class="mb-1">{{ conv.name ?: 'Conversation #' ~ conv.id }}</h5>
                            <div class="conversation-meta">{{ conv.type }}</div>
                        </div>
                        <div class="conversation-actions">
                            <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="genric-btn info-border small">View</a>
                            <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display:inline;">
                                <button type="submit" class="genric-btn success-border small">Unarchive</button>
                            </form>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>

<div id="renameModal" class="msg-modal">
    <div class="msg-modal-card">
        <h4 class="mb-3">Rename Conversation</h4>
        <input type="text" id="renameInput" class="form-control" style="margin-bottom: 14px;">
        <div class="msg-modal-actions">
            <button onclick="closeRenameModal()" class="genric-btn default-border small">Cancel</button>
            <button onclick="submitRename()" class="genric-btn primary small">Save</button>
        </div>
        <form id="renameForm" method="POST" style="display:none;">
            <input type="hidden" name="name" id="renameFormName">
        </form>
    </div>
</div>

<div id="deleteModal" class="msg-modal">
    <div class="msg-modal-card" style="max-width: 430px;">
        <h4 class="mb-3">Delete Conversation</h4>
        <p class="text-muted">Are you sure you want to delete this conversation and all messages? This cannot be undone.</p>
        <div class="msg-modal-actions">
            <button type="button" onclick="closeDeleteModal()" class="genric-btn default-border small">Cancel</button>
            <button type="button" onclick="submitDelete()" class="genric-btn danger small">Delete</button>
        </div>
    </div>
</div>

<script>
    let currentConversationId = null;
    let deleteConversationId = null;

    function renameConversation(id, currentName) {
        currentConversationId = id;
        document.getElementById('renameInput').value = currentName;
        document.getElementById('renameModal').style.display = 'flex';
    }

    function closeRenameModal() {
        document.getElementById('renameModal').style.display = 'none';
        currentConversationId = null;
    }

    function submitRename() {
        if (!currentConversationId) {
            return;
        }

        const newName = document.getElementById('renameInput').value;
        const form = document.getElementById('renameForm');
        form.action = '{{ path("messaging_conversation_rename", {id: 0}) }}'.replace('0', currentConversationId);
        document.getElementById('renameFormName').value = newName;
        form.submit();
    }

    function prepareDeleteConversation(id) {
        deleteConversationId = id;
        document.getElementById('deleteModal').style.display = 'flex';
    }

    function closeDeleteModal() {
        document.getElementById('deleteModal').style.display = 'none';
        deleteConversationId = null;
    }

    function submitDelete() {
        if (deleteConversationId) {
            const form = document.getElementById('deleteForm_' + deleteConversationId);
            if (form) {
                form.submit();
            }
        }
        closeDeleteModal();
    }

    document.getElementById('renameModal')?.addEventListener('click', function (e) {
        if (e.target === this) {
            closeRenameModal();
        }
    });

    document.getElementById('deleteModal')?.addEventListener('click', function (e) {
        if (e.target === this) {
            closeDeleteModal();
        }
    });
</script>
{% endblock %}