{% extends 'base.html.twig' %}

{% block title %}Messaging - WanderLust{% endblock %}

{% block content %}
<div class="page-hero">
    <div class="page-hero-content">
        <span class="page-hero-icon">💬</span>
        <h1 class="page-hero-title">Messaging</h1>
        <p class="page-hero-subtitle">Connect with fellow adventurers</p>
    </div>
</div>

<div class="page-content">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <h2 style="font-family: var(--font-display);">Your Conversations</h2>
        <a href="{{ path('messaging_conversation_new') }}" class="btn btn-primary">➕ New Conversation</a>
    </div>

    <!-- Search Conversations -->
    <div style="margin-bottom: 24px;">
        <form method="GET" action="" style="display: flex; gap: 8px;">
            <input type="text" name="search" placeholder="🔍 Search conversations..."
                   value="{{ app.request.query.get('search') }}"
                   style="flex: 1; padding: 10px 16px; border: 1px solid var(--gray-200); border-radius: 24px; outline: none;">
            <button type="submit" class="btn btn-primary" style="border-radius: 24px;">Search</button>
            {% if app.request.query.get('search') %}
                <a href="{{ path('app_messaging') }}" class="btn btn-outline" style="border-radius: 24px;">Clear</a>
            {% endif %}
        </form>
    </div>
    
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Active Conversations -->
    <h3 style="margin: 24px 0 16px 0;">Active</h3>
    {% if conversations is empty %}
        <div class="mp-empty" style="padding: 40px;">
            <div style="font-size: 48px;">💬</div>
            <p>No active conversations. Start a new one!</p>
        </div>
    {% else %}
        <div style="display: flex; flex-direction: column; gap: 12px;">
            {% for conv in conversations %}
                <div style="background: white; border-radius: 12px; border: 1px solid var(--gray-200); padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; {% if conv.is_pinned %}border-left: 4px solid #F59E0B;{% endif %}">
                    <div>
                        <h3 style="margin-bottom: 4px;">
                            {{ conv.name ?: 'Conversation #' ~ conv.id }}
                            {% if conv.is_pinned %} 📌{% endif %}
                        </h3>
                        <span style="font-size: 12px; color: var(--gray-400);">{{ conv.type }}</span>
                    </div>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="btn btn-primary" style="padding: 6px 16px;">Open</a>
                        
                        <!-- Pin/Unpin Button -->
                        <form method="POST" action="{{ path('messaging_conversation_pin', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="btn btn-outline" style="padding: 6px 16px;" title="{{ conv.is_pinned ? 'Unpin' : 'Pin' }}">
                                {{ conv.is_pinned ? '📌 Unpin' : '📍 Pin' }}
                            </button>
                        </form>
                        
                        <!-- Archive Button -->
                        <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="btn btn-outline" style="padding: 6px 16px;" title="Archive">
                                📦 Archive
                            </button>
                        </form>
                        
                        <!-- Rename Button -->
                        <button onclick="renameConversation({{ conv.id }}, '{{ conv.name|e('js') }}')" class="btn btn-outline" style="padding: 6px 16px;">✏️ Rename</button>
                        
                        <!-- Delete Button (only for creator) -->
                        {% if conv.user_role == 'CREATOR' %}
                            <form method="POST" id="deleteForm_{{ conv.id }}" action="{{ path('messaging_conversation_delete', {id: conv.id}) }}" style="display: none;">
                            </form>
                            <button type="button" class="btn" style="padding: 6px 16px; background: #EF4444; color: white; border: none; border-radius: 8px; cursor: pointer;" onclick="prepareDeleteConversation({{ conv.id }})">🗑️ Delete</button>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
    
    <!-- Archived Conversations Section -->
    {% if archivedConversations is not empty %}
        <h3 style="margin: 32px 0 16px 0;">Archived 📦</h3>
        <div style="display: flex; flex-direction: column; gap: 12px; opacity: 0.7;">
            {% for conv in archivedConversations %}
                <div style="background: #f5f5f5; border-radius: 12px; border: 1px solid var(--gray-200); padding: 16px 20px; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h3 style="margin-bottom: 4px;">{{ conv.name ?: 'Conversation #' ~ conv.id }}</h3>
                        <span style="font-size: 12px; color: var(--gray-400);">{{ conv.type }}</span>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="btn btn-primary" style="padding: 6px 16px;">View</a>
                        
                        <!-- Unarchive Button -->
                        <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="btn btn-outline" style="padding: 6px 16px;">📤 Unarchive</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <!-- Rename Modal -->
    <div id="renameModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div style="background: white; border-radius: 16px; padding: 24px; width: 400px; max-width: 90%;">
            <h3 style="margin-bottom: 16px;">Rename Conversation</h3>
            <input type="text" id="renameInput" style="width: 100%; padding: 12px; border: 1px solid var(--gray-200); border-radius: 8px; margin-bottom: 16px;">
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button onclick="closeRenameModal()" style="padding: 8px 16px; border: 1px solid var(--gray-200); background: white; border-radius: 8px; cursor: pointer;">Cancel</button>
                <button onclick="submitRename()" style="padding: 8px 16px; background: var(--blue-primary); color: white; border: none; border-radius: 8px; cursor: pointer;">Save</button>
            </div>
            <form id="renameForm" method="POST" style="display: none;">
                <input type="hidden" name="name" id="renameFormName">
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; align-items: center; justify-content: center;">
        <div style="background: white; border-radius: 16px; padding: 32px; max-width: 400px; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
            <h2 style="margin: 0 0 16px 0; font-size: 18px; color: #1f2937;">Delete Conversation</h2>
            <p style="color: #6b7280; margin: 0 0 24px 0;">Are you sure you want to delete this conversation and all messages? This cannot be undone.</p>
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" onclick="closeDeleteModal()" class="btn" style="padding: 8px 16px; background: #e5e7eb; color: #1f2937; border: none; border-radius: 8px; cursor: pointer;">Cancel</button>
                <button type="button" onclick="submitDelete()" class="btn" style="padding: 8px 16px; background: #ef4444; color: white; border: none; border-radius: 8px; cursor: pointer;">Delete</button>
            </div>
        </div>
    </div>

    <script>
        let currentConversationId = null;
        let deleteConversationId = null;
        
        function renameConversation(id, currentName) {
            currentConversationId = id;
            document.getElementById('renameInput').value = currentName;
            document.getElementById('renameModal').style.display = 'flex';
        }
        
        function closeRenameModal() {
            document.getElementById('renameModal').style.display = 'none';
            currentConversationId = null;
        }
        
        function submitRename() {
            if (currentConversationId) {
                const newName = document.getElementById('renameInput').value;
                const form = document.getElementById('renameForm');
                form.action = '{{ path("messaging_conversation_rename", {id: 0}) }}'.replace('0', currentConversationId);
                document.getElementById('renameFormName').value = newName;
                form.submit();
            }
        }
        
        function prepareDeleteConversation(id) {
            deleteConversationId = id;
            document.getElementById('deleteModal').style.display = 'flex';
        }
        
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            deleteConversationId = null;
        }
        
        function submitDelete() {
            if (deleteConversationId) {
                const form = document.getElementById('deleteForm_' + deleteConversationId);
                if (form) {
                    form.submit();
                }
            }
            closeDeleteModal();
        }
        
        // Close modals when clicking outside
        document.getElementById('renameModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeRenameModal();
            }
        });
        
        document.getElementById('deleteModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });
    </script>
</div>
{% endblock %}