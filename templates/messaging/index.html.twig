{% extends 'base.html.twig' %}

{% block title %}Messaging - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
{% endblock %}

{% block content %}
<div class="msg-page">
<div class="page-hero" style="background: linear-gradient(180deg, #2144b8 0%, #1d49cf 58%, #1e4ed8 100%); color: #ffffff; border-bottom: 1px solid rgba(255,255,255,0.14); padding: 92px 40px 84px; text-align: center;">
    <div class="page-hero-content">
        <span class="page-hero-icon" style="display: inline-flex; width: 54px; height: 54px; align-items: center; justify-content: center; border-radius: 999px; margin-bottom: 18px; background: rgba(255,255,255,0.16); box-shadow: 0 10px 24px rgba(0,0,0,0.12);">💬</span>
        <h1 class="page-hero-title msg-hero-title serif" style="color: #ffffff; margin: 0;">Messaging</h1>
        <p class="page-hero-subtitle" style="color: rgba(255,255,255,0.78); font-size: 16px; margin-top: 12px;">Connect with fellow adventurers</p>
    </div>
</div>

<div class="page-content msg-fade-in">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
        <div>
            <h2 class="msg-section-title">Your Conversations</h2>
            <p class="msg-section-subtitle">Open a thread, pin it, archive it, or rename it in a click.</p>
        </div>
        <a href="{{ path('messaging_conversation_new') }}" class="msg-btn msg-btn-primary">➕ New Conversation</a>
    </div>
    
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Active Conversations -->
    <h3 class="msg-section-title" style="margin: 24px 0 16px 0;">Active</h3>
    {% if conversations is empty %}
        <div class="mp-empty" style="padding: 40px;">
            <div style="font-size: 48px;">💬</div>
            <p>No active conversations. Start a new one!</p>
        </div>
    {% else %}
        <div style="display: flex; flex-direction: column; gap: 12px;">
            {% for conv in conversations %}
                <div class="msg-card msg-card-hover msg-pop-in" style="padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; {% if conv.is_pinned %}border-left: 4px solid #F59E0B;{% endif %}">
                    <div>
                        <h3 class="msg-section-title" style="margin-bottom: 4px; font-size: 1.05rem;">
                            {{ conv.name ?: 'Conversation #' ~ conv.id }}
                            {% if conv.is_pinned %} 📌{% endif %}
                        </h3>
                        <span style="font-size: 12px; color: var(--gray-400);">{{ conv.type }}</span>
                    </div>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="msg-btn msg-btn-primary msg-btn-sm">Open</a>
                        
                        <!-- Pin/Unpin Button -->
                        <form method="POST" action="{{ path('messaging_conversation_pin', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="msg-btn msg-btn-secondary msg-btn-sm" title="{{ conv.is_pinned ? 'Unpin' : 'Pin' }}">
                                {{ conv.is_pinned ? '📌 Unpin' : '📍 Pin' }}
                            </button>
                        </form>
                        
                        <!-- Archive Button -->
                        <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="msg-btn msg-btn-secondary msg-btn-sm" title="Archive">
                                📦 Archive
                            </button>
                        </form>
                        
                        <!-- Rename Button -->
                        <button onclick="renameConversation({{ conv.id }}, '{{ conv.name|e('js') }}')" class="msg-btn msg-btn-secondary msg-btn-sm">✏️ Rename</button>
                        
                        <!-- Delete Button (only for creator) -->
                        {% if conv.user_role == 'CREATOR' %}
                            <form method="POST" id="deleteForm_{{ conv.id }}" action="{{ path('messaging_conversation_delete', {id: conv.id}) }}" style="display: none;">
                            </form>
                            <button type="button" class="msg-btn msg-btn-danger msg-btn-sm" onclick="prepareDeleteConversation({{ conv.id }})">🗑️ Delete</button>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
    
    <!-- Archived Conversations Section -->
    {% if archivedConversations is not empty %}
        <div style="margin: 32px 0 16px 0;">
            <h3 class="msg-section-title">Archived Conversations</h3>
            <p class="msg-section-subtitle">Closed threads stay available here for quick reference.</p>
        </div>
        <div style="display: flex; flex-direction: column; gap: 12px; opacity: 0.78;">
            {% for conv in archivedConversations %}
                <div class="msg-card msg-card-hover msg-fade-in" style="background: #f8fafc; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #d9e3f8;">
                    <div>
                        <h3 class="msg-section-title" style="margin-bottom: 4px; font-size: 1.05rem;">{{ conv.name ?: 'Conversation #' ~ conv.id }}</h3>
                        <span style="font-size: 12px; color: var(--gray-400);">{{ conv.type }}</span>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <a href="{{ path('messaging_conversation_show', {id: conv.id}) }}" class="msg-btn msg-btn-primary msg-btn-sm">View</a>
                        
                        <!-- Unarchive Button -->
                        <form method="POST" action="{{ path('messaging_conversation_archive', {id: conv.id}) }}" style="display: inline;">
                            <button type="submit" class="msg-btn msg-btn-secondary msg-btn-sm">📤 Unarchive</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <!-- Rename Modal -->
    <div id="renameModal" class="msg-modal-backdrop">
        <div class="msg-modal msg-pop-in">
            <div class="msg-modal-head">
                <h3 class="msg-modal-title">Rename Conversation</h3>
            </div>
            <div class="msg-modal-body">
                <input type="text" id="renameInput" class="msg-input">
            </div>
            <div class="msg-modal-actions">
                <button onclick="closeRenameModal()" class="msg-btn msg-btn-secondary">Cancel</button>
                <button onclick="submitRename()" class="msg-btn msg-btn-primary">Save</button>
            </div>
            <form id="renameForm" method="POST" style="display: none;">
                <input type="hidden" name="name" id="renameFormName">
            </form>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div id="deleteModal" class="msg-modal-backdrop" style="z-index: 999;">
        <div class="msg-modal msg-pop-in">
            <div class="msg-modal-head">
                <h2 class="msg-modal-title">Delete Conversation</h2>
            </div>
            <div class="msg-modal-body">
                Are you sure you want to delete this conversation and all messages? This cannot be undone.
            </div>
            <div class="msg-modal-actions">
                <button type="button" onclick="closeDeleteModal()" class="msg-btn msg-btn-secondary">Cancel</button>
                <button type="button" onclick="submitDelete()" class="msg-btn msg-btn-danger">Delete</button>
            </div>
        </div>
    </div>

    <script>
        let currentConversationId = null;
        let deleteConversationId = null;
        
        function renameConversation(id, currentName) {
            currentConversationId = id;
            document.getElementById('renameInput').value = currentName;
            document.getElementById('renameModal').style.display = 'flex';
        }
        
        function closeRenameModal() {
            document.getElementById('renameModal').style.display = 'none';
            currentConversationId = null;
        }
        
        function submitRename() {
            if (currentConversationId) {
                const newName = document.getElementById('renameInput').value;
                const form = document.getElementById('renameForm');
                form.action = '{{ path("messaging_conversation_rename", {id: 0}) }}'.replace('0', currentConversationId);
                document.getElementById('renameFormName').value = newName;
                form.submit();
            }
        }
        
        function prepareDeleteConversation(id) {
            deleteConversationId = id;
            document.getElementById('deleteModal').style.display = 'flex';
        }
        
        function closeDeleteModal() {
            document.getElementById('deleteModal').style.display = 'none';
            deleteConversationId = null;
        }
        
        function submitDelete() {
            if (deleteConversationId) {
                const form = document.getElementById('deleteForm_' + deleteConversationId);
                if (form) {
                    form.submit();
                }
            }
            closeDeleteModal();
        }
        
        // Close modals when clicking outside
        document.getElementById('renameModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeRenameModal();
            }
        });
        
        document.getElementById('deleteModal')?.addEventListener('click', function(e) {
            if (e.target === this) {
                closeDeleteModal();
            }
        });
    </script>
</div>
</div>
{% endblock %}
