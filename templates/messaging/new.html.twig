{% extends 'base.html.twig' %}

{% block title %}New Conversation - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
{% endblock %}

{% block content %}
<div class="msg-page">
<div class="page-hero" style="background: white; color: var(--gray-900); border-bottom: 1px solid var(--gray-200); padding: 30px 40px;">
    <div class="page-hero-content">
        <a href="{{ path('app_messaging') }}" style="color: var(--gray-700); text-decoration: none; display: inline-block; margin-bottom: 16px;">← Back</a>
        <h1 class="page-hero-title">New Conversation</h1>
        <p class="page-hero-subtitle">Start chatting with someone</p>
    </div>
</div>

<div class="page-content">
    <div style="max-width: 500px; margin: 0 auto;">
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}
        
        <form method="POST" id="conversationForm" class="msg-card" style="padding: 32px;">
            <div class="form-group">
                <label class="form-label">Conversation Name</label>
                <input type="text" name="name" class="msg-input" placeholder="e.g., Tunisia Trip" required>
            </div>
            
            <div class="form-group">
                <label class="form-label">Conversation Type</label>
                <select name="type" id="conversationType" class="msg-select" onchange="toggleParticipantFields()">
                    <option value="PERSONAL">Personal (1 person)</option>
                    <option value="GROUP">Group (2+ people)</option>
                </select>
            </div>
            
            <div class="form-group" id="personalFields">
                <label class="form-label">Participant Email</label>
                <input type="email" name="participant_emails[]" class="msg-input" placeholder="friend@example.com">
            </div>
            
            <div id="groupFields" style="display: none;">
                <div class="form-group">
                    <label class="form-label">Participant Emails</label>
                    <div id="participantList">
                        <div class="participant-input" style="display: flex; gap: 8px; margin-bottom: 8px;">
                            <input type="email" name="participant_emails[]" class="msg-input" style="flex: 1;" placeholder="friend1@example.com">
                            <button type="button" class="msg-btn msg-btn-danger msg-btn-sm" onclick="removeParticipant(this)" style="display: none;">❌</button>
                        </div>
                        <div class="participant-input" style="display: flex; gap: 8px; margin-bottom: 8px;">
                            <input type="email" name="participant_emails[]" class="msg-input" style="flex: 1;" placeholder="friend2@example.com">
                            <button type="button" class="msg-btn msg-btn-danger msg-btn-sm" onclick="removeParticipant(this)" style="display: none;">❌</button>
                        </div>
                    </div>
                    <button type="button" onclick="addParticipant()" class="msg-btn msg-btn-secondary" style="margin-top: 8px;">+ Add Another Participant</button>
                </div>
            </div>
            
            <button type="submit" class="msg-btn msg-btn-primary" style="width: 100%;">Create Conversation</button>
        </form>
    </div>
</div>

<script>
    function toggleParticipantFields() {
        const type = document.getElementById('conversationType').value;
        if (type === 'GROUP') {
            document.getElementById('personalFields').style.display = 'none';
            document.getElementById('groupFields').style.display = 'block';
        } else {
            document.getElementById('personalFields').style.display = 'block';
            document.getElementById('groupFields').style.display = 'none';
        }
    }
    
    function addParticipant() {
        const container = document.getElementById('participantList');
        const newDiv = document.createElement('div');
        newDiv.className = 'participant-input';
        newDiv.style.display = 'flex';
        newDiv.style.gap = '8px';
        newDiv.style.marginBottom = '8px';
        newDiv.innerHTML = `
            <input type="email" name="participant_emails[]" class="msg-input" style="flex: 1;" placeholder="newfriend@example.com">
            <button type="button" class="msg-btn msg-btn-danger msg-btn-sm" onclick="removeParticipant(this)">❌</button>
        `;
        container.appendChild(newDiv);
    }
    
    function removeParticipant(btn) {
        btn.parentElement.remove();
    }
</script>
</div>
{% endblock %}