{% extends 'base.html.twig' %}

{% block title %}Conversation Participants - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
{% endblock %}

{% block content %}
<div class="msg-page">
<div class="page-hero" style="background: linear-gradient(180deg, #2144b8 0%, #1d49cf 58%, #1e4ed8 100%); color: #ffffff; border-bottom: 1px solid rgba(255,255,255,0.14); padding: 92px 40px 84px; text-align: center;">
    <div class="page-hero-content">
        <span class="page-hero-icon" style="display: inline-flex; width: 54px; height: 54px; align-items: center; justify-content: center; border-radius: 999px; margin-bottom: 18px; background: rgba(255,255,255,0.16); box-shadow: 0 10px 24px rgba(0,0,0,0.12);">👥</span>
        <h1 class="page-hero-title msg-hero-title serif" style="color: #ffffff; margin: 0;">Conversation Participants</h1>
        <p class="page-hero-subtitle" style="color: rgba(255,255,255,0.78); font-size: 16px; margin-top: 12px;">Manage members in this group</p>
    </div>
</div>

<div class="page-content msg-fade-in" style="max-width: 800px;">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Leave Button (for non-creator members) - Top Position -->
    {% if userRole != 'CREATOR' %}
        <div style="margin-bottom: 24px;">
            <button type="button" class="msg-btn msg-btn-warning" onclick="openConfirmModal('leave')">🚪 Leave Conversation</button>
        </div>
    {% endif %}
    
    <!-- Add Participant (only for CREATOR/ADMIN) -->
    {% if userRole == 'CREATOR' or userRole == 'ADMIN' %}
        <div class="msg-card msg-card-hover" style="padding: 24px; margin-bottom: 24px;">
            <h3 class="msg-admin-title" style="margin-bottom: 6px; font-size: 1.5rem;">Add New Participant</h3>
            <p class="msg-section-subtitle" style="margin-bottom: 16px;">Invite someone by email and manage the conversation together.</p>
            <form method="POST" action="{{ path('messaging_conversation_add_participant', {id: conversationId}) }}" style="display: flex; gap: 12px;">
                <input type="email" name="email" placeholder="user@example.com" class="msg-input" style="flex: 1;" required>
                <button type="submit" class="msg-btn msg-btn-primary">➕ Add</button>
            </form>
        </div>
    {% endif %}
    
    <!-- Participants List -->
    <div class="msg-card msg-card-hover" style="overflow: hidden;">
        <div style="padding: 16px 20px; background: #eff4ff; border-bottom: 1px solid var(--gray-200);">
            <strong>Members ({{ participants|length }})</strong>
        </div>
        
        {% for participant in participants %}
            <div class="msg-fade-in" style="padding: 16px 20px; border-bottom: 1px solid var(--gray-100); display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <div style="font-weight: 700; color: var(--msg-text);">
                        {{ participant.full_name ?: 'User ' ~ participant.user_id|slice(0,8) }}
                        {% if participant.user_id == currentUserId %}
                            <span style="font-size: 11px; background: var(--gray-100); padding: 2px 8px; border-radius: 12px; margin-left: 8px;">(You)</span>
                        {% endif %}
                    </div>
                    <div style="font-size: 12px; color: var(--gray-400);">
                        {{ participant.email }}
                        {% if participant.role == 'CREATOR' %}
                            <span style="color: #d4af37; margin-left: 8px;">👑 Creator</span>
                        {% elseif participant.role == 'ADMIN' %}
                            <span style="color: #2d7a2d; margin-left: 8px;">🔧 Admin</span>
                        {% else %}
                            <span style="color: #666; margin-left: 8px;">👤 Member</span>
                        {% endif %}
                    </div>
                </div>
                
                <div style="display: flex; gap: 8px;">
                    {% if participant.user_id != currentUserId %}
                        <!-- Promote/Demote (only CREATOR) -->
                        {% if userRole == 'CREATOR' and participant.role != 'CREATOR' %}
                            {% if participant.role == 'ADMIN' %}
                                <form method="POST" action="{{ path('messaging_conversation_demote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="msg-btn msg-btn-secondary msg-btn-sm">⬇ Demote</button>
                                </form>
                            {% else %}
                                <form method="POST" action="{{ path('messaging_conversation_promote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="msg-btn msg-btn-secondary msg-btn-sm">⬆ Promote to Admin</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        
                        <!-- Remove (only CREATOR/ADMIN, cannot remove CREATOR) -->
                        {% if (userRole == 'CREATOR' or userRole == 'ADMIN') and participant.role != 'CREATOR' %}
                            <form method="POST" id="removeForm_{{ participant.user_id }}" action="{{ path('messaging_conversation_remove_participant', {id: conversationId, userId: participant.user_id}) }}" style="display: none;">
                            </form>
                            <button type="button" class="msg-btn msg-btn-danger msg-btn-sm" onclick="prepareRemoveParticipant('{{ participant.user_id }}')">❌ Remove</button>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
    
    <div style="margin-top: 24px; text-align: center;">
        <a href="{{ path('messaging_conversation_show', {id: conversationId}) }}" class="msg-btn msg-btn-primary">← Back to Chat</a>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirmModal" class="msg-modal-backdrop">
    <div class="msg-modal msg-pop-in">
        <div class="msg-modal-head">
            <h2 id="modalTitle" class="msg-modal-title">Confirm Action</h2>
        </div>
        <div id="modalMessage" class="msg-modal-body">Are you sure?</div>
        <div class="msg-modal-actions">
            <button type="button" onclick="closeConfirmModal()" class="msg-btn msg-btn-secondary">Cancel</button>
            <button type="button" id="confirmButton" onclick="submitConfirmAction()" class="msg-btn msg-btn-danger">Confirm</button>
        </div>
    </div>
</div>

<script>
    let currentAction = null;
    let conversationId = '{{ conversationId }}';
    let removeTargetUserId = null;
    
    function openConfirmModal(action) {
        currentAction = action;
        const modal = document.getElementById('confirmModal');
        const title = document.getElementById('modalTitle');
        const message = document.getElementById('modalMessage');
        const confirmBtn = document.getElementById('confirmButton');
        
        if (action === 'leave') {
            title.textContent = 'Leave Conversation';
            message.textContent = 'Are you sure you want to leave this conversation? You won\'t be able to see new messages.';
            confirmBtn.style.background = '#F59E0B';
        } else if (action === 'remove') {
            title.textContent = 'Remove Participant';
            message.textContent = 'Are you sure you want to remove this participant?';
            confirmBtn.style.background = '#ef4444';
        }
        
        modal.style.display = 'flex';
    }
    
    function prepareRemoveParticipant(userId) {
        removeTargetUserId = userId;
        openConfirmModal('remove');
    }
    
    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.style.display = 'none';
        currentAction = null;
        removeTargetUserId = null;
    }
    
    function submitConfirmAction() {
        if (currentAction === 'leave') {
            // Submit leave form
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path('messaging_conversation_leave', {id: conversationId}) }}';
            document.body.appendChild(form);
            form.submit();
        } else if (currentAction === 'remove') {
            // Get the userId from the modal context and submit remove form
            const form = document.getElementById('removeForm_' + removeTargetUserId);
            if (form) {
                form.submit();
            }
        }
        closeConfirmModal();
    }
    
    // Close modal when clicking outside
    document.addEventListener('click', function(event) {
        const modal = document.getElementById('confirmModal');
        if (event.target === modal) {
            closeConfirmModal();
        }
    });
</script>
</div>
{% endblock %}
