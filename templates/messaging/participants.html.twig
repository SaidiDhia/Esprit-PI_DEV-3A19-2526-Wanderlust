{% extends 'base.html.twig' %}

{% block title %}Conversation Participants - WanderLust{% endblock %}

{% block content %}
<div class="page-hero" style="padding: 30px 40px;">
    <div class="page-hero-content">
        <a href="{{ path('app_messaging') }}" style="color: white; text-decoration: none; display: inline-block; margin-bottom: 16px;">← Back to conversations</a>
        <h1 class="page-hero-title">Conversation Participants</h1>
        <p class="page-hero-subtitle">Manage members in this group</p>
    </div>
</div>

<div class="page-content" style="max-width: 800px;">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Leave Button (for non-creator members) - Top Position -->
    {% if userRole != 'CREATOR' %}
        <div style="margin-bottom: 24px;">
            <button type="button" class="btn" style="padding: 8px 16px; background: #F59E0B; color: white; border: none; border-radius: 8px; cursor: pointer;" onclick="openConfirmModal('leave')">🚪 Leave Conversation</button>
        </div>
    {% endif %}
    
    <!-- Add Participant (only for CREATOR/ADMIN) -->
    {% if userRole == 'CREATOR' or userRole == 'ADMIN' %}
        <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 24px; margin-bottom: 24px;">
            <h3 style="margin-bottom: 16px;">Add New Participant</h3>
            <form method="POST" action="{{ path('messaging_conversation_add_participant', {id: conversationId}) }}" style="display: flex; gap: 12px;">
                <input type="email" name="email" placeholder="user@example.com" class="form-input" style="flex: 1;" required>
                <button type="submit" class="btn btn-primary">➕ Add</button>
            </form>
        </div>
    {% endif %}
    
    <!-- Participants List -->
    <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); overflow: hidden;">
        <div style="padding: 16px 20px; background: var(--gray-50); border-bottom: 1px solid var(--gray-200);">
            <strong>Members ({{ participants|length }})</strong>
        </div>
        
        {% for participant in participants %}
            <div style="padding: 16px 20px; border-bottom: 1px solid var(--gray-100); display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <div style="font-weight: 600;">
                        {{ participant.full_name ?: 'User ' ~ participant.user_id|slice(0,8) }}
                        {% if participant.user_id == '123e4567-e89b-12d3-a456-426614174000' %}
                            <span style="font-size: 11px; background: var(--gray-100); padding: 2px 8px; border-radius: 12px; margin-left: 8px;">(You)</span>
                        {% endif %}
                    </div>
                    <div style="font-size: 12px; color: var(--gray-400);">
                        {{ participant.email }}
                        {% if participant.role == 'CREATOR' %}
                            <span style="color: #d4af37; margin-left: 8px;">👑 Creator</span>
                        {% elseif participant.role == 'ADMIN' %}
                            <span style="color: #2d7a2d; margin-left: 8px;">🔧 Admin</span>
                        {% else %}
                            <span style="color: #666; margin-left: 8px;">👤 Member</span>
                        {% endif %}
                    </div>
                </div>
                
                <div style="display: flex; gap: 8px;">
                    {% if participant.user_id != '123e4567-e89b-12d3-a456-426614174000' %}
                        <!-- Promote/Demote (only CREATOR) -->
                        {% if userRole == 'CREATOR' and participant.role != 'CREATOR' %}
                            {% if participant.role == 'ADMIN' %}
                                <form method="POST" action="{{ path('messaging_conversation_demote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="btn btn-outline" style="padding: 4px 12px; font-size: 12px;">⬇ Demote</button>
                                </form>
                            {% else %}
                                <form method="POST" action="{{ path('messaging_conversation_promote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="btn btn-outline" style="padding: 4px 12px; font-size: 12px;">⬆ Promote to Admin</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        
                        <!-- Remove (only CREATOR/ADMIN, cannot remove CREATOR) -->
                        {% if (userRole == 'CREATOR' or userRole == 'ADMIN') and participant.role != 'CREATOR' %}
                            <form method="POST" id="removeForm_{{ participant.user_id }}" action="{{ path('messaging_conversation_remove_participant', {id: conversationId, userId: participant.user_id}) }}" style="display: none;">
                            </form>
                            <button type="button" class="btn" style="padding: 4px 12px; font-size: 12px; background: #EF4444; color: white; border: none; border-radius: 8px; cursor: pointer;" onclick="prepareRemoveParticipant('{{ participant.user_id }}')">❌ Remove</button>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
    
    <div style="margin-top: 24px; text-align: center;">
        <a href="{{ path('messaging_conversation_show', {id: conversationId}) }}" class="btn btn-primary">← Back to Chat</a>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirmModal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div style="background: white; border-radius: 16px; padding: 32px; max-width: 400px; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
        <h2 id="modalTitle" style="margin: 0 0 16px 0; font-size: 18px; color: #1f2937;">Confirm Action</h2>
        <p id="modalMessage" style="color: #6b7280; margin: 0 0 24px 0;">Are you sure?</p>
        <div style="display: flex; gap: 12px; justify-content: flex-end;">
            <button type="button" onclick="closeConfirmModal()" class="btn" style="padding: 8px 16px; background: #e5e7eb; color: #1f2937; border: none; border-radius: 8px; cursor: pointer;">Cancel</button>
            <button type="button" id="confirmButton" onclick="submitConfirmAction()" class="btn" style="padding: 8px 16px; background: #ef4444; color: white; border: none; border-radius: 8px; cursor: pointer;">Confirm</button>
        </div>
    </div>
</div>

<script>
    let currentAction = null;
    let conversationId = '{{ conversationId }}';
    let removeTargetUserId = null;
    
    function openConfirmModal(action) {
        currentAction = action;
        const modal = document.getElementById('confirmModal');
        const title = document.getElementById('modalTitle');
        const message = document.getElementById('modalMessage');
        const confirmBtn = document.getElementById('confirmButton');
        
        if (action === 'leave') {
            title.textContent = 'Leave Conversation';
            message.textContent = 'Are you sure you want to leave this conversation? You won\'t be able to see new messages.';
            confirmBtn.style.background = '#F59E0B';
        } else if (action === 'remove') {
            title.textContent = 'Remove Participant';
            message.textContent = 'Are you sure you want to remove this participant?';
            confirmBtn.style.background = '#ef4444';
        }
        
        modal.style.display = 'flex';
    }
    
    function prepareRemoveParticipant(userId) {
        removeTargetUserId = userId;
        openConfirmModal('remove');
    }
    
    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.style.display = 'none';
        currentAction = null;
        removeTargetUserId = null;
    }
    
    function submitConfirmAction() {
        if (currentAction === 'leave') {
            // Submit leave form
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path('messaging_conversation_leave', {id: conversationId}) }}';
            document.body.appendChild(form);
            form.submit();
        } else if (currentAction === 'remove') {
            // Get the userId from the modal context and submit remove form
            const form = document.getElementById('removeForm_' + removeTargetUserId);
            if (form) {
                form.submit();
            }
        }
        closeConfirmModal();
    }
    
    // Close modal when clicking outside
    document.addEventListener('click', function(event) {
        const modal = document.getElementById('confirmModal');
        if (event.target === modal) {
            closeConfirmModal();
        }
    });
</script>
{% endblock %}
