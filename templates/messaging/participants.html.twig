{% extends 'base.html.twig' %}

{% block title %}Conversation Participants - WanderLust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% include 'messaging/_ui_theme.html.twig' %}
    <style>
        .participants-wrap {
            max-width: 980px;
            margin: 0 auto 60px;
        }

        .participants-hero {
            position: relative;
            background: url('{{ asset('adventure/img/winter-silence-peaceful-snowy-landscape-message-serene-winter-scene-featuring-large-tree-covered-frost-standing-376930438.png') }}') center/cover no-repeat;
            color: #f8fafc;
            margin-top: -96px;
            padding: 116px 0 16px;
            margin-bottom: 30px;
            border-bottom: 1px solid rgba(148, 163, 184, 0.35);
            overflow: hidden;
        }

        .participants-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(180deg, rgba(15, 23, 42, 0.36), rgba(15, 23, 42, 0.22)),
                radial-gradient(circle at 72% 20%, rgba(79, 70, 229, 0.16), transparent 36%);
        }

        .participants-hero .participants-wrap {
            position: relative;
            z-index: 1;
        }

        .participants-hero h1 {
            color: #f8fafc;
            margin-bottom: 4px;
            font-size: clamp(1.9rem, 3.6vw, 2.6rem);
            line-height: 1.08;
            text-shadow: 0 10px 28px rgba(15, 23, 42, 0.35);
        }

        .participants-hero p {
            margin-bottom: 0;
            color: rgba(241, 245, 249, 0.9);
            font-size: 15px;
        }

        .participants-panel {
            background: linear-gradient(180deg, #ffffff, #fbfdff);
            border: 1px solid #d6e0ea;
            border-radius: 20px;
            box-shadow: 0 20px 42px rgba(15, 23, 42, 0.13);
            overflow: hidden;
        }

        .participants-back-link {
            color: #e2e8f0;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .participants-back-link:hover {
            color: #ffffff;
        }

        .participants-add-form {
            display: flex;
            gap: 12px;
        }

        .participants-you-chip {
            font-size: 11px;
            background: var(--gray-100);
            padding: 2px 8px;
            border-radius: 12px;
            margin-left: 8px;
        }

        @media (max-width: 640px) {
            .participants-add-form {
                flex-wrap: wrap;
            }

            .participants-add-form .btn {
                width: 100%;
            }
        }

        .participants-panel .msg-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 16px;
            border-bottom: 1px solid #eef2f7;
        }

        .participants-panel .msg-row:last-child {
            border-bottom: none;
        }
    </style>
{% endblock %}

{% block content %}
<section class="participants-hero">
    <div class="container participants-wrap" style="margin-bottom:0;">
        <a href="{{ path('app_messaging') }}" class="participants-back-link">← Back to conversations</a>
        <h1>Conversation Participants</h1>
        <p>Manage members in this group</p>
    </div>
</section>

<div class="container participants-wrap">
    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}
    
    <!-- Leave Button (for non-creator members) - Top Position -->
    {% if userRole != 'CREATOR' %}
        <div style="margin-bottom: 24px;">
            <button type="button" class="btn msg-btn-warning" onclick="openConfirmModal('leave')">🚪 Leave Conversation</button>
        </div>
    {% endif %}
    
    <!-- Add Participant (only for CREATOR/ADMIN) -->
    {% if userRole == 'CREATOR' or userRole == 'ADMIN' %}
        <div class="participants-panel" style="padding: 18px; margin-bottom: 20px;">
            <h3 style="margin-bottom: 16px;">Add New Participant</h3>
            <form method="POST" action="{{ path('messaging_conversation_add_participant', {id: conversationId}) }}" class="participants-add-form">
                <input type="email" name="email" placeholder="user@example.com" class="form-input" style="flex: 1;" required>
                <button type="submit" class="btn btn-primary">➕ Add</button>
            </form>
        </div>
    {% endif %}
    
    <!-- Participants List -->
    <div class="participants-panel">
        <div class="msg-card-list-head">
            <strong>Members ({{ participants|length }})</strong>
        </div>
        
        {% for participant in participants %}
            <div class="msg-row">
                <div>
                    <div class="msg-row-title">
                        {{ participant.full_name ?: 'User ' ~ participant.user_id|slice(0,8) }}
                        {% if participant.user_id == currentUserId %}
                            <span class="participants-you-chip">(You)</span>
                        {% endif %}
                    </div>
                    <div class="msg-row-subtitle">
                        {{ participant.email }}
                        {% if participant.role == 'CREATOR' %}
                            <span style="color: #d4af37; margin-left: 8px;">👑 Creator</span>
                        {% elseif participant.role == 'ADMIN' %}
                            <span style="color: #2d7a2d; margin-left: 8px;">🔧 Admin</span>
                        {% else %}
                            <span style="color: #666; margin-left: 8px;">👤 Member</span>
                        {% endif %}
                    </div>
                </div>
                
                <div class="msg-actions-tight">
                    {% if participant.user_id != currentUserId %}
                        <!-- Promote/Demote (only CREATOR) -->
                        {% if userRole == 'CREATOR' and participant.role != 'CREATOR' %}
                            {% if participant.role == 'ADMIN' %}
                                <form method="POST" action="{{ path('messaging_conversation_demote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="btn btn-outline msg-btn-sm">⬇ Demote</button>
                                </form>
                            {% else %}
                                <form method="POST" action="{{ path('messaging_conversation_promote', {id: conversationId, userId: participant.user_id}) }}">
                                    <button type="submit" class="btn btn-outline msg-btn-sm">⬆ Promote to Admin</button>
                                </form>
                            {% endif %}
                        {% endif %}
                        
                        <!-- Remove (only CREATOR/ADMIN, cannot remove CREATOR) -->
                        {% if (userRole == 'CREATOR' or userRole == 'ADMIN') and participant.role != 'CREATOR' %}
                            <form method="POST" id="removeForm_{{ participant.user_id }}" action="{{ path('messaging_conversation_remove_participant', {id: conversationId, userId: participant.user_id}) }}" style="display: none;">
                            </form>
                            <button type="button" class="btn msg-btn-danger msg-btn-sm" onclick="prepareRemoveParticipant('{{ participant.user_id }}')">❌ Remove</button>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>
    
    <div class="msg-center-action">
        <a href="{{ path('messaging_conversation_show', {id: conversationId}) }}" class="btn btn-primary">← Back to Chat</a>
    </div>
</div>

<!-- Confirmation Modal -->
<div id="confirmModal" class="msg-dialog-backdrop">
    <div class="msg-dialog" style="padding: 32px; max-width: 400px; box-shadow: 0 10px 40px rgba(0,0,0,0.2);">
        <h2 id="modalTitle" class="msg-dialog-title">Confirm Action</h2>
        <p id="modalMessage" class="msg-dialog-text">Are you sure?</p>
        <div class="msg-dialog-actions">
            <button type="button" onclick="closeConfirmModal()" class="btn msg-btn-neutral-compact">Cancel</button>
            <button type="button" id="confirmButton" onclick="submitConfirmAction()" class="btn msg-btn-danger-compact">Confirm</button>
        </div>
    </div>
</div>

<script>
    let currentAction = null;
    let conversationId = '{{ conversationId }}';
    let removeTargetUserId = null;
    
    function openConfirmModal(action) {
        currentAction = action;
        const modal = document.getElementById('confirmModal');
        const title = document.getElementById('modalTitle');
        const message = document.getElementById('modalMessage');
        const confirmBtn = document.getElementById('confirmButton');
        
        if (action === 'leave') {
            title.textContent = 'Leave Conversation';
            message.textContent = 'Are you sure you want to leave this conversation? You won\'t be able to see new messages.';
            confirmBtn.style.background = '#F59E0B';
        } else if (action === 'remove') {
            title.textContent = 'Remove Participant';
            message.textContent = 'Are you sure you want to remove this participant?';
            confirmBtn.style.background = '#ef4444';
        }
        
        modal.style.display = 'flex';
    }
    
    function prepareRemoveParticipant(userId) {
        removeTargetUserId = userId;
        openConfirmModal('remove');
    }
    
    function closeConfirmModal() {
        const modal = document.getElementById('confirmModal');
        modal.style.display = 'none';
        currentAction = null;
        removeTargetUserId = null;
    }
    
    function submitConfirmAction() {
        if (currentAction === 'leave') {
            // Submit leave form
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path('messaging_conversation_leave', {id: conversationId}) }}';
            document.body.appendChild(form);
            form.submit();
        } else if (currentAction === 'remove') {
            // Get the userId from the modal context and submit remove form
            const form = document.getElementById('removeForm_' + removeTargetUserId);
            if (form) {
                form.submit();
            }
        }
        closeConfirmModal();
    }
    
    // Close modal when clicking outside
    document.addEventListener('click', function(event) {
        const modal = document.getElementById('confirmModal');
        if (event.target === modal) {
            closeConfirmModal();
        }
    });
</script>
{% endblock %}