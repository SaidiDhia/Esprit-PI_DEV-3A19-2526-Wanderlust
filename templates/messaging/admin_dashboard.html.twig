{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard - WanderLust{% endblock %}

{% block content %}
<div class="page-hero" style="background: linear-gradient(135deg, #1e3a8a, #1D4ED8); padding: 30px 40px;">
    <div class="page-hero-content">
        <span class="page-hero-icon">👑</span>
        <h1 class="page-hero-title">Admin Dashboard</h1>
        <p class="page-hero-subtitle">Platform overview and analytics</p>
    </div>
</div>

<div class="page-content" style="max-width: 1200px;">
    
    <!-- Stats Cards -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 32px;">
        <div style="background: white; border-radius: 16px; padding: 24px; text-align: center; border: 1px solid var(--gray-200);">
            <div style="font-size: 36px;">👥</div>
            <div style="font-size: 28px; font-weight: 700; color: var(--blue-primary);">{{ totalUsers }}</div>
            <div style="font-size: 13px; color: var(--gray-400);">Total Users</div>
        </div>
        <div style="background: white; border-radius: 16px; padding: 24px; text-align: center; border: 1px solid var(--gray-200);">
            <div style="font-size: 36px;">💬</div>
            <div style="font-size: 28px; font-weight: 700; color: var(--blue-primary);">{{ totalConversations }}</div>
            <div style="font-size: 13px; color: var(--gray-400);">Total Conversations</div>
        </div>
        <div style="background: white; border-radius: 16px; padding: 24px; text-align: center; border: 1px solid var(--gray-200);">
            <div style="font-size: 36px;">📝</div>
            <div style="font-size: 28px; font-weight: 700; color: var(--blue-primary);">{{ totalMessages }}</div>
            <div style="font-size: 13px; color: var(--gray-400);">Total Messages</div>
        </div>
        <div style="background: white; border-radius: 16px; padding: 24px; text-align: center; border: 1px solid var(--gray-200);">
            <div style="font-size: 36px;">📎</div>
            <div style="font-size: 28px; font-weight: 700; color: var(--blue-primary);">{{ totalMedia }}</div>
            <div style="font-size: 13px; color: var(--gray-400);">Media Files</div>
        </div>
    </div>
    
    <!-- Charts Row -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
        <!-- Conversation Types -->
        <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px;">
            <h3 style="margin-bottom: 16px;">📊 Conversation Types</h3>
            <div style="display: flex; gap: 20px;">
                {% for type in conversationTypes %}
                    <div style="text-align: center;">
                        <div style="font-size: 32px; font-weight: 700; color: var(--blue-primary);">{{ type.count }}</div>
                        <div style="font-size: 12px; color: var(--gray-400);">{{ type.type }}</div>
                    </div>
                {% endfor %}
            </div>
        </div>
        
        <!-- Message Types Distribution -->
        <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px;">
            <h3 style="margin-bottom: 16px;">📁 Message Types</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 15px;">
                {% for type in messageTypes %}
                    <div style="text-align: center;">
                        <div style="font-size: 32px; font-weight: 700; color: var(--blue-primary);">{{ type.count }}</div>
                        <div style="font-size: 12px; color: var(--gray-400);">
                            {% if type.message_type == 'TEXT' %}📝 Text
                            {% elseif type.message_type == 'IMAGE' %}📷 Image
                            {% elseif type.message_type == 'VIDEO' %}🎥 Video
                            {% elseif type.message_type == 'AUDIO' %}🎵 Audio
                            {% else %}📎 File
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    
    <!-- Daily Messages -->
    <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px; margin-bottom: 32px;">
        <h3 style="margin-bottom: 16px;">📈 Messages per Day (Last 7 days)</h3>
        <div style="display: flex; gap: 15px; flex-wrap: wrap;">
            {% for day in messagesPerDay %}
                <div style="text-align: center; flex: 1; min-width: 60px;">
                    <div style="height: 100px; display: flex; flex-direction: column; justify-content: flex-end;">
                        <div style="background: var(--blue-primary); height: {{ (day.count / 20) * 100 }}px; border-radius: 4px; min-height: 4px;"></div>
                    </div>
                    <div style="font-size: 12px; font-weight: 600; margin-top: 8px;">{{ day.count }}</div>
                    <div style="font-size: 10px; color: var(--gray-400);">{{ day.date|date('M d') }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
    
    <!-- Top Conversations -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px;">
        <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px;">
            <h3 style="margin-bottom: 16px;">🏆 Most Active Conversations</h3>
            {% for conv in topConversations %}
                <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--gray-100);">
                    <span>{{ conv.name ?: 'Conversation #' ~ conv.id }}</span>
                    <span style="font-weight: 600; color: var(--blue-primary);">{{ conv.message_count }} messages</span>
                </div>
            {% else %}
                <p style="color: var(--gray-400);">No conversations yet</p>
            {% endfor %}
        </div>
        
        <!-- Top Senders -->
        <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px;">
            <h3 style="margin-bottom: 16px;">⭐ Top Message Senders</h3>
            {% for sender in topSenders %}
                <div style="display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid var(--gray-100);">
                    <span>{{ sender.full_name ?: sender.email }}</span>
                    <span style="font-weight: 600; color: var(--blue-primary);">{{ sender.message_count }} messages</span>
                </div>
            {% else %}
                <p style="color: var(--gray-400);">No messages yet</p>
            {% endfor %}
        </div>
    </div>
    
    <!-- Recent Activity -->
    <div style="background: white; border-radius: 16px; border: 1px solid var(--gray-200); padding: 20px;">
        <h3 style="margin-bottom: 16px;">🕐 Recent Activity</h3>
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid var(--gray-200);">
                        <th style="text-align: left; padding: 8px;">Time</th>
                        <th style="text-align: left; padding: 8px;">User</th>
                        <th style="text-align: left; padding: 8px;">Conversation</th>
                        <th style="text-align: left; padding: 8px;">Content</th>
                    </tr>
                </thead>
                <tbody>
                    {% for activity in recentActivity %}
                        <tr style="border-bottom: 1px solid var(--gray-100);">
                            <td style="padding: 8px; font-size: 12px;">{{ activity.created_at|date('H:i:s') }}</td>
                            <td style="padding: 8px; font-size: 12px;">{{ activity.sender_name ?: activity.sender_id|slice(0,8) }}</td>
                            <td style="padding: 8px; font-size: 12px;">{{ activity.conversation_name ?: '#' ~ activity.conversation_id }}</td>
                            <td style="padding: 8px; font-size: 12px;">
                                {% if activity.message_type == 'TEXT' %}
                                    {{ activity.content|slice(0, 30) }}
                                {% elseif activity.message_type == 'IMAGE' %}
                                    📷 Image
                                {% elseif activity.message_type == 'VIDEO' %}
                                    🎥 Video
                                {% elseif activity.message_type == 'AUDIO' %}
                                    🎵 Audio
                                {% else %}
                                    📎 File
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
