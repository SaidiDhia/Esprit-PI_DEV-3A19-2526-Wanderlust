{% extends 'base.html.twig' %}

{% block title %}Log in - Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.50), rgba(0, 0, 0, 0.50)), url('{{ asset('adventure/img/slider1.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .auth-card {
            max-width: 520px;
            margin: 0 auto 60px;
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 24px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Welcome Back</h1>
        <p class="mb-0">Sign in to continue your Wanderlust journey.</p>
    </div>
</section>

<div class="container">
    <div class="auth-card">
        <h3 class="mb-2">Sign in</h3>
        <p class="text-muted mb-4">Enter your credentials to continue.</p>

        <form method="post">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <div class="form-group">
                <label for="inputEmail">Email Address</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control" placeholder="you@example.com" autocomplete="email" required autofocus>
            </div>

            <div class="form-group">
                <div class="d-flex justify-content-between align-items-center">
                    <label for="inputPassword">Password</label>
                    <a href="{{ path('app_forgot_password_request') }}" class="small">Forgot Password?</a>
                </div>
                <input type="password" name="password" id="inputPassword" class="form-control" placeholder="********" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group form-check mt-3">
                <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                <label class="form-check-label" for="remember_me">Keep me signed in</label>
            </div>

            <button class="primary-btn text-uppercase w-100" style="border:none;" type="submit">Sign in</button>
        </form>

        <p class="text-center mt-4 mb-0">Don't have an account? <a href="{{ path('app_signup') }}">Create one</a></p>
    </div>
</div>
{% endblock %}