{% extends 'base.html.twig' %}

{% block title %}Sign up - Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.52), rgba(0, 0, 0, 0.52)), url('{{ asset('adventure/img/slider2.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .auth-card {
            max-width: 860px;
            margin: 0 auto 60px;
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            padding: 28px;
        }

        .role-option {
            border: 1px solid #e7e7e7;
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all .2s ease;
        }

        .role-option input {
            margin-right: 8px;
        }

        .role-option.active {
            border-color: #ff5e13;
            box-shadow: 0 0 0 2px rgba(255, 94, 19, .12);
        }

        .password-meter {
            height: 6px;
            border-radius: 99px;
            background: #ececec;
            overflow: hidden;
            margin-top: 8px;
        }

        .password-meter span {
            display: block;
            height: 100%;
            width: 0;
            transition: width .2s ease;
        }

        .avatar-preview {
            width: 86px;
            height: 86px;
            border-radius: 50%;
            border: 2px solid #ececec;
            object-fit: cover;
            display: none;
            margin-top: 8px;
        }

        .field-error {
            color: #d93025;
            font-size: .82rem;
            margin-top: .25rem;
        }
    </style>
{% endblock %}

{% block content %}
{% set errors = errors|default({}) %}
{% set old = old|default({}) %}

<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Create Your Account</h1>
        <p class="mb-0">Join Wanderlust and start booking, hosting, and exploring.</p>
    </div>
</section>

<div class="container">
    <div class="auth-card">
        <div class="mb-4">
            <h3 class="mb-2">Sign up</h3>
            <p class="text-muted mb-0">Fill in your details to create your account.</p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <form id="signup-form" method="post" action="{{ path('app_signup') }}" enctype="multipart/form-data" novalidate>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('signup') }}">

            <div class="form-group">
                <label class="d-block">Account type</label>
                {% set selectedRole = old.role|default('PARTICIPANT') %}
                <label class="role-option" data-role-option>
                    <input type="radio" name="role" value="PARTICIPANT" {% if selectedRole == 'PARTICIPANT' %}checked{% endif %}> Traveler (Participant)
                </label>
                <label class="role-option" data-role-option>
                    <input type="radio" name="role" value="HOST" {% if selectedRole == 'HOST' %}checked{% endif %}> Host
                </label>
                {% if errors.role is defined %}<div class="field-error">{{ errors.role }}</div>{% endif %}
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="fullName">Full name</label>
                        <input id="fullName" name="fullName" type="text" class="form-control" value="{{ old.fullName|default('') }}" required>
                        {% if errors.fullName is defined %}<div class="field-error">{{ errors.fullName }}</div>{% endif %}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input id="phone" name="phoneNumber" type="text" class="form-control" value="{{ old.phoneNumber|default('') }}" required>
                        {% if errors.phoneNumber is defined %}<div class="field-error">{{ errors.phoneNumber }}</div>{% endif %}
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" class="form-control" value="{{ old.email|default('') }}" required>
                {% if errors.email is defined %}<div class="field-error">{{ errors.email }}</div>{% endif %}
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input id="password" name="password" type="password" class="form-control" minlength="8" required>
                        <div class="password-meter"><span id="password-meter-fill"></span></div>
                        {% if errors.password is defined %}<div class="field-error">{{ errors.password }}</div>{% endif %}
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="confirmPassword">Confirm password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" class="form-control" minlength="8" required>
                        {% if errors.confirmPassword is defined %}<div class="field-error">{{ errors.confirmPassword }}</div>{% endif %}
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="profilePicture">Profile picture (optional)</label>
                <input id="profilePicture" name="profilePicture" type="file" class="form-control" accept="image/*">
                <img id="avatar-preview" class="avatar-preview" alt="Preview">
                {% if errors.profilePicture is defined %}<div class="field-error">{{ errors.profilePicture }}</div>{% endif %}
            </div>

            <button type="submit" class="primary-btn text-uppercase" style="border:none;">Create account</button>
            <p class="mt-3 mb-0">Already have an account? <a href="{{ path('app_login') }}">Sign in</a></p>
        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    function refreshRoleCards() {
        const options = document.querySelectorAll('[data-role-option]');
        options.forEach((option) => {
            const radio = option.querySelector('input[type="radio"]');
            option.classList.toggle('active', !!(radio && radio.checked));
        });
    }

    function updatePasswordMeter() {
        const password = document.getElementById('password');
        const meter = document.getElementById('password-meter-fill');
        if (!password || !meter) {
            return;
        }

        const value = password.value || '';
        let score = 0;
        if (value.length >= 8) score += 25;
        if (/[A-Z]/.test(value)) score += 25;
        if (/[0-9]/.test(value)) score += 25;
        if (/[^A-Za-z0-9]/.test(value)) score += 25;

        meter.style.width = score + '%';
        meter.style.background = score < 50 ? '#dc3545' : (score < 75 ? '#f0ad4e' : '#28a745');
    }

    function initAvatarPreview() {
        const input = document.getElementById('profilePicture');
        const preview = document.getElementById('avatar-preview');
        if (!input || !preview) {
            return;
        }

        input.addEventListener('change', () => {
            const file = input.files && input.files[0] ? input.files[0] : null;
            if (!file) {
                preview.style.display = 'none';
                preview.removeAttribute('src');
                return;
            }

            const reader = new FileReader();
            reader.onload = (event) => {
                preview.src = event.target.result;
                preview.style.display = 'block';
            };
            reader.readAsDataURL(file);
        });
    }

    function initSignupValidation() {
        const form = document.getElementById('signup-form');
        if (!form) {
            return;
        }

        form.addEventListener('submit', (event) => {
            const password = document.getElementById('password');
            const confirm = document.getElementById('confirmPassword');
            if (password && confirm && password.value !== confirm.value) {
                event.preventDefault();
                confirm.focus();
                alert('Passwords do not match.');
            }
        });
    }

    document.querySelectorAll('[data-role-option] input[type="radio"]').forEach((radio) => {
        radio.addEventListener('change', refreshRoleCards);
    });

    const passwordInput = document.getElementById('password');
    if (passwordInput) {
        passwordInput.addEventListener('input', updatePasswordMeter);
    }

    refreshRoleCards();
    updatePasswordMeter();
    initAvatarPreview();
    initSignupValidation();
    </script>
{% endblock %}