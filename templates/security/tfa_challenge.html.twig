{% extends 'base.html.twig' %}

{% block title %}Two-Factor Verification - Wanderlust{% endblock %}

{% block content %}
<div class="min-h-[calc(100vh-64px)] bg-background flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-lg rounded-2xl border border-border bg-white p-8 shadow-sm">
        <h1 class="text-2xl font-heading font-bold text-foreground">Two-factor verification</h1>
        <p class="mt-2 text-sm text-muted-foreground">
            {% if method.value == 'EMAIL' %}
                Enter the 6-digit code sent to your email.
            {% elseif method.value == 'SMS' %}
                Enter the 6-digit code sent to your phone.
            {% elseif method.value == 'WHATSAPP' %}
                Enter the 6-digit code sent to your WhatsApp.
            {% elseif method.value == 'APP' %}
                Enter the 6-digit code from your authenticator app.
            {% elseif method.value == 'FACE_ID' %}
                Capture a live selfie to verify your face.
            {% endif %}
        </p>

        {% for message in app.flashes('success') %}
            <div class="mt-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm text-emerald-700">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">{{ message }}</div>
        {% endfor %}
        {% if errorMessage %}
            <div class="mt-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm text-rose-700">{{ errorMessage }}</div>
        {% endif %}

        {% if method.value in ['EMAIL', 'SMS', 'WHATSAPP', 'APP'] %}
            <form method="post" class="mt-6 space-y-4">
                <input type="hidden" name="action" value="verify">
                <label for="code" class="block text-xs font-bold uppercase tracking-wider text-muted-foreground">Verification code</label>
                <input id="code" name="code" inputmode="numeric" autocomplete="one-time-code" maxlength="6" required class="w-full rounded-xl border border-border px-4 py-3 text-lg tracking-[0.35em] text-center font-bold text-foreground focus:border-primary focus:outline-none" placeholder="000000">
                <button type="submit" class="w-full rounded-xl bg-primary py-3 font-bold text-white">Verify and continue</button>
            </form>

            {% if method.value in ['SMS', 'WHATSAPP'] and userPhoneNumber %}
                <div class="mt-4 rounded-xl border border-border bg-secondary/20 p-3">
                    <p class="text-xs text-muted-foreground">We sent the code to:</p>
                    <p class="mt-1 text-sm font-semibold text-foreground">{{ userPhoneNumber }}</p>
                </div>
            {% endif %}

            {% if method.value in ['EMAIL', 'SMS', 'WHATSAPP'] %}
                <form method="post" action="{{ path('app_tfa_resend') }}" class="mt-3">
                    <button type="submit" class="w-full rounded-xl border border-border bg-secondary/30 py-2.5 text-sm font-semibold text-foreground hover:bg-secondary/50">Resend code</button>
                </form>
            {% elseif method.value == 'APP' %}
                {% if otpQrCodeUrl %}
                    <div class="mt-4 flex flex-col items-center gap-3 rounded-xl border border-border bg-secondary/20 p-4">
                        <img src="{{ otpQrCodeUrl }}" alt="Authenticator QR code" class="h-52 w-52 rounded-xl border border-border bg-white p-2">
                        <p class="text-xs text-muted-foreground text-center">Scan this QR code in your authenticator app.</p>
                    </div>
                {% endif %}
                {% if otpAuthUri %}
                    <div class="mt-4 rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-xs text-muted-foreground">Manual setup URI:</p>
                        <p class="mt-2 break-all text-xs font-mono text-foreground">{{ otpAuthUri }}</p>
                    </div>
                {% endif %}
            {% endif %}
        {% else %}
            {% if not hasFaceReference %}
                <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-2 text-sm text-amber-700">
                    Face ID is enabled but no reference image exists. Upload a profile or face image in Settings first.
                </div>
            {% endif %}

            <form method="post" class="mt-6 space-y-4" id="face-verify-form">
                <input type="hidden" name="action" value="verify">
                <input type="hidden" name="faceImageData" id="faceImageData">

                <div class="overflow-hidden rounded-xl border border-border">
                    <video id="face-video" class="h-64 w-full bg-slate-100 object-cover" autoplay playsinline muted></video>
                    <canvas id="face-canvas" class="hidden"></canvas>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <button type="button" id="start-camera" class="rounded-xl border border-border bg-secondary/30 py-2.5 text-sm font-semibold text-foreground">Start camera</button>
                    <button type="button" id="capture-face" class="rounded-xl border border-primary bg-primary py-2.5 text-sm font-semibold text-white">Capture selfie</button>
                </div>

                <button type="button" id="retake-face" class="w-full rounded-xl border border-border bg-secondary/30 py-2.5 text-sm font-semibold text-foreground">Retake selfie</button>

                <button type="submit" id="verify-face-submit" class="w-full rounded-xl bg-primary py-3 font-bold text-white" {% if not hasFaceReference %}disabled{% endif %}>Verify face and continue</button>
            </form>

            <script>
                (function () {
                    const video = document.getElementById('face-video');
                    const canvas = document.getElementById('face-canvas');
                    const startBtn = document.getElementById('start-camera');
                    const captureBtn = document.getElementById('capture-face');
                    const retakeBtn = document.getElementById('retake-face');
                    const verifyBtn = document.getElementById('verify-face-submit');
                    const faceInput = document.getElementById('faceImageData');
                    const form = document.getElementById('face-verify-form');

                    if (!video || !canvas || !startBtn || !captureBtn || !retakeBtn || !verifyBtn || !faceInput || !form) {
                        return;
                    }

                    let mediaStream = null;

                    async function startCamera() {
                        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
                            alert('Camera access is not supported in this browser.');
                            return;
                        }

                        try {
                            mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' } });
                            video.srcObject = mediaStream;
                        } catch (error) {
                            alert('Unable to access camera. Please allow camera permission.');
                        }
                    }

                    function captureFace() {
                        if (!video.videoWidth || !video.videoHeight) {
                            alert('Start your camera before capturing.');
                            return;
                        }

                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        const context = canvas.getContext('2d');
                        context.drawImage(video, 0, 0, canvas.width, canvas.height);
                        faceInput.value = canvas.toDataURL('image/jpeg', 0.92);
                        captureBtn.textContent = 'Selfie captured';
                        verifyBtn.disabled = false;
                    }

                    function resetCapture() {
                        faceInput.value = '';
                        captureBtn.textContent = 'Capture selfie';
                        verifyBtn.disabled = true;
                    }

                    startBtn.addEventListener('click', startCamera);
                    captureBtn.addEventListener('click', captureFace);
                    retakeBtn.addEventListener('click', resetCapture);

                    if (faceInput.value === '') {
                        verifyBtn.disabled = true;
                    }

                    form.addEventListener('submit', (event) => {
                        if (!faceInput.value) {
                            event.preventDefault();
                            alert('Please capture your face before verification.');
                        }
                    });
                })();
            </script>
        {% endif %}

        <p class="mt-6 text-center text-xs text-muted-foreground">
            Need to change your 2FA method? Update it in <a href="{{ path('app_settings') }}" class="font-semibold text-primary hover:underline">Settings</a>.
        </p>
    </div>
</div>
{% endblock %}
