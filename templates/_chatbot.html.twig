{# templates/_chatbot.html.twig
   Inclure avec : {% include '_chatbot.html.twig' with { chatContext: 'events' } %}
   chatContext : 'activities' | 'events' | 'reservations'
#}

{# ─────────────────────────────────────────────────────────────────
   STYLES
───────────────────────────────────────────────────────────────── #}
<style>
/* ── Bouton flottant ────────────────────────────────────────────── */
#wander-chat-btn {
    position: fixed;
    bottom: 28px;
    right: 28px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    cursor: pointer;
    box-shadow: 0 8px 25px rgba(102,126,234,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9998;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s;
    animation: chat-pulse 3s ease-in-out infinite;
}
#wander-chat-btn:hover {
    transform: scale(1.12);
    box-shadow: 0 12px 35px rgba(102,126,234,0.7);
    animation: none;
}
#wander-chat-btn svg { width: 28px; height: 28px; fill: #fff; }
@keyframes chat-pulse {
    0%,100% { box-shadow: 0 8px 25px rgba(102,126,234,0.55); }
    50%      { box-shadow: 0 8px 35px rgba(118,75,162,0.75); }
}

/* Notification dot */
#wander-chat-btn::after {
    content: '';
    position: absolute;
    top: 4px; right: 4px;
    width: 12px; height: 12px;
    background: #4ade80;
    border-radius: 50%;
    border: 2px solid #fff;
    animation: dot-blink 2s ease-in-out infinite;
}
@keyframes dot-blink {
    0%,100% { opacity: 1; } 50% { opacity: 0.4; }
}

/* ── Fenêtre chat ───────────────────────────────────────────────── */
#wander-chatbox {
    position: fixed;
    bottom: 100px;
    right: 28px;
    width: 370px;
    max-height: 520px;
    border-radius: 20px;
    background: #0f172a;
    box-shadow: 0 25px 60px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.08);
    display: flex;
    flex-direction: column;
    z-index: 9999;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(0.97);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
#wander-chatbox.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
}

/* Header */
.wchat-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
}
.wchat-avatar {
    width: 42px; height: 42px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
    border: 2px solid rgba(255,255,255,0.4);
}
.wchat-info { flex: 1; }
.wchat-name  { color: #fff; font-weight: 700; font-size: 0.95rem; margin: 0; }
.wchat-status {
    color: rgba(255,255,255,0.8);
    font-size: 0.75rem;
    display: flex; align-items: center; gap: 5px;
}
.wchat-status::before {
    content: '';
    width: 7px; height: 7px;
    background: #4ade80;
    border-radius: 50%;
    display: inline-block;
}
.wchat-close {
    background: rgba(255,255,255,0.15);
    border: none; color: #fff;
    width: 30px; height: 30px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    transition: background 0.2s;
    flex-shrink: 0;
}
.wchat-close:hover { background: rgba(255,255,255,0.28); }

/* Messages */
.wchat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.12) transparent;
}
.wchat-messages::-webkit-scrollbar { width: 4px; }
.wchat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }

/* Bulles */
.wchat-msg {
    max-width: 82%;
    line-height: 1.5;
    font-size: 0.875rem;
    padding: 10px 14px;
    border-radius: 16px;
    word-break: break-word;
    animation: msg-in 0.25s ease;
}
@keyframes msg-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
}
.wchat-msg.bot {
    background: rgba(255,255,255,0.09);
    color: #e2e8f0;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
}
.wchat-msg.user {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: #fff;
    border-bottom-right-radius: 4px;
    align-self: flex-end;
}

/* Typing indicator */
.wchat-typing {
    align-self: flex-start;
    padding: 10px 14px;
    background: rgba(255,255,255,0.09);
    border-radius: 16px;
    border-bottom-left-radius: 4px;
    display: none;
    gap: 4px;
    align-items: center;
}
.wchat-typing.visible { display: flex; }
.wchat-typing span {
    width: 7px; height: 7px;
    background: #94a3b8;
    border-radius: 50%;
    animation: typing-dot 1.2s ease-in-out infinite;
}
.wchat-typing span:nth-child(2) { animation-delay: 0.2s; }
.wchat-typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing-dot {
    0%,80%,100% { transform: scale(0.7); opacity: 0.4; }
    40%          { transform: scale(1);   opacity: 1; }
}

/* Suggestions rapides */
.wchat-suggestions {
    padding: 8px 14px 4px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    flex-shrink: 0;
}
.wchat-suggest-btn {
    background: rgba(102,126,234,0.15);
    border: 1px solid rgba(102,126,234,0.35);
    color: #a5b4fc;
    padding: 5px 10px;
    border-radius: 20px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
}
.wchat-suggest-btn:hover {
    background: rgba(102,126,234,0.3);
    border-color: rgba(102,126,234,0.6);
    color: #c7d2fe;
}

/* Barre d'entrée */
.wchat-input-bar {
    padding: 12px 14px;
    border-top: 1px solid rgba(255,255,255,0.07);
    display: flex;
    gap: 8px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.03);
}
#wchat-input {
    flex: 1;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 22px;
    padding: 9px 16px;
    color: #e2e8f0;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s;
}
#wchat-input::placeholder { color: rgba(255,255,255,0.3); }
#wchat-input:focus { border-color: #667eea; }
#wchat-send {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border: none;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s, opacity 0.2s;
    flex-shrink: 0;
}
#wchat-send:hover { transform: scale(1.08); }
#wchat-send:disabled { opacity: 0.5; cursor: not-allowed; }
#wchat-send svg { width: 18px; height: 18px; fill: #fff; }

/* Responsive mobile */
@media (max-width: 480px) {
    #wander-chatbox { width: calc(100vw - 24px); right: 12px; }
}
</style>

{# ─────────────────────────────────────────────────────────────────
   HTML
───────────────────────────────────────────────────────────────── #}

{# Bouton flottant #}
<button id="wander-chat-btn" onclick="toggleWanderChat()" title="Parler à WanderBot" aria-label="Ouvrir le chatbot WanderBot">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
    </svg>
</button>

{# Fenêtre chatbot #}
<div id="wander-chatbox" role="dialog" aria-label="WanderBot assistant" aria-hidden="true">

    {# Header #}
    <div class="wchat-header">
        <div class="wchat-avatar">🤖</div>
        <div class="wchat-info">
            <p class="wchat-name">WanderBot</p>
            <span class="wchat-status">En ligne · Assistant Wanderlust</span>
        </div>
        <button class="wchat-close" onclick="toggleWanderChat()" title="Fermer" aria-label="Fermer le chatbot">✕</button>
    </div>

    {# Zone messages #}
    <div class="wchat-messages" id="wchat-messages">
        <div class="wchat-msg bot">
            👋 Bonjour ! Je suis <strong>WanderBot</strong>, votre assistant Wanderlust.<br>
            Comment puis-je vous aider aujourd'hui ?
        </div>
    </div>

    {# Indicateur de frappe #}
    <div class="wchat-typing" id="wchat-typing">
        <span></span><span></span><span></span>
    </div>

    {# Suggestions rapides (selon contexte) #}
    <div class="wchat-suggestions" id="wchat-suggestions">
        {% if chatContext == 'activities' %}
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">🏃 Quelles activités proposez-vous ?</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">🌿 Activités en plein air</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">💪 Niveau requis</button>
        {% elseif chatContext == 'events' %}
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">📅 Prochains événements</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">💰 Comment sont calculés les prix ?</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">🎟️ Comment s'inscrire ?</button>
        {% elseif chatContext == 'reservations' %}
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">📋 Statuts de réservation</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">❌ Annuler une réservation</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">💳 Modes de paiement</button>
        {% else %}
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">ℹ️ Comment fonctionne Wanderlust ?</button>
            <button class="wchat-suggest-btn" onclick="wchatSuggest(this)">📞 Contacter le support</button>
        {% endif %}
    </div>

    {# Barre de saisie #}
    <div class="wchat-input-bar">
        <input type="text" id="wchat-input" placeholder="Votre message…"
               maxlength="400" autocomplete="off"
               onkeydown="if(event.key==='Enter' && !event.shiftKey){ event.preventDefault(); wchatSend(); }">
        <button id="wchat-send" onclick="wchatSend()" aria-label="Envoyer">
            <svg viewBox="0 0 24 24"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
        </button>
    </div>
</div>

{# ─────────────────────────────────────────────────────────────────
   JAVASCRIPT
───────────────────────────────────────────────────────────────── #}
<script>
(function () {
    // Config
    const CHAT_CONTEXT = {{ chatContext|default('general')|json_encode|raw }};
    const API_URL      = '/api/ai/chat';
    let chatHistory    = [];
    let isOpen         = false;
    let isSending      = false;

    // ── Toggle ─────────────────────────────────────────────────────
    window.toggleWanderChat = function () {
        const box = document.getElementById('wander-chatbox');
        isOpen = !isOpen;
        box.classList.toggle('open', isOpen);
        box.setAttribute('aria-hidden', String(!isOpen));
        if (isOpen) {
            setTimeout(() => document.getElementById('wchat-input')?.focus(), 300);
        }
    };

    // ── Suggestion rapide ──────────────────────────────────────────
    window.wchatSuggest = function (btn) {
        const text = btn.textContent.replace(/^[\p{Emoji}\s]+/u, '').trim();
        document.getElementById('wchat-input').value = text;
        // Hide suggestions after first use
        document.getElementById('wchat-suggestions').style.display = 'none';
        wchatSend();
    };

    // ── Ajouter un message ─────────────────────────────────────────
    function addMessage(text, role) {
        const msgs = document.getElementById('wchat-messages');
        const div  = document.createElement('div');
        div.className = 'wchat-msg ' + role;
        // Basic markdown-like: **bold**, newlines
        div.innerHTML = text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\n/g, '<br>');
        msgs.appendChild(div);
        msgs.scrollTop = msgs.scrollHeight;
        return div;
    }

    // ── Typing indicator ───────────────────────────────────────────
    function setTyping(visible) {
        const el = document.getElementById('wchat-typing');
        el.classList.toggle('visible', visible);
        if (visible) {
            document.getElementById('wchat-messages').scrollTop = 9999;
        }
    }

    // ── Envoi ──────────────────────────────────────────────────────
    window.wchatSend = async function () {
        if (isSending) return;
        const input = document.getElementById('wchat-input');
        const msg   = input.value.trim();
        if (!msg) return;

        input.value = '';
        document.getElementById('wchat-send').disabled = true;
        isSending = true;

        // Afficher le message utilisateur
        addMessage(msg, 'user');
        chatHistory.push({ role: 'user', content: msg });

        // Loading
        setTyping(true);

        try {
            const res = await fetch(API_URL, {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({
                    message: msg,
                    context: CHAT_CONTEXT,
                    history: chatHistory.slice(-10),
                }),
            });

            const data = await res.json();
            setTyping(false);

            const reply = data.reply || data.error || '😕 Réponse introuvable.';
            addMessage(reply, 'bot');
            chatHistory.push({ role: 'assistant', content: reply });

        } catch (err) {
            setTyping(false);
            addMessage('📡 Problème de connexion. Vérifiez votre réseau.', 'bot');
        } finally {
            isSending = false;
            document.getElementById('wchat-send').disabled = false;
            input.focus();
        }
    };
})();
</script>
