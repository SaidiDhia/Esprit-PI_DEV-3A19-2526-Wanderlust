{% extends 'base.html.twig' %}

{% block body %}
<div class="row">
    <div class="col-md-3">
        <div class="admin-sidebar p-3 rounded">
            <h5 class="text-white">🛡 Admin</h5>
            <ul class="nav flex-column">
                <li class="nav-item"><a href="#posts" class="nav-link active" data-bs-toggle="pill">📄 Posts</a></li>
                <li class="nav-item"><a href="#comments" class="nav-link" data-bs-toggle="pill">💬 Commentaires</a></li>
                <li class="nav-item"><a href="#reactions" class="nav-link" data-bs-toggle="pill">♥ Réactions</a></li>
            </ul>
        </div>
    </div>
    <div class="col-md-9">
        <div class="tab-content">
            <div class="tab-pane fade show active" id="posts">
                <div class="card">
                    <div class="card-header">Toutes les publications</div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead class="admin-table-header">
                                <tr>
                                    <th>#</th>
                                    <th>Contenu</th>
                                    <th>Utilisateur</th>
                                    <th>Statut</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for post in posts %}
                                <tr>
                                    <td>{{ post.idPost }}</td>
                                    <td>{{ post.contenu|slice(0,50) }}…</td>
                                    <td>{{ post.user.email }}</td>
                                    <td>{{ post.statut }}</td>
                                    <td>
                                        <form method="post" action="{{ path('admin_post_delete', {'id': post.idPost}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_delete' ~ post.idPost) }}">
                                            <button class="btn btn-sm btn-danger">🗑</button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="5">Aucun post.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="comments">
                <div class="card">
                    <div class="card-header">Commentaires</div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead class="admin-table-header">
                                <tr>
                                    <th>#</th>
                                    <th>Contenu</th>
                                    <th>Post</th>
                                    <th>Utilisateur</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for comment in comments %}
                                <tr>
                                    <td>{{ comment.idCommentaire }}</td>
                                    <td>{{ comment.contenu|slice(0,50) }}…</td>
                                    <td>{{ comment.post.idPost }}</td>
                                    <td>{{ comment.user.email }}</td>
                                    <td>
                                        <form method="post" action="{{ path('admin_comment_delete', {'id': comment.idCommentaire}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_comment' ~ comment.idCommentaire) }}">
                                            <button class="btn btn-sm btn-danger">🗑</button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="5">Aucun commentaire.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="reactions">
                <div class="card">
                    <div class="card-header">Réactions</div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <thead class="admin-table-header">
                                <tr>
                                    <th>#</th>
                                    <th>Type</th>
                                    <th>Post</th>
                                    <th>Commentaire</th>
                                    <th>Utilisateur</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            {% for reaction in reactions %}
                                <tr>
                                    <td>{{ reaction.idReaction }}</td>
                                    <td>{{ reaction.type }}</td>
                                    <td>{{ reaction.post ? reaction.post.idPost : '-' }}</td>
                                    <td>{{ reaction.commentaire ? reaction.commentaire.idCommentaire : '-' }}</td>
                                    <td>{{ reaction.user.email }}</td>
                                    <td>
                                        <form method="post" action="{{ path('admin_reaction_delete', {'id': reaction.idReaction}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_delete_reaction' ~ reaction.idReaction) }}">
                                            <button class="btn btn-sm btn-danger">🗑</button>
                                        </form>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="6">Aucune réaction.</td></tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}