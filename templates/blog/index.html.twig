{% extends 'base.html.twig' %}

{% block title %}Blog — WanderLust{% endblock %}

{% block content %}

<div class="bg-primary/5 border-b border-border py-12 px-4">
    <div class="container mx-auto text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-2xl mb-4 text-primary text-3xl">📝</div>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-foreground mb-4">Travel Blog</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto">Stories, tips, and guides from travelers who've been there and done that.</p>
    </div>
</div>

<div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Blog 1 -->
        <a href="#" class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-48 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-purple-500/20 flex items-center justify-center text-6xl">🏛️</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-primary">Culture</div>
            </div>
            <div class="p-6">
                <h2 class="font-heading font-bold text-xl mb-3 group-hover:text-primary transition-colors line-clamp-2">7 Days in Carthage: A Journey Through Time</h2>
                <p class="text-muted-foreground text-sm mb-6 line-clamp-3">From the ancient ruins to the vibrant Medina, Carthage offers a layered experience that no history lover should miss.</p>
                <div class="flex items-center justify-between border-t border-border pt-4 text-xs text-muted-foreground">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-foreground">Amira Khelifi</span>
                    </div>
                    <span>March 28, 2026</span>
                </div>
            </div>
        </a>

        <!-- Blog 2 -->
        <a href="#" class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-48 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-amber-500/20 to-red-500/20 flex items-center justify-center text-6xl">🌅</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-primary">Adventure</div>
            </div>
            <div class="p-6">
                <h2 class="font-heading font-bold text-xl mb-3 group-hover:text-primary transition-colors line-clamp-2">Sleeping Under the Sahara Stars</h2>
                <p class="text-muted-foreground text-sm mb-6 line-clamp-3">No phone signal, no city lights — just you, the dunes, and a million stars. My unforgettable overnight desert camping experience.</p>
                <div class="flex items-center justify-between border-t border-border pt-4 text-xs text-muted-foreground">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-foreground">Rami Gharbi</span>
                    </div>
                    <span>March 15, 2026</span>
                </div>
            </div>
        </a>

        <!-- Blog 3 -->
        <a href="#" class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-48 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/20 to-blue-500/20 flex items-center justify-center text-6xl">🍜</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-primary">Food & Drink</div>
            </div>
            <div class="p-6">
                <h2 class="font-heading font-bold text-xl mb-3 group-hover:text-primary transition-colors line-clamp-2">The Ultimate Guide to Tunisian Street Food</h2>
                <p class="text-muted-foreground text-sm mb-6 line-clamp-3">Brik, lablabi, fricassée — discover the must-eat street foods of Tunisia and where to find the best versions.</p>
                <div class="flex items-center justify-between border-t border-border pt-4 text-xs text-muted-foreground">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-foreground">Nadia Smaoui</span>
                    </div>
                    <span>February 20, 2026</span>
                </div>
            </div>
        </a>
    </div>

    <div class="mt-12 text-center">
        <button class="bg-background border border-border hover:border-primary hover:text-primary text-foreground font-bold px-8 py-3 rounded-xl transition-all shadow-sm">
            Load More Stories →
        </button>
    </div>
</div>

{% endblock %}
