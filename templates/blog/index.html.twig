{% extends 'base.html.twig' %}

{% block content %}
<div class="bg-primary/5 border-b border-border py-12 px-4">
    <div class="container mx-auto text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-2xl mb-4 text-primary text-3xl">📝</div>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-foreground mb-4">Travel Blog</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto">Stories, tips, and guides from travelers who've been there and done that.</p>
    </div>
</div>

<div class="container mx-auto px-4 py-12">
    {% if posts|length == 0 %}
        <div class="text-center py-16">
            <p class="text-muted-foreground text-lg mb-6">No posts yet. Be the first to share your story!</p>
            <a href="{{ path('blog_post_new') }}" class="bg-primary hover:bg-primary/90 text-white font-bold px-6 py-3 rounded-xl transition-all inline-block">
                📝 Write Your First Post
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for post in posts %}
            <a href="{{ path('blog_post_show', {'id': post.idPost}) }}" class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
                <div class="relative h-48 overflow-hidden bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center">
                    {% if post.media %}
                        <img src="{{ asset('uploads/' ~ post.media) }}" alt="Post image" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300">
                    {% else %}
                        <div class="text-6xl">📖</div>
                    {% endif %}
                </div>
                <div class="p-6">
                    <div class="flex items-start justify-between mb-3">
                        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-primary/10 text-primary">
                            {{ post.statut == 'private' ? '🔒 Private' : '🌐 Public' }}
                        </span>
                    </div>
                    <h3 class="font-heading font-bold text-lg text-foreground mb-2 line-clamp-2 group-hover:text-primary transition-colors">
                        {{ post.contenu|slice(0, 50) }}{% if post.contenu|length > 50 %}...{% endif %}
                    </h3>
                    <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
                        {{ post.contenu|slice(0, 150) }}{% if post.contenu|length > 150 %}...{% endif %}
                    </p>
                    <div class="flex items-center justify-between pt-4 border-t border-border/50">
                        <div class="text-xs text-muted-foreground">
                            <span class="font-semibold">{{ post.user.fullName }}</span> • {{ post.dateCreation|date('M d, Y') }}
                        </div>
                        <svg class="w-4 h-4 text-primary group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}