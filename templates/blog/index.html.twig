{% extends 'base.html.twig' %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">📄 Publications récentes</h2>
        {% for post in posts %}
            <div class="card-post mb-4 p-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <small class="text-muted">Par {{ post.user.email }} • {{ post.dateCreation|date('d M Y H:i') }}</small>
                        <h5 class="mt-2">{{ post.contenu|slice(0, 100) }}{% if post.contenu|length > 100 %}...{% endif %}</h5>
                    </div>
                    <span class="badge bg-secondary">{{ post.statut == 'private' ? '🔒 Privé' : '🌐 Public' }}</span>
                </div>
                <div class="mt-2">
                    <a href="{{ path('blog_post_show', {'id': post.idPost}) }}" class="btn btn-sm btn-primary-custom">Lire la suite</a>
                </div>
            </div>
        {% else %}
            <div class="text-center py-5"><p class="text-muted">Aucune publication pour le moment.</p></div>
        {% endfor %}
    </div>
</div>
{% endblock %}