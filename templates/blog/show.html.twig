{% extends 'base.html.twig' %}

{% block body %}

{# ── Toast notifications ── #}
<div id="toast-container" class="toast-container"></div>
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="wl-toast-data" data-type="{{ type }}" data-message="{{ message }}"></div>
    {% endfor %}
{% endfor %}

<div class="row justify-content-center">
    <div class="col-md-8">

        {# ── Post card ── #}
        <div class="card-post p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start">
                <div class="flex-grow-1">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="user-avatar-sm">{{ post.user.email|first|upper }}</div>
                        <div>
                            <strong class="d-block" style="font-size:14px">{{ post.user.fullName ?? post.user.email }}</strong>
                            <small class="text-muted">{{ post.dateCreation|date('d M Y · H:i') }}</small>
                        </div>
                    </div>
                    <p class="mt-2 mb-0 post-content">{{ post.contenu }}</p>
                </div>
                <span class="badge-status ms-3">
                    {{ post.statut == 'private' ? '🔒 Privé' : '🌐 Public' }}
                </span>
            </div>

            {# ── Media ── #}
            {% if post.media %}
                <div class="mt-3">
                    {% if post.media matches '/\\.(mp4|avi|mov|mkv)$/i' %}
                        <video controls class="media-display">
                            <source src="{{ asset('uploads/' ~ post.media) }}">
                        </video>
                    {% else %}
                        <img src="{{ asset('uploads/' ~ post.media) }}"
                             class="media-display" alt="Media">
                    {% endif %}
                </div>
            {% endif %}

            <hr class="my-3">

            {# ── Actions bar ── #}
            <div class="d-flex align-items-center gap-3 flex-wrap">

                <button
                    type="button"
                    class="react-btn reaction-post-btn {{ userReaction ? 'reacted' : '' }}"
                    data-url="{{ path('blog_react', {'id': post.idPost, 'type': 'LIKE'}) }}"
                    title="{{ userReaction ? 'Retirer la réaction' : 'J\'aime' }}">
                    <span class="heart-icon">♥</span>
                    <span class="reaction-count">{{ reactionsCount }}</span>
                </button>

                <span class="comment-count-badge">
                    💬 {{ post.commentaires|length }} commentaire{{ post.commentaires|length != 1 ? 's' }}
                </span>

                {# ── Owner / Admin actions ── #}
                {% if currentUser and (currentUser.id == post.user.id or app.session.get('is_admin')) %}
                    <a href="{{ path('blog_post_edit', {'id': post.idPost}) }}"
                       class="btn-action btn-action-edit">✏ Modifier</a>
                    <button type="button"
                            class="btn-action btn-action-delete"
                            onclick="confirmDelete('{{ path('blog_post_delete', {'id': post.idPost}) }}', '{{ csrf_token('delete' ~ post.idPost) }}', 'Supprimer ce post définitivement ?')">
                        🗑 Supprimer
                    </button>
                {% endif %}

            </div>
        </div>

        {# ── New comment form ── #}
        <div class="comment-section-card mb-4">
            <h5 class="section-title">💬 Laisser un commentaire</h5>
            {{ form_start(commentForm, {'attr': {'class': 'comment-form-wrapper', 'novalidate': 'novalidate'}}) }}
                <div class="textarea-wrapper">
                    {{ form_widget(commentForm.contenu, {
                        'attr': {
                            'placeholder': 'Partagez votre avis...',
                            'class': 'wl-textarea',
                            'rows': 3,
                            'maxlength': 500,
                            'id': 'main-comment-textarea'
                        }
                    }) }}
                    <span class="char-counter" id="main-comment-counter">0 / 500</span>
                </div>
                {{ form_errors(commentForm.contenu) }}
                <div class="d-flex justify-content-end mt-2">
                    <button type="submit" class="btn-wl-primary">
                        <span>✉ Publier</span>
                    </button>
                </div>
            {{ form_end(commentForm) }}
        </div>

        {# ── Comments list ── #}
        <div class="comments-list">
            <h5 class="section-title">{{ comments|length }} Commentaire{{ comments|length != 1 ? 's' }}</h5>

            {% for comment in comments %}
                <div class="comment-card mb-3" id="comment-{{ comment.idCommentaire }}">

                    <div class="comment-header">
                        <div class="user-avatar-sm">{{ comment.user.email|first|upper }}</div>
                        <div>
                            <strong>{{ comment.user.fullName ?? comment.user.email }}</strong>
                            <small class="text-muted ms-2">{{ comment.date|date('d M Y · H:i') }}</small>
                        </div>
                    </div>

                    {# ── Comment content (static view) ── #}
                    <div class="comment-body" id="body-{{ comment.idCommentaire }}">
                        <p class="mb-1">{{ comment.contenu }}</p>
                    </div>

                    {# ── Inline edit form (hidden by default) ── #}
                    {% if currentUser and currentUser.id == comment.user.id %}
                    <div class="edit-form-wrapper d-none" id="edit-{{ comment.idCommentaire }}">
                        <form method="post" action="{{ path('blog_comment_edit', {'id': comment.idCommentaire}) }}">
                            <div class="textarea-wrapper">
                                <textarea name="contenu"
                                          class="wl-textarea"
                                          rows="2"
                                          maxlength="500"
                                          data-counter="edit-counter-{{ comment.idCommentaire }}">{{ comment.contenu }}</textarea>
                                <span class="char-counter" id="edit-counter-{{ comment.idCommentaire }}">{{ comment.contenu|length }} / 500</span>
                            </div>
                            <div class="d-flex gap-2 mt-2">
                                <button type="submit" class="btn-wl-primary btn-sm-wl">💾 Enregistrer</button>
                                <button type="button" class="btn-wl-ghost btn-sm-wl"
                                        onclick="cancelEdit({{ comment.idCommentaire }})">Annuler</button>
                            </div>
                        </form>
                    </div>
                    {% endif %}

                    {# ── Comment actions ── #}
                    <div class="comment-actions d-flex gap-2 align-items-center mt-2">
                        <button
                            type="button"
                            class="react-comment-btn {{ comment.reactions|length > 0 ? 'has-reactions' : '' }}"
                            data-url="{{ path('blog_comment_react', {'id': comment.idCommentaire, 'type': 'LIKE'}) }}">
                            ♥ <span class="comment-reaction-count">{{ comment.reactions|length }}</span>
                        </button>

                        {# FIX: pure JS toggle — no Bootstrap collapse dependency #}
                        <button type="button"
                                class="btn-reply-toggle"
                                onclick="toggleReply({{ comment.idCommentaire }})">
                            ↩ Répondre
                        </button>

                        {% if currentUser and currentUser.id == comment.user.id %}
                            <button type="button"
                                    class="btn-edit-comment"
                                    onclick="toggleEdit({{ comment.idCommentaire }})">✏ Modifier</button>
                            <button type="button"
                                    class="btn-delete-comment"
                                    onclick="confirmDelete('{{ path('blog_comment_delete', {'id': comment.idCommentaire}) }}', '{{ csrf_token('delete_comment' ~ comment.idCommentaire) }}', 'Supprimer ce commentaire ?')">
                                🗑
                            </button>
                        {% endif %}
                    </div>

                    {# ── Reply form (hidden by default, toggled with pure JS) ── #}
                    <div class="reply-collapse mt-2" id="reply-{{ comment.idCommentaire }}" style="display:none">
                        <form method="post" action="{{ path('blog_comment_reply', {'id': comment.idCommentaire}) }}"
                              class="reply-form">
                            <div class="textarea-wrapper">
                                <textarea name="contenu" rows="2"
                                          class="wl-textarea wl-textarea-sm"
                                          placeholder="Votre réponse..."
                                          maxlength="500"
                                          data-counter="reply-counter-{{ comment.idCommentaire }}"></textarea>
                                <span class="char-counter" id="reply-counter-{{ comment.idCommentaire }}">0 / 500</span>
                            </div>
                            <div class="d-flex gap-2 mt-2">
                                <button type="submit" class="btn-wl-primary btn-sm-wl">↩ Répondre</button>
                                <button type="button" class="btn-wl-ghost btn-sm-wl"
                                        onclick="toggleReply({{ comment.idCommentaire }})">Annuler</button>
                            </div>
                        </form>
                    </div>

                    {# ── Nested replies ── #}
                    {% for reply in comment.replies %}
                        <div class="reply-card mt-2 ms-4" id="comment-{{ reply.idCommentaire }}">
                            <div class="comment-header">
                                <div class="user-avatar-sm user-avatar-xs">{{ reply.user.email|first|upper }}</div>
                                <div>
                                    <strong style="font-size:13px">{{ reply.user.fullName ?? reply.user.email }}</strong>
                                    <small class="text-muted ms-1">{{ reply.date|date('d M Y · H:i') }}</small>
                                </div>
                            </div>

                            <div class="comment-body" id="body-{{ reply.idCommentaire }}">
                                <p class="mb-1" style="font-size:13px">{{ reply.contenu }}</p>
                            </div>

                            {% if currentUser and currentUser.id == reply.user.id %}
                            <div class="edit-form-wrapper d-none" id="edit-{{ reply.idCommentaire }}">
                                <form method="post" action="{{ path('blog_comment_edit', {'id': reply.idCommentaire}) }}">
                                    <div class="textarea-wrapper">
                                        <textarea name="contenu"
                                                  class="wl-textarea wl-textarea-sm"
                                                  rows="2"
                                                  maxlength="500"
                                                  data-counter="edit-counter-{{ reply.idCommentaire }}">{{ reply.contenu }}</textarea>
                                        <span class="char-counter" id="edit-counter-{{ reply.idCommentaire }}">{{ reply.contenu|length }} / 500</span>
                                    </div>
                                    <div class="d-flex gap-2 mt-1">
                                        <button type="submit" class="btn-wl-primary btn-sm-wl">💾 Enregistrer</button>
                                        <button type="button" class="btn-wl-ghost btn-sm-wl"
                                                onclick="cancelEdit({{ reply.idCommentaire }})">Annuler</button>
                                    </div>
                                </form>
                            </div>
                            {% endif %}

                            <div class="comment-actions d-flex gap-2 align-items-center mt-2">
                                <button
                                    type="button"
                                    class="react-comment-btn"
                                    data-url="{{ path('blog_comment_react', {'id': reply.idCommentaire, 'type': 'LIKE'}) }}">
                                    ♥ <span class="comment-reaction-count">{{ reply.reactions|length }}</span>
                                </button>
                                {% if currentUser and currentUser.id == reply.user.id %}
                                    <button type="button"
                                            class="btn-edit-comment"
                                            onclick="toggleEdit({{ reply.idCommentaire }})">✏ Modifier</button>
                                    <button type="button"
                                            class="btn-delete-comment"
                                            onclick="confirmDelete('{{ path('blog_comment_delete', {'id': reply.idCommentaire}) }}', '{{ csrf_token('delete_comment' ~ reply.idCommentaire) }}', 'Supprimer cette réponse ?')">
                                        🗑
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}

                </div>
            {% else %}
                <div class="empty-comments">
                    <span style="font-size:2rem">💬</span>
                    <p>Aucun commentaire. Soyez le premier !</p>
                </div>
            {% endfor %}
        </div>

    </div>
</div>

{# ── Confirm Delete Modal ── #}
<div class="wl-modal-overlay d-none" id="confirm-modal">
    <div class="wl-modal">
        <div class="wl-modal-icon">🗑</div>
        <h5 class="wl-modal-title" id="confirm-modal-title">Confirmer la suppression</h5>
        <p class="wl-modal-text" id="confirm-modal-text">Êtes-vous sûr ?</p>
        <div class="wl-modal-actions">
            <button type="button" class="btn-wl-ghost" onclick="closeConfirmModal()">Annuler</button>
            <button type="button" class="btn-wl-danger" id="confirm-modal-ok">Supprimer</button>
        </div>
    </div>
</div>

<style>
/* ── Toasts ─────────────────────────────────── */
.toast-container {
    position: fixed; top: 24px; right: 24px; z-index: 9999;
    display: flex; flex-direction: column; gap: 10px; max-width: 360px;
}
.wl-toast {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 14px 18px; border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.14);
    font-size: 14px; font-weight: 500;
    animation: toastIn .35s cubic-bezier(.22,1,.36,1) forwards;
    background: white; border-left: 4px solid;
}
.wl-toast.toast-success { border-color: #10b981; }
.wl-toast.toast-error   { border-color: #ef4444; }
.wl-toast.toast-info    { border-color: var(--blue-primary, #1d4ed8); }
.wl-toast-icon { font-size: 18px; }
.wl-toast-msg  { flex: 1; }
.wl-toast-close {
    background: none; border: none; cursor: pointer;
    color: #9ca3af; font-size: 16px; padding: 0; line-height: 1;
}
@keyframes toastIn {
    from { opacity: 0; transform: translateX(30px); }
    to   { opacity: 1; transform: translateX(0); }
}
@keyframes toastOut {
    from { opacity: 1; transform: translateX(0); }
    to   { opacity: 0; transform: translateX(30px); }
}

/* ── Post styles ───────────────────────────── */
.card-post { background: white; border-radius: 16px; box-shadow: 0 2px 20px rgba(0,0,0,0.07); }
.post-content { font-size: 15px; line-height: 1.65; }
.media-display { width: 100%; max-height: 420px; object-fit: cover; border-radius: 10px; }
.badge-status {
    background: #f0f9ff; color: #0369a1;
    border: 1px solid #bae6fd; border-radius: 20px;
    padding: 4px 12px; font-size: 12px; font-weight: 600; white-space: nowrap;
}
.user-avatar-sm {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    color: white; font-weight: 700; font-size: 14px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.user-avatar-xs { width: 28px; height: 28px; font-size: 11px; }
.comment-header { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }

/* ── Reaction button ───────────────────────── */
.reaction-post-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 16px; border-radius: 20px; border: 2px solid #e5e7eb;
    background: white; cursor: pointer; font-size: 14px; font-weight: 600;
    color: #6b7280; transition: all .2s ease;
}
.reaction-post-btn:hover, .reaction-post-btn.reacted {
    background: #fff1f2; border-color: #fda4af; color: #e11d48;
}
.reaction-post-btn.reacted .heart-icon { animation: heartPop .3s ease; }
@keyframes heartPop {
    0%   { transform: scale(1); }
    50%  { transform: scale(1.4); }
    100% { transform: scale(1); }
}
.comment-count-badge { font-size: 14px; color: #6b7280; }

/* ── Action buttons ────────────────────────── */
.btn-action {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 14px; border-radius: 8px; font-size: 13px;
    font-weight: 600; cursor: pointer; border: none; transition: all .18s ease;
}
.btn-action-edit { background: #f0f9ff; color: #0369a1; text-decoration: none; }
.btn-action-edit:hover { background: #e0f2fe; color: #0284c7; }
.btn-action-delete { background: #fff1f2; color: #be123c; }
.btn-action-delete:hover { background: #ffe4e6; }

/* ── Comment section ───────────────────────── */
.comment-section-card {
    background: white; border-radius: 16px;
    padding: 20px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
}
.comment-card { background: #f8fafc; border-radius: 12px; padding: 14px 16px; border: 1px solid #e2e8f0; }
.reply-card   { background: #f1f5f9; border-radius: 10px; padding: 10px 14px; border: 1px solid #e2e8f0; }
.section-title { font-weight: 700; font-size: 15px; margin-bottom: 14px; color: #1e293b; }

/* ── WL Textarea ───────────────────────────── */
.textarea-wrapper { position: relative; }
.wl-textarea {
    width: 100%; padding: 12px 14px;
    border: 2px solid #e2e8f0; border-radius: 10px;
    font-size: 14px; font-family: inherit;
    resize: vertical; transition: border-color .2s; background: white;
}
.wl-textarea:focus {
    outline: none; border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59,130,246,.12);
}
.wl-textarea-sm { padding: 8px 12px; font-size: 13px; }
.char-counter {
    position: absolute; bottom: 8px; right: 10px;
    font-size: 11px; color: #94a3b8; pointer-events: none;
}

/* ── Buttons ───────────────────────────────── */
.btn-wl-primary {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 20px; border-radius: 8px; border: none;
    background: linear-gradient(135deg, #1d4ed8, #3b82f6);
    color: white; font-weight: 600; font-size: 14px; cursor: pointer; transition: all .2s;
}
.btn-wl-primary:hover {
    background: linear-gradient(135deg, #1e40af, #2563eb);
    transform: translateY(-1px); box-shadow: 0 4px 12px rgba(29,78,216,.3);
}
.btn-wl-ghost {
    display: inline-flex; align-items: center;
    padding: 7px 16px; border-radius: 8px; border: 2px solid #e2e8f0;
    background: white; color: #64748b; font-weight: 600; font-size: 13px;
    cursor: pointer; transition: all .18s;
}
.btn-wl-ghost:hover { border-color: #cbd5e1; background: #f8fafc; }
.btn-wl-danger {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 20px; border-radius: 8px; border: none;
    background: linear-gradient(135deg, #dc2626, #ef4444);
    color: white; font-weight: 600; font-size: 14px; cursor: pointer; transition: all .2s;
}
.btn-wl-danger:hover { background: linear-gradient(135deg, #b91c1c, #dc2626); }
.btn-sm-wl { padding: 6px 12px; font-size: 12px; }

/* ── Comment action buttons ────────────────── */
.react-comment-btn {
    background: none; border: none; cursor: pointer;
    font-size: 13px; color: #94a3b8; padding: 2px 6px;
    border-radius: 6px; transition: all .18s;
}
.react-comment-btn:hover, .react-comment-btn.reacted { color: #e11d48; }
.btn-reply-toggle {
    background: none; border: none; cursor: pointer;
    font-size: 12px; color: #64748b; font-weight: 600;
    padding: 2px 6px; border-radius: 6px; transition: color .18s;
}
.btn-reply-toggle:hover { color: #1d4ed8; }
.btn-edit-comment {
    background: none; border: none; cursor: pointer;
    font-size: 12px; color: #64748b; font-weight: 600;
    padding: 2px 6px; border-radius: 6px; transition: color .18s;
}
.btn-edit-comment:hover { color: #0369a1; }
.btn-delete-comment {
    background: none; border: none; cursor: pointer;
    font-size: 13px; color: #cbd5e1; padding: 2px 6px;
    border-radius: 6px; transition: color .18s;
}
.btn-delete-comment:hover { color: #e11d48; }

/* ── Empty state ───────────────────────────── */
.empty-comments { text-align: center; padding: 40px; color: #94a3b8; }

/* ── Edit form ─────────────────────────────── */
.edit-form-wrapper { padding: 10px 0; }

/* ── Reply form ───────────────────────────── */
.reply-form { background: white; border-radius: 10px; padding: 12px; }

/* ── Confirm Modal ─────────────────────────── */
.wl-modal-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,.45);
    display: flex; align-items: center; justify-content: center;
    animation: fadeIn .2s ease;
}
.wl-modal-overlay.d-none { display: none !important; }
.wl-modal {
    background: white; border-radius: 16px; padding: 32px 28px;
    max-width: 380px; width: 90%; text-align: center;
    box-shadow: 0 20px 60px rgba(0,0,0,.2); animation: slideUp .25s ease;
}
.wl-modal-icon { font-size: 2.4rem; margin-bottom: 10px; }
.wl-modal-title { font-weight: 700; font-size: 18px; margin-bottom: 8px; }
.wl-modal-text  { color: #64748b; font-size: 14px; margin-bottom: 22px; }
.wl-modal-actions { display: flex; gap: 10px; justify-content: center; }
@keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
}
@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}
</style>

<script>
// ─── Toast system ─────────────────────────────────────────────────────────────
function showToast(type, message) {
    const icons = { success: '✅', error: '❌', info: 'ℹ️', warning: '⚠️' };
    const container = document.getElementById('toast-container');
    const toast = document.createElement('div');
    toast.className = `wl-toast toast-${type === 'error' ? 'error' : type === 'success' ? 'success' : 'info'}`;
    toast.innerHTML = `
        <span class="wl-toast-icon">${icons[type] || 'ℹ️'}</span>
        <span class="wl-toast-msg">${message}</span>
        <button class="wl-toast-close" onclick="dismissToast(this.parentElement)">×</button>`;
    container.appendChild(toast);
    setTimeout(() => dismissToast(toast), 4500);
}
function dismissToast(toast) {
    if (!toast || !toast.parentElement) return;
    toast.style.animation = 'toastOut .3s ease forwards';
    setTimeout(() => toast.remove(), 300);
}
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.wl-toast-data').forEach(el => {
        showToast(el.dataset.type, el.dataset.message);
        el.remove();
    });
});

// ─── Confirm delete modal ─────────────────────────────────────────────────────
let _deleteAction = null;
let _deleteToken  = null;
function confirmDelete(url, token, message) {
    _deleteAction = url;
    _deleteToken  = token;
    document.getElementById('confirm-modal-text').textContent = message || 'Cette action est irréversible.';
    document.getElementById('confirm-modal').classList.remove('d-none');
}
function closeConfirmModal() {
    document.getElementById('confirm-modal').classList.add('d-none');
    _deleteAction = null;
    _deleteToken  = null;
}
document.getElementById('confirm-modal-ok').addEventListener('click', function () {
    if (!_deleteAction) return;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = _deleteAction;
    const tokenInput = document.createElement('input');
    tokenInput.type  = 'hidden';
    tokenInput.name  = '_token';
    tokenInput.value = _deleteToken;
    form.appendChild(tokenInput);
    document.body.appendChild(form);
    form.submit();
});
document.getElementById('confirm-modal').addEventListener('click', function (e) {
    if (e.target === this) closeConfirmModal();
});

// ─── Comment inline edit ──────────────────────────────────────────────────────
function toggleEdit(id) {
    document.getElementById('body-' + id).classList.toggle('d-none');
    document.getElementById('edit-' + id).classList.toggle('d-none');
}
function cancelEdit(id) {
    document.getElementById('body-' + id).classList.remove('d-none');
    document.getElementById('edit-' + id).classList.add('d-none');
}

// ─── Reply toggle (pure JS — no Bootstrap collapse needed) ───────────────────
function toggleReply(commentId) {
    const el = document.getElementById('reply-' + commentId);
    if (!el) return;
    const isHidden = el.style.display === 'none' || el.style.display === '';
    el.style.display = isHidden ? 'block' : 'none';
    if (isHidden) {
        const ta = el.querySelector('textarea');
        if (ta) { ta.focus(); }
    }
}

// ─── Character counters ───────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
    const mainTA      = document.getElementById('main-comment-textarea');
    const mainCounter = document.getElementById('main-comment-counter');
    if (mainTA && mainCounter) {
        mainTA.addEventListener('input', function () {
            mainCounter.textContent = this.value.length + ' / 500';
            mainCounter.style.color = this.value.length > 450 ? '#ef4444' : '#94a3b8';
        });
    }
    document.querySelectorAll('textarea[data-counter]').forEach(ta => {
        const counter = document.getElementById(ta.dataset.counter);
        if (!counter) return;
        counter.textContent = ta.value.length + ' / 500';
        ta.addEventListener('input', function () {
            counter.textContent = this.value.length + ' / 500';
            counter.style.color = this.value.length > 450 ? '#ef4444' : '#94a3b8';
        });
    });
});

// ─── Reaction system ──────────────────────────────────────────────────────────
// Use a Set to track in-flight requests and block double-fire
const _reactingUrls = new Set();

document.body.addEventListener('click', function (e) {
    const btn = e.target.closest('.reaction-post-btn, .react-comment-btn');
    if (!btn) return;
    e.preventDefault();

    const url = btn.dataset.url;
    if (!url) return;
    if (_reactingUrls.has(url)) return; // already in-flight, ignore
    _reactingUrls.add(url);
    btn.style.opacity = '0.6';

    fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Content-Type': 'application/json'
        }
    })
    .then(response => {
        if (response.status === 401) throw new Error('Connectez-vous pour réagir');
        if (!response.ok) throw new Error('Erreur serveur ' + response.status);
        return response.json();
    })
    .then(data => {
        if (data.error && data.count === undefined) {
            showToast('error', data.error);
            return;
        }

        const isPostBtn  = btn.classList.contains('reaction-post-btn');
        const countSpan  = btn.querySelector(isPostBtn ? '.reaction-count' : '.comment-reaction-count');
        if (countSpan) countSpan.textContent = data.count;

        btn.classList.toggle('reacted', !!data.added);

        if (!isPostBtn) {
            btn.style.color      = data.added ? '#e11d48' : '';
            btn.style.fontWeight = data.added ? '700' : '';

            // Micro +1 / -1 animation
            const flash = document.createElement('span');
            flash.textContent = data.added ? ' +1' : ' -1';
            flash.style.cssText = 'font-size:11px;color:' + (data.added ? '#e11d48' : '#94a3b8') + ';transition:opacity 1s;pointer-events:none';
            btn.appendChild(flash);
            setTimeout(() => { flash.style.opacity = '0'; }, 600);
            setTimeout(() => { flash.remove(); }, 1000);
        }
    })
    .catch(err => showToast('error', err.message))
    .finally(() => {
        _reactingUrls.delete(url);
        btn.style.opacity = '1';
    });
});
</script>
{% endblock %}