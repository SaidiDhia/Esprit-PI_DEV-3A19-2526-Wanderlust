{% extends 'base.html.twig' %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">✎ Nouvelle publication</div>
            <div class="card-body">
                {{ form_start(form) }}
                    {{ form_row(form.contenu) }}
                    {{ form_row(form.media) }}
                    {{ form_row(form.statut) }}
                    <button class="btn btn-primary-custom">Publier</button>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}