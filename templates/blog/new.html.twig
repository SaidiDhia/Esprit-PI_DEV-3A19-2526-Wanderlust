{% extends 'base.html.twig' %}

{% block content %}
<div class="container mx-auto px-4 py-12">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-4xl font-heading font-bold mb-8">✍️ Create a New Post</h1>
        
        <div class="bg-card border border-border rounded-2xl p-8">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data'}}) }}
            
                <div class="space-y-2">
                    {{ form_label(form.contenu, 'Your Story') }}
                    {{ form_widget(form.contenu, {'attr': {'class': 'w-full border border-border rounded-lg p-3', 'rows': '8', 'placeholder': 'Share your travel experience...'}}) }}
                    {{ form_errors(form.contenu) }}
                </div>

                <div class="space-y-2">
                    {{ form_label(form.media, 'Add Photo or Video') }}
                    {{ form_widget(form.media, {'attr': {'class': 'w-full border border-border rounded-lg p-3'}}) }}
                    {{ form_errors(form.media) }}
                </div>

                <div class="space-y-2">
                    {{ form_label(form.statut, 'Privacy') }}
                    {{ form_widget(form.statut, {'attr': {'class': 'w-full border border-border rounded-lg p-3'}}) }}
                    {{ form_errors(form.statut) }}
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-bold py-2 px-6 rounded-lg">Publish Post</button>
                    <a href="{{ path('app_blog') }}" class="bg-secondary hover:bg-secondary/80 text-foreground font-bold py-2 px-6 rounded-lg">Cancel</a>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}