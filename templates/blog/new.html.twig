{% extends 'base.html.twig' %}

{% block content %}

{# ── Validation Popup ── #}
<div id="validation-popup" style="display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:18px;max-width:420px;width:92%;box-shadow:0 24px 64px rgba(0,0,0,.22);overflow:hidden">
        <div id="popup-header" style="background:linear-gradient(135deg,#dc2626,#ef4444);padding:22px 24px 16px;display:flex;align-items:center;gap:14px">
            <div style="width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">⚠</div>
            <div>
                <div id="popup-title" style="color:#fff;font-weight:700;font-size:16px">Formulaire incomplet</div>
                <div id="popup-subtitle" style="color:rgba(255,255,255,.8);font-size:12px;margin-top:2px">Veuillez corriger les erreurs suivantes</div>
            </div>
        </div>
        <div style="padding:20px 24px">
            <ul id="popup-errors" style="margin:0;padding:0 0 0 18px;color:#374151;font-size:14px;line-height:1.7"></ul>
        </div>
        <div style="padding:0 24px 20px;text-align:right">
            <button onclick="closePopup()" style="padding:9px 24px;border-radius:8px;border:none;background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;font-weight:700;font-size:14px;cursor:pointer">
                Corriger
            </button>
        </div>
    </div>
</div>

{# AI Moderation flash popup #}
{% set flashErrors = app.flashes('error') %}
{% if flashErrors|length > 0 %}
<div id="flash-popup" style="display:flex;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.5);align-items:center;justify-content:center">
    <div style="background:#fff;border-radius:18px;max-width:440px;width:92%;box-shadow:0 24px 64px rgba(0,0,0,.22);overflow:hidden">
        <div style="background:linear-gradient(135deg,#d97706,#f59e0b);padding:22px 24px 16px;display:flex;align-items:center;gap:14px">
            <div style="width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">🤖</div>
            <div>
                <div style="color:#fff;font-weight:700;font-size:16px">Modération IA</div>
                <div style="color:rgba(255,255,255,.85);font-size:12px;margin-top:2px">Contenu analysé automatiquement</div>
            </div>
        </div>
        <div style="padding:20px 24px">
            {% for msg in flashErrors %}
                <p style="margin:0 0 8px;color:#374151;font-size:14px;line-height:1.6">{{ msg }}</p>
            {% endfor %}
        </div>
        <div style="padding:0 24px 20px;text-align:right">
            <button onclick="document.getElementById('flash-popup').style.display='none'"
                    style="padding:9px 24px;border-radius:8px;border:none;background:linear-gradient(135deg,#d97706,#f59e0b);color:#fff;font-weight:700;font-size:14px;cursor:pointer">
                Compris
            </button>
        </div>
    </div>
</div>
{% endif %}

<div style="background:linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)),url('{{ asset('adventure/img/slider3.jpg') }}') center/cover no-repeat;padding:80px 0 50px;color:#fff">
    <div class="container">
        <h1 style="font-size:2.2rem;font-weight:700;margin-bottom:8px">✍ Créer une publication</h1>
        <p style="opacity:0.8">Partagez votre expérience de voyage avec la communauté.</p>
    </div>
</div>

<div class="container" style="padding:40px 15px">
<div class="row justify-content-center">
<div class="col-md-8">

    <div style="background:#fff;border-radius:16px;box-shadow:0 2px 20px rgba(0,0,0,.07);padding:32px">

        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'id': 'post-form', 'novalidate': 'novalidate'}}) }}

            {# ── Content field ── #}
            <div style="margin-bottom:20px">
                <label style="font-weight:700;font-size:13px;color:#374151;display:block;margin-bottom:6px">
                    Contenu <span style="color:#ef4444">*</span>
                </label>
                <div style="position:relative">
                    {{ form_widget(form.contenu, {
                        'attr': {
                            'rows': 8,
                            'placeholder': 'Partagez votre histoire de voyage...',
                            'style': 'width:100%;padding:12px 14px 30px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px;font-family:inherit;resize:vertical;transition:border-color .2s',
                            'maxlength': 2000
                        }
                    }) }}
                    <span id="contenu-counter" style="position:absolute;bottom:8px;right:12px;font-size:11px;color:#94a3b8;pointer-events:none">0 / 2000</span>
                </div>
                <div id="contenu-error" style="display:none;color:#ef4444;font-size:12px;margin-top:4px;padding:6px 10px;background:#fef2f2;border-radius:6px;border-left:3px solid #ef4444"></div>
                {% if form.contenu.vars.errors|length > 0 %}
                    <div style="color:#ef4444;font-size:12px;margin-top:4px">
                        {% for error in form.contenu.vars.errors %}<span>⚠ {{ error.message }}</span>{% endfor %}
                    </div>
                {% endif %}
            </div>

            {# ── Media field ── #}
            <div style="margin-bottom:20px">
                <label style="font-weight:700;font-size:13px;color:#374151;display:block;margin-bottom:6px">
                    📷 Photo ou vidéo <span style="color:#94a3b8;font-weight:400">(optionnel)</span>
                </label>
                {{ form_widget(form.media, {
                    'attr': {
                        'style': 'width:100%;padding:10px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px',
                        'accept': 'image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime,video/x-msvideo'
                    }
                }) }}
                <div id="media-error" style="display:none;color:#ef4444;font-size:12px;margin-top:4px;padding:6px 10px;background:#fef2f2;border-radius:6px;border-left:3px solid #ef4444"></div>
                <small style="color:#94a3b8;font-size:12px;display:block;margin-top:4px">JPG, PNG, GIF, WebP, MP4, AVI, MOV — max 10 Mo</small>
                {% if form.media.vars.errors|length > 0 %}
                    <div style="color:#ef4444;font-size:12px;margin-top:4px">
                        {% for error in form.media.vars.errors %}<span>⚠ {{ error.message }}</span>{% endfor %}
                    </div>
                {% endif %}
            </div>

            {# ── Statut field ── #}
            <div style="margin-bottom:20px">
                <label style="font-weight:700;font-size:13px;color:#374151;display:block;margin-bottom:6px">
                    Visibilité <span style="color:#ef4444">*</span>
                </label>
                {{ form_widget(form.statut, {
                    'attr': {
                        'id': 'statut-select',
                        'style': 'width:100%;padding:10px 14px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px',
                        'onchange': 'toggleScheduledBlock()'
                    }
                }) }}
                <div id="statut-error" style="display:none;color:#ef4444;font-size:12px;margin-top:4px;padding:6px 10px;background:#fef2f2;border-radius:6px;border-left:3px solid #ef4444"></div>
                {% if form.statut.vars.errors|length > 0 %}
                    <div style="color:#ef4444;font-size:12px;margin-top:4px">
                        {% for error in form.statut.vars.errors %}<span>⚠ {{ error.message }}</span>{% endfor %}
                    </div>
                {% endif %}
            </div>

            {# ── Scheduled date picker ── #}
            {#
              ROOT FIX: bypass form_widget for scheduledAt entirely.
              A plain <input type="datetime-local"> has zero browser-injected constraints.
              The hidden Symfony field is kept in sync via oninput so the form submits correctly.
            #}
            <div id="scheduled-block" style="display:none;margin-bottom:24px;padding:18px;background:#eff6ff;border-radius:12px;border:2px solid #bfdbfe">
                <label style="font-weight:700;font-size:13px;color:#1e40af;display:block;margin-bottom:8px">
                    📅 Date et heure de publication programmée
                </label>

                {# Hidden Symfony-bound field — keeps the form binding intact on submit #}
                {{ form_widget(form.scheduledAt, {'attr': {'style': 'display:none', 'id': 'scheduled-at-hidden'}}) }}

                {# Visible plain input — absolutely no min/max constraints #}
                <input type="datetime-local"
                       id="scheduled-at-input"
                       style="width:100%;padding:10px 14px;border:2px solid #bfdbfe;border-radius:10px;font-size:14px;background:#fff;color:#1e40af"
                       oninput="document.getElementById('scheduled-at-hidden').value = this.value">

                <small style="color:#3b82f6;font-size:12px;margin-top:6px;display:block">
                    ⏰ Le post sera automatiquement publié à cette date et heure.
                </small>
                <div id="scheduled-error" style="display:none;color:#ef4444;font-size:12px;margin-top:4px;padding:6px 10px;background:#fef2f2;border-radius:6px;border-left:3px solid #ef4444"></div>
            </div>

            <div class="d-flex" style="gap:12px">
                <button type="button" onclick="validateAndSubmit()"
                        style="padding:11px 28px;border-radius:8px;border:none;background:linear-gradient(135deg,#1d4ed8,#3b82f6);color:#fff;font-weight:700;font-size:15px;cursor:pointer;transition:all .2s">
                    🚀 Publier
                </button>
                <a href="{{ path('app_blog') }}"
                   style="padding:11px 22px;border-radius:8px;border:2px solid #e2e8f0;background:#fff;color:#64748b;font-size:14px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
</div>
</div>

<script>
var FIELD_CONTENU_ID  = '{{ form.contenu.vars.id }}';
var FIELD_MEDIA_ID    = '{{ form.media.vars.id }}';
var FIELD_STATUT_ID   = '{{ form.statut.vars.id }}';

function closePopup() {
    document.getElementById('validation-popup').style.display = 'none';
}

function showValidationPopup(errors) {
    var ul = document.getElementById('popup-errors');
    ul.innerHTML = '';
    errors.forEach(function(e) {
        var li = document.createElement('li');
        li.textContent = e;
        li.style.marginBottom = '4px';
        ul.appendChild(li);
    });
    document.getElementById('validation-popup').style.display = 'flex';
}

function markError(fieldId, errorDivId, message) {
    var el = document.getElementById(fieldId);
    if (el) el.style.borderColor = '#ef4444';
    var errDiv = document.getElementById(errorDivId);
    if (errDiv) { errDiv.textContent = message; errDiv.style.display = 'block'; }
}

function clearError(fieldId, errorDivId) {
    var el = document.getElementById(fieldId);
    if (el) el.style.borderColor = '#e2e8f0';
    var errDiv = document.getElementById(errorDivId);
    if (errDiv) errDiv.style.display = 'none';
}

function getScheduledInput() {
    return document.getElementById('scheduled-at-input')
        || document.querySelector('#scheduled-block input[type="datetime-local"]');
}

function getScheduledHiddenInput() {
    return document.getElementById('scheduled-at-hidden')
        || document.querySelector('input[name$="[scheduledAt]"]');
}

function toggleScheduledBlock() {
    var statutEl = document.getElementById(FIELD_STATUT_ID) || document.getElementById('statut-select');
    var block    = document.getElementById('scheduled-block');
    if (!statutEl || !block) return;
    block.style.display = statutEl.value === 'scheduled' ? 'block' : 'none';
}

function validateAndSubmit() {
    var errors = [];

    clearError(FIELD_CONTENU_ID, 'contenu-error');
    clearError(FIELD_MEDIA_ID,   'media-error');
    clearError(FIELD_STATUT_ID,  'statut-error');
    clearError('scheduled-at-input', 'scheduled-error');

    // ── Contenu ──────────────────────────────────────────────────────────────
    var contenuEl  = document.getElementById(FIELD_CONTENU_ID);
    var contenuVal = contenuEl ? contenuEl.value.trim() : '';
    if (!contenuVal) {
        markError(FIELD_CONTENU_ID, 'contenu-error', 'Le contenu est obligatoire.');
        errors.push('Le contenu de la publication est obligatoire.');
    } else if (contenuVal.length < 5) {
        markError(FIELD_CONTENU_ID, 'contenu-error', 'Minimum 5 caractères requis.');
        errors.push('Le contenu doit contenir au moins 5 caractères.');
    } else if (contenuVal.length > 2000) {
        markError(FIELD_CONTENU_ID, 'contenu-error', 'Maximum 2000 caractères.');
        errors.push('Le contenu ne peut pas dépasser 2000 caractères.');
    }

    // ── Media (optional) ──────────────────────────────────────────────────────
    var mediaEl = document.getElementById(FIELD_MEDIA_ID);
    if (mediaEl && mediaEl.files && mediaEl.files.length > 0) {
        var file    = mediaEl.files[0];
        var ext     = file.name.toLowerCase().split('.').pop();
        var allowed = ['jpg','jpeg','png','gif','webp','mp4','avi','mov'];
        if (!allowed.includes(ext)) {
            markError(FIELD_MEDIA_ID, 'media-error', 'Type non autorisé.');
            errors.push('Le fichier doit être une image ou vidéo valide.');
        } else if (file.size > 10 * 1024 * 1024) {
            markError(FIELD_MEDIA_ID, 'media-error', 'Fichier trop volumineux (max 10 Mo).');
            errors.push('Le fichier média ne doit pas dépasser 10 Mo.');
        }
    }

    // ── Statut ────────────────────────────────────────────────────────────────
    var statutEl = document.getElementById(FIELD_STATUT_ID);
    if (!statutEl || !statutEl.value) {
        markError(FIELD_STATUT_ID, 'statut-error', 'Veuillez choisir une visibilité.');
        errors.push('La visibilité de la publication est obligatoire.');
    }

    // ── Scheduled date ────────────────────────────────────────────────────────
    if (statutEl && statutEl.value === 'scheduled') {
        var dateInput = getScheduledInput();
        var hiddenInput = getScheduledHiddenInput();
        var errDiv    = document.getElementById('scheduled-error');

        if (dateInput && hiddenInput) {
            hiddenInput.value = dateInput.value;
        }

        if (!dateInput || !dateInput.value) {
            if (errDiv) {
                errDiv.textContent = 'Veuillez choisir une date et heure de publication.';
                errDiv.style.display = 'block';
            }
            if (dateInput) dateInput.style.borderColor = '#ef4444';
            errors.push('Une date de publication est requise pour le mode programmé.');
        } else {
            var selectedDate = new Date(dateInput.value);
            var minDate      = new Date(Date.now() + 60 * 1000); // now + 1 minute

            if (isNaN(selectedDate.getTime())) {
                if (errDiv) {
                    errDiv.textContent = 'La date saisie est invalide.';
                    errDiv.style.display = 'block';
                }
                dateInput.style.borderColor = '#ef4444';
                errors.push('La date de publication saisie est invalide.');
            } else if (selectedDate < minDate) {
                if (errDiv) {
                    errDiv.textContent = 'La date doit être dans le futur (au moins 1 minute à partir de maintenant).';
                    errDiv.style.display = 'block';
                }
                dateInput.style.borderColor = '#ef4444';
                errors.push('La date de publication programmée doit être dans le futur.');
            }
        }
    }

    if (errors.length > 0) {
        showValidationPopup(errors);
        return;
    }

    document.getElementById('post-form').submit();
}

document.addEventListener('DOMContentLoaded', function() {
    var popup = document.getElementById('validation-popup');
    if (popup) popup.addEventListener('click', function(e) { if (e.target === this) closePopup(); });

    var ta  = document.getElementById(FIELD_CONTENU_ID);
    var ctr = document.getElementById('contenu-counter');
    if (ta && ctr) {
        ctr.textContent = ta.value.length + ' / 2000';
        ta.addEventListener('input', function() {
            var len = this.value.length;
            ctr.textContent = len + ' / 2000';
            ctr.style.color = len > 1800 ? '#ef4444' : len > 1500 ? '#f59e0b' : '#94a3b8';
            if (len > 0) clearError(FIELD_CONTENU_ID, 'contenu-error');
        });
    }

    var statutEl = document.getElementById(FIELD_STATUT_ID);
    if (statutEl) {
        statutEl.addEventListener('change', function() {
            if (this.value) clearError(FIELD_STATUT_ID, 'statut-error');
            toggleScheduledBlock();
        });
        toggleScheduledBlock();
    }

    // Clear scheduled date error when the user picks a new date
    var dateInput = document.getElementById('scheduled-at-input');
    if (dateInput) {
        var hiddenInput = getScheduledHiddenInput();
        if (hiddenInput && hiddenInput.value && !dateInput.value) {
            dateInput.value = hiddenInput.value;
        }

        dateInput.addEventListener('change', function() {
            this.style.borderColor = '#bfdbfe';
            var errDiv = document.getElementById('scheduled-error');
            if (errDiv) errDiv.style.display = 'none';
            var hidden = getScheduledHiddenInput();
            if (hidden) hidden.value = this.value;
        });

        dateInput.addEventListener('input', function() {
            var hidden = getScheduledHiddenInput();
            if (hidden) hidden.value = this.value;
        });
    }
});
</script>

{% endblock %}
