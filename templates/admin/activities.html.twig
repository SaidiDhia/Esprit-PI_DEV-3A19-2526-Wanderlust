{% extends 'base.html.twig' %}

{% block title %}Admin - Gestion des Activités{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .admin-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f8f9fa;
    }

    .admin-sidebar {
        width: 280px;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
    }

    .admin-sidebar-header {
        padding: 1.5rem;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .admin-sidebar-header h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
    }

    .admin-nav {
        list-style: none;
        padding: 1rem 0;
        margin: 0;
    }

    .admin-nav-item {
        margin: 0.25rem 1rem;
    }

    .admin-nav-link {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .admin-nav-link i {
        width: 24px;
        margin-right: 12px;
    }

    .admin-nav-link:hover {
        background: rgba(255,255,255,0.1);
        color: white;
    }

    .admin-nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .admin-content {
        flex: 1;
        margin-left: 280px;
        padding: 2rem;
    }

    .table-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .table-header {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-bottom: 1px solid #dee2e6;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .admin-table {
        width: 100%;
        margin-bottom: 0;
    }

    .admin-table th {
        background: #f8f9fa;
        padding: 1rem;
        font-weight: 600;
        border-bottom: 2px solid #dee2e6;
    }

    .admin-table td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
    }

    .admin-table tr:hover {
        background: #f8f9fa;
    }

    .activity-image {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 10px;
    }

    .badge-category {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .action-buttons .btn {
        padding: 0.25rem 0.5rem;
        margin: 0 0.125rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="admin-wrapper">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
            <h3>🏜️ Wonderlust</h3>
            <p>Administration Panel</p>
        </div>
        <ul class="admin-nav">
            <li class="admin-nav-item">
                <a href="{{ path('admin_dashboard') }}" class="admin-nav-link">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('admin_activities') }}" class="admin-nav-link active">
                    <i class="fas fa-hiking"></i> Activités
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('admin_events') }}" class="admin-nav-link">
                    <i class="fas fa-calendar-alt"></i> Événements
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('app_home') }}" class="admin-nav-link">
                    <i class="fas fa-arrow-left"></i> Retour au site
                </a>
            </li>
        </ul>
    </aside>
    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="fas fa-hiking me-2 text-primary"></i>
                Gestion des Activités
            </h1>
            <a href="{{ path('app_activities_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Nouvelle activité
            </a>
        </div>
        <div class="table-card">
            <div class="table-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="mb-0">Liste des activités</h5>
                        <small class="text-muted">{{ activities|length }} activité(s) au total</small>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="admin-table table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Titre</th>
                            <th>Catégorie</th>
                            <th>Type</th>
                            <th>Date création</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for activity in activities %}
                            <tr>
                                <td>{{ activity.id }}</td>
                                <td>
                                    {% if activity.image %}
                                        <img src="{{ asset('uploads/activities/' ~ activity.image) }}" class="activity-image" alt="{{ activity.titre }}">
                                    {% else %}
                                        <div class="activity-image bg-light d-flex align-items-center justify-content-center">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    <strong>{{ activity.titre }}</strong><br>
                                    <small class="text-muted">{{ activity.description|slice(0, 50) }}...</small>
                                </td>
                                <td>
                                    <span class="badge-category" style="background: rgba(102,126,234,0.1); color: #667eea;">
                                        {{ activity.categorie ? activity.categorie.value : 'Non classé' }}
                                    </span>
                                </td>
                                <td>{{ activity.typeActivite }}</td>
                                <td>
                                    <small>{{ activity.dateCreation ? activity.dateCreation|date('d/m/Y') : 'N/A' }}</small>
                                </td>
                                <td class="action-buttons">
                                    <a href="{{ path('app_activities_show', {'id': activity.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_activities_edit', {'id': activity.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" class="text-center py-4">
                                    <i class="fas fa-inbox fa-3x text-muted mb-2 d-block"></i>
                                    <p class="text-muted mb-0">Aucune activité trouvée</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
{% endblock %}
