{% extends 'base.html.twig' %}

{% block title %}Admin - Gestion des Événements{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .admin-wrapper {
        display: flex;
        min-height: 100vh;
        background: #f8f9fa;
    }

    .admin-sidebar {
        width: 280px;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
        color: white;
        position: fixed;
        height: 100vh;
        overflow-y: auto;
    }

    .admin-sidebar-header {
        padding: 1.5rem;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    .admin-nav {
        list-style: none;
        padding: 1rem 0;
        margin: 0;
    }

    .admin-nav-item {
        margin: 0.25rem 1rem;
    }

    .admin-nav-link {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .admin-nav-link i {
        width: 24px;
        margin-right: 12px;
    }

    .admin-nav-link:hover {
        background: rgba(255,255,255,0.1);
        color: white;
    }

    .admin-nav-link.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .admin-content {
        flex: 1;
        margin-left: 280px;
        padding: 2rem;
    }

    .table-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .table-header {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-bottom: 1px solid #dee2e6;
    }

    .admin-table th {
        background: #f8f9fa;
        padding: 1rem;
        font-weight: 600;
    }

    .admin-table td {
        padding: 1rem;
        vertical-align: middle;
    }

    .admin-table tr:hover {
        background: #f8f9fa;
    }

    .status-select {
        padding: 4px 8px;
        border-radius: 20px;
        border: 1px solid #dee2e6;
        font-size: 0.8rem;
        cursor: pointer;
    }

    .status-select.en_attente { background: #fff3cd; color: #856404; border-color: #ffc107; }
    .status-select.accepte { background: #d4edda; color: #155724; border-color: #28a745; }
    .status-select.refuse { background: #f8d7da; color: #721c24; border-color: #dc3545; }

    .event-image {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 10px;
    }

    .action-buttons .btn {
        padding: 0.25rem 0.5rem;
        margin: 0 0.125rem;
    }
</style>
{% endblock %}

{% block content %}
<div class="admin-wrapper">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
            <h3>🏜️ Wonderlust</h3>
            <p>Administration Panel</p>
        </div>
        <ul class="admin-nav">
            <li class="admin-nav-item">
                <a href="{{ path('admin_dashboard') }}" class="admin-nav-link">
                    <i class="fas fa-chart-line"></i> Dashboard
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('admin_activities') }}" class="admin-nav-link">
                    <i class="fas fa-hiking"></i> Activités
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('admin_events') }}" class="admin-nav-link active">
                    <i class="fas fa-calendar-alt"></i> Événements
                </a>
            </li>
            <li class="admin-nav-item">
                <a href="{{ path('app_home') }}" class="admin-nav-link">
                    <i class="fas fa-arrow-left"></i> Retour au site
                </a>
            </li>
        </ul>
    </aside>
    <main class="admin-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">
                <i class="fas fa-calendar-alt me-2 text-primary"></i>
                Gestion des Événements
            </h1>
            <a href="{{ path('app_events_new') }}" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Nouvel événement
            </a>
        </div>
        <div class="table-card">
            <div class="table-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 class="mb-0">Liste des événements</h5>
                        <small class="text-muted">{{ events|length }} événement(s) au total</small>
                    </div>
                </div>
            </div>
            <div class="table-responsive">
                <table class="admin-table table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Titre / Lieu</th>
                            <th>Dates</th>
                            <th>Prix</th>
                            <th>Places</th>
                            <th>Statut</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for event in events %}
                            <tr>
                                <td>{{ event.id }}</td>
                                <td>
                                    {% if event.image %}
                                        <img src="{{ asset('uploads/events/' ~ event.image) }}" class="event-image" alt="{{ event.titre }}">
                                    {% else %}
                                        <div class="event-image bg-light d-flex align-items-center justify-content-center">
                                            <i class="fas fa-image text-muted"></i>
                                        </div>
                                    {% endif %}
                                </td>
                                <td>
                                    <strong>{{ event.titre }}</strong><br>
                                    <small class="text-muted">
                                        <i class="fas fa-map-marker-alt me-1"></i>{{ event.lieu }}
                                    </small><br>
                                    <small class="text-muted">
                                        <i class="fas fa-user me-1"></i>{{ event.organisateur }}
                                    </small>
                                </td>
                                <td>
                                    <small>
                                        <i class="fas fa-calendar-alt me-1"></i>{{ event.dateDebut ? event.dateDebut|date('d/m/Y H:i') : 'N/A' }}<br>
                                        <i class="fas fa-calendar-check me-1"></i>{{ event.dateFin ? event.dateFin|date('d/m/Y H:i') : 'N/A' }}
                                    </small>
                                </td>
                                <td>{{ event.prix }} €</td>
                                <td>
                                    <small>{{ event.placesDisponibles }}/{{ event.capaciteMax }}</small>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('admin_event_change_status', {'id': event.id, 'status': '__STATUS__'}) }}" class="status-form" data-event-id="{{ event.id }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('change_status' ~ event.id) }}">
                                        <select class="status-select {{ event.statut }}" onchange="changeStatus(this, {{ event.id }})">
                                            <option value="en_attente" {{ event.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>
                                            <option value="accepte" {{ event.statut == 'accepte' ? 'selected' : '' }}>Accepté</option>
                                            <option value="refuse" {{ event.statut == 'refuse' ? 'selected' : '' }}>Refusé</option>
                                        </select>
                                    </form>
                                </td>
                                <td class="action-buttons">
                                    <a href="{{ path('app_events_show', {'id': event.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_events_edit', {'id': event.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <i class="fas fa-inbox fa-3x text-muted mb-2 d-block"></i>
                                    <p class="text-muted mb-0">Aucun événement trouvé</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<script>
function changeStatus(select, eventId) {
    const newStatus = select.value;
    const form = select.closest('.status-form');
    if (form) {
        form.action = form.action.replace('__STATUS__', newStatus);
        form.submit();
    }
}
</script>
{% endblock %}
