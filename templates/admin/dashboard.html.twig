{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard — Wanderlust{% endblock %}

{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-white px-4 py-10">
    <div class="container mx-auto space-y-8">
        {% for message in app.flashes('success') %}
            <div class="rounded-xl border border-primary/30 bg-primary/10 px-4 py-3 text-sm font-medium text-primary">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="rounded-xl border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm font-medium text-destructive">{{ message }}</div>
        {% endfor %}

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Total users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ stats.total }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Active users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ stats.active }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Banned users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-destructive">{{ stats.banned }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">New this month</p>
                <p class="mt-2 text-3xl font-heading font-bold text-accent">{{ stats.newThisMonth }}</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-[280px_1fr]">
            <aside class="rounded-[2rem] border border-border bg-card p-6 xl:sticky xl:top-24 xl:h-fit">
                <div class="mb-6">
                    <p class="text-xs font-bold uppercase tracking-[0.28em] text-primary">Navigation</p>
                    <h2 class="mt-2 text-xl font-heading font-bold text-foreground">Modules</h2>
                    <p class="mt-1 text-sm text-muted-foreground">Use this sidebar to move between platform sections.</p>
                </div>

                <nav class="space-y-2">
                    <a href="{{ path('app_admin_dashboard', { section: 'users' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-bold transition-colors {{ activeSection == 'users' ? 'border-primary/30 bg-primary/15 text-primary shadow-sm' : 'border-primary/20 bg-transparent text-foreground hover:bg-secondary/40' }}">
                        <span>Admin Dashboard</span>
                        {% if activeSection == 'users' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'marketplace' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'marketplace' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Marketplace</span>
                        {% if activeSection == 'marketplace' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_booking') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Booking</a>
                    <a href="{{ path('app_activities') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Activities</a>
                    <a href="{{ path('app_blog') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Blog</a>
                    <a href="{{ path('app_admin_dashboard', { section: 'messaging' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'messaging' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Messaging</span>
                        {% if activeSection == 'messaging' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'booking' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'booking' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Booking</span>
                        {% if activeSection == 'booking' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                </nav>

                <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3 xl:grid-cols-1">
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Admins</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.admins }}</p>
                    </div>
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Hosts</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.hosts }}</p>
                    </div>
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Travelers</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.participants }}</p>
                    </div>
                </div>
            </aside>

            <div class="space-y-6">
                <div id="users-section" class="{{ activeSection == 'users' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6">
                    <form method="get" action="{{ path('app_admin_dashboard') }}" class="grid grid-cols-1 gap-3 md:grid-cols-4">
                        <input type="text" name="q" value="{{ filters.q }}" placeholder="Search name, email, phone" class="md:col-span-2 rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                        <select name="role" class="rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                            <option value="">All roles</option>
                            {% for role in roles %}
                                <option value="{{ role.value }}" {% if filters.role == role.value %}selected{% endif %}>{{ role.label }}</option>
                            {% endfor %}
                        </select>
                        <select name="status" class="rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                            <option value="">Any status</option>
                            <option value="active" {% if filters.status == 'active' %}selected{% endif %}>Active</option>
                            <option value="banned" {% if filters.status == 'banned' %}selected{% endif %}>Banned</option>
                        </select>
                        <button type="submit" class="md:col-span-4 rounded-xl border border-border px-3 py-2 text-sm font-semibold transition-colors hover:bg-secondary/50">Apply Filters</button>
                    </form>
                </div>

                <div class="{{ activeSection == 'users' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6">
                    <div class="mb-5 flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Users</h2>
                            <p class="text-sm text-muted-foreground">Click Edit to open a modal, update avatars, passwords, roles, and 2FA values.</p>
                        </div>
                        <button type="button" onclick="openCreateUserModal()" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
                            New User
                        </button>
                    </div>

                    <div class="mb-6 grid grid-cols-1 gap-4 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Users by Role</h3>
                                <span class="text-xs text-muted-foreground">Circle chart</span>
                            </div>
                            <div class="mx-auto h-[260px] w-full max-w-[320px]">
                                <canvas id="usersRoleChart" class="h-full w-full"></canvas>
                            </div>
                        </div>

                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Users Trend</h3>
                                <span class="text-xs text-muted-foreground">Curve chart</span>
                            </div>
                            <div class="h-[260px] w-full">
                                <canvas id="usersTrendChart" class="h-full w-full"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[1100px] border-collapse">
                            <thead>
                            <tr class="border-b border-border text-left">
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">User</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Role</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">2FA</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Status</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Created</th>
                                <th class="py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for user in users %}
                                {% set protectedUser = user.isAdmin or app.user.id == user.id %}
                                {% set avatarSrc = user.profilePicture ? asset('uploads/profiles/' ~ user.profilePicture) : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' ~ user.fullName|url_encode %}
                                <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                    <td class="py-4 pr-3">
                                        <div class="flex items-center gap-4">
                                            <div class="h-14 w-14 shrink-0 overflow-hidden rounded-full border-2 border-border bg-secondary/20">
                                                <img src="{{ avatarSrc }}" alt="{{ user.fullName }}" class="h-full w-full object-cover">
                                            </div>
                                            <div class="min-w-0">
                                                <p class="truncate font-semibold text-foreground">{{ user.fullName }}</p>
                                                <p class="truncate text-sm text-muted-foreground">{{ user.email }}</p>
                                                <p class="truncate text-xs text-muted-foreground">{{ user.phoneNumber ?: 'No phone number' }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 pr-3 text-sm font-medium text-foreground">{{ user.roleLabel }}</td>
                                    <td class="py-4 pr-3 text-sm text-muted-foreground">{{ user.tfaLabel }}</td>
                                    <td class="py-4 pr-3">
                                        {% if user.isIsActive %}
                                            <span class="inline-flex rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">Active</span>
                                        {% else %}
                                            <span class="inline-flex rounded-full bg-destructive/10 px-3 py-1 text-xs font-bold text-destructive">Banned</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-4 pr-3 text-sm text-muted-foreground">{{ user.createdAt|date('Y-m-d H:i') }}</td>
                                    <td class="py-4">
                                        <div class="flex flex-wrap items-center gap-2">
                                            {% if user.roleValue == 'HOST' %}
                                                <a href="{{ path('app_booking_host_view', { id: user.id }) }}" class="rounded-xl bg-sky-600 px-3 py-2 text-xs font-bold text-white transition-opacity hover:opacity-90">
                                                    Host Dashboard
                                                </a>
                                            {% endif %}
                                            <button
                                                type="button"
                                                onclick="openEditUserModal(this)"
                                                data-update-url="{{ path('app_admin_user_update', { id: user.id }) }}"
                                                data-update-token="{{ csrf_token('admin_user_update_' ~ user.id) }}"
                                                data-id="{{ user.id }}"
                                                data-full-name="{{ user.fullName|e('html_attr') }}"
                                                data-email="{{ user.email|e('html_attr') }}"
                                                data-phone-number="{{ user.phoneNumber|default('')|e('html_attr') }}"
                                                data-role="{{ user.roleValue }}"
                                                data-tfa-method="{{ user.tfaValue }}"
                                                data-avatar-src="{{ user.profilePicture ? asset('uploads/profiles/' ~ user.profilePicture) : '' }}"
                                                class="rounded-xl bg-foreground px-3 py-2 text-xs font-bold text-background transition-opacity hover:opacity-90"
                                            >
                                                Edit
                                            </button>

                                            <form method="post" action="{{ path('app_admin_user_toggle_ban', { id: user.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_ban_' ~ user.id) }}">
                                                <button type="submit" class="rounded-xl px-3 py-2 text-xs font-bold {{ protectedUser ? 'cursor-not-allowed bg-muted text-muted-foreground' : (user.isIsActive ? 'bg-destructive/10 text-destructive hover:bg-destructive/20' : 'bg-primary/10 text-primary hover:bg-primary/20') }}" {% if protectedUser %}disabled title="Protected user"{% endif %}>
                                                    {{ user.isIsActive ? 'Ban' : 'Unban' }}
                                                </button>
                                            </form>

                                            <form method="post" action="{{ path('app_admin_user_delete', { id: user.id }) }}" onsubmit="return confirm('Delete this user? This action cannot be undone.');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_delete_' ~ user.id) }}">
                                                <button type="submit" class="rounded-xl px-3 py-2 text-xs font-bold {{ protectedUser ? 'cursor-not-allowed bg-muted text-muted-foreground' : 'bg-destructive text-white hover:bg-destructive/90' }}" {% if protectedUser %}disabled title="Protected user"{% endif %}>Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="py-10 text-center text-sm text-muted-foreground">No users found for current filters.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="messaging-analytics" class="{{ activeSection == 'messaging' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6 space-y-6">
                    <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Messaging Analytics</h2>
                            <p class="text-sm text-muted-foreground">Data pulled from the messaging module dashboard and merged into the user admin view.</p>
                        </div>
                        <a href="{{ path('app_admin_dashboard', { section: 'users' }) }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">
                            Show Users
                        </a>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Conversations</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ messagingStats.totalConversations }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Messages</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ messagingStats.totalMessages }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Media Messages</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-accent">{{ messagingStats.totalMedia }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Top Senders</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-destructive">{{ topSenders|length }}</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Messages per Day</h3>
                                <span class="text-xs text-muted-foreground">Last 7 days</span>
                            </div>
                            <div class="h-[260px] w-full">
                                <canvas id="messagesPerDayChart" class="h-full w-full"></canvas>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-4">
                            <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                <div class="mb-3 flex items-center justify-between">
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Conversation Types</h3>
                                    <span class="text-xs text-muted-foreground">Distribution</span>
                                </div>
                                <div class="h-[210px] w-full">
                                    <canvas id="conversationTypesChart" class="h-full w-full"></canvas>
                                </div>
                            </div>

                            <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                <div class="mb-3 flex items-center justify-between">
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Message Types</h3>
                                    <span class="text-xs text-muted-foreground">Distribution</span>
                                </div>
                                <div class="h-[210px] w-full">
                                    <canvas id="messageTypesChart" class="h-full w-full"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Top Conversations</h3>
                            <div class="space-y-3">
                                {% for conv in topConversations %}
                                    <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                                        <span class="truncate text-sm font-semibold text-foreground">{{ conv.name ?: 'Conversation #' ~ conv.id }}</span>
                                        <span class="ml-3 shrink-0 rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">{{ conv.message_count }} messages</span>
                                    </div>
                                {% else %}
                                    <p class="text-sm text-muted-foreground">No conversation activity yet.</p>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Top Senders</h3>
                            <div class="space-y-3">
                                {% for sender in topSenders %}
                                    <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                                        <div class="min-w-0">
                                            <p class="truncate text-sm font-semibold text-foreground">{{ sender.full_name ?: sender.email }}</p>
                                            <p class="truncate text-xs text-muted-foreground">{{ sender.email }}</p>
                                        </div>
                                        <span class="ml-3 shrink-0 rounded-full bg-accent/10 px-3 py-1 text-xs font-bold text-accent">{{ sender.message_count }} messages</span>
                                    </div>
                                {% else %}
                                    <p class="text-sm text-muted-foreground">No sender activity yet.</p>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Recent Messaging Activity</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full min-w-[900px] border-collapse">
                                <thead>
                                <tr class="border-b border-border text-left">
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Time</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">User</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Conversation</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Content</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for activity in recentActivity %}
                                    <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">{{ activity.created_at|date('H:i:s') }}</td>
                                        <td class="py-3 pr-3 text-sm text-foreground">{{ activity.sender_name ?: activity.sender_id|slice(0,8) }}</td>
                                        <td class="py-3 pr-3 text-sm text-foreground">{{ activity.conversation_name ?: '#' ~ activity.conversation_id }}</td>
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">
                                            {% if activity.message_type == 'TEXT' %}
                                                {{ activity.content|slice(0, 50) }}
                                            {% elseif activity.message_type == 'IMAGE' %}
                                                📷 Image
                                            {% elseif activity.message_type == 'VIDEO' %}
                                                🎥 Video
                                            {% elseif activity.message_type == 'AUDIO' %}
                                                🎵 Audio
                                            {% else %}
                                                📎 File
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="py-8 text-center text-sm text-muted-foreground">No recent messaging activity.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div id="booking-analytics" class="{{ activeSection == 'booking' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6 space-y-6">
                    <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Booking Analytics</h2>
                            <p class="text-sm text-muted-foreground">Booking module insights integrated into the main admin dashboard.</p>
                        </div>
                        <a href="{{ path('app_admin_dashboard', { section: 'users' }) }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">
                            Show Users
                        </a>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Total Places</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ bookingStats.totalPlaces }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Approved Places</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ bookingStats.approvedPlaces }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Pending Places</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-accent">{{ bookingStats.pendingPlaces }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Total Bookings</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ bookingStats.totalBookings }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Pending Bookings</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-destructive">{{ bookingStats.pendingBookings }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Confirmed Bookings</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ bookingStats.confirmedBookings }}</p>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Create Place</h3>
                                <p class="text-xs text-muted-foreground">Open the modal to create a place with multiple images.</p>
                            </div>
                            <button type="button" onclick="openCreatePlaceModal()" class="inline-flex items-center justify-center rounded-xl bg-primary px-4 py-2 text-xs font-bold text-white transition-colors hover:bg-primary/90">Create Place</button>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Manage Places (CRUD)</h3>
                        <div class="space-y-3">
                            {% for place in bookingPlaces %}
                                {% set placePreviewImage = bookingPlacePreviewImages[place.id]|default(place.imageUrl) %}
                                {% set placeExistingImages = [] %}
                                {% for image in place.images %}
                                    {% set placeExistingImages = placeExistingImages|merge([{ id: image.id, url: image.url }]) %}
                                {% endfor %}
                                <div class="rounded-xl border border-border bg-background p-3">
                                    <div class="flex items-start justify-between gap-3">
                                        <div class="flex min-w-0 items-start gap-3">
                                            {% if placePreviewImage %}
                                                <img src="{{ placePreviewImage starts with('http') ? placePreviewImage : asset('uploads/places/' ~ placePreviewImage) }}" alt="{{ place.title }}" class="h-14 w-18 rounded-lg object-cover">
                                            {% endif %}
                                            <div class="min-w-0">
                                                <p class="truncate text-sm font-semibold text-foreground">{{ place.title }}</p>
                                                <p class="truncate text-xs text-muted-foreground">{{ place.city }} · {{ place.host ? place.host.fullName : 'Unknown host' }}</p>
                                            </div>
                                        </div>
                                        <span class="rounded-full bg-secondary/40 px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider text-foreground">{{ place.status }}</span>
                                    </div>
                                    <div class="mt-3 flex flex-wrap gap-2">
                                        <button
                                            type="button"
                                            onclick="openEditPlaceModal(this)"
                                            data-update-url="{{ path('app_admin_place_update', { id: place.id }) }}"
                                            data-update-token="{{ csrf_token('admin_place_update_' ~ place.id) }}"
                                            data-title="{{ place.title|e('html_attr') }}"
                                            data-host-id="{{ place.host ? place.host.id : '' }}"
                                            data-status="{{ place.status|e('html_attr') }}"
                                            data-city="{{ place.city|e('html_attr') }}"
                                            data-category="{{ (place.category ?? '')|e('html_attr') }}"
                                            data-price-per-day="{{ place.pricePerDay|e('html_attr') }}"
                                            data-capacity="{{ place.capacity|e('html_attr') }}"
                                            data-max-guests="{{ place.maxGuests|e('html_attr') }}"
                                            data-address="{{ place.address|e('html_attr') }}"
                                            data-latitude="{{ (place.latitude ?: '36.80650000')|e('html_attr') }}"
                                            data-longitude="{{ (place.longitude ?: '10.18150000')|e('html_attr') }}"
                                            data-description="{{ (place.description ?? '')|e('html_attr') }}"
                                            data-existing-images="{{ placeExistingImages|json_encode|e('html_attr') }}"
                                            class="rounded-xl bg-primary px-4 py-2 text-xs font-bold text-white"
                                        >
                                            Edit
                                        </button>
                                        <button
                                            type="button"
                                            onclick="openDeletePlaceModal(this)"
                                            data-delete-url="{{ path('app_admin_place_delete', { id: place.id }) }}"
                                            data-delete-token="{{ csrf_token('admin_place_delete_' ~ place.id) }}"
                                            data-place-title="{{ place.title|e('html_attr') }}"
                                            class="rounded-xl bg-destructive px-4 py-2 text-xs font-bold text-white"
                                        >
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-muted-foreground">No places found.</p>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Pending Place Requests</h3>
                            <div class="space-y-3">
                                {% for place in bookingPendingPlaces %}
                                    {% set placePreviewImage = bookingPlacePreviewImages[place.id]|default(place.imageUrl) %}
                                    <article class="rounded-xl border border-border bg-background p-3">
                                        <div class="flex items-start gap-3">
                                            {% if placePreviewImage %}
                                                <img src="{{ placePreviewImage starts with('http') ? placePreviewImage : asset('uploads/places/' ~ placePreviewImage) }}" alt="{{ place.title }}" class="h-16 w-20 rounded-lg object-cover">
                                            {% endif %}
                                            <div class="min-w-0 flex-1">
                                                <p class="truncate text-sm font-semibold text-foreground">{{ place.title }}</p>
                                                <p class="truncate text-xs text-muted-foreground">{{ place.city }} · {{ place.host ? place.host.fullName : 'Unknown host' }}</p>
                                                <p class="mt-1 text-xs font-bold uppercase tracking-wider text-accent">{{ place.status }}</p>
                                            </div>
                                        </div>
                                        <div class="mt-3 flex flex-wrap items-center gap-2">
                                            <form method="post" action="{{ path('app_admin_place_approve', { id: place.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_place_approve_' ~ place.id) }}">
                                                <button type="submit" class="rounded-lg bg-primary px-3 py-1.5 text-xs font-bold text-white">Accept</button>
                                            </form>
                                            <form method="post" action="{{ path('app_admin_place_reject', { id: place.id }) }}" class="flex items-center gap-2">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_place_reject_' ~ place.id) }}">
                                                <input type="text" name="reason" placeholder="Reject reason (optional)" class="w-44 rounded-lg border border-border bg-secondary/20 px-2 py-1.5 text-xs">
                                                <button type="submit" class="rounded-lg bg-destructive px-3 py-1.5 text-xs font-bold text-white">Reject</button>
                                            </form>
                                        </div>
                                    </article>
                                {% else %}
                                    <p class="text-sm text-muted-foreground">No pending places right now.</p>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Recent Bookings</h3>
                            <div class="space-y-3">
                                {% for booking in bookingRecentBookings %}
                                    {% set place = booking.place %}
                                    {% set placePreviewImage = place ? bookingPlacePreviewImages[place.id]|default(place.imageUrl) : null %}
                                    <article class="rounded-xl border border-border bg-background p-3">
                                        <div class="flex items-start gap-3">
                                            {% if placePreviewImage %}
                                                <img src="{{ placePreviewImage starts with('http') ? placePreviewImage : asset('uploads/places/' ~ placePreviewImage) }}" alt="{{ place ? place.title : 'Place' }}" class="h-16 w-20 rounded-lg object-cover">
                                            {% endif %}
                                            <div class="min-w-0 flex-1">
                                                <p class="truncate text-sm font-semibold text-foreground">{{ place ? place.title : 'Unknown place' }}</p>
                                                <p class="truncate text-xs text-muted-foreground">Guest: {{ booking.guest ? booking.guest.fullName : 'Unknown user' }}</p>
                                                <p class="mt-1 text-xs text-muted-foreground">{{ booking.startDate|date('Y-m-d') }} to {{ booking.endDate|date('Y-m-d') }}</p>
                                                <p class="mt-1 text-xs font-bold uppercase tracking-wider text-primary">{{ booking.status }}</p>
                                            </div>
                                        </div>
                                    </article>
                                {% else %}
                                    <p class="text-sm text-muted-foreground">No bookings yet.</p>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <div id="marketplace-analytics" class="{{ activeSection == 'marketplace' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6 space-y-6">
                    <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Marketplace Analytics</h2>
                            <p class="text-sm text-muted-foreground">Seller and buyer activity, orders, and revenue in one view.</p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <a href="{{ path('app_marketplace_buyer') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-xs font-bold transition-colors hover:bg-secondary/50">Buyer View</a>
                            <a href="{{ path('app_marketplace_seller') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-xs font-bold transition-colors hover:bg-secondary/50">Seller View</a>
                            <a href="{{ path('app_admin_dashboard', { section: 'users' }) }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2 text-xs font-bold transition-colors hover:bg-secondary/50">Show Users</a>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Total Products</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ marketplaceStats.totalProducts }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Active Listings</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ marketplaceStats.activeListings }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Sellers</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-accent">{{ marketplaceStats.sellerCount }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-5">
                            <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Gross Revenue</p>
                            <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ marketplaceStats.grossRevenue|number_format(2) }} TND</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Orders Total</p>
                            <p class="mt-1 text-2xl font-heading font-bold text-foreground">{{ marketplaceStats.totalOrders }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Pending</p>
                            <p class="mt-1 text-2xl font-heading font-bold text-destructive">{{ marketplaceStats.pendingOrders }}</p>
                        </div>
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <p class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Confirmed</p>
                            <p class="mt-1 text-2xl font-heading font-bold text-primary">{{ marketplaceStats.confirmedOrders }}</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Orders Trend</h3>
                                <span class="text-xs text-muted-foreground">Last 7 days</span>
                            </div>
                            <div class="h-[260px] w-full">
                                <canvas id="marketplaceOrdersTrendChart" class="h-full w-full"></canvas>
                            </div>
                        </div>

                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Top Products</h3>
                            <div class="space-y-3">
                                {% for product in marketplaceTopProducts %}
                                    <div class="flex items-center justify-between rounded-xl border border-border bg-background px-4 py-3">
                                        <div class="min-w-0">
                                            <p class="truncate text-sm font-semibold text-foreground">{{ product.title }}</p>
                                            <p class="truncate text-xs text-muted-foreground">{{ product.category ?: 'Uncategorized' }}</p>
                                        </div>
                                        <div class="ml-3 shrink-0 text-right">
                                            <p class="text-sm font-bold text-primary">{{ product.sold_units }} sold</p>
                                            <p class="text-xs text-muted-foreground">{{ product.revenue|number_format(2) }} TND</p>
                                        </div>
                                    </div>
                                {% else %}
                                    <p class="text-sm text-muted-foreground">No product sales data yet.</p>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Recent Orders</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full min-w-[860px] border-collapse">
                                <thead>
                                <tr class="border-b border-border text-left">
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Order</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Customer</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">City</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Date</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Total</th>
                                    <th class="py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Status</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for order in marketplaceRecentOrders %}
                                    <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                        <td class="py-3 pr-3 text-sm font-semibold text-foreground">#{{ order.id_facture }}</td>
                                        <td class="py-3 pr-3 text-sm text-foreground">{{ order.customer_name ?: 'Unknown customer' }}</td>
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">{{ order.customer_city ?: '-' }}</td>
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">{{ order.date_facture|date('Y-m-d H:i') }}</td>
                                        <td class="py-3 pr-3 text-sm font-semibold text-foreground">{{ order.total_price|number_format(2) }} TND</td>
                                        <td class="py-3 text-sm">
                                            {% set status = order.delivery_status|lower %}
                                            <span class="inline-flex rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider {{ status == 'confirmed' ? 'bg-primary/10 text-primary' : (status == 'pending' ? 'bg-accent/20 text-accent' : 'bg-destructive/10 text-destructive') }}">{{ order.delivery_status }}</span>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="py-8 text-center text-sm text-muted-foreground">No marketplace orders yet.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-5 space-y-4">
                        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                            <div>
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Create Marketplace Product</h3>
                                <p class="text-xs text-muted-foreground">Admin can create listings for any active seller.</p>
                            </div>
                        </div>
                        <form method="post" action="{{ path('app_admin_marketplace_product_create') }}" class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_marketplace_product_create') }}">
                            <input type="text" name="title" required placeholder="Title" class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                            <input type="text" name="category" required placeholder="Category" class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                            <select name="type" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                <option value="For Sale">For Sale</option>
                                <option value="For Rent">For Rent</option>
                            </select>
                            <select name="user_id" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                <option value="">Select seller</option>
                                {% for seller in marketplaceSellerOptions %}
                                    <option value="{{ seller.id }}">{{ seller.full_name }} ({{ seller.email }})</option>
                                {% endfor %}
                            </select>
                            <input type="number" name="price" min="0.01" step="0.01" required placeholder="Price" class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                            <input type="number" name="quantity" min="0" required placeholder="Quantity" class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                            <input type="url" name="image" placeholder="Image URL (optional)" class="rounded-xl border border-border bg-background px-3 py-2 text-sm md:col-span-2">
                            <textarea name="description" rows="2" required placeholder="Product description" class="rounded-xl border border-border bg-background px-3 py-2 text-sm xl:col-span-3"></textarea>
                            <button type="submit" class="rounded-xl bg-primary px-4 py-2 text-sm font-bold text-white transition-colors hover:bg-primary/90">Create Product</button>
                        </form>
                    </div>

                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Manage Products (CRUD)</h3>
                        <div class="space-y-3">
                            {% for product in marketplaceProducts %}
                                <details class="rounded-xl border border-border bg-background p-3">
                                    <summary class="cursor-pointer list-none">
                                        <div class="flex flex-wrap items-center justify-between gap-3">
                                            <div class="min-w-0">
                                                <p class="truncate text-sm font-semibold text-foreground">{{ product.title }}</p>
                                                <p class="truncate text-xs text-muted-foreground">Seller: {{ product.seller_name }} · {{ product.type }} · {{ product.category }}</p>
                                            </div>
                                            <div class="flex items-center gap-2 text-xs">
                                                <span class="rounded-full bg-secondary/30 px-2.5 py-1 font-semibold text-foreground">{{ product.price|number_format(2) }} TND</span>
                                                <span class="rounded-full bg-primary/10 px-2.5 py-1 font-semibold text-primary">Qty {{ product.quantity }}</span>
                                                <span class="rounded-full bg-accent/20 px-2.5 py-1 font-semibold text-accent">Reserved {{ product.reserved_quantity }}</span>
                                            </div>
                                        </div>
                                    </summary>

                                    <div class="mt-3 space-y-3 border-t border-border/60 pt-3">
                                        <form method="post" action="{{ path('app_admin_marketplace_product_update', { id: product.id }) }}" class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_marketplace_product_update_' ~ product.id) }}">
                                            <input type="text" name="title" value="{{ product.title }}" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                            <input type="text" name="category" value="{{ product.category }}" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                            <select name="type" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                                <option value="For Sale" {% if product.type == 'For Sale' %}selected{% endif %}>For Sale</option>
                                                <option value="For Rent" {% if product.type == 'For Rent' %}selected{% endif %}>For Rent</option>
                                            </select>
                                            <select name="user_id" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                                {% for seller in marketplaceSellerOptions %}
                                                    <option value="{{ seller.id }}" {% if seller.id == product.userId %}selected{% endif %}>{{ seller.full_name }} ({{ seller.email }})</option>
                                                {% endfor %}
                                            </select>
                                            <input type="number" name="price" min="0.01" step="0.01" value="{{ product.price }}" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                            <input type="number" name="quantity" min="0" value="{{ product.quantity }}" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                            <input type="url" name="image" value="{{ product.image }}" placeholder="Image URL" class="rounded-xl border border-border bg-background px-3 py-2 text-sm md:col-span-2">
                                            <textarea name="description" rows="2" required class="rounded-xl border border-border bg-background px-3 py-2 text-sm xl:col-span-3">{{ product.description }}</textarea>
                                            <div class="flex gap-2">
                                                <button type="submit" class="rounded-xl bg-primary px-4 py-2 text-xs font-bold text-white">Save</button>
                                            </div>
                                        </form>

                                        <form method="post" action="{{ path('app_admin_marketplace_product_delete', { id: product.id }) }}" onsubmit="return confirm('Delete this product?');" class="flex justify-end">
                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_marketplace_product_delete_' ~ product.id) }}">
                                            <button type="submit" class="rounded-xl bg-destructive px-4 py-2 text-xs font-bold text-white">Delete Product</button>
                                        </form>
                                    </div>
                                </details>
                            {% else %}
                                <p class="text-sm text-muted-foreground">No products found. Create one above.</p>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="user-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-slate-950/60 px-4 py-8 backdrop-blur-sm">
    <div class="w-full max-w-3xl rounded-[2rem] border border-border bg-background shadow-2xl">
        <div class="flex items-start justify-between border-b border-border px-6 py-5">
            <div>
                <p class="text-xs font-bold uppercase tracking-[0.28em] text-primary">Administration</p>
                <h3 id="user-modal-title" class="mt-1 text-2xl font-heading font-bold text-foreground">Create User</h3>
                <p id="user-modal-subtitle" class="mt-1 text-sm text-muted-foreground">Add a user with avatar and 2FA settings.</p>
            </div>
            <button type="button" onclick="closeUserModal()" class="rounded-full p-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
            </button>
