                uploader.__resetUploader();
            }
        });
    }

    function getFieldLabel(field) {
        const wrapper = field.closest('.space-y-1, .space-y-2');
        const label = wrapper ? wrapper.querySelector('label') : null;
        return label ? label.textContent.trim() : (field.name || 'This field');
    }

    function getOrCreateErrorElement(field) {
        let errorElement = field.nextElementSibling;
        if (errorElement && errorElement.classList.contains('js-input-error')) {
            return errorElement;
        }

        errorElement = document.createElement('p');
        errorElement.className = 'js-input-error mt-1 text-xs font-semibold text-rose-600';
        field.insertAdjacentElement('afterend', errorElement);
        return errorElement;
    }

    function setFieldError(field, message) {
        const errorElement = getOrCreateErrorElement(field);
        errorElement.textContent = message;
        field.classList.add('border-rose-500');
    }

    function clearFieldError(field) {
        const errorElement = field.nextElementSibling;
        if (errorElement && errorElement.classList.contains('js-input-error')) {
            errorElement.remove();
        }
        field.classList.remove('border-rose-500');
    }

    function buildFieldErrorMessage(field) {
        const label = getFieldLabel(field);
        if (field.classList.contains('js-image-input') && field.required && (!field.files || field.files.length === 0)) {
            return label + ' is required.';
        }

        if (field.validity.valueMissing) {
            return label + ' is required.';
        }
        if (field.validity.typeMismatch) {
            return 'Please enter a valid ' + field.type + '.';
        }
        if (field.validity.rangeUnderflow) {
            return label + ' is below the minimum value.';
        }
        if (field.validity.rangeOverflow) {
            return label + ' is above the maximum value.';
        }
        if (field.validity.stepMismatch) {
            return label + ' has an invalid step value.';
        }
        if (field.validity.patternMismatch) {
            return label + ' format is invalid.';
        }

        return field.validationMessage || (label + ' is invalid.');
    }

    function validateField(field) {
        if (field.disabled || field.type === 'hidden' && !field.classList.contains('js-image-input')) {
            return true;
        }

        const isImageInput = field.classList.contains('js-image-input');
        const isValid = isImageInput
            ? (!field.required || (field.files && field.files.length > 0))
            : field.checkValidity();

        if (isValid) {
            clearFieldError(field);
            return true;
        }

        setFieldError(field, buildFieldErrorMessage(field));
        return false;
    }

    function resetFormErrors(form) {
        if (!form) {
            return;
        }

        form.querySelectorAll('.js-input-error').forEach((item) => item.remove());
        form.querySelectorAll('.border-rose-500').forEach((item) => item.classList.remove('border-rose-500'));
    }

    function initFormValidation() {
        document.querySelectorAll('form[data-validate-form]').forEach((form) => {
            if (form.dataset.validationInitialized === '1') {
                return;
            }

            form.dataset.validationInitialized = '1';
            const fields = form.querySelectorAll('input, select, textarea');

            fields.forEach((field) => {
                if (field.type === 'hidden' && !field.classList.contains('js-image-input')) {
                    return;
                }

                const eventName = field.tagName === 'SELECT' || field.type === 'file' ? 'change' : 'input';
                field.addEventListener(eventName, () => validateField(field));
                field.addEventListener('blur', () => validateField(field));
            });

            form.addEventListener('submit', (event) => {
                let firstInvalid = null;

                fields.forEach((field) => {
                    const valid = validateField(field);
                    if (!valid && !firstInvalid) {
                        firstInvalid = field;
                    }
                });

                if (firstInvalid) {
                    event.preventDefault();
                    if (!firstInvalid.classList.contains('js-image-input')) {
                        firstInvalid.focus();
                    }
                }
            });
        });
    }

    function initLocationPicker(config) {
        if (typeof L === 'undefined') {
            return null;
        }

        const addressInput = document.getElementById(config.addressId);
        const latitudeInput = document.getElementById(config.latitudeId);
        const longitudeInput = document.getElementById(config.longitudeId);
        const suggestionsBox = document.getElementById(config.suggestionsId);
        const mapContainer = document.getElementById(config.mapId);

        if (!addressInput || !latitudeInput || !longitudeInput || !suggestionsBox || !mapContainer) {
            return null;
        }

        const initialLat = parseFloat(latitudeInput.value) || 36.8065;
        const initialLng = parseFloat(longitudeInput.value) || 10.1815;
        const map = L.map(mapContainer, {
            maxBounds: tunisiaBounds,
            maxBoundsViscosity: 1.0,
            minZoom: 6,
            maxZoom: 19,
        }).setView([initialLat, initialLng], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors',
        }).addTo(map);

        const marker = L.marker([initialLat, initialLng], { draggable: true }).addTo(map);

        const updateCoordinates = (lat, lng) => {
            const boundedLat = Math.min(37.6, Math.max(30.1, Number(lat)));
            const boundedLng = Math.min(11.8, Math.max(7.4, Number(lng)));
            latitudeInput.value = boundedLat.toFixed(8);
            longitudeInput.value = boundedLng.toFixed(8);
            marker.setLatLng([boundedLat, boundedLng]);
            map.setView([boundedLat, boundedLng], 14);
        };

        marker.on('dragend', () => {
            const position = marker.getLatLng();
            updateCoordinates(position.lat, position.lng);
        });

        let debounceTimer = null;

        const clearSuggestions = () => {
            suggestionsBox.innerHTML = '';
            suggestionsBox.classList.add('hidden');
        };

        const renderSuggestions = (items) => {
            suggestionsBox.innerHTML = '';
            if (!Array.isArray(items) || items.length === 0) {
                clearSuggestions();
                return;
            }

            items.forEach((item) => {
                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'location-suggestion-item';
                button.textContent = item.name;
                button.addEventListener('click', () => {
                    addressInput.value = item.name;
                    updateCoordinates(parseFloat(item.latitude), parseFloat(item.longitude));
                    clearSuggestions();
                });
                suggestionsBox.appendChild(button);
            });

            suggestionsBox.classList.remove('hidden');
        };

        const mapNominatimItems = (items) => {
            if (!Array.isArray(items)) {
                return [];
            }

            return items
                .map((item) => ({
                    name: item.name || item.display_name || '',
                    latitude: item.latitude || item.lat || '',
                    longitude: item.longitude || item.lon || '',
                }))
                .filter((item) => item.name && item.latitude && item.longitude);
        };

        const searchLocationsDirectly = async (query) => {
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=jsonv2&addressdetails=1&countrycodes=tn&limit=8&q=' + encodeURIComponent(query), {
                headers: { 'Accept': 'application/json' },
            });

            if (!response.ok) {
                return [];
            }

            const data = await response.json();
            return mapNominatimItems(data);
        };

        const searchLocations = async (query) => {
            try {
                const response = await fetch(locationSearchUrl + '?q=' + encodeURIComponent(query), {
                    headers: { 'Accept': 'application/json' },
                });

                let items = [];
                if (response.ok) {
                    const data = await response.json();
                    items = mapNominatimItems(data.items || []);
                }

                if (items.length === 0) {
                    items = await searchLocationsDirectly(query);
                }

                renderSuggestions(items);
            } catch (error) {
                try {
                    const fallbackItems = await searchLocationsDirectly(query);
                    renderSuggestions(fallbackItems);
                } catch (fallbackError) {
                    clearSuggestions();
                }
            }
        };

        addressInput.addEventListener('input', () => {
            const query = addressInput.value.trim();
            if (debounceTimer) {
                window.clearTimeout(debounceTimer);
            }

            if (query.length < 3) {
                clearSuggestions();
                return;
            }

            debounceTimer = window.setTimeout(() => searchLocations(query), 250);
        });

        document.addEventListener('click', (event) => {
            if (!addressInput.closest('[data-location-picker]')?.contains(event.target)) {
                clearSuggestions();
            }
        });

        latitudeInput.addEventListener('change', () => {
            const lat = parseFloat(latitudeInput.value);
            const lng = parseFloat(longitudeInput.value);
            if (Number.isFinite(lat) && Number.isFinite(lng)) {
                updateCoordinates(lat, lng);
            }
        });

        longitudeInput.addEventListener('change', () => {
            const lat = parseFloat(latitudeInput.value);
            const lng = parseFloat(longitudeInput.value);
            if (Number.isFinite(lat) && Number.isFinite(lng)) {
                updateCoordinates(lat, lng);
            }
        });

        window.setTimeout(() => map.invalidateSize(), 300);

        return {
            refresh: function () {
                window.setTimeout(() => map.invalidateSize(), 160);
            },
        };
    }

