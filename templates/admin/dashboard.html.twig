    function setAvatarPreview(src, seed) {
        if (src) {
            userAvatarImage.src = src;
        } else {
            userAvatarImage.src = 'https://api.dicebear.com/7.x/avataaars/svg?seed=' + encodeURIComponent(seed || 'Wanderlust');
        }

        userAvatarImage.classList.remove('hidden');
        userAvatarPlaceholder.classList.add('hidden');
    }

    function previewModalAvatar(event) {
        const file = event.target.files && event.target.files[0];
        if (!file) {
            return;
        }

        const reader = new FileReader();
        reader.onload = function () {
            userAvatarImage.src = reader.result;
            userAvatarImage.classList.remove('hidden');
            userAvatarPlaceholder.classList.add('hidden');
        };
        reader.readAsDataURL(file);
    }

    function initImageUploaders() {
        document.querySelectorAll('[data-image-uploader]').forEach((uploader) => {
            if (uploader.dataset.initialized === '1') {
                return;
            }

            const trigger = uploader.querySelector('.js-upload-trigger');
            const input = uploader.querySelector('.js-image-input');
            const grid = uploader.querySelector('.js-image-preview-grid');
            if (!trigger || !input || !grid) {
                return;
            }

            uploader.dataset.initialized = '1';
            let selectedFiles = [];

            const syncInputFiles = () => {
                const dataTransfer = new DataTransfer();
                selectedFiles.forEach((file) => dataTransfer.items.add(file));
                input.files = dataTransfer.files;
            };

            const appendSelectedFiles = (newFiles) => {
                const existingKeys = new Set(selectedFiles.map((file) => file.name + '|' + file.size + '|' + file.lastModified));
                newFiles.forEach((file) => {
                    const key = file.name + '|' + file.size + '|' + file.lastModified;
                    if (!existingKeys.has(key)) {
                        selectedFiles.push(file);
                        existingKeys.add(key);
                    }
                });
            };

            const renderSelectedFiles = () => {
                grid.innerHTML = '';

                selectedFiles.forEach((file, index) => {
                    const url = URL.createObjectURL(file);
                    const card = document.createElement('div');
                    card.className = 'relative';
                    card.innerHTML = '<img src="' + url + '" alt="selected image" class="h-14 w-full rounded-lg object-cover"><button type="button" class="js-remove-selected-image absolute -right-1 -top-1 h-5 w-5 rounded-full bg-destructive text-[11px] font-bold text-white">x</button>';

                    const removeButton = card.querySelector('.js-remove-selected-image');
                    removeButton.addEventListener('click', () => {
                        selectedFiles.splice(index, 1);
                        syncInputFiles();
                        renderSelectedFiles();
                    });

                    grid.appendChild(card);
                });
            };

            trigger.addEventListener('click', () => input.click());
            input.addEventListener('change', () => {
                appendSelectedFiles(Array.from(input.files || []));
                syncInputFiles();
                renderSelectedFiles();
            });

            uploader.__resetUploader = () => {
                selectedFiles = [];
                syncInputFiles();
                renderSelectedFiles();
            };
        });
    }

    function resetUploadersInContainer(container) {
        if (!container) {
            return;
        }

        container.querySelectorAll('[data-image-uploader]').forEach((uploader) => {
            if (typeof uploader.__resetUploader === 'function') {
                uploader.__resetUploader();
            }
        });
    }

    function getFieldLabel(field) {
        const wrapper = field.closest('.space-y-1, .space-y-2');
        const label = wrapper ? wrapper.querySelector('label') : null;
        return label ? label.textContent.trim() : (field.name || 'This field');
    }

    function getOrCreateErrorElement(field) {
        let errorElement = field.nextElementSibling;
        if (errorElement && errorElement.classList.contains('js-input-error')) {
            return errorElement;
        }

        errorElement = document.createElement('p');
        errorElement.className = 'js-input-error mt-1 text-xs font-semibold text-rose-600';
        field.insertAdjacentElement('afterend', errorElement);
        return errorElement;
    }

    function setFieldError(field, message) {
        const errorElement = getOrCreateErrorElement(field);
        errorElement.textContent = message;
        field.classList.add('border-rose-500');
    }

    function clearFieldError(field) {
        const errorElement = field.nextElementSibling;
        if (errorElement && errorElement.classList.contains('js-input-error')) {
            errorElement.remove();
        }
        field.classList.remove('border-rose-500');
    }

    function buildFieldErrorMessage(field) {
        const label = getFieldLabel(field);
        if (field.classList.contains('js-image-input') && field.required && (!field.files || field.files.length === 0)) {
            return label + ' is required.';
        }

        if (field.validity.valueMissing) {
            return label + ' is required.';
        }
        if (field.validity.typeMismatch) {
            return 'Please enter a valid ' + field.type + '.';
        }
        if (field.validity.rangeUnderflow) {
            return label + ' is below the minimum value.';
        }
        if (field.validity.rangeOverflow) {
            return label + ' is above the maximum value.';
        }
        if (field.validity.stepMismatch) {
            return label + ' has an invalid step value.';
        }
        if (field.validity.patternMismatch) {
            return label + ' format is invalid.';
        }

        return field.validationMessage || (label + ' is invalid.');
    }

    function validateField(field) {
        if (field.disabled || field.type === 'hidden' && !field.classList.contains('js-image-input')) {
            return true;
        }

        const isImageInput = field.classList.contains('js-image-input');
        const isValid = isImageInput
            ? (!field.required || (field.files && field.files.length > 0))
            : field.checkValidity();

        if (isValid) {
            clearFieldError(field);
            return true;
        }

        setFieldError(field, buildFieldErrorMessage(field));
        return false;
    }

    function resetFormErrors(form) {
        if (!form) {
            return;
        }

        form.querySelectorAll('.js-input-error').forEach((item) => item.remove());
        form.querySelectorAll('.border-rose-500').forEach((item) => item.classList.remove('border-rose-500'));
    }

    function initFormValidation() {
        document.querySelectorAll('form[data-validate-form]').forEach((form) => {
            if (form.dataset.validationInitialized === '1') {
                return;
            }

            form.dataset.validationInitialized = '1';
            const fields = form.querySelectorAll('input, select, textarea');

            fields.forEach((field) => {
                if (field.type === 'hidden' && !field.classList.contains('js-image-input')) {
                    return;
                }

                const eventName = field.tagName === 'SELECT' || field.type === 'file' ? 'change' : 'input';
                field.addEventListener(eventName, () => validateField(field));
                field.addEventListener('blur', () => validateField(field));
            });

            form.addEventListener('submit', (event) => {
                let firstInvalid = null;

                fields.forEach((field) => {
                    const valid = validateField(field);
                    if (!valid && !firstInvalid) {
                        firstInvalid = field;
                    }
                });

                if (firstInvalid) {
                    event.preventDefault();
                    if (!firstInvalid.classList.contains('js-image-input')) {
                        firstInvalid.focus();
                    }
                }
            });
        });
    }

    function initExistingImageRemoval() {
        document.querySelectorAll('.js-existing-image-item').forEach((item) => {
            if (item.dataset.initialized === '1') {
                return;
            }

            const removeButton = item.querySelector('.js-remove-existing-image');
            const checkbox = item.querySelector('.js-existing-image-checkbox');
            if (!removeButton || !checkbox) {
                return;
            }

            item.dataset.initialized = '1';
            removeButton.addEventListener('click', () => {
                checkbox.checked = true;
                item.classList.add('hidden');
            });
        });
    }

    function renderExistingImagesInEditModal(existingImagesJson) {
        if (!placeEditExistingImagesGrid || !placeEditExistingImagesEmpty) {
            return;
        }

        let existingImages = [];
        try {
            existingImages = JSON.parse(existingImagesJson || '[]');
        } catch (error) {
            existingImages = [];
        }

        placeEditExistingImagesGrid.innerHTML = '';

        if (!Array.isArray(existingImages) || existingImages.length === 0) {
            placeEditExistingImagesEmpty.classList.remove('hidden');
            return;
        }

        placeEditExistingImagesEmpty.classList.add('hidden');

        existingImages.forEach((image) => {
            const imageUrl = String(image.url || '');
            const resolvedUrl = imageUrl.startsWith('http') ? imageUrl : placeUploadsBaseUrl + imageUrl;
            const wrapper = document.createElement('div');
            wrapper.className = 'js-existing-image-item relative overflow-hidden rounded-xl border border-border bg-background';
            wrapper.innerHTML = `
                <img src="${resolvedUrl}" alt="Existing place image" class="h-20 w-full object-cover">
                <input type="checkbox" name="remove_image_ids[]" value="${image.id}" class="js-existing-image-checkbox hidden">
                <button type="button" class="js-remove-existing-image absolute right-1 top-1 rounded-full bg-destructive px-2 py-1 text-[10px] font-bold text-white shadow">X</button>
            `;
            placeEditExistingImagesGrid.appendChild(wrapper);
        });

        initExistingImageRemoval();
    }

    userModal.addEventListener('click', function (event) {
        if (event.target === userModal) {
            closeUserModal();
        }
    });

    if (placeModal) {
        placeModal.addEventListener('click', function (event) {
            if (event.target === placeModal) {
                closeCreatePlaceModal();
            }
        });
    }

    if (placeEditModal) {
        placeEditModal.addEventListener('click', function (event) {
            if (event.target === placeEditModal) {
                closeEditPlaceModal();
            }
        });
    }

    if (placeDeleteModal) {
        placeDeleteModal.addEventListener('click', function (event) {
            if (event.target === placeDeleteModal) {
                closeDeletePlaceModal();
            }
        });
    }

    document.addEventListener('keydown', function (event) {
        if (event.key !== 'Escape') {
            return;
        }

        if (!userModal.classList.contains('hidden')) {
            closeUserModal();
        }

        if (placeModal && !placeModal.classList.contains('hidden')) {
            closeCreatePlaceModal();
        }

        if (placeEditModal && !placeEditModal.classList.contains('hidden')) {
            closeEditPlaceModal();
        }

        if (placeDeleteModal && !placeDeleteModal.classList.contains('hidden')) {
            closeDeletePlaceModal();
        }
    });

    {% if activeSection == 'users' %}
    initUserCharts();
    {% endif %}
    {% if activeSection == 'messaging' %}
    initMessagingCharts();
    {% endif %}
    {% if activeSection == 'marketplace' %}
    initMarketplaceCharts();
    {% endif %}
    initImageUploaders();
    initExistingImageRemoval();
    initFormValidation();
</script>
{% endblock %}
