                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ item.cancelled_at|date('Y-m-d H:i:s') }}</td>
                                                    <td class="py-3 pr-3 text-xs font-semibold text-foreground">#{{ item.id }}</td>
                                                    <td class="py-3 pr-3 text-xs text-foreground">{{ item.place_title ?: ('Place #' ~ item.place_id) }}{% if item.place_city %} · {{ item.place_city }}{% endif %}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ item.start_date|date('Y-m-d') }} to {{ item.end_date|date('Y-m-d') }}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ item.total_price }}</td>
                                                    <td class="py-3 text-xs text-muted-foreground">{{ item.created_at|date('Y-m-d H:i:s') }}</td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="6" class="py-8 text-center text-sm text-muted-foreground">No booking cancellations tracked for this user.</td>
                                                </tr>
                                            {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>

                                <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                    <div class="mb-3 flex items-center justify-between gap-2">
