                                <div class="mb-3 flex items-center justify-between">
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Message Types</h3>
                                    <span class="text-xs text-muted-foreground">Distribution</span>
                                </div>
                                <div class="h-[210px] w-full">
                                    <canvas id="messageTypesChart" class="h-full w-full"></canvas>
