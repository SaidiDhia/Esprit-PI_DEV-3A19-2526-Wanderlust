                                    <article class="rounded-xl border border-border bg-background p-3">
                                        <div class="flex items-start gap-3">
                                            {% if placePreviewImage %}
                                                <img src="{{ placePreviewImage starts with('http') ? placePreviewImage : asset('uploads/places/' ~ placePreviewImage) }}" alt="{{ place.title }}" class="h-16 w-20 rounded-lg object-cover">
                                            {% endif %}
                                            <div class="min-w-0 flex-1">
                                                <p class="truncate text-sm font-semibold text-foreground">{{ place.title }}</p>
                                                <p class="truncate text-xs text-muted-foreground">{{ place.city }} · {{ place.host ? place.host.fullName : 'Unknown host' }}</p>
                                                <p class="mt-1 text-xs font-bold uppercase tracking-wider text-accent">{{ place.status }}</p>
                                            </div>
                                        </div>
                                        <div class="mt-3 flex flex-wrap items-center gap-2">
                                            <form method="post" action="{{ path('app_admin_place_approve', { id: place.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_place_approve_' ~ place.id) }}">
                                                <button type="submit" class="rounded-lg bg-primary px-3 py-1.5 text-xs font-bold text-white">Accept</button>
                                            </form>
                                            <form method="post" action="{{ path('app_admin_place_reject', { id: place.id }) }}" class="flex items-center gap-2">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_place_reject_' ~ place.id) }}">
                                                <input type="text" name="reason" placeholder="Reject reason (optional)" class="w-44 rounded-lg border border-border bg-secondary/20 px-2 py-1.5 text-xs">
                                                <button type="submit" class="rounded-lg bg-destructive px-3 py-1.5 text-xs font-bold text-white">Reject</button>
