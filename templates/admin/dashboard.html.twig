                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Booking</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Cancelled For</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Stay</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Amount</th>
                                                <th class="py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Created</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% for item in activityUserInsights.cancellation_tracking.recent_cancellations %}
