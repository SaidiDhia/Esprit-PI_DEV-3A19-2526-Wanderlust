    function openCreateUserModal() {
        userForm.action = '{{ path('app_admin_user_create') }}';
        userFormToken.value = '{{ csrf_token('admin_user_create') }}';
        userModalTitle.textContent = 'Create User';
        userModalSubtitle.textContent = 'Add a user with avatar and 2FA settings.';
        userModalSubmit.textContent = 'Create User';
        userPassword.required = true;
        userPassword.value = '';
        userPassword.placeholder = 'Upper+lower+number';
        userRole.value = 'PARTICIPANT';
        userTfaMethod.value = 'NONE';
        userFullName.value = '';
        userEmail.value = '';
        userPhoneNumber.value = '';
        profileInput.value = '';
        setAvatarPreview('', 'Wanderlust');
        userModal.classList.remove('hidden');
        userModal.classList.add('flex');
    }

    function openEditUserModal(button) {
        const data = button.dataset;
        userForm.action = data.updateUrl;
        userFormToken.value = data.updateToken;
        userModalTitle.textContent = 'Edit User';
        userModalSubtitle.textContent = 'Update account details, avatar, role, and 2FA.';
        userModalSubmit.textContent = 'Save Changes';
        userPassword.required = false;
        userPassword.value = '';
        userPassword.placeholder = 'Leave blank to keep current password';
        userFullName.value = data.fullName || '';
        userEmail.value = data.email || '';
        userPhoneNumber.value = data.phoneNumber || '';
        userRole.value = data.role || 'PARTICIPANT';
        userTfaMethod.value = data.tfaMethod || 'NONE';
        profileInput.value = '';
        setAvatarPreview(data.avatarSrc || '', data.fullName || 'Wanderlust');
        userModal.classList.remove('hidden');
        userModal.classList.add('flex');
    }

    function closeUserModal() {
        userModal.classList.add('hidden');
        userModal.classList.remove('flex');
    }

    function openCreatePlaceModal() {
        if (!placeModal) {
            return;
        }

        placeModal.classList.remove('hidden');
        placeModal.classList.add('flex');
    }

    function closeCreatePlaceModal() {
        if (!placeModal) {
            return;
        }

        placeModal.classList.add('hidden');
        placeModal.classList.remove('flex');
    }

    function openEditPlaceModal(button) {
        if (!placeEditModal || !placeEditForm || !placeEditToken) {
            return;
        }

        const data = button.dataset;
        placeEditForm.action = data.updateUrl || '';
        placeEditToken.value = data.updateToken || '';

        document.getElementById('place-edit-title').value = data.title || '';
        document.getElementById('place-edit-host').value = data.hostId || '';
        document.getElementById('place-edit-status').value = data.status || 'PENDING';
        document.getElementById('place-edit-city').value = data.city || '';
        document.getElementById('place-edit-category').value = data.category || '';
        document.getElementById('place-edit-price').value = data.pricePerDay || '';
        document.getElementById('place-edit-capacity').value = data.capacity || '';
        document.getElementById('place-edit-max-guests').value = data.maxGuests || '';
        document.getElementById('place-edit-address').value = data.address || '';
        document.getElementById('place-edit-latitude').value = data.latitude || '36.80650000';
        document.getElementById('place-edit-longitude').value = data.longitude || '10.18150000';
        document.getElementById('place-edit-description').value = data.description || '';

        resetFormErrors(placeEditForm);
        resetUploadersInContainer(placeEditModal);
        renderExistingImagesInEditModal(data.existingImages || '[]');

        placeEditModal.classList.remove('hidden');
        placeEditModal.classList.add('flex');
    }

    function closeEditPlaceModal() {
        if (!placeEditModal) {
            return;
        }

        placeEditModal.classList.add('hidden');
        placeEditModal.classList.remove('flex');
    }

    function openDeletePlaceModal(button) {
        if (!placeDeleteModal || !placeDeleteForm || !placeDeleteToken || !placeDeleteName) {
            return;
        }

        const data = button.dataset;
        placeDeleteForm.action = data.deleteUrl || '';
        placeDeleteToken.value = data.deleteToken || '';
        placeDeleteName.textContent = data.placeTitle ? 'Place: ' + data.placeTitle : '';

        placeDeleteModal.classList.remove('hidden');
        placeDeleteModal.classList.add('flex');
    }

    function closeDeletePlaceModal() {
        if (!placeDeleteModal) {
            return;
        }

        placeDeleteModal.classList.add('hidden');
        placeDeleteModal.classList.remove('flex');
