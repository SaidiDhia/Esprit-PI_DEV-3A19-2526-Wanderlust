                        <div class="flex flex-wrap items-center gap-2">
                            <a href="{{ path('app_activities_new') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">New Activity</a>
                            <a href="{{ path('app_events_new') }}" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">New Event</a>
