{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard — Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        .location-suggestions {
            position: absolute;
            z-index: 45;
            top: calc(100% + 6px);
            left: 0;
            right: 0;
            max-height: 210px;
            overflow-y: auto;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            background: #ffffff;
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12);
        }

        .location-suggestion-item {
            width: 100%;
            display: block;
            text-align: left;
            border: 0;
            border-bottom: 1px solid #e2e8f0;
            background: transparent;
            padding: 10px 12px;
            cursor: pointer;
            font-size: 0.82rem;
            color: #0f172a;
        }

        .location-suggestion-item:last-child {
            border-bottom: 0;
        }

        .location-suggestion-item:hover {
            background: #f8fafc;
        }

        .location-map {
            height: 220px;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            overflow: hidden;
        }
    </style>
{% endblock %}

{% block content %}
<section class="min-h-[calc(100vh-64px)] bg-white px-4 py-10">
    <div class="container mx-auto space-y-8">
        {% for message in app.flashes('success') %}
            <div class="rounded-xl border border-primary/30 bg-primary/10 px-4 py-3 text-sm font-medium text-primary">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="rounded-xl border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm font-medium text-destructive">{{ message }}</div>
        {% endfor %}

        {% if highRiskRecentAlerts|default([]) is not empty %}
            <div class="rounded-2xl border border-destructive/30 bg-destructive/10 p-5">
                <div class="mb-3 flex items-center justify-between gap-3">
                    <h2 class="text-lg font-heading font-bold text-destructive">High-Risk Recent Activities</h2>
                    <div class="flex flex-wrap items-center gap-2">
                        <form method="post" action="{{ path('app_admin_dashboard_ack_alerts') }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_recent_risk_alert_ack') }}">
                            {% for alert in highRiskRecentAlerts %}
                                <input type="hidden" name="alert_ids[]" value="{{ alert.id }}">
                            {% endfor %}
                            <button type="submit" class="rounded-full bg-destructive/20 px-3 py-1 text-xs font-bold uppercase tracking-wider text-destructive transition-colors hover:bg-destructive/30">Mark visible as read</button>
                        </form>
                        <span class="rounded-full bg-destructive/20 px-3 py-1 text-xs font-bold uppercase tracking-wider text-destructive">Alert</span>
                    </div>
                </div>
                <div class="space-y-2">
                    {% for alert in highRiskRecentAlerts %}
                        <article class="rounded-xl border border-destructive/20 bg-white/80 px-3 py-2 text-sm">
                            <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
                                <span class="rounded-full bg-destructive/10 px-2 py-0.5 font-bold uppercase tracking-wider text-destructive">{{ alert.module }}</span>
                                <span>{{ alert.action|replace({'_': ' '}) }}</span>
                                {% set severityScore = (alert.severity_score ?? 0) + 0 %}
                                {% set severityLabel = severityScore >= 95 ? 'Critical' : (severityScore >= 85 ? 'High' : 'Elevated') %}
                                {% set severityClass = severityScore >= 95
                                    ? 'bg-destructive/20 text-destructive border border-destructive/30'
                                    : (severityScore >= 85
                                        ? 'bg-orange-100 text-orange-700 border border-orange-300'
                                        : 'bg-amber-100 text-amber-700 border border-amber-300') %}
                                <span class="rounded-full px-2 py-0.5 font-bold uppercase tracking-wider {{ severityClass }}">{{ severityLabel }} {{ severityScore|number_format(0) }}</span>
                                <span>{{ alert.created_at|date('Y-m-d H:i:s') }}</span>
                            </div>
                            <p class="mt-1 text-sm text-foreground">{{ alert.content ? alert.content|slice(0, 170) : 'High-risk event without content payload.' }}</p>
                            <div class="mt-2 flex flex-wrap items-center gap-3">
                                {% if alert.user_id %}
                                    <a href="{{ path('app_admin_dashboard', { section: 'activity_logs', activity_user: alert.user_id }) }}" class="inline-flex text-xs font-bold text-primary hover:underline">Open user activity log</a>
                                {% endif %}
                                <form method="post" action="{{ path('app_admin_dashboard_ack_alerts') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_recent_risk_alert_ack') }}">
                                    <input type="hidden" name="alert_ids[]" value="{{ alert.id }}">
                                    <button type="submit" class="inline-flex text-xs font-bold text-destructive hover:underline">Mark read</button>
                                </form>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Total users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-foreground">{{ stats.total }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Active users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-primary">{{ stats.active }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">Banned users</p>
                <p class="mt-2 text-3xl font-heading font-bold text-destructive">{{ stats.banned }}</p>
            </div>
            <div class="rounded-2xl border border-border bg-card p-5">
                <p class="text-xs font-bold uppercase tracking-widest text-muted-foreground">New this month</p>
                <p class="mt-2 text-3xl font-heading font-bold text-accent">{{ stats.newThisMonth }}</p>
            </div>
        </div>

        <div class="grid grid-cols-1 gap-6 xl:grid-cols-[280px_1fr]">
            <aside class="rounded-[2rem] border border-border bg-card p-6 xl:sticky xl:top-24 xl:h-fit">
                <div class="mb-6">
                    <p class="text-xs font-bold uppercase tracking-[0.28em] text-primary">Navigation</p>
                    <h2 class="mt-2 text-xl font-heading font-bold text-foreground">Modules</h2>
                    <p class="mt-1 text-sm text-muted-foreground">Use this sidebar to move between platform sections.</p>
                </div>

                <nav class="space-y-2">
                    <a href="{{ path('app_admin_dashboard', { section: 'users' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-bold transition-colors {{ activeSection == 'users' ? 'border-primary/30 bg-primary/15 text-primary shadow-sm' : 'border-primary/20 bg-transparent text-foreground hover:bg-secondary/40' }}">
                        <span>Admin Dashboard</span>
                        {% if activeSection == 'users' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'marketplace' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'marketplace' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Marketplace</span>
                        {% if activeSection == 'marketplace' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_booking') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Booking</a>
                    <a href="{{ path('app_activities_index') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Activities</a>
                    <a href="{{ path('app_blog') }}" class="block rounded-xl border border-border px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-secondary/40">Blog</a>
                    <a href="{{ path('app_admin_dashboard', { section: 'messaging' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'messaging' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Messaging</span>
                        {% if activeSection == 'messaging' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'booking' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'booking' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Booking</span>
                        {% if activeSection == 'booking' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'experiences' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'experiences' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Experiences</span>
                        {% if activeSection == 'experiences' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'risk' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'risk' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Risk Monitor</span>
                        {% if activeSection == 'risk' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'activity_logs' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'activity_logs' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Activity Logs</span>
                        {% if activeSection == 'activity_logs' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                    <a href="{{ path('app_admin_dashboard', { section: 'activity_feed' }) }}" class="flex items-center justify-between rounded-xl border px-4 py-3 text-sm font-semibold transition-colors {{ activeSection == 'activity_feed' ? 'border-primary/30 bg-primary/15 font-bold text-primary shadow-sm' : 'border-border text-foreground hover:bg-secondary/40' }}">
                        <span>Platform Feed</span>
                        {% if activeSection == 'activity_feed' %}
                            <span class="rounded-md bg-primary/20 px-2 py-0.5 text-[10px] uppercase tracking-wider text-primary">Current</span>
                        {% endif %}
                    </a>
                </nav>

                <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-3 xl:grid-cols-1">
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Admins</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.admins }}</p>
                    </div>
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Hosts</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.hosts }}</p>
                    </div>
                    <div class="rounded-xl border border-border bg-secondary/20 p-3">
                        <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Travelers</p>
                        <p class="mt-1 text-xl font-heading font-bold text-foreground">{{ stats.participants }}</p>
                    </div>
                </div>
            </aside>

            <div class="space-y-6">
                <div id="activity-feed" class="{{ activeSection == 'activity_feed' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6">
                    <div class="mb-4 flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Platform Activity Feed</h2>
                            <p class="text-sm text-muted-foreground">Latest actions from booking, messaging, marketplace, and authentication modules.</p>
                        </div>
                        <span class="rounded-full bg-secondary/30 px-3 py-1 text-xs font-bold uppercase tracking-wider text-foreground">Live Audit</span>
                    </div>

                    <div class="space-y-3">
                        {% for item in systemActivityFeed %}
                            <article class="rounded-2xl border border-border/80 bg-secondary/10 p-4">
                                <div class="flex items-start gap-3">
                                    {% set feedAvatar = item.user_avatar ? asset('uploads/profiles/' ~ item.user_avatar) : ('https://api.dicebear.com/7.x/avataaars/svg?seed=' ~ (item.user_name ?: 'Guest')|url_encode) %}
                                    <img src="{{ feedAvatar }}" alt="{{ item.user_name ?: 'Unknown user' }}" class="h-11 w-11 rounded-full border border-border object-cover">
                                    <div class="min-w-0 flex-1">
                                        <div class="flex flex-wrap items-center gap-2 text-xs">
                                            <span class="rounded-full bg-primary/10 px-2.5 py-1 font-bold uppercase tracking-wider text-primary">{{ item.module }}</span>
                                            <span class="rounded-full bg-secondary/40 px-2.5 py-1 font-bold uppercase tracking-wider text-foreground">{{ item.action|replace({'_': ' '}) }}</span>
                                            <span class="text-muted-foreground">{{ item.created_at|date('Y-m-d H:i:s') }}</span>
                                        </div>
                                        <p class="mt-2 text-sm text-foreground">
                                            {% if item.user_id %}
                                                <a href="{{ path('app_admin_dashboard', { section: 'activity_logs', activity_user: item.user_id }) }}" class="font-bold text-primary hover:underline">{{ item.user_name ?: 'Unknown user' }}</a>
                                            {% else %}
                                                <span class="font-bold">{{ item.user_name ?: 'Unknown user' }}</span>
                                            {% endif %}
                                            {% if item.target_name %}
                                                · {{ item.target_name }}
                                            {% endif %}
                                        </p>
                                        {% if item.content %}
                                            <p class="mt-1 rounded-lg bg-background px-3 py-2 text-xs text-muted-foreground">{{ item.content|slice(0, 220) }}</p>
                                        {% endif %}
                                        <div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
                                            {% if item.destination %}
                                                <span>To: {{ item.destination }}</span>
                                            {% endif %}
                                            {% if item.target_id %}
                                                <span>ID: {{ item.target_id }}</span>
                                            {% endif %}
                                            {% if item.target_type %}
                                                <span>Type: {{ item.target_type }}</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if item.target_image %}
                                        <div class="hidden shrink-0 sm:block">
                                            <img src="{{ item.target_image starts with('http') ? item.target_image : asset('uploads/places/' ~ item.target_image) }}" alt="{{ item.target_name ?: 'Target image' }}" class="h-14 w-20 rounded-lg border border-border object-cover">
                                        </div>
                                    {% endif %}
                                </div>
                            </article>
                        {% else %}
                            <p class="rounded-xl border border-border bg-secondary/10 px-4 py-6 text-center text-sm text-muted-foreground">No platform activity yet. Actions will appear here after users interact with booking, messaging, auth, and marketplace modules.</p>
                        {% endfor %}
                    </div>
                </div>

                <div id="users-section" class="{{ activeSection == 'users' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6">
                    <form method="get" action="{{ path('app_admin_dashboard') }}" class="grid grid-cols-1 gap-3 md:grid-cols-4">
                        <input type="text" name="q" value="{{ filters.q }}" placeholder="Search name, email, phone" class="md:col-span-2 rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                        <select name="role" class="rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                            <option value="">All roles</option>
                            {% for role in roles %}
                                <option value="{{ role.value }}" {% if filters.role == role.value %}selected{% endif %}>{{ role.label }}</option>
                            {% endfor %}
                        </select>
                        <select name="status" class="rounded-xl border border-border bg-secondary/30 px-3 py-2 text-sm">
                            <option value="">Any status</option>
                            <option value="active" {% if filters.status == 'active' %}selected{% endif %}>Active</option>
                            <option value="banned" {% if filters.status == 'banned' %}selected{% endif %}>Banned</option>
                        </select>
                        <button type="submit" class="md:col-span-4 rounded-xl border border-border px-3 py-2 text-sm font-semibold transition-colors hover:bg-secondary/50">Apply Filters</button>
                    </form>
                </div>

                <div class="{{ activeSection == 'users' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6">
                    <div class="mb-5 flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
                            <h2 class="text-xl font-heading font-bold text-foreground">Users</h2>
                            <p class="text-sm text-muted-foreground">Click Edit to open a modal, update avatars, passwords, roles, and 2FA values.</p>
                        </div>
                        <button type="button" onclick="openCreateUserModal()" class="inline-flex items-center gap-2 rounded-xl border border-border px-4 py-2.5 text-sm font-bold transition-colors hover:bg-secondary/50">
                            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
                            New User
                        </button>
                    </div>

                    <div class="mb-6 grid grid-cols-1 gap-4 xl:grid-cols-2">
                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Users by Role</h3>
                                <span class="text-xs text-muted-foreground">Circle chart</span>
                            </div>
                            <div class="mx-auto h-[260px] w-full max-w-[320px]">
                                <canvas id="usersRoleChart" class="h-full w-full"></canvas>
                            </div>
                        </div>

                        <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                            <div class="mb-3 flex items-center justify-between">
                                <h3 class="text-sm font-bold uppercase tracking-wider text-foreground">Users Trend</h3>
                                <span class="text-xs text-muted-foreground">Curve chart</span>
                            </div>
                            <div class="h-[260px] w-full">
                                <canvas id="usersTrendChart" class="h-full w-full"></canvas>
                            </div>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[1100px] border-collapse">
                            <thead>
                            <tr class="border-b border-border text-left">
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">User</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Role</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">2FA</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Status</th>
                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Created</th>
                                <th class="py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for user in users %}
                                {% set protectedUser = user.isAdmin or app.user.id == user.id %}
                                {% set avatarSrc = user.profilePicture ? asset('uploads/profiles/' ~ user.profilePicture) : 'https://api.dicebear.com/7.x/avataaars/svg?seed=' ~ user.fullName|url_encode %}
                                <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                    <td class="py-4 pr-3">
                                        <div class="flex items-center gap-4">
                                            <div class="h-14 w-14 shrink-0 overflow-hidden rounded-full border-2 border-border bg-secondary/20">
                                                <img src="{{ avatarSrc }}" alt="{{ user.fullName }}" class="h-full w-full object-cover">
                                            </div>
                                            <div class="min-w-0">
                                                <p class="truncate font-semibold text-foreground">{{ user.fullName }}</p>
                                                <p class="truncate text-sm text-muted-foreground">{{ user.email }}</p>
                                                <p class="truncate text-xs text-muted-foreground">{{ user.phoneNumber ?: 'No phone number' }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 pr-3 text-sm font-medium text-foreground">{{ user.roleLabel }}</td>
                                    <td class="py-4 pr-3 text-sm text-muted-foreground">{{ user.tfaLabel }}</td>
                                    <td class="py-4 pr-3">
                                        {% if user.isIsActive %}
                                            <span class="inline-flex rounded-full bg-primary/10 px-3 py-1 text-xs font-bold text-primary">Active</span>
                                        {% else %}
                                            <span class="inline-flex rounded-full bg-destructive/10 px-3 py-1 text-xs font-bold text-destructive">Banned</span>
                                        {% endif %}
                                    </td>
                                    <td class="py-4 pr-3 text-sm text-muted-foreground">{{ user.createdAt|date('Y-m-d H:i') }}</td>
                                    <td class="py-4">
                                        <div class="flex flex-wrap items-center gap-2">
                                            {% if user.roleValue == 'HOST' %}
                                                <a href="{{ path('app_booking_host_view', { id: user.id }) }}" class="rounded-xl bg-sky-600 px-3 py-2 text-xs font-bold text-white transition-opacity hover:opacity-90">
                                                    Host Dashboard
                                                </a>
                                            {% endif %}
                                            <button
                                                type="button"
                                                onclick="openEditUserModal(this)"
                                                data-update-url="{{ path('app_admin_user_update', { id: user.id }) }}"
                                                data-update-token="{{ csrf_token('admin_user_update_' ~ user.id) }}"
                                                data-id="{{ user.id }}"
                                                data-full-name="{{ user.fullName|e('html_attr') }}"
                                                data-email="{{ user.email|e('html_attr') }}"
                                                data-phone-number="{{ user.phoneNumber|default('')|e('html_attr') }}"
                                                data-role="{{ user.roleValue }}"
                                                data-tfa-method="{{ user.tfaValue }}"
                                                data-avatar-src="{{ user.profilePicture ? asset('uploads/profiles/' ~ user.profilePicture) : '' }}"
                                                class="rounded-xl bg-foreground px-3 py-2 text-xs font-bold text-background transition-opacity hover:opacity-90"
                                            >
                                                Edit
                                            </button>

                                            <a href="{{ path('app_admin_dashboard', { section: 'activity_logs', activity_user: user.id }) }}" class="rounded-xl bg-primary/10 px-3 py-2 text-xs font-bold text-primary transition-colors hover:bg-primary/20">
                                                Activity Logs
                                            </a>

                                            <form method="post" action="{{ path('app_admin_user_toggle_ban', { id: user.id }) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_ban_' ~ user.id) }}">
                                                <button type="submit" class="rounded-xl px-3 py-2 text-xs font-bold {{ protectedUser ? 'cursor-not-allowed bg-muted text-muted-foreground' : (user.isIsActive ? 'bg-destructive/10 text-destructive hover:bg-destructive/20' : 'bg-primary/10 text-primary hover:bg-primary/20') }}" {% if protectedUser %}disabled title="Protected user"{% endif %}>
                                                    {{ user.isIsActive ? 'Ban' : 'Unban' }}
                                                </button>
                                            </form>

                                            <form method="post" action="{{ path('app_admin_user_delete', { id: user.id }) }}" onsubmit="return confirm('Delete this user? This action cannot be undone.');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('admin_user_delete_' ~ user.id) }}">
                                                <button type="submit" class="rounded-xl px-3 py-2 text-xs font-bold {{ protectedUser ? 'cursor-not-allowed bg-muted text-muted-foreground' : 'bg-destructive text-white hover:bg-destructive/90' }}" {% if protectedUser %}disabled title="Protected user"{% endif %}>Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="py-10 text-center text-sm text-muted-foreground">No users found for current filters.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
