                                            <p>First seen: <span class="font-semibold text-foreground">{{ activityUserInsights.summary.first_activity_at ? activityUserInsights.summary.first_activity_at|date('Y-m-d H:i:s') : 'n/a' }}</span></p>
                                            <p>Last seen: <span class="font-semibold text-foreground">{{ activityUserInsights.summary.last_activity_at ? activityUserInsights.summary.last_activity_at|date('Y-m-d H:i:s') : 'n/a' }}</span></p>
                                        </div>
                                    </div>
                                </div>

                                <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                    <div class="mb-3 flex items-center justify-between gap-2">
