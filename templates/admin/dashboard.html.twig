<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
    const userModal = document.getElementById('user-modal');
    const userForm = document.getElementById('user-form');
    const userModalTitle = document.getElementById('user-modal-title');
    const userModalSubtitle = document.getElementById('user-modal-subtitle');
    const userModalSubmit = document.getElementById('user-modal-submit');
    const userFormToken = document.getElementById('user-form-token');
    const userFullName = document.getElementById('user-fullName');
    const userEmail = document.getElementById('user-email');
    const userPhoneNumber = document.getElementById('user-phoneNumber');
    const userRole = document.getElementById('user-role');
    const userTfaMethod = document.getElementById('user-tfaMethod');
    const userPassword = document.getElementById('user-password');
    const userAvatarImage = document.getElementById('user-avatar-image');
    const userAvatarPlaceholder = document.getElementById('user-avatar-placeholder');
    const profileInput = document.getElementById('user-profile-picture');
    const placeModal = document.getElementById('place-modal');
    const placeEditModal = document.getElementById('place-edit-modal');
    const placeDeleteModal = document.getElementById('place-delete-modal');
    const placeEditForm = document.getElementById('place-edit-form');
    const placeEditToken = document.getElementById('place-edit-token');
    const placeEditExistingImagesGrid = document.getElementById('place-edit-existing-images-grid');
    const placeEditExistingImagesEmpty = document.getElementById('place-edit-existing-images-empty');
    const placeDeleteForm = document.getElementById('place-delete-form');
    const placeDeleteToken = document.getElementById('place-delete-token');
    const placeDeleteName = document.getElementById('place-delete-name');
    const placeUploadsBaseUrl = '{{ asset('uploads/places/') }}';
    const locationSearchUrl = '{{ path('app_booking_location_search') }}';
    const tunisiaBounds = L.latLngBounds([30.1, 7.4], [37.6, 11.8]);

    function initUserCharts() {
        if (typeof Chart === 'undefined') {
            return;
        }

        const roleChartElement = document.getElementById('usersRoleChart');
        if (roleChartElement) {
            new Chart(roleChartElement, {
                type: 'doughnut',
                data: {
                    labels: ['Admins', 'Hosts', 'Travelers'],
                    datasets: [{
                        data: [{{ stats.admins }}, {{ stats.hosts }}, {{ stats.participants }}],
                        backgroundColor: ['#0ea5e9', '#f59e0b', '#10b981'],
                        borderColor: ['#0ea5e9', '#f59e0b', '#10b981'],
                        borderWidth: 1,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                boxWidth: 8,
                            },
                        },
                    },
                },
            });
        }

        const trendChartElement = document.getElementById('usersTrendChart');
        if (trendChartElement) {
            const userCreationDates = [{% for user in users %}'{{ user.createdAt|date('Y-m-d') }}'{% if not loop.last %}, {% endif %}{% endfor %}];
            const now = new Date();
            const labels = [];
            const counts = [];

            for (let i = 5; i >= 0; i--) {
                const date = new Date(now.getFullYear(), now.getMonth() - i, 1);
                const year = date.getFullYear();
                const month = date.getMonth();
                const label = date.toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
                labels.push(label);

                let monthlyCount = 0;
                userCreationDates.forEach((value) => {
                    const createdAt = new Date(value + 'T00:00:00');
                    if (createdAt.getFullYear() === year && createdAt.getMonth() === month) {
                        monthlyCount++;
                    }
                });

                counts.push(monthlyCount);
            }

            new Chart(trendChartElement, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: 'New Users',
                        data: counts,
                        borderColor: '#0ea5e9',
                        backgroundColor: 'rgba(14, 165, 233, 0.16)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false,
                        },
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                precision: 0,
                            },
                        },
                    },
                },
            });
        }
    }

    function initMessagingCharts() {
        if (typeof Chart === 'undefined') {
            return;
        }

        const messagesPerDayElement = document.getElementById('messagesPerDayChart');
        if (messagesPerDayElement) {
            const messagesPerDayData = {{ messagesPerDayChart|json_encode|raw }};
            new Chart(messagesPerDayElement, {
                type: 'line',
                data: {
                    labels: messagesPerDayData.map((item) => item.label),
                    datasets: [{
                        label: 'Messages',
                        data: messagesPerDayData.map((item) => item.count),
                        borderColor: '#1e4ed8',
                        backgroundColor: 'rgba(30, 78, 216, 0.14)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                },
            });
        }

        const conversationTypesElement = document.getElementById('conversationTypesChart');
        if (conversationTypesElement) {
            const conversationTypesData = {{ conversationTypeChartData|json_encode|raw }};
            new Chart(conversationTypesElement, {
                type: 'doughnut',
                data: {
                    labels: conversationTypesData.map((item) => item.label),
                    datasets: [{
                        data: conversationTypesData.map((item) => item.count),
                        backgroundColor: ['#1e4ed8', '#60a5fa', '#93c5fd', '#dbeafe'],
                        borderColor: ['#1e4ed8', '#60a5fa', '#93c5fd', '#dbeafe'],
                        borderWidth: 1,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, boxWidth: 8 } } },
                },
            });
        }

        const messageTypesElement = document.getElementById('messageTypesChart');
        if (messageTypesElement) {
            const messageTypesData = {{ messageTypeChartData|json_encode|raw }};
            new Chart(messageTypesElement, {
                type: 'bar',
                data: {
                    labels: messageTypesData.map((item) => item.label),
                    datasets: [{
                        label: 'Messages',
                        data: messageTypesData.map((item) => item.count),
                        backgroundColor: '#1e4ed8',
                        borderRadius: 8,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                },
            });
        }
    }

    function initMarketplaceCharts() {
        if (typeof Chart === 'undefined') {
            return;
        }

        const marketplaceOrdersTrendElement = document.getElementById('marketplaceOrdersTrendChart');
        if (marketplaceOrdersTrendElement) {
            const ordersTrendData = {{ marketplaceOrdersPerDay|json_encode|raw }};
            new Chart(marketplaceOrdersTrendElement, {
                type: 'line',
                data: {
                    labels: ordersTrendData.map((item) => item.label),
                    datasets: [{
                        label: 'Orders',
                        data: ordersTrendData.map((item) => item.count),
                        borderColor: '#0ea5e9',
                        backgroundColor: 'rgba(14, 165, 233, 0.14)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                },
            });
        }
    }

    function initExperienceCharts() {
        if (typeof Chart === 'undefined') {
            return;
        }

        const reservationTrendElement = document.getElementById('experienceReservationTrendChart');
        if (reservationTrendElement) {
            const trendData = {{ experienceReservationTrend|json_encode|raw }};
            new Chart(reservationTrendElement, {
                type: 'line',
                data: {
                    labels: trendData.map((item) => item.label),
                    datasets: [{
                        label: 'Reservations',
                        data: trendData.map((item) => item.count),
                        borderColor: '#16a34a',
                        backgroundColor: 'rgba(22, 163, 74, 0.14)',
                        fill: true,
                        tension: 0.35,
                        pointRadius: 3,
                        pointHoverRadius: 5,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                },
            });
