                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Recent Messaging Activity</h3>
                        <div class="overflow-x-auto">
                            <table class="w-full min-w-[900px] border-collapse">
                                <thead>
                                <tr class="border-b border-border text-left">
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Time</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">User</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Conversation</th>
                                    <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Content</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for activity in recentActivity %}
                                    <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">{{ activity.created_at|date('H:i:s') }}</td>
                                        <td class="py-3 pr-3 text-sm text-foreground">{{ activity.sender_name ?: activity.sender_id|slice(0,8) }}</td>
                                        <td class="py-3 pr-3 text-sm text-foreground">{{ activity.conversation_name ?: '#' ~ activity.conversation_id }}</td>
                                        <td class="py-3 pr-3 text-sm text-muted-foreground">
                                            {% if activity.message_type == 'TEXT' %}
                                                {{ activity.content|slice(0, 50) }}
                                            {% elseif activity.message_type == 'IMAGE' %}
                                                📷 Image
                                            {% elseif activity.message_type == 'VIDEO' %}
                                                🎥 Video
                                            {% elseif activity.message_type == 'AUDIO' %}
                                                🎵 Audio
                                            {% else %}
                                                📎 File
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="4" class="py-8 text-center text-sm text-muted-foreground">No recent messaging activity.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div id="booking-analytics" class="{{ activeSection == 'booking' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6 space-y-6">
