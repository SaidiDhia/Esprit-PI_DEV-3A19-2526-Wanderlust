{% extends 'base.html.twig' %}



{% block title %}Admin Dashboard - Wonderlust{% endblock %}



{% block stylesheets %}

{{ parent() }}

<style>

    :root {

        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

        --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);

        --warning-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);

        --card-shadow: 0 10px 40px rgba(0,0,0,0.1);

        --hover-shadow: 0 20px 60px rgba(0,0,0,0.15);

        --border-radius: 20px;

    }



    .admin-wrapper {

        display: flex;

        min-height: 100vh;

        background: #f8f9fa;

    }



    .admin-sidebar {

        width: 280px;

        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);

        color: white;

        position: fixed;

        height: 100vh;

        overflow-y: auto;

        transition: all 0.3s ease;

        z-index: 1000;

    }



    .admin-sidebar-header {

        padding: 1.5rem;

        text-align: center;

        border-bottom: 1px solid rgba(255,255,255,0.1);

    }



    .admin-sidebar-header h3 {

        margin: 0;

        font-size: 1.5rem;

        font-weight: 700;

    }



    .admin-sidebar-header p {

        margin: 0.5rem 0 0;

        font-size: 0.8rem;

        opacity: 0.7;

    }



    .admin-nav {

        list-style: none;

        padding: 1rem 0;

        margin: 0;

    }



    .admin-nav-item {

        margin: 0.25rem 1rem;

    }



    .admin-nav-link {

        display: flex;

        align-items: center;

        padding: 0.75rem 1rem;

        color: rgba(255,255,255,0.8);

        text-decoration: none;

        border-radius: 12px;

        transition: all 0.3s ease;

    }



    .admin-nav-link i {

        width: 24px;

        margin-right: 12px;

        font-size: 1.1rem;

    }



    .admin-nav-link:hover {

        background: rgba(255,255,255,0.1);

        color: white;

    }



    .admin-nav-link.active {

        background: var(--primary-gradient);

        color: white;

        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);

    }



    .admin-content {

        flex: 1;

        margin-left: 280px;

        padding: 2rem;

    }



    .stat-card {

        background: white;

        border-radius: var(--border-radius);

        padding: 1.5rem;

        box-shadow: var(--card-shadow);

        transition: all 0.3s ease;

        height: 100%;

        border: none;

    }



    .stat-card:hover {

        transform: translateY(-5px);

        box-shadow: var(--hover-shadow);

    }



    .stat-icon {

        width: 60px;

        height: 60px;

        border-radius: 15px;

        display: flex;

        align-items: center;

        justify-content: center;

        font-size: 1.8rem;

        margin-bottom: 1rem;

    }



    .stat-icon.blue { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; }

    .stat-icon.green { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; }

    .stat-icon.orange { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; }

    .stat-icon.purple { background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); color: #764ba2; }



    .stat-value {

        font-size: 2rem;

        font-weight: 700;

        margin: 0;

    }



    .stat-label {

        color: #6c757d;

        margin: 0;

        font-size: 0.9rem;

    }



    .chart-card {

        background: white;

        border-radius: var(--border-radius);

        padding: 1.5rem;

        box-shadow: var(--card-shadow);

        margin-bottom: 1.5rem;

        height: 100%;

    }



    .chart-title {

        font-size: 1.1rem;

        font-weight: 600;

        margin-bottom: 1rem;

        padding-bottom: 0.5rem;

        border-bottom: 2px solid #e9ecef;

    }



    .event-list {

        list-style: none;

        padding: 0;

        margin: 0;

    }



    .event-item {

        display: flex;

        align-items: center;

        justify-content: space-between;

        padding: 1rem;

        border-bottom: 1px solid #e9ecef;

        transition: all 0.3s ease;

    }



    .event-item:hover {

        background: #f8f9fa;

    }



    .event-info h6 {

        margin: 0;

        font-size: 0.95rem;

    }



    .event-info small {

        color: #6c757d;

        font-size: 0.8rem;

    }



    .status-badge {

        padding: 4px 12px;

        border-radius: 20px;

        font-size: 0.7rem;

        font-weight: 600;

    }



    .status-badge.en_attente { background: #ffc107; color: #856404; }

    .status-badge.accepte { background: #28a745; color: white; }

    .status-badge.refuse { background: #dc3545; color: white; }



    .progress-custom {

        height: 8px;

        border-radius: 4px;

        background: #e9ecef;

        overflow: hidden;

    }



    .progress-custom-bar {

        height: 100%;

        border-radius: 4px;

        transition: width 0.3s ease;

    }



    .category-bar {

        margin-bottom: 1rem;

    }



    .category-label {

        display: flex;

        justify-content: space-between;

        margin-bottom: 0.25rem;

        font-size: 0.85rem;

    }



    .admin-table {

        width: 100%;

        border-collapse: collapse;

        margin-bottom: 0;

    }



    .admin-table th,

    .admin-table td {

        padding: 0.9rem 1rem;

        border-bottom: 1px solid #e9ecef;

        vertical-align: middle;

    }



    .admin-table th {

        background: #f8f9fa;

        font-weight: 600;

    }



    .admin-table tr:hover {

        background: #f8f9fa;

    }



    .status-select {

        padding: 0.4rem 0.75rem;

        border-radius: 20px;

        border: 1px solid #dee2e6;

        font-size: 0.85rem;

        width: 100%;

        max-width: 180px;

    }



    .admin-action-buttons .btn {

        padding: 0.25rem 0.5rem;

        margin-right: 0.25rem;

    }



    .admin-table .badge-category {

        display: inline-block;

        padding: 0.35rem 0.7rem;

        border-radius: 999px;

        background: rgba(102,126,234,0.12);

        color: #333;

        font-size: 0.8rem;

    }



    @media (max-width: 768px) {

        .admin-sidebar {

            transform: translateX(-100%);

        }

        .admin-sidebar.open {

            transform: translateX(0);

        }

        .admin-content {

            margin-left: 0;

        }

    }

</style>

{% endblock %}



{% block content %}

<div class="admin-wrapper">

    <aside class="admin-sidebar">

        <div class="admin-sidebar-header">

            <h3>🏜️ Wonderlust</h3>

            <p>Administration Panel</p>

        </div>



        <ul class="admin-nav">

            <li class="admin-nav-item">

                <a href="{{ path('admin_dashboard') }}" class="admin-nav-link active">

                    <i class="fas fa-chart-line"></i>

                    Dashboard

                </a>

            </li>

            <li class="admin-nav-item">

                <a href="{{ path('admin_activities') }}" class="admin-nav-link">

                    <i class="fas fa-hiking"></i>

                    Activités

                </a>

            </li>

            <li class="admin-nav-item">

                <a href="{{ path('admin_events') }}" class="admin-nav-link">

                    <i class="fas fa-calendar-alt"></i>

                    Événements

                </a>

            </li>

            <li class="admin-nav-item">

                <a href="{{ path('app_home') }}" class="admin-nav-link">

                    <i class="fas fa-arrow-left"></i>

                    Retour au site

                </a>

            </li>

        </ul>

    </aside>



    <main class="admin-content">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h1 class="h3 mb-0">Tableau de bord</h1>

            <div class="text-muted">

                <i class="fas fa-calendar-alt me-1"></i>

                {{ "now"|date("d/m/Y") }}

            </div>

        </div>



        <div class="row g-4 mb-4">

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-icon blue">

                        <i class="fas fa-hiking"></i>

                    </div>

                    <h3 class="stat-value">{{ totalActivities }}</h3>

                    <p class="stat-label">Activités totales</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-icon green">

                        <i class="fas fa-calendar-alt"></i>

                    </div>

                    <h3 class="stat-value">{{ totalEvents }}</h3>

                    <p class="stat-label">Événements totaux</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-icon orange">

                        <i class="fas fa-ticket-alt"></i>

                    </div>

                    <h3 class="stat-value">{{ totalReservations }}</h3>

                    <p class="stat-label">Réservations</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-card">

                    <div class="stat-icon purple">

                        <i class="fas fa-euro-sign"></i>

                    </div>

                    <h3 class="stat-value">{{ totalRevenue|number_format(2) }} €</h3>

                    <p class="stat-label">Chiffre d'affaires</p>

                </div>

            </div>

        </div>



        <div class="row g-4">

            <div class="col-md-6">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-chart-pie me-2 text-primary"></i>

                        Événements par statut

                    </h5>

                    <canvas id="eventsStatusChart" width="400" height="300"></canvas>

                </div>

            </div>

            <div class="col-md-6">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-chart-bar me-2 text-success"></i>

                        Activités par catégorie

                    </h5>

                    <canvas id="activitiesCategoryChart" width="400" height="300"></canvas>

                </div>

            </div>

        </div>



        <div class="row g-4 mt-2">

            <div class="col-md-6">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-clock me-2 text-warning"></i>

                        Événements à venir

                    </h5>

                    {% if upcomingEvents|length > 0 %}

                        <ul class="event-list">

                            {% for event in upcomingEvents %}

                                <li class="event-item">

                                    <div class="event-info">

                                        <h6>{{ event.titre }}</h6>

                                        <small>

                                            <i class="fas fa-map-marker-alt me-1"></i>{{ event.lieu }} |

                                            <i class="fas fa-calendar me-1"></i>{{ event.dateDebut|date('d/m/Y') }}

                                        </small>

                                    </div>

                                    <span class="status-badge {{ event.statut }}">

                                        {{ event.statutLabel }}

                                    </span>

                                </li>

                            {% endfor %}

                        </ul>

                    {% else %}

                        <p class="text-muted text-center py-4">Aucun événement à venir</p>

                    {% endif %}

                </div>

            </div>

            <div class="col-md-6">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-receipt me-2 text-info"></i>

                        Dernières réservations

                    </h5>

                    {% if recentReservations|length > 0 %}

                        <ul class="event-list">

                            {% for reservation in recentReservations %}

                                <li class="event-item">

                                    <div class="event-info">

                                        <h6>{{ reservation.nomComplet }}</h6>

                                        <small>

                                            <i class="fas fa-envelope me-1"></i>{{ reservation.email }} |

                                            <i class="fas fa-users me-1"></i>{{ reservation.nombrePersonnes }} pers.

                                        </small>

                                    </div>

                                    <span class="status-badge {{ reservation.statut }}">

                                        {{ reservation.statutLabel }}

                                    </span>

                                </li>

                            {% endfor %}

                        </ul>

                    {% else %}

                        <p class="text-muted text-center py-4">Aucune réservation récente</p>

                    {% endif %}

                </div>

            </div>

        </div>



        <div class="row g-4 mt-2">

            <div class="col-md-12">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-chart-simple me-2 text-primary"></i>

                        Répartition des activités par catégorie

                    </h5>

                    {% for category, count in activitiesByCategory %}

                        <div class="category-bar">

                            <div class="category-label">

                                <span>{{ category }}</span>

                                <span>{{ count }} activité{{ count > 1 ? 's' : '' }}</span>

                            </div>

                            <div class="progress-custom">

                                <div class="progress-custom-bar" style="width: {{ totalActivities ? (count / totalActivities) * 100 : 0 }}%; background: linear-gradient(135deg, #667eea, #764ba2);"></div>

                            </div>

                        </div>

                    {% endfor %}

                </div>

            </div>

        </div>



        <div class="row g-4 mt-4">

            <div class="col-md-6">

                <div class="chart-card">

                    <h5 class="chart-title">

                        <i class="fas fa-chart-pie me-2 text-info"></i>

                        Répartition des activités par statut

                    </h5>

                </div>

                <div class="chart-container">

                    <canvas id="activitiesStatusChart" width="400" height="300"></canvas>

                </div>

            </div>

            <div class="col-md-6">

                <div class="chart-card">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h5 class="chart-title mb-0">

                            <i class="fas fa-hiking me-2 text-primary"></i>

                            Gestion des Activités

                        </h5>

                        <a href="{{ path('app_activities_new') }}" class="btn btn-sm btn-primary">

                            <i class="fas fa-plus me-1"></i> Ajouter une activité

                        </a>

                    </div>

                    <table class="admin-table">

                        <thead>

                            <tr>

                                <th>ID</th>

                                <th>Titre</th>

                                <th>Catégorie</th>

                                <th>Type</th>

                                <th>Date création</th>

                                <th>Statut</th>

                                <th>Actions</th>

                            </tr>

                        </thead>

                        <tbody>

                            {% for activity in activities %}

                                <tr>

                                    <td>{{ activity.id }}</td>

                                    <td>{{ activity.titre }}</td>

                                    <td><span class="badge-category">{{ activity.categorie ? activity.categorie.value : 'Non classé' }}</span></td>

                                    <td>{{ activity.typeActivite }}</td>

                                    <td>{{ activity.dateCreation ? activity.dateCreation|date('d/m/Y') : 'N/A' }}</td>

                                    <td>

                                        <span class="status-badge {{ activity.status.value }}">

                                            {% if activity.status.value == 'en_attente' %}En attente

                                            {% elseif activity.status.value == 'accepte' %}Accepté

                                            {% else %}Refusé

                                            {% endif %}

                                        </span>

                                    </td>

                                    <td class="admin-action-buttons">

                                        <form method="post" action="{{ path('admin_activity_change_status', {'id': activity.id, 'status': '__STATUS__'}) }}" class="status-form" data-activity-id="{{ activity.id }}">

                                            <input type="hidden" name="_token" value="{{ csrf_token('change_status' ~ activity.id) }}">

                                            <select class="status-select {{ activity.status.value }}" onchange="changeActivityStatus(this)">

                                                <option value="en_attente" {{ activity.status.value == 'en_attente' ? 'selected' : '' }}>En attente</option>

                                                <option value="accepte" {{ activity.status.value == 'accepte' ? 'selected' : '' }}>Accepté</option>

                                                <option value="refuse" {{ activity.status.value == 'refuse' ? 'selected' : '' }}>Refusé</option>

                                            </select>

                                        </form>

                                        <a href="{{ path('app_activities_show', {'id': activity.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir"><i class="fas fa-eye"></i></a>

                                        <a href="{{ path('app_activities_edit', {'id': activity.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier"><i class="fas fa-edit"></i></a>

                                        <form method="post" action="{{ path('app_activities_delete', {'id': activity.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette activité ?')" style="display: inline;">

                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activity.id) }}">

                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">

                                                <i class="fas fa-trash"></i>

                                            </button>

                                        </form>

                                    </td>

                                </tr>

                            {% else %}

                                <tr>

                                    <td colspan="7" class="text-center py-4">Aucune activité trouvée</td>

                                </tr>

                            {% endfor %}

                        </tbody>

                    </table>

                </div>

            </div>

        </div>



        <div class="row g-4 mt-4">

            <div class="col-lg-6">

                <div class="chart-card">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h5 class="chart-title mb-0">

                            <i class="fas fa-hiking me-2 text-primary"></i>

                            Gestion des Activités

                        </h5>

                        <a href="{{ path('app_activities_new') }}" class="btn btn-sm btn-primary">

                            <i class="fas fa-plus me-1"></i> Nouvelle activité

                        </a>

                    </div>

                    <div class="table-responsive">

                        <table class="admin-table">

                            <thead>

                                <tr>

                                    <th>ID</th>

                                    <th>Titre</th>

                                    <th>Catégorie</th>

                                    <th>Type</th>

                                    <th>Date création</th>

                                    <th>Actions</th>

                                </tr>

                            </thead>

                            <tbody>

                                {% for activity in activities %}

                                    <tr>

                                        <td>{{ activity.id }}</td>

                                        <td>{{ activity.titre }}</td>

                                        <td><span class="badge-category">{{ activity.categorie ? activity.categorie.value : 'Non classé' }}</span></td>

                                        <td>{{ activity.typeActivite }}</td>

                                        <td>{{ activity.dateCreation ? activity.dateCreation|date('d/m/Y') : 'N/A' }}</td>

                                        <td>

                                            <span class="status-badge {{ activity.status.value }}">

                                                {% if activity.status.value == 'en_attente' %}En attente

                                                {% elseif activity.status.value == 'accepte' %}Accepté

                                                {% else %}Refusé

                                                {% endif %}

                                            </span>

                                        </td>

                                        <td class="admin-action-buttons">

                                            <form method="post" action="{{ path('admin_activity_change_status', {'id': activity.id, 'status': '__STATUS__'}) }}" class="status-form" data-activity-id="{{ activity.id }}">

                                                <input type="hidden" name="_token" value="{{ csrf_token('change_status' ~ activity.id) }}">

                                                <select class="status-select {{ activity.status.value }}" onchange="changeActivityStatus(this)">

                                                    <option value="en_attente" {{ activity.status.value == 'en_attente' ? 'selected' : '' }}>En attente</option>

                                                    <option value="accepte" {{ activity.status.value == 'accepte' ? 'selected' : '' }}>Accepté</option>

                                                    <option value="refuse" {{ activity.status.value == 'refuse' ? 'selected' : '' }}>Refusé</option>

                                                </select>

                                            </form>

                                            <a href="{{ path('app_activities_show', {'id': activity.id}) }}" class="btn btn-sm btn-outline-primary" title="Voir"><i class="fas fa-eye"></i></a>

                                            <a href="{{ path('app_activities_edit', {'id': activity.id}) }}" class="btn btn-sm btn-outline-warning" title="Modifier"><i class="fas fa-edit"></i></a>

                                            <form method="post" action="{{ path('app_activities_delete', {'id': activity.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette activité ?')" style="display: inline;">

                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ activity.id) }}">

                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">

                                                    <i class="fas fa-trash"></i>

                                                </button>

                                            </form>

                                        </td>

                                    </tr>

                                {% else %}

                                    <tr>

                                        <td colspan="7" class="text-center py-4">Aucune activité trouvée</td>

                                    </tr>

                                {% endfor %}

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

            <div class="col-lg-6">

                <div class="chart-card">

                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <h5 class="chart-title mb-0">

                            <i class="fas fa-calendar-alt me-2 text-primary"></i>

                            Gestion des Événements

                        </h5>

                        <a href="{{ path('app_events_new') }}" class="btn btn-sm btn-primary">

                            <i class="fas fa-plus me-1"></i> Nouvel événement

                        </a>

                    </div>

                    <div class="table-responsive">

                        <table class="admin-table">

                            <thead>

                                <tr>

                                    <th>ID</th>

                                    <th>Organisateur</th>

                                    <th>Lieu</th>

                                    <th>Dates</th>

                                    <th>Places</th>

                                    <th>Statut</th>

                                </tr>

                            </thead>

                            <tbody>

                                {% for event in events %}

                                    <tr>

                                        <td>{{ event.id }}</td>

                                        <td>{{ event.organisateur }}</td>

                                        <td>{{ event.lieu }}</td>

                                        <td>{{ event.dateDebut ? event.dateDebut|date('d/m/Y') : 'N/A' }} - {{ event.dateFin ? event.dateFin|date('d/m/Y') : 'N/A' }}</td>

                                        <td>{{ event.placesDisponibles }}/{{ event.capaciteMax }}</td>

                                        <td>

                                            <form method="post" action="{{ path('admin_event_change_status', {'id': event.id, 'status': '__STATUS__'}) }}" class="status-form" data-event-id="{{ event.id }}">

                                                <input type="hidden" name="_token" value="{{ csrf_token('change_status' ~ event.id) }}">

                                                <select class="status-select {{ event.statut }}" onchange="changeStatus(this)">

                                                    <option value="en_attente" {{ event.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>

                                                    <option value="accepte" {{ event.statut == 'accepte' ? 'selected' : '' }}>Accepté</option>

                                                    <option value="refuse" {{ event.statut == 'refuse' ? 'selected' : '' }}>Refusé</option>

                                                </select>

                                            </form>

                                        </td>

                                    </tr>

                                {% else %}

                                    <tr>

                                        <td colspan="6" class="text-center py-4">Aucun événement trouvé</td>

                                    </tr>

                                {% endfor %}

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>



            <!-- Réservations Section -->

            <div class="col-12">

                <div class="admin-card">

                    <div class="card-header">

                        <h5 class="mb-0">

                            <i class="fas fa-receipt me-2 text-info"></i>

                            Réservations

                        </h5>

                        <span class="badge bg-info">{{ reservations|length }} réservations</span>

                    </div>

                    <div class="table-responsive">

                        <table class="admin-table">

                            <thead>

                                <tr>

                                    <th>ID</th>

                                    <th>Nom</th>

                                    <th>Email</th>

                                    <th>Événement</th>

                                    <th>Places</th>

                                    <th>Prix</th>

                                    <th>Statut</th>

                                    <th>Date</th>

                                </tr>

                            </thead>

                            <tbody>

                                {% for reservation in reservations %}

                                    <tr>

                                        <td>{{ reservation.id }}</td>

                                        <td>{{ reservation.nomComplet }}</td>

                                        <td>{{ reservation.email }}</td>

                                        <td>

                                            {% if reservation.event %}

                                                {{ reservation.event.lieu }}

                                            {% else %}

                                                N/A

                                            {% endif %}

                                        </td>

                                        <td>{{ reservation.nombrePersonnes }}</td>

                                        <td>{{ reservation.prixTotal }} €</td>

                                        <td>

                                            <form method="post" action="{{ path('admin_reservation_change_status', {'id': reservation.id, 'status': '__STATUS__'}) }}" class="status-form" data-reservation-id="{{ reservation.id }}">

                                                <input type="hidden" name="_token" value="{{ csrf_token('change_status' ~ reservation.id) }}">

                                                <select class="status-select {{ reservation.statut }}" onchange="changeReservationStatus(this, {{ reservation.id }})">

                                                    <option value="en_attente" {{ reservation.statut == 'en_attente' ? 'selected' : '' }}>En attente</option>

                                                    <option value="confirmee" {{ reservation.statut == 'confirmee' ? 'selected' : '' }}>Confirmée</option>

                                                    <option value="annulee" {{ reservation.statut == 'annulee' ? 'selected' : '' }}>Annulée</option>

                                                    <option value="terminee" {{ reservation.statut == 'terminee' ? 'selected' : '' }}>Terminée</option>

                                                </select>

                                            </form>

                                        </td>

                                        <td>{{ reservation.dateCreation ? reservation.dateCreation|date('d/m/Y') : 'N/A' }}</td>

                                    </tr>

                                {% else %}

                                    <tr>

                                        <td colspan="8" class="text-center py-4">Aucune réservation trouvée</td>

                                    </tr>

                                {% endfor %}

                            </tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>

    </main>

</div>

{% endblock %}



{% block javascripts %}

{{ parent() }}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

document.addEventListener('DOMContentLoaded', function() {

    const eventsStatusCtx = document.getElementById('eventsStatusChart').getContext('2d');

    new Chart(eventsStatusCtx, {

        type: 'doughnut',

        data: {

            labels: ['En attente', 'Acceptés', 'Refusés'],

            datasets: [{

                data: [{{ eventsByStatus.en_attente }}, {{ eventsByStatus.accepte }}, {{ eventsByStatus.refuse }}],

                backgroundColor: ['#ffc107', '#28a745', '#dc3545'],

                borderWidth: 0,

                hoverOffset: 10

            }]

        },

        options: {

            responsive: true,

            maintainAspectRatio: true,

            plugins: {

                legend: {

                    position: 'bottom'

                }

            }

        }

    });




    const activitiesStatusCtx = document.getElementById('activitiesStatusChart').getContext('2d');
    const activitiesStatusData = {{ activitiesByStatus|json_encode|raw }};
    const statusLabels = ['En attente', 'Accepté', 'Refusé'];
    
    new Chart(activitiesStatusCtx, {
        type: 'doughnut',
        data: {
            labels: statusLabels,
            datasets: [{
                data: [activitiesStatusData.en_attente, activitiesStatusData.accepte, activitiesStatusData.refuse],
                backgroundColor: ['#ffc107', '#28a745', '#dc3545'],
                borderWidth: 0,
                hoverOffset: 10
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            }
        }
    });




    const activitiesCategoryCtx = document.getElementById('activitiesCategoryChart').getContext('2d');

    const categoryData = {{ activitiesByCategory|json_encode|raw }};

    const categories = Object.keys(categoryData);

    const categoryCounts = Object.values(categoryData);



    new Chart(activitiesCategoryCtx, {

        type: 'bar',

        data: {

            labels: categories,

            datasets: [{

                label: 'Nombre d\'activités',

                data: categoryCounts,

                backgroundColor: 'rgba(102, 126, 234, 0.7)',

                borderRadius: 8,

                barPercentage: 0.6

            }]

        },

        options: {

            responsive: true,

            maintainAspectRatio: true,

            plugins: {

                legend: {

                    display: false

                }

            },

            scales: {

                y: {

                    beginAtZero: true,

                    ticks: { stepSize: 1 }

                }

            }

        }

    });

});



function changeStatus(select) {

    const newStatus = select.value;

    const form = select.closest('.status-form');

    if (form) {

        form.action = form.action.replace('__STATUS__', newStatus);

        form.submit();

    }

}

function changeActivityStatus(select) {

    const newStatus = select.value;

    const form = select.closest('.status-form');

    if (form) {

        form.action = form.action.replace('__STATUS__', newStatus);

        form.submit();

    }

}



function changeReservationStatus(select, reservationId) {

    const newStatus = select.value;

    const form = select.closest('.status-form');

    if (form) {

        form.action = form.action.replace('__STATUS__', newStatus);

        form.submit();

    }

}

</script>

{% endblock %}

