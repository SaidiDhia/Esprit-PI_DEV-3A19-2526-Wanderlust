                                        {% set marketplaceFraud = activityUserInsights.risk and activityUserInsights.risk.marketplace_fraud_score is defined ? activityUserInsights.risk.marketplace_fraud_score : 0 %}
                                        <span class="inline-flex rounded-full px-2.5 py-1 text-[10px] font-bold uppercase tracking-wider {{ marketplaceFraud >= 60 ? 'bg-destructive/10 text-destructive' : (marketplaceFraud >= 30 ? 'bg-accent/20 text-accent' : 'bg-primary/10 text-primary') }}">
                                            {{ marketplaceFraud >= 60 ? 'AI Flagged (High)' : (marketplaceFraud >= 30 ? 'AI Flagged (Medium)' : 'AI Clear') }}
                                        </span>
                                    </div>
                                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Marketplace Fraud Score</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ marketplaceFraud }}</p>
                                        </div>
                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Fake Orders Signal</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ marketplaceFraud >= 40 ? 'Elevated' : 'Normal' }}</p>
                                        </div>
                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Fake Products Signal</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ marketplaceFraud >= 55 ? 'Elevated' : 'Normal' }}</p>
                                        </div>
                                    </div>
                                    <p class="mt-3 text-xs text-muted-foreground">AI model signals include suspicious order cancellation behavior, fast order bursts, rapid listing creation, and abnormal pricing patterns.</p>
                                </div>

                                <div class="grid grid-cols-1 gap-4 xl:grid-cols-2">
                                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Module Statistics</h3>
                                        <div class="space-y-2">
                                            {% for row in activityUserInsights.module_breakdown %}
                                                <div class="flex items-center justify-between rounded-xl border border-border bg-background px-3 py-2 text-sm">
                                                    <span class="font-semibold text-foreground">{{ row.module ?: 'unknown' }}</span>
                                                    <span class="rounded-full bg-secondary/30 px-2 py-0.5 text-xs font-bold text-foreground">{{ row.action_count }} actions</span>
                                                </div>
                                            {% else %}
                                                <p class="text-sm text-muted-foreground">No module activity found.</p>
                                            {% endfor %}
                                        </div>
                                    </div>

                                    <div class="rounded-2xl border border-border bg-secondary/10 p-4">
                                        <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">Top Actions</h3>
                                        <div class="space-y-2">
                                            {% for row in activityUserInsights.action_breakdown|slice(0, 12) %}
                                                {% set isActiveTopAction = (activityModuleFilter|default('') == (row.module ?: '')) and (activityActionFilter|default('') == (row.action ?: '')) %}
                                                <a href="{{ path('app_admin_dashboard', {
                                                    section: 'activity_logs',
                                                    activity_user: activityFocusUser.id,
                                                    activity_module: row.module,
                                                    activity_action: row.action
                                                }) }}#user-doings" class="flex items-center justify-between rounded-xl border px-3 py-2 text-sm transition-colors {{ isActiveTopAction ? 'border-primary/30 bg-primary/10' : 'border-border bg-background hover:bg-secondary/30' }}">
                                                    <span class="truncate font-semibold text-foreground">{{ row.module ?: 'unknown' }} · {{ row.action|replace({'_': ' '}) }}</span>
                                                    <span class="rounded-full bg-secondary/30 px-2 py-0.5 text-xs font-bold text-foreground">{{ row.action_count }}</span>
                                                </a>
                                            {% else %}
                                                <p class="text-sm text-muted-foreground">No action statistics available.</p>
                                            {% endfor %}
                                        </div>
                                    </div>
                                </div>

                                <div id="user-doings" class="rounded-2xl border border-border bg-secondary/10 p-4">
                                    <h3 class="mb-3 text-sm font-bold uppercase tracking-wider text-foreground">What This User Did (Recent Activity)</h3>
                                    {% if activityModuleFilter|default('') != '' or activityActionFilter|default('') != '' %}
                                        <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
                                            <span class="rounded-full bg-primary/10 px-2.5 py-1 font-bold text-primary">Filtered</span>
                                            {% if activityModuleFilter|default('') != '' %}
                                                <span class="rounded-full bg-secondary/30 px-2.5 py-1 font-semibold text-foreground">module: {{ activityModuleFilter }}</span>
                                            {% endif %}
                                            {% if activityActionFilter|default('') != '' %}
                                                <span class="rounded-full bg-secondary/30 px-2.5 py-1 font-semibold text-foreground">action: {{ activityActionFilter|replace({'_': ' '}) }}</span>
                                            {% endif %}
                                            <a href="{{ path('app_admin_dashboard', { section: 'activity_logs', activity_user: activityFocusUser.id }) }}#user-doings" class="rounded-full border border-border px-2.5 py-1 font-semibold text-foreground hover:bg-secondary/30">Clear filter</a>
                                        </div>
                                    {% endif %}
                                    <div class="overflow-x-auto">
                                        <table class="w-full min-w-[1200px] border-collapse">
                                            <thead>
                                            <tr class="border-b border-border text-left">
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Time</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Module</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Action</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Target</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Content</th>
                                                <th class="py-3 pr-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Analysis</th>
                                                <th class="py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground">Severity</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                            {% for row in activityUserInsights.recent_entries %}
                                                <tr class="border-b border-border/70 align-top hover:bg-secondary/20">
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ row.created_at|date('Y-m-d H:i:s') }}</td>
                                                    <td class="py-3 pr-3 text-xs font-semibold text-foreground">{{ row.module ?: 'n/a' }}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ row.action|replace({'_': ' '}) }}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ row.target_name ?: row.target_type ?: row.target_id ?: 'n/a' }}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ row.content ? row.content|slice(0, 140) : 'No content' }}</td>
                                                    <td class="py-3 pr-3 text-xs text-muted-foreground">{{ row.analysis }}</td>
                                                    <td class="py-3 text-xs">
                                                        <span class="inline-flex rounded-full px-2.5 py-1 font-bold uppercase tracking-wider {{ row.severity == 'high' ? 'bg-destructive/10 text-destructive' : (row.severity == 'medium' ? 'bg-accent/20 text-accent' : 'bg-primary/10 text-primary') }}">{{ row.severity }}</span>
                                                    </td>
                                                </tr>
                                            {% else %}
                                                <tr>
                                                    <td colspan="7" class="py-8 text-center text-sm text-muted-foreground">No activity rows found for this user.</td>
                                                </tr>
                                            {% endfor %}
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            {% else %}
                                <div class="rounded-2xl border border-border bg-secondary/10 px-6 py-10 text-center text-sm text-muted-foreground">
                                    Select a user from the left list, or click “Activity Logs” from Users/Risk to open a full per-user activity timeline.
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div id="experiences-analytics" class="{{ activeSection == 'experiences' ? '' : 'hidden' }} rounded-[2rem] border border-border bg-card p-6 space-y-6">
                    <div class="flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
                        <div>
