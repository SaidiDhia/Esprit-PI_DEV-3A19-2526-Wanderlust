                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Closest Interval</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ cancelBurst.closest_interval_minutes is not null ? cancelBurst.closest_interval_minutes ~ ' min' : 'n/a' }}</p>
                                        </div>
                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Rapid Pairs</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ cancelBurst.rapid_pair_count }}</p>
                                        </div>
                                        <div class="rounded-xl border border-border bg-background px-3 py-2">
                                            <p class="text-[11px] font-bold uppercase tracking-wider text-muted-foreground">Max in 2h Window</p>
                                            <p class="mt-1 text-sm font-semibold text-foreground">{{ cancelBurst.max_burst_size }}</p>
                                        </div>
                                    </div>
