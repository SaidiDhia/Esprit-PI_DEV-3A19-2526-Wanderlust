{% extends 'base.html.twig' %}

{% block title %}{{ place.title }} — Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .relative { position: relative; }
        .absolute { position: absolute; }
        .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
        .z-10 { z-index: 10; }
        .z-20 { z-index: 20; }
        .overflow-hidden { overflow: hidden; }
        .h-full { height: 100%; }
        .w-full { width: 100%; }
        .mx-auto { margin-left: auto; margin-right: auto; }
        .max-w-2xl { max-width: 42rem; }
        .min-h-\[70vh\] { min-height: 70vh; }
        .bg-cover { background-size: cover; }
        .bg-center { background-position: center; }
        .text-white { color: #fff; }
        .text-slate-950 { color: #0f172a; }
        .text-slate-700 { color: #334155; }
        .text-slate-600 { color: #475569; }
        .text-slate-500 { color: #64748b; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-300 { color: #cbd5e1; }
        .text-rose-600 { color: #e11d48; }
        .text-emerald-700 { color: #047857; }
        .text-amber-700 { color: #b45309; }
        .text-sm { font-size: .875rem; }
        .text-xs { font-size: .75rem; }
        .text-2xl { font-size: 1.5rem; }
        .text-4xl { font-size: 2.25rem; }
        .font-bold { font-weight: 700; }
        .font-semibold { font-weight: 600; }
        .uppercase { text-transform: uppercase; }
        .italic { font-style: italic; }
        .leading-relaxed { line-height: 1.65; }
        .block { display: block; }
        .hidden { display: none; }
        .inline-flex { display: inline-flex; }
        .flex { display: flex; }
        .grid { display: grid; }
        .items-center { align-items: center; }
        .items-end { align-items: flex-end; }
        .justify-between { justify-content: space-between; }
        .justify-center { justify-content: center; }
        .gap-2 { gap: .5rem; }
        .gap-3 { gap: .75rem; }
        .gap-4 { gap: 1rem; }
        .gap-8 { gap: 2rem; }
        .space-y-2 > * + * { margin-top: .5rem; }
        .space-y-4 > * + * { margin-top: 1rem; }
        .space-y-6 > * + * { margin-top: 1.5rem; }
        .space-y-8 > * + * { margin-top: 2rem; }
        .rounded-full { border-radius: 9999px; }
        .rounded-2xl { border-radius: 1rem; }
        .rounded-3xl { border-radius: 1.5rem; }
        .rounded-xl { border-radius: .75rem; }
        .border { border: 1px solid #e2e8f0; }
        .border-border { border-color: #e2e8f0; }
        .border-slate-200 { border-color: #e2e8f0; }
        .border-slate-300 { border-color: #cbd5e1; }
        .border-rose-200 { border-color: #fecdd3; }
        .border-emerald-200 { border-color: #a7f3d0; }
        .bg-white { background: #fff; }
        .bg-slate-50 { background: #f8fafc; }
        .bg-slate-100 { background: #f1f5f9; }
        .bg-slate-900 { background: #0f172a; }
        .bg-slate-950 { background: #020617; }
        .bg-rose-50 { background: #fff1f2; }
        .bg-rose-100 { background: #ffe4e6; }
        .bg-emerald-50 { background: #ecfdf5; }
        .bg-amber-100 { background: #fef3c7; }
        .shadow-sm { box-shadow: 0 6px 20px rgba(15, 23, 42, 0.08); }
        .shadow-lg { box-shadow: 0 12px 30px rgba(15, 23, 42, 0.2); }
        .backdrop-blur-md { backdrop-filter: blur(8px); }
        .opacity-100 { opacity: 1; }
        .opacity-0 { opacity: 0; }
        .transition { transition: all .2s ease; }
        .transition-opacity { transition: opacity .7s ease; }
        .transition-colors { transition: color .2s ease, background-color .2s ease; }
        .mt-1 { margin-top: .25rem; }
        .mt-2 { margin-top: .5rem; }
        .mt-3 { margin-top: .75rem; }
        .mt-4 { margin-top: 1rem; }
        .mt-5 { margin-top: 1.25rem; }
        .mt-6 { margin-top: 1.5rem; }
        .mt-10 { margin-top: 2.5rem; }
        .mb-2 { margin-bottom: .5rem; }
        .mb-8 { margin-bottom: 2rem; }
        .p-4 { padding: 1rem; }
        .p-5 { padding: 1.25rem; }
        .p-6 { padding: 1.5rem; }
        .px-2 { padding-left: .5rem; padding-right: .5rem; }
        .px-3 { padding-left: .75rem; padding-right: .75rem; }
        .px-4 { padding-left: 1rem; padding-right: 1rem; }
        .px-5 { padding-left: 1.25rem; padding-right: 1.25rem; }
        .py-0\.5 { padding-top: .125rem; padding-bottom: .125rem; }
        .py-1 { padding-top: .25rem; padding-bottom: .25rem; }
        .py-2 { padding-top: .5rem; padding-bottom: .5rem; }
        .py-3 { padding-top: .75rem; padding-bottom: .75rem; }
        .py-14 { padding-top: 3.5rem; padding-bottom: 3.5rem; }
        .py-24 { padding-top: 6rem; padding-bottom: 6rem; }
        .outline-none { outline: none; }

        .grid.gap-4.sm\:grid-cols-3 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
        .grid.gap-8.lg\:grid-cols-\[0\.9fr_1\.1fr\] { grid-template-columns: 1fr; }
        .grid.gap-4.md\:grid-cols-2 { grid-template-columns: 1fr; }

        .bg-gradient-to-br.from-slate-950\/75.via-slate-900\/55.to-slate-900\/45 {
            background: linear-gradient(135deg, rgba(2, 6, 23, .75) 0%, rgba(15, 23, 42, .55) 50%, rgba(15, 23, 42, .45) 100%);
        }

        .w-10 { width: 2.5rem; }
        .h-10 { height: 2.5rem; }
        .h-9 { height: 2.25rem; }
        .w-9 { width: 2.25rem; }
        .h-2\.5 { height: .625rem; }
        .w-2\.5 { width: .625rem; }

        .bg-white\/35 { background-color: rgba(255, 255, 255, .35); }
        .bg-slate-950\/55 { background-color: rgba(2, 6, 23, .55); }
        .border-white\/20 { border-color: rgba(255, 255, 255, .2); }
        .text-sky-200\/80 { color: rgba(186, 230, 253, .8); }

        input[type="date"], input[type="number"], textarea {
            width: 100%;
            border-radius: 12px;
            border: 1px solid #d7dde5;
            padding: 10px 14px;
        }

        @media (min-width: 768px) {
            .md\:min-h-\[820px\] { min-height: 820px; }
            .md\:py-32 { padding-top: 8rem; padding-bottom: 8rem; }
            .md\:text-6xl { font-size: 3.6rem; }
            .grid.gap-4.md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (min-width: 640px) {
            .grid.gap-4.sm\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        }

        @media (min-width: 1024px) {
            .grid.gap-8.lg\:grid-cols-\[0\.9fr_1\.1fr\] { grid-template-columns: 0.9fr 1.1fr; }
        }
    </style>
{% endblock %}

{% block content %}
{% set bookingFormErrors = bookingFormErrors|default({}) %}
{% set bookingFormData = bookingFormData|default({start_date: '', end_date: '', guests_count: '1'}) %}
{% set todayDate = todayDate|default('now'|date('Y-m-d')) %}
{% set bookedRanges = bookedRanges|default([]) %}
{% set reviewFormErrors = reviewFormErrors|default({}) %}
{% set reviewFormData = reviewFormData|default({rating: '5', comment: ''}) %}
{% set galleryUrls = [] %}
{% for image in images %}
    {% set galleryUrls = galleryUrls|merge([image.url starts with('http') ? image.url : asset('uploads/places/' ~ image.url)]) %}
{% endfor %}
{% if galleryUrls is empty and mainImageUrl %}
    {% set galleryUrls = [mainImageUrl starts with('http') ? mainImageUrl : asset('uploads/places/' ~ mainImageUrl)] %}
{% endif %}

<section class="relative min-h-[70vh] overflow-hidden text-white md:min-h-[820px]">
    <div id="hero-bg-a" class="absolute inset-0 bg-cover bg-center opacity-100 transition-opacity duration-700" style="background-image: url('{{ galleryUrls is not empty ? galleryUrls[0] : 'https://images.unsplash.com/photo-1468824357306-a439d58ccb1c?auto=format&fit=crop&w=1920&q=80' }}');"></div>
    <div id="hero-bg-b" class="absolute inset-0 bg-cover bg-center opacity-0 transition-opacity duration-700"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950/75 via-slate-900/55 to-slate-900/45"></div>
    <div class="container mx-auto flex h-full items-end px-4 py-24 md:py-32">
        <div class="relative z-10 space-y-8">
            <div class="space-y-6">
                <div>
                    <p class="text-xs font-bold uppercase tracking-[0.3em] text-sky-200/80">{{ place.category ?? 'Stay' }}</p>
                    <h1 class="mt-3 text-4xl font-heading font-bold md:text-6xl">{{ place.title }}</h1>
                    <p class="mt-4 max-w-2xl text-slate-300">{{ place.description }}</p>
                </div>
            </div>
        </div>
    </div>
</section>

{% if galleryUrls|length > 1 %}
    <div class="relative -mt-5 z-20 flex justify-center px-4">
        <div id="hero-bg-dots" class="hero-liquid-dots flex items-center gap-2 rounded-full border border-white/20 bg-slate-950/55 px-4 py-3 shadow-lg backdrop-blur-md">
            {% for _ in galleryUrls %}
                <button type="button" data-hero-slide-index="{{ loop.index0 }}" class="hero-liquid-dot h-2.5 w-2.5 rounded-full {{ loop.first ? 'bg-white' : 'bg-white/35' }} transition-colors"></button>
            {% endfor %}
        </div>
    </div>
{% endif %}

<section class="bg-slate-50 py-14">
    <div class="container mx-auto px-4">
        <div class="mb-8 grid gap-4 sm:grid-cols-3">
            <div class="rounded-3xl border border-border bg-white p-5 shadow-sm">
                <p class="text-sm text-slate-500">Price</p>
                <p class="mt-2 text-2xl font-bold text-slate-950">{{ place.pricePerDay }}</p>
            </div>
            <div class="rounded-3xl border border-border bg-white p-5 shadow-sm">
                <p class="text-sm text-slate-500">Guests</p>
                <p class="mt-2 text-2xl font-bold text-slate-950">{{ place.maxGuests }}</p>
            </div>
            <div class="rounded-3xl border border-border bg-white p-5 shadow-sm">
                <p class="text-sm text-slate-500">Location</p>
                <p class="mt-2 text-2xl font-bold text-slate-950">{{ place.city }}</p>
            </div>
        </div>

        <div class="mb-8 rounded-3xl border border-border bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-500">Address</p>
            <p class="mt-2 text-2xl font-bold text-slate-950">{{ place.address }}</p>
            <p class="mt-1 text-sm text-slate-500">{{ place.city }}</p>
        </div>

        <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
            <form id="booking-date-form" method="post" action="{{ path('app_booking_book', { id: place.id }) }}" class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                <h2 class="text-2xl font-heading font-bold text-slate-950">Request booking</h2>
                <p class="mt-2 text-sm text-slate-500">Explorer-style date control: past dates and reserved ranges are blocked.</p>
                <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                    <div class="flex items-center justify-between gap-3">
                        <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">Unavailable dates</p>
                        <p class="text-[11px] font-semibold text-slate-400">These dates are already reserved in the calendar</p>
                    </div>
                    <div class="mt-3 space-y-2">
                        {% for range in bookedRanges %}
                            <div class="flex items-center justify-between gap-3 rounded-xl bg-white px-3 py-2 text-sm text-slate-700 shadow-sm">
                                <span class="font-semibold">{{ range.start|date('M d, Y') }} to {{ range.end|date('M d, Y') }}</span>
                                <span class="rounded-full bg-rose-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-rose-700">Unavailable</span>
                            </div>
                        {% else %}
                            <p class="text-sm text-slate-500">No reserved dates yet.</p>
                        {% endfor %}
                    </div>
                </div>
                {% if bookingFormErrors._global is defined %}
                    <p class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">{{ bookingFormErrors._global }}</p>
                {% endif %}
                <div class="mt-6 grid gap-4">
                    <div>
                        <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Start date</label>
                        <input id="booking-start-date" type="date" name="start_date" value="{{ bookingFormData.start_date }}" min="{{ todayDate }}" class="w-full rounded-2xl border border-border px-4 py-3 outline-none transition focus:border-primary" required>
                        {% if bookingFormErrors.start_date is defined %}
                            <p class="mt-1 text-xs font-semibold text-rose-600">{{ bookingFormErrors.start_date }}</p>
                        {% endif %}
                        <p id="booking-start-date-error" class="mt-1 hidden text-xs font-semibold text-rose-600"></p>
                    </div>
                    <div>
                        <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">End date</label>
                        <input id="booking-end-date" type="date" name="end_date" value="{{ bookingFormData.end_date }}" min="{{ todayDate }}" class="w-full rounded-2xl border border-border px-4 py-3 outline-none transition focus:border-primary" required>
                        {% if bookingFormErrors.end_date is defined %}
                            <p class="mt-1 text-xs font-semibold text-rose-600">{{ bookingFormErrors.end_date }}</p>
                        {% endif %}
                        <p id="booking-end-date-error" class="mt-1 hidden text-xs font-semibold text-rose-600"></p>
                    </div>
                    <div>
                        <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Guests</label>
                        <input type="number" min="1" max="{{ place.maxGuests }}" name="guests_count" value="{{ bookingFormData.guests_count }}" class="w-full rounded-2xl border border-border px-4 py-3 outline-none transition focus:border-primary" required>
                        {% if bookingFormErrors.guests_count is defined %}
                            <p class="mt-1 text-xs font-semibold text-rose-600">{{ bookingFormErrors.guests_count }}</p>
                        {% endif %}
                    </div>
                </div>
                <button class="mt-6 w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-slate-800">Send request</button>
            </form>

            <div class="space-y-6">
                {% for message in app.flashes('success') %}
                    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700">{{ message }}</div>
                {% endfor %}


                <div class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                    <h2 class="text-2xl font-heading font-bold text-slate-950">Write a review</h2>
                    {% if app.user %}
                        <form method="post" action="{{ path('app_booking_review', { id: place.id }) }}" class="mt-4 space-y-4">
                            <div>
                                <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Rating</label>
                                <div class="flex items-center gap-2">
                                    {% for score in [1, 2, 3, 4, 5] %}
                                        <label class="cursor-pointer">
                                            <input type="radio" name="rating" value="{{ score }}" class="hidden peer" {% if reviewFormData.rating|default('5') == (score ~ '') %}checked{% endif %}>
                                            <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-300 bg-white text-sm font-bold text-slate-500 transition peer-checked:border-amber-400 peer-checked:bg-amber-100 peer-checked:text-amber-700">{{ score }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                                {% if reviewFormErrors.rating is defined %}
                                    <p class="mt-1 text-xs font-semibold text-rose-600">{{ reviewFormErrors.rating }}</p>
                                {% endif %}
                            </div>

                            <div>
                                <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Comment</label>
                                <textarea name="comment" rows="4" maxlength="1200" placeholder="Share what you loved, what could be better, and tips for other travelers." class="w-full rounded-2xl border border-border px-4 py-3 outline-none transition focus:border-primary">{{ reviewFormData.comment|default('') }}</textarea>
                                {% if reviewFormErrors.comment is defined %}
                                    <p class="mt-1 text-xs font-semibold text-rose-600">{{ reviewFormErrors.comment }}</p>
                                {% endif %}
                            </div>

                            <button class="w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-slate-800">Submit review</button>
                        </form>
                    {% else %}
                        <p class="mt-4 text-sm text-slate-500">You need to be logged in to leave a review.</p>
                        <a href="{{ path('app_login') }}" class="mt-4 inline-flex rounded-xl bg-slate-950 px-4 py-2 text-sm font-bold text-white">Login</a>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="mt-10 rounded-[2rem] border border-border bg-white p-6 shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <h2 class="text-2xl font-heading font-bold text-slate-950">Guest reviews</h2>
                {% set liveReviewsCount = reviews|length %}
                {% set averageRating = place.avgRating ? place.avgRating + 0 : 0 %}
                {% set averageRoundedStars = averageRating|round(0, 'common') %}
                <div class="flex flex-wrap items-center gap-3">
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-600">{{ liveReviewsCount }} review{{ liveReviewsCount == 1 ? '' : 's' }}</span>
                    <div class="flex items-center gap-2 rounded-full bg-amber-50 px-3 py-1">
                        <div class="flex items-center gap-0.5" aria-label="Average rating">
                            {% for i in 1..5 %}
                                <span class="text-sm {{ i <= averageRoundedStars ? 'text-amber-500' : 'text-slate-300' }}">★</span>
                            {% endfor %}
                        </div>
                        <span class="text-xs font-bold text-slate-700">{{ averageRating > 0 ? averageRating|number_format(1) ~ '/5' : 'No ratings' }}</span>
                        <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">Total ratings: {{ liveReviewsCount }}</span>
                    </div>
                </div>
            </div>
            <div class="mt-5 grid gap-4 md:grid-cols-2">
                {% for review in reviews %}
                    <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-center justify-between gap-4">
                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white">{{ (review.user.fullName ?? review.user.email)|slice(0,1)|upper }}</div>
                                <div>
                                    <p class="font-semibold text-slate-950">{{ review.user.fullName ?? review.user.email }}</p>
                                    <p class="text-xs text-slate-500">{{ review.createdAt|date('M d, Y') }}</p>
                                </div>
                            </div>
                            <div class="inline-flex items-center gap-0.5 rounded-full bg-amber-50 px-3 py-1" aria-label="Review rating">
                                {% for i in 1..5 %}
                                    <span class="text-sm {{ i <= review.rating ? 'text-amber-500' : 'text-slate-300' }}">★</span>
                                {% endfor %}
                            </div>
                        </div>
                        {% if review.comment %}
                            <p class="mt-3 text-sm leading-relaxed text-slate-700">{{ review.comment }}</p>
                        {% else %}
                            <p class="mt-3 text-sm italic text-slate-500">No written comment provided.</p>
                        {% endif %}

                        <div class="mt-3 rounded-xl border border-sky-100 bg-sky-50 px-3 py-2">
                            <div class="flex items-center gap-2">
                                {% set sentiment = review.sentiment ?? 'NEUTRAL' %}
                                {% set sentimentClass = sentiment == 'POSITIVE'
                                    ? 'bg-emerald-100 text-emerald-700'
                                    : (sentiment == 'NEGATIVE' ? 'bg-rose-100 text-rose-700' : 'bg-slate-200 text-slate-700') %}
                                {% set languageQuality = review.languageQuality ?? 'UNKNOWN' %}
                                {% set languageClass = languageQuality == 'GOOD'
                                    ? 'bg-emerald-100 text-emerald-700'
                                    : (languageQuality == 'BAD' ? 'bg-rose-100 text-rose-700' : 'bg-slate-200 text-slate-700') %}
                                <span class="rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider {{ sentimentClass }}">{{ sentiment }}</span>
                                <span class="rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider {{ languageClass }}">Language: {{ languageQuality }}</span>
                                <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-500">AI review result</span>
                            </div>
                            <p class="mt-2 text-xs leading-relaxed text-slate-600">{{ review.aiSummary ?? 'No AI summary available for this review yet.' }}</p>
                        </div>
                    </article>
                {% else %}
                    <p class="text-sm text-slate-500">No reviews yet. Be the first to share your experience.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<script>
    const bookedRanges = {{ bookedRanges|json_encode|raw }};
    const todayDate = '{{ todayDate }}';
    const galleryUrls = {{ galleryUrls|json_encode|raw }};

    const liquidStyles = document.createElement('style');
    liquidStyles.textContent = `
        @keyframes heroLiquidFloat {
            0%, 100% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(-3px) scale(1.03); }
        }

        @keyframes heroLiquidPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.16); }
            50% { box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
        }

        .hero-liquid-dots {
            animation: heroLiquidFloat 4s ease-in-out infinite;
        }

        .hero-liquid-dot {
            position: relative;
        }

        .hero-liquid-dot::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 9999px;
            animation: heroLiquidPulse 2.8s ease-out infinite;
        }
    `;
    document.head.appendChild(liquidStyles);

    function initHeroBackgroundSlider() {
        if (!Array.isArray(galleryUrls) || galleryUrls.length <= 1) {
            return;
        }

        const layerA = document.getElementById('hero-bg-a');
        const layerB = document.getElementById('hero-bg-b');
        const dotButtons = document.querySelectorAll('#hero-bg-dots [data-hero-slide-index]');
        if (!layerA || !layerB) {
            return;
        }

        let currentIndex = 0;
        let activeLayerIsA = true;
        let timerId = null;

        const updateDots = () => {
            dotButtons.forEach((button) => {
                const index = Number(button.getAttribute('data-hero-slide-index'));
                if (index === currentIndex) {
                    button.classList.add('bg-white');
                    button.classList.remove('bg-white/35');
                } else {
                    button.classList.add('bg-white/35');
                    button.classList.remove('bg-white');
                }
            });
        };

        const goToSlide = (index) => {
            currentIndex = (index + galleryUrls.length) % galleryUrls.length;
            const incoming = activeLayerIsA ? layerB : layerA;
            const outgoing = activeLayerIsA ? layerA : layerB;

            incoming.style.backgroundImage = 'url("' + galleryUrls[currentIndex] + '")';
            incoming.style.opacity = '1';
            outgoing.style.opacity = '0';
            activeLayerIsA = !activeLayerIsA;
            updateDots();
        };

        const startAutoPlay = () => {
            if (timerId) {
                clearInterval(timerId);
            }

            timerId = setInterval(() => {
                goToSlide(currentIndex + 1);
            }, 4200);
        };

        dotButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const index = Number(button.getAttribute('data-hero-slide-index'));
                goToSlide(index);
                startAutoPlay();
            });
        });

        updateDots();
        startAutoPlay();
    }

    function dateToTimestamp(dateStr) {
        return new Date(dateStr + 'T00:00:00').getTime();
    }

    function overlapsReservedRange(startStr, endStr) {
        if (!startStr || !endStr) {
            return false;
        }

        const startTs = dateToTimestamp(startStr);
        const endTs = dateToTimestamp(endStr);
        return bookedRanges.some((range) => {
            const rangeStart = dateToTimestamp(range.start);
            const rangeEnd = dateToTimestamp(range.end);
            return !(endTs <= rangeStart || startTs >= rangeEnd);
        });
    }

    function isDateReserved(dateStr) {
        if (!dateStr) {
            return false;
        }

        const targetTs = dateToTimestamp(dateStr);
        return bookedRanges.some((range) => {
            const rangeStart = dateToTimestamp(range.start);
            const rangeEnd = dateToTimestamp(range.end);
            return targetTs >= rangeStart && targetTs <= rangeEnd;
        });
    }

    function showDateError(elementId, message) {
        const el = document.getElementById(elementId);
        if (!el) {
            return;
        }

        el.textContent = message;
        el.classList.remove('hidden');
    }

    function hideDateError(elementId) {
        const el = document.getElementById(elementId);
        if (!el) {
            return;
        }

        el.textContent = '';
        el.classList.add('hidden');
    }

    function validateBookingDates() {
        const startInput = document.getElementById('booking-start-date');
        const endInput = document.getElementById('booking-end-date');
        if (!startInput || !endInput) {
            return true;
        }

        const start = startInput.value;
        const end = endInput.value;
        let valid = true;

        hideDateError('booking-start-date-error');
        hideDateError('booking-end-date-error');
        startInput.setCustomValidity('');
        endInput.setCustomValidity('');

        if (start && start < todayDate) {
            startInput.setCustomValidity('Start date cannot be before today.');
            showDateError('booking-start-date-error', 'Start date cannot be before today.');
            valid = false;
        }

        if (start && isDateReserved(start)) {
            startInput.setCustomValidity('Selected start date is unavailable because it is already reserved.');
            showDateError('booking-start-date-error', 'Selected start date is unavailable because it is already reserved.');
            valid = false;
        }

        if (end && end <= todayDate) {
            endInput.setCustomValidity('End date must be after today.');
            showDateError('booking-end-date-error', 'End date must be after today.');
            valid = false;
        }

        if (end && isDateReserved(end)) {
            endInput.setCustomValidity('Selected end date is unavailable because it is already reserved.');
            showDateError('booking-end-date-error', 'Selected end date is unavailable because it is already reserved.');
            valid = false;
        }

        if (start && end && start >= end) {
            endInput.setCustomValidity('End date must be after start date.');
            showDateError('booking-end-date-error', 'End date must be after start date.');
            valid = false;
        }

        if (start && end && overlapsReservedRange(start, end)) {
            endInput.setCustomValidity('Selected dates overlap with reserved dates.');
            showDateError('booking-end-date-error', 'Selected dates overlap with reserved dates.');
            valid = false;
        }

        return valid;
    }

    const bookingForm = document.getElementById('booking-date-form');
    const bookingStart = document.getElementById('booking-start-date');
    const bookingEnd = document.getElementById('booking-end-date');

    if (bookingStart) {
        bookingStart.addEventListener('change', validateBookingDates);
        bookingStart.addEventListener('input', validateBookingDates);
    }

    if (bookingEnd) {
        bookingEnd.addEventListener('change', validateBookingDates);
        bookingEnd.addEventListener('input', validateBookingDates);
    }

    if (bookingForm) {
        bookingForm.addEventListener('submit', (event) => {
            if (!validateBookingDates()) {
                event.preventDefault();
            }
        });
    }

    initHeroBackgroundSlider();
    validateBookingDates();
</script>
{% endblock %}