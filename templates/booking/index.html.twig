{% extends 'base.html.twig' %}

{% block title %}Stays - Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .module-hero {
            background: linear-gradient(rgba(0, 0, 0, 0.46), rgba(0, 0, 0, 0.46)), url('{{ asset('adventure/img/slider3.jpg') }}') center center/cover no-repeat;
            padding: 120px 0 80px;
            color: #fff;
            margin-bottom: 50px;
        }

        .stay-filter {
            border: 1px solid #eee;
            border-radius: 12px;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.06);
            padding: 18px;
            margin-bottom: 30px;
        }

        .stay-filter .form-control {
            border-radius: 10px;
            border-color: #e5e7eb;
            min-height: 44px;
        }

        .stay-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
            margin-bottom: 30px;
            height: 100%;
            display: flex;
            flex-direction: column;
        }

        .stay-card .thumb {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #f7f7f7;
        }

        .stay-body {
            padding: 18px;
            flex: 1;
        }

        .stay-actions {
            border-top: 1px solid #f0f0f0;
            padding: 14px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }

        .stay-meta {
            font-size: 13px;
            color: #777;
            margin-bottom: 6px;
        }

        .pending-box {
            border: 1px solid #fde68a;
            background: #fffbeb;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 28px;
        }

        .pending-item {
            border: 1px solid #fcd34d;
            border-radius: 8px;
            background: #fff;
            padding: 10px 12px;
            margin-bottom: 8px;
        }
    </style>
{% endblock %}

{% block content %}
<section class="module-hero">
    <div class="container">
        <h1 class="mb-10">Stays</h1>
        <p class="mb-20">Discover approved places, book quickly, and manage hosting flows from one module.</p>
        <div class="d-flex flex-wrap" style="gap:10px;">
            <a href="#explore" class="primary-btn text-uppercase">Explore Stays</a>
            <a href="{{ path('app_booking_host') }}" class="primary-btn text-uppercase">Create Stay</a>
            <a href="{{ path('app_booking_host') }}" class="genric-btn info-border">Host Dashboard</a>
        </div>
    </div>
</section>

<section id="explore" class="section-gap pt-0">
    <div class="container">
        {% if myPendingPlaces is not empty %}
            <div class="pending-box">
                <h5 class="mb-2">Your places waiting review</h5>
                <p class="text-muted mb-3">These are not bookable until admin approval.</p>
                <div class="row">
                    {% for place in myPendingPlaces %}
                        <div class="col-md-6">
                            <div class="pending-item">
                                <strong>{{ place.title }}</strong>
                                <div class="small text-warning text-uppercase">{{ place.status }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <form method="get" class="stay-filter">
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label class="small text-uppercase">Search</label>
                    <input name="q" value="{{ filters.q ?? '' }}" type="text" placeholder="Hotel, camp, villa..." class="form-control">
                </div>
                <div class="col-md-3 mb-3">
                    <label class="small text-uppercase">City</label>
                    <input name="city" value="{{ filters.city ?? '' }}" type="text" placeholder="Tunis" class="form-control">
                </div>
                <div class="col-md-2 mb-3">
                    <label class="small text-uppercase">Category</label>
                    <input name="category" value="{{ filters.category ?? '' }}" type="text" placeholder="Resort" class="form-control">
                </div>
                <div class="col-md-2 mb-3 d-flex align-items-end">
                    <button class="primary-btn text-uppercase w-100" style="border:none;">Search</button>
                </div>
            </div>
        </form>

        {% if places is empty %}
            <div class="text-center p-5 border rounded bg-white">
                <h4>No approved stays yet</h4>
                <p class="text-muted mb-3">Use host dashboard to submit a place, then admin can approve it.</p>
                <div class="d-flex justify-content-center flex-wrap" style="gap:10px;">
                    <a href="{{ path('app_booking_host') }}" class="primary-btn text-uppercase">Create Stay</a>
                    <a href="{{ path('app_booking_host') }}" class="genric-btn info-border text-uppercase">Host Dashboard</a>
                </div>
            </div>
        {% else %}
            <div class="row">
                {% for place in places %}
                    {% set previewImage = placePreviewImages[place.id]|default(place.imageUrl) %}
                    <div class="col-md-6 col-lg-4 d-flex">
                        <article class="stay-card w-100">
                            {% if previewImage %}
                                <img class="thumb" src="{{ previewImage starts with('http') ? previewImage : asset('uploads/places/' ~ previewImage) }}" alt="{{ place.title }}">
                            {% else %}
                                <img class="thumb" src="{{ asset('adventure/img/g6.jpg') }}" alt="Stay placeholder">
                            {% endif %}

                            <div class="stay-body">
                                <h5 class="mb-2">{{ place.title }}</h5>
                                <div class="stay-meta"><i class="fa fa-map-marker"></i> {{ place.city }}</div>
                                <div class="stay-meta"><i class="fa fa-users"></i> Up to {{ place.maxGuests }} guests</div>
                                {% if place.avgRating %}
                                    <div class="stay-meta"><i class="fa fa-star" style="color:#f59e0b;"></i> {{ place.avgRating }}/5</div>
                                {% endif %}
                                <p class="mb-0 mt-2"><strong>${{ place.pricePerDay }}</strong> / night</p>
                            </div>

                            <div class="stay-actions">
                                <span class="small text-muted">{{ place.category ?? 'Stay' }}</span>
                                <a href="{{ path('app_booking_place', { id: place.id }) }}" class="genric-btn info-border small">View</a>
                            </div>
                        </article>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}