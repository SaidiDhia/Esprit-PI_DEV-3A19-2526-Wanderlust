{% extends 'base.html.twig' %}

{% block title %}Réservations — WanderLust{% endblock %}

{% block content %}
<div class="container mt-4">
    <h1 class="mb-4">Liste des Réservations</h1>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="mb-3">
        <a href="{{ path('app_booking_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Ajouter une réservation
        </a>
    </div>

    <div class="row">
        {% if reservations is empty %}
            <div class="col">
                <div class="alert alert-info">
                    Aucune réservation trouvée.
                </div>
            </div>
        {% else %}
            {% for reservation in reservations %}
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header">
                            <div class="d-flex justify-content-between align-items-center">
                                <h6 class="card-title mb-0">Réservation #{{ reservation.id }}</h6>
                                {% if reservation.statut == 'confirmee' %}
                                    <span class="badge bg-success">Confirmée</span>
                                {% elseif reservation.statut == 'en_attente' %}
                                    <span class="badge bg-warning">En attente</span>
                                {% elseif reservation.statut == 'annulee' %}
                                    <span class="badge bg-danger">Annulée</span>
                                {% else %}
                                    <span class="badge bg-info">Terminée</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong>Événement ID:</strong> {{ reservation.idEvent }}<br>
                                <strong>Client ID:</strong> {{ reservation.idClient }}<br>
                                <strong>Date réservation:</strong> {{ reservation.dateReservation ? reservation.dateReservation|date('d/m/Y') : '' }}<br>
                                <strong>Date événement:</strong> {{ reservation.dateEvenement ? reservation.dateEvenement|date('d/m/Y') : '' }}<br>
                                <strong>Places:</strong> {{ reservation.nombrePlaces }}<br>
                                <strong>Prix total:</strong> <span class="badge bg-primary">{{ reservation.prixTotal }} €</span>
                            </p>
                            
                            {% if reservation.emailClient %}
                                <p class="card-text">
                                    <small class="text-muted">
                                        <i class="fas fa-envelope"></i> {{ reservation.emailClient }}
                                        {% if reservation.telephoneClient %}
                                            <br><i class="fas fa-phone"></i> {{ reservation.telephoneClient }}
                                        {% endif %}
                                    </small>
                                </p>
                            {% endif %}

                            <div class="mb-2">
                                <div class="progress" style="height: 20px;">
                                    {% set pourcentage = (reservation.montantPaye / reservation.prixTotal) * 100 %}
                                    <div class="progress-bar 
                                        {% if reservation.isPayeComplet %}bg-success{% else %}bg-warning{% endif %}" 
                                        role="progressbar" 
                                        style="width: {{ pourcentage }}%"
                                        aria-valuenow="{{ pourcentage }}" 
                                        aria-valuemin="0" 
                                        aria-valuemax="100">
                                        {{ pourcentage|round(0) }}% payé
                                    </div>
                                </div>
                                <small class="text-muted">
                                    {{ reservation.montantPaye }} € / {{ reservation.prixTotal }} €
                                </small>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="btn-group w-100" role="group">
                                <a href="{{ path('app_booking_show', {'id': reservation.id}) }}" class="btn btn-info btn-sm">
                                    <i class="fas fa-eye"></i> Voir
                                </a>
                                <a href="{{ path('app_booking_edit', {'id': reservation.id}) }}" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i> Modifier
                                </a>
                                <form method="post" action="{{ path('app_booking_delete', {'id': reservation.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette réservation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i> Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
{% endblock %}
