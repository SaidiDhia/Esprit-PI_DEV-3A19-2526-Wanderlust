{% extends 'base.html.twig' %}

{% block title %}Booking — WanderLust{% endblock %}

{% block content %}

<div class="bg-primary/5 border-b border-border py-12 px-4">
    <div class="container mx-auto text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-2xl mb-4 text-primary text-3xl">🏨</div>
        <h1 class="text-3xl md:text-5xl font-heading font-bold text-foreground mb-4">Hotel Booking</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto">Find and reserve the perfect stay — from cozy guesthouses to luxury resorts.</p>
    </div>
</div>

<div class="container mx-auto px-4 py-12">
    <!-- Search Filters -->
    <div class="glass-strong rounded-2xl p-6 mb-12 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Destination</label>
                <input type="text" class="bg-secondary/50 border border-border rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20" placeholder="City or Hotel name...">
            </div>
            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Check-in</label>
                <input type="date" class="bg-secondary/50 border border-border rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Check-out</label>
                <input type="date" class="bg-secondary/50 border border-border rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
            </div>
            <div class="flex flex-col gap-2">
                <label class="text-xs font-bold text-muted-foreground uppercase tracking-wider">Guests</label>
                <select class="bg-secondary/50 border border-border rounded-xl px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary/20">
                    <option>1 Guest</option>
                    <option>2 Guests</option>
                    <option>3 Guests</option>
                    <option>4+ Guests</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-2.5 rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    Search
                </button>
            </div>
        </div>
    </div>

    <!-- Hotel Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Hotel 1 -->
        <div class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-56 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-accent/20 flex items-center justify-center text-6xl">🏝️</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground">Resort</div>
            </div>
            <div class="p-6">
                <div class="flex justify-between items-start mb-2">
                    <h3 class="font-heading font-bold text-xl group-hover:text-primary transition-colors">Hammamet Beach Resort</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>5.0</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-4">Stunning beachfront resort with private beach, infinity pool, and world-class spa.</p>
                <div class="flex items-center gap-2 text-xs text-muted-foreground mb-6">
                    <span>📍 Hammamet, Tunisia</span>
                    <span>•</span>
                    <span>🛏 Superior Room</span>
                </div>
                <div class="flex items-center justify-between border-t border-border pt-4">
                    <p class="text-foreground font-bold text-xl">320 TND <span class="text-muted-foreground text-xs font-normal">/ night</span></p>
                    <a href="#" class="bg-primary hover:bg-primary/90 text-white text-sm font-bold px-6 py-2 rounded-lg transition-all">Reserve</a>
                </div>
            </div>
        </div>

        <!-- Hotel 2 -->
        <div class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-56 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-500/20 to-pink-500/20 flex items-center justify-center text-6xl">🏛️</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground">Riad</div>
            </div>
            <div class="p-6">
                <div class="flex justify-between items-start mb-2">
                    <h3 class="font-heading font-bold text-xl group-hover:text-primary transition-colors">Medina Heritage Riad</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>4.7</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-4">An authentic boutique riad in the heart of the Medina. Traditional Tunisian architecture.</p>
                <div class="flex items-center gap-2 text-xs text-muted-foreground mb-6">
                    <span>📍 Tunis Medina</span>
                    <span>•</span>
                    <span>🛏 Deluxe Suite</span>
                </div>
                <div class="flex items-center justify-between border-t border-border pt-4">
                    <p class="text-foreground font-bold text-xl">180 TND <span class="text-muted-foreground text-xs font-normal">/ night</span></p>
                    <a href="#" class="bg-primary hover:bg-primary/90 text-white text-sm font-bold px-6 py-2 rounded-lg transition-all">Reserve</a>
                </div>
            </div>
        </div>

        <!-- Hotel 3 -->
        <div class="group bg-card border border-border rounded-2xl overflow-hidden hover:shadow-lg transition-all">
            <div class="relative h-56 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-orange-500/20 to-emerald-500/20 flex items-center justify-center text-6xl">🌴</div>
                <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground">Desert Camp</div>
            </div>
            <div class="p-6">
                <div class="flex justify-between items-start mb-2">
                    <h3 class="font-heading font-bold text-xl group-hover:text-primary transition-colors">Sahara Luxury Camp</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>4.9</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-4">Sleep under the stars in glamorous desert tents with gourmet dining. An unforgettable experience.</p>
                <div class="flex items-center gap-2 text-xs text-muted-foreground mb-6">
                    <span>📍 Douz, Tunisia</span>
                    <span>•</span>
                    <span>🛏 Royal Tent</span>
                </div>
                <div class="flex items-center justify-between border-t border-border pt-4">
                    <p class="text-foreground font-bold text-xl">450 TND <span class="text-muted-foreground text-xs font-normal">/ night</span></p>
                    <a href="#" class="bg-primary hover:bg-primary/90 text-white text-sm font-bold px-6 py-2 rounded-lg transition-all">Reserve</a>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
