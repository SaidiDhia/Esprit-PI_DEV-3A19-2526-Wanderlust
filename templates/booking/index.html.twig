{% extends 'base.html.twig' %}

{% block title %}Stay Explorer — Wanderlust{% endblock %}

{% block content %}
<section class="relative overflow-hidden text-white">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: linear-gradient(135deg, rgba(15, 23, 42, 0.72), rgba(15, 23, 42, 0.38)), url('https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1920&q=80');"></div>
    <div class="relative container mx-auto px-4 py-20 md:py-28">
        <div class="max-w-4xl">
            <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-100/90">
                Curated stays
            </span>
            <h1 class="mt-6 text-4xl font-heading font-bold tracking-tight md:text-6xl">Find a stay that feels designed, not listed.</h1>
            <p class="mt-5 max-w-2xl text-base leading-7 text-slate-200 md:text-lg">Browse approved places, send booking requests, and switch into host or admin review flows from the same booking module.</p>
            <div class="mt-8 flex flex-wrap gap-3">
                <a href="#explore" class="rounded-xl bg-sky-400 px-5 py-3 text-sm font-bold text-slate-950 transition-colors hover:bg-sky-300">Explore stays</a>
                <a href="{{ path('app_booking_host') }}" class="rounded-xl border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-white/10">Become a host</a>
            </div>
        </div>

        <div class="mt-10 grid gap-4 md:grid-cols-4">
            <div class="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur">
                <p class="text-sm text-slate-200">Places</p>
                <p class="mt-2 text-3xl font-heading font-bold">{{ stats.places ?? 0 }}</p>
            </div>
            <div class="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur">
                <p class="text-sm text-slate-200">Bookings</p>
                <p class="mt-2 text-3xl font-heading font-bold">{{ stats.bookings ?? 0 }}</p>
            </div>
            <div class="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur">
                <p class="text-sm text-slate-200">Hosts</p>
                <p class="mt-2 text-3xl font-heading font-bold">{{ stats.hosts ?? 0 }}</p>
            </div>
            <div class="rounded-3xl border border-white/15 bg-white/10 p-5 backdrop-blur">
                <p class="text-sm text-slate-200">Reviews</p>
                <p class="mt-2 text-3xl font-heading font-bold">{{ stats.reviews ?? 0 }}</p>
            </div>
        </div>
    </div>
</section>

<section id="explore" class="bg-slate-50 py-14 md:py-20">
    <div class="container mx-auto px-4">
        {% if myPendingPlaces is not empty %}
            <div class="mb-8 rounded-[2rem] border border-amber-200 bg-amber-50 p-6">
                <h2 class="text-xl font-heading font-bold text-amber-900">Your places waiting review</h2>
                <p class="mt-1 text-sm text-amber-700">These are not bookable yet. Admin approval is required first.</p>
                <div class="mt-4 grid gap-3 md:grid-cols-2">
                    {% for place in myPendingPlaces %}
                        <div class="rounded-2xl border border-amber-200 bg-white p-4">
                            <p class="font-semibold text-slate-900">{{ place.title }}</p>
                            <p class="mt-1 text-xs uppercase tracking-[0.18em] text-amber-700">{{ place.status }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        <form method="get" class="glass-strong rounded-[2rem] border border-border/60 p-5 shadow-sm md:p-6">
            <div class="grid gap-4 md:grid-cols-[2fr_1fr_1fr_auto]">
                <div>
                    <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Search</label>
                    <input name="q" value="{{ filters.q ?? '' }}" type="text" placeholder="Hotel, riad, camp, villa..." class="w-full rounded-2xl border border-border bg-white px-4 py-3 text-sm outline-none ring-0 transition focus:border-primary" />
                </div>
                <div>
                    <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">City</label>
                    <input name="city" value="{{ filters.city ?? '' }}" type="text" placeholder="Tunis" class="w-full rounded-2xl border border-border bg-white px-4 py-3 text-sm outline-none transition focus:border-primary" />
                </div>
                <div>
                    <label class="mb-2 block text-xs font-bold uppercase tracking-[0.2em] text-muted-foreground">Category</label>
                    <input name="category" value="{{ filters.category ?? '' }}" type="text" placeholder="Resort" class="w-full rounded-2xl border border-border bg-white px-4 py-3 text-sm outline-none transition focus:border-primary" />
                </div>
                <div class="flex items-end">
                    <button class="w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white transition hover:bg-slate-800">Search</button>
                </div>
            </div>
        </form>

        <div class="mt-10 grid gap-8 md:grid-cols-2 xl:grid-cols-3">
            {% for place in places %}
                <article class="group overflow-hidden rounded-[2rem] bg-white transition duration-300 hover:-translate-y-1">
                    <div class="relative aspect-[4/3] overflow-hidden rounded-[2rem] bg-slate-100 shadow-sm">
                        {% set previewImage = placePreviewImages[place.id]|default(place.imageUrl) %}
                        {% if previewImage %}
                            <img src="{{ previewImage starts with('http') ? previewImage : asset('uploads/places/' ~ previewImage) }}" alt="{{ place.title }}" class="h-full w-full object-cover transition duration-500 group-hover:scale-105">
                        {% else %}
                            <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-sky-100 via-white to-amber-100 text-6xl">✦</div>
                        {% endif %}
                        <div class="absolute left-4 top-4 rounded-full bg-white/90 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-slate-900 shadow-sm">{{ place.category ?? 'Stay' }}</div>
                    </div>
                    <div class="space-y-3 px-2 pt-5">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <h2 class="text-[1.35rem] font-heading font-bold text-slate-950 transition group-hover:text-sky-700">{{ place.title }}</h2>
                                <p class="mt-1 text-sm text-slate-500">{{ place.city }}</p>
                            </div>
                            {% if place.avgRating %}
                                <div class="flex items-center gap-1 pt-1 text-sm font-bold text-slate-950">
                                    <svg class="h-4 w-4 fill-amber-500 text-amber-500" viewBox="0 0 24 24" aria-hidden="true">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                                    </svg>
                                    <span>{{ place.avgRating }}</span>
                                </div>
                            {% endif %}
                        </div>
                        <div class="flex items-end justify-between gap-4 border-t border-slate-100 pt-4">
                            <p class="text-2xl font-heading font-bold text-slate-950">${{ place.pricePerDay }} <span class="text-sm font-medium text-slate-500">/ night</span></p>
                            <a href="{{ path('app_booking_place', { id: place.id }) }}" class="rounded-full bg-slate-950 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-slate-800">View</a>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="col-span-full rounded-[2rem] border border-dashed border-border bg-white p-10 text-center">
                    <p class="text-lg font-heading font-bold text-slate-950">No approved places yet.</p>
                    <p class="mt-2 text-sm text-slate-500">Use the host flow to submit a place, then approve it from the admin dashboard.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
