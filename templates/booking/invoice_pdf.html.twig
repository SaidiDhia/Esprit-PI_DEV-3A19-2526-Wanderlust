<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reservation Invoice {{ invoiceNumber }}</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 12px;
            color: #0f172a;
            margin: 28px;
        }

        .header {
            border-bottom: 2px solid #0ea5e9;
            padding-bottom: 12px;
            margin-bottom: 18px;
        }

        .brand {
            font-size: 24px;
            font-weight: 700;
            color: #0369a1;
        }

        .muted {
            color: #64748b;
        }

        .title {
            margin-top: 18px;
            font-size: 18px;
            font-weight: 700;
        }

        .meta-table,
        .line-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 14px;
        }

        .meta-table td {
            padding: 6px 0;
            vertical-align: top;
        }

        .label {
            color: #475569;
            width: 150px;
        }

        .line-table th,
        .line-table td {
            border: 1px solid #cbd5e1;
            padding: 8px;
            text-align: left;
        }

        .line-table th {
            background: #f1f5f9;
            font-weight: 700;
        }

        .num {
            text-align: right;
        }

        .total-row td {
            font-weight: 700;
            background: #f8fafc;
        }

        .footer {
            margin-top: 24px;
            border-top: 1px solid #cbd5e1;
            padding-top: 10px;
            font-size: 11px;
            color: #64748b;
        }
    </style>
</head>
<body>
<div class="header">
    <div class="brand">Wanderlust</div>
    <div class="muted">Reservation Invoice</div>
</div>

<div class="title">Invoice {{ invoiceNumber }}</div>

<table class="meta-table">
    <tr>
        <td class="label">Issued At</td>
        <td>{{ issuedAt|date('Y-m-d H:i') }}</td>
    </tr>
    <tr>
        <td class="label">Booking ID</td>
        <td>#{{ booking.id }}</td>
    </tr>
    <tr>
        <td class="label">Guest</td>
        <td>{{ booking.guest.fullName ?: booking.guest.email }}</td>
    </tr>
    <tr>
        <td class="label">Guest Email</td>
        <td>{{ booking.guest.email }}</td>
    </tr>
    <tr>
        <td class="label">Property</td>
        <td>{{ booking.place.title }}</td>
    </tr>
    <tr>
        <td class="label">Location</td>
        <td>{{ booking.place.city }}{% if booking.place.address %}, {{ booking.place.address }}{% endif %}</td>
    </tr>
    <tr>
        <td class="label">Stay Dates</td>
        <td>{{ booking.startDate|date('Y-m-d') }} to {{ booking.endDate|date('Y-m-d') }}</td>
    </tr>
    <tr>
        <td class="label">Guests</td>
        <td>{{ booking.guestsCount }}</td>
    </tr>
</table>

<table class="line-table">
    <thead>
    <tr>
        <th>Description</th>
        <th class="num">Unit Price</th>
        <th class="num">Qty</th>
        <th class="num">Amount</th>
    </tr>
    </thead>
    <tbody>
    <tr>
        <td>Accommodation reservation ({{ booking.place.title }})</td>
        <td class="num">{{ booking.place.pricePerDay|number_format(2, '.', ' ') }}</td>
        <td class="num">{{ nights }} night{{ nights == 1 ? '' : 's' }}</td>
        <td class="num">{{ booking.totalPrice|number_format(2, '.', ' ') }}</td>
    </tr>
    <tr class="total-row">
        <td colspan="3" class="num">Total</td>
        <td class="num">{{ booking.totalPrice|number_format(2, '.', ' ') }}</td>
    </tr>
    </tbody>
</table>

<div class="footer">
    Thank you for booking with Wanderlust. This invoice is generated automatically for confirmed reservations.
</div>
</body>
</html>
