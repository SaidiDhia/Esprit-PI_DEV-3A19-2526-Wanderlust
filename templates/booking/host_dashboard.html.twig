{% extends 'base.html.twig' %}

{% block title %}Host Dashboard — Wanderlust{% endblock %}

{% block content %}
{% set formErrors = formErrors|default({}) %}
{% set formData = formData|default({
    title: '',
    description: '',
    city: '',
    category: '',
    price_per_day: '',
    capacity: '',
    max_guests: '',
    address: '',
    latitude: '36.80650000',
    longitude: '10.18150000'
}) %}
{% set hostDisplayName = hostUser.fullName ?? hostUser.email %}
{% set dashboardStats = dashboardStats|default({
    places: 0,
    approvedPlaces: 0,
    pendingPlaces: 0,
    bookings: 0,
    pendingBookings: 0,
    confirmedBookings: 0,
    rejectedBookings: 0,
    earningsTotal: '0.00'
}) %}
{% set bookingStatusChartData = bookingStatusChartData|default([]) %}
{% set earningsChartData = earningsChartData|default({labels: [], values: []}) %}

<section class="relative overflow-hidden text-white py-16">
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: linear-gradient(135deg, rgba(15, 23, 42, 0.82), rgba(15, 23, 42, 0.42)), url('https://images.unsplash.com/photo-1468824357306-a439d58ccb1c?auto=format&fit=crop&w=1920&q=80');"></div>
    <div class="container mx-auto px-4">
        <div class="relative z-10 max-w-3xl">
            <p class="text-xs font-bold uppercase tracking-[0.3em] text-sky-200/80">Hosting</p>
            <h1 class="mt-3 text-4xl font-heading font-bold md:text-6xl">{{ hostDisplayName }}'s host dashboard</h1>
            <p class="mt-4 max-w-2xl text-slate-300">Manage your places, review booking requests, and keep track of earnings and booking performance.</p>
            {% if viewerIsAdmin %}
                <p class="mt-3 inline-flex rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-100">Admin viewing host workspace</p>
            {% endif %}
        </div>
        <div class="relative z-10 mt-8 grid gap-4 md:grid-cols-4">
            <div class="rounded-[2rem] border border-white/10 bg-white/8 p-5 backdrop-blur">
                <p class="text-sm text-slate-300">Places</p>
                <p class="mt-2 text-4xl font-heading font-bold">{{ dashboardStats.places }}</p>
            </div>
            <div class="rounded-[2rem] border border-white/10 bg-white/8 p-5 backdrop-blur">
                <p class="text-sm text-slate-300">Pending bookings</p>
                <p class="mt-2 text-4xl font-heading font-bold">{{ dashboardStats.pendingBookings }}</p>
            </div>
            <div class="rounded-[2rem] border border-white/10 bg-white/8 p-5 backdrop-blur">
                <p class="text-sm text-slate-300">Confirmed bookings</p>
                <p class="mt-2 text-4xl font-heading font-bold">{{ dashboardStats.confirmedBookings }}</p>
            </div>
            <div class="rounded-[2rem] border border-white/10 bg-white/8 p-5 backdrop-blur">
                <p class="text-sm text-slate-300">Earnings</p>
                <p class="mt-2 text-4xl font-heading font-bold">${{ dashboardStats.earningsTotal }}</p>
            </div>
        </div>
    </div>
</section>

<section class="bg-slate-50 py-14">
    <div class="container mx-auto px-4 space-y-8">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-[2rem] border border-border bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Approved places</p>
                <p class="mt-2 text-3xl font-heading font-bold text-slate-950">{{ dashboardStats.approvedPlaces }}</p>
            </div>
            <div class="rounded-[2rem] border border-border bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Pending places</p>
                <p class="mt-2 text-3xl font-heading font-bold text-slate-950">{{ dashboardStats.pendingPlaces }}</p>
            </div>
            <div class="rounded-[2rem] border border-border bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Total bookings</p>
                <p class="mt-2 text-3xl font-heading font-bold text-slate-950">{{ dashboardStats.bookings }}</p>
            </div>
            <div class="rounded-[2rem] border border-border bg-white p-5 shadow-sm">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Rejected bookings</p>
                <p class="mt-2 text-3xl font-heading font-bold text-slate-950">{{ dashboardStats.rejectedBookings }}</p>
            </div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
            <div class="space-y-8">
                <div class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-2xl font-heading font-bold text-slate-950">Booking performance</h2>
                            <p class="mt-1 text-sm text-slate-500">Booking status distribution and monthly earnings.</p>
                        </div>
                    </div>
                    <div class="mt-6 grid gap-6 xl:grid-cols-2">
                        <div class="rounded-3xl border border-slate-100 bg-slate-50 p-4">
                            <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Status mix</p>
                            <div class="h-[280px]"><canvas id="bookingStatusChart"></canvas></div>
                        </div>
                        <div class="rounded-3xl border border-slate-100 bg-slate-50 p-4">
                            <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Earnings curve</p>
                            <div class="h-[280px]"><canvas id="earningsChart"></canvas></div>
                        </div>
                    </div>
                </div>

                <div class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-2xl font-heading font-bold text-slate-950">Booking requests</h2>
                            <p class="mt-1 text-sm text-slate-500">Approve or reject requests from your guests.</p>
                        </div>
                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-wider text-slate-600">{{ dashboardStats.pendingBookings }} pending</span>
                    </div>
                    <div class="mt-5 space-y-4">
                        {% for booking in bookings %}
                            <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
                                <div class="flex flex-wrap items-start justify-between gap-4">
                                    <div>
                                        <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">{{ booking.place.title }}</p>
                                        <h3 class="mt-1 text-lg font-heading font-bold text-slate-950">{{ booking.guest.fullName ?? booking.guest.email }}</h3>
                                        <p class="mt-1 text-sm text-slate-500">{{ booking.startDate|date('M d, Y') }} to {{ booking.endDate|date('M d, Y') }}</p>
                                        <p class="mt-1 text-sm text-slate-500">Guests: {{ booking.guestsCount }} · Total: ${{ booking.totalPrice }}</p>
                                    </div>
                                    <span class="rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider {{ booking.status == 'PENDING' ? 'bg-amber-100 text-amber-700' : (booking.status == 'CONFIRMED' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-200 text-slate-700') }}">{{ booking.status }}</span>
                                </div>
                                {% if booking.status == 'PENDING' %}
                                    <div class="mt-4 flex flex-wrap gap-3">
                                        <form method="post" action="{{ path('app_booking_host_booking_confirm', { id: booking.id }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('booking_host_confirm_' ~ booking.id) }}">
                                            <button type="submit" class="rounded-xl bg-emerald-600 px-4 py-2 text-xs font-bold text-white">Approve</button>
                                        </form>
                                        <form method="post" action="{{ path('app_booking_host_booking_reject', { id: booking.id }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('booking_host_reject_' ~ booking.id) }}">
                                            <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-xs font-bold text-white">Reject</button>
                                        </form>
                                    </div>
                                {% endif %}
                            </article>
                        {% else %}
                            <p class="text-sm text-slate-500">No booking requests yet.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="space-y-8">
                <form id="host-place-form" method="post" action="{{ path('app_booking_host_request') }}" enctype="multipart/form-data" data-validate-form novalidate class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                    <h2 class="text-2xl font-heading font-bold text-slate-950">Submit a place</h2>
                    <p class="mt-2 text-sm text-slate-500">Create a new place request with multiple photos.</p>
                    <div class="mt-6 grid gap-4">
                        <div>
                            <input name="title" type="text" value="{{ formData.title }}" placeholder="Place title" class="w-full rounded-2xl border border-border px-4 py-3" required>
                            {% if formErrors.title is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.title }}</p>{% endif %}
                        </div>
                        <div>
                            <textarea name="description" rows="4" placeholder="Short description" class="w-full rounded-2xl border border-border px-4 py-3">{{ formData.description }}</textarea>
                        </div>
                        <div class="grid gap-4 md:grid-cols-2">
                            <div>
                                <input name="city" type="text" value="{{ formData.city }}" placeholder="City" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.city is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.city }}</p>{% endif %}
                            </div>
                            <div>
                                <input name="category" type="text" value="{{ formData.category }}" placeholder="Category" class="w-full rounded-2xl border border-border px-4 py-3">
                            </div>
                        </div>
                        <div class="grid gap-4 md:grid-cols-2">
                            <div>
                                <input name="price_per_day" type="number" step="0.01" min="0" value="{{ formData.price_per_day }}" placeholder="Price per day" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.price_per_day is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.price_per_day }}</p>{% endif %}
                            </div>
                            <div>
                                <input name="capacity" type="number" min="1" value="{{ formData.capacity }}" placeholder="Capacity" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.capacity is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.capacity }}</p>{% endif %}
                            </div>
                        </div>
                        <div class="grid gap-4 md:grid-cols-2">
                            <div>
                                <input name="max_guests" type="number" min="1" value="{{ formData.max_guests }}" placeholder="Max guests" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.max_guests is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.max_guests }}</p>{% endif %}
                            </div>
                            <div data-image-uploader>
                                <div class="flex items-center gap-3">
                                    <button type="button" class="js-upload-trigger rounded-2xl border border-border px-4 py-3 text-xs font-bold">Upload images</button>
                                    <span class="text-xs text-slate-500">Choose one or many images</span>
                                </div>
                                <input name="images[]" type="file" accept="image/*" multiple required class="js-image-input hidden">
                                <div class="js-image-preview-grid mt-2 grid grid-cols-4 gap-2"></div>
                                {% if formErrors.images is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.images }}</p>{% endif %}
                            </div>
                        </div>
                        <div>
                            <input name="address" type="text" value="{{ formData.address }}" placeholder="Address" class="w-full rounded-2xl border border-border px-4 py-3" required>
                            {% if formErrors.address is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.address }}</p>{% endif %}
                        </div>
                        <div class="grid gap-4 md:grid-cols-2">
                            <div>
                                <input name="latitude" type="number" step="0.00000001" min="-90" max="90" value="{{ formData.latitude }}" placeholder="Latitude" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.latitude is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.latitude }}</p>{% endif %}
                            </div>
                            <div>
                                <input name="longitude" type="number" step="0.00000001" min="-180" max="180" value="{{ formData.longitude }}" placeholder="Longitude" class="w-full rounded-2xl border border-border px-4 py-3" required>
                                {% if formErrors.longitude is defined %}<p class="mt-1 text-xs font-semibold text-rose-600">{{ formErrors.longitude }}</p>{% endif %}
                            </div>
                        </div>
                    </div>
                    <button class="mt-6 w-full rounded-2xl bg-slate-950 px-5 py-3 text-sm font-bold text-white">Submit for review</button>
                </form>

                <div class="rounded-[2rem] border border-border bg-white p-6 shadow-sm">
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <h2 class="text-2xl font-heading font-bold text-slate-950">Your places</h2>
                            <p class="mt-1 text-sm text-slate-500">Edit or delete any place you own.</p>
                        </div>
                    </div>

                    <div class="mt-5 space-y-4">
                        {% for place in places %}
                            {% set previewImage = placePreviewImages[place.id]|default(place.imageUrl) %}
                            {% set galleryImages = placeGalleryImages[place.id]|default([]) %}
                            <article class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                                {% if previewImage %}
                                    <img src="{{ previewImage starts with('http') ? previewImage : asset('uploads/places/' ~ previewImage) }}" alt="{{ place.title }}" class="mb-4 h-44 w-full rounded-2xl object-cover">
                                {% endif %}
                                {% if galleryImages is not empty %}
                                    <div class="mb-4 grid grid-cols-4 gap-2">
                                        {% for imageUrl in galleryImages|slice(0, 8) %}
                                            <img src="{{ imageUrl starts with('http') ? imageUrl : asset('uploads/places/' ~ imageUrl) }}" alt="{{ place.title }} image {{ loop.index }}" class="h-16 w-full rounded-xl object-cover">
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <div class="flex flex-wrap items-start justify-between gap-4">
                                    <div>
                                        <h3 class="text-2xl font-heading font-bold text-slate-950">{{ place.title }}</h3>
                                        <p class="mt-2 text-sm text-slate-500">{{ place.city }} · {{ place.address }}</p>
                                    </div>
                                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-slate-600">{{ place.status }}</span>
                                </div>
                                <div class="mt-5 flex flex-wrap items-center justify-between gap-3 border-t border-slate-200 pt-4 text-sm text-slate-600">
                                    <span>${{ place.pricePerDay }} / day</span>
                                    <div class="flex flex-wrap gap-2">
                                        <button
                                            type="button"
                                            onclick="openEditHostPlaceModal(this)"
                                            data-update-url="{{ path('app_booking_host_place_update', { id: place.id }) }}"
                                            data-update-token="{{ csrf_token('booking_host_place_update_' ~ place.id) }}"
                                            data-title="{{ place.title|e('html_attr') }}"
                                            data-description="{{ (place.description ?? '')|e('html_attr') }}"
                                            data-city="{{ place.city|e('html_attr') }}"
                                            data-category="{{ (place.category ?? '')|e('html_attr') }}"
                                            data-price-per-day="{{ place.pricePerDay|e('html_attr') }}"
                                            data-capacity="{{ place.capacity|e('html_attr') }}"
                                            data-max-guests="{{ place.maxGuests|e('html_attr') }}"
                                            data-address="{{ place.address|e('html_attr') }}"
                                            data-latitude="{{ (place.latitude ?: '36.80650000')|e('html_attr') }}"
                                            data-longitude="{{ (place.longitude ?: '10.18150000')|e('html_attr') }}"
                                            class="rounded-xl bg-slate-950 px-4 py-2 text-xs font-bold text-white"
                                        >
                                            Edit
                                        </button>
                                        <button
                                            type="button"
                                            onclick="openDeleteHostPlaceModal(this)"
                                            data-delete-url="{{ path('app_booking_host_place_delete', { id: place.id }) }}"
                                            data-delete-token="{{ csrf_token('booking_host_place_delete_' ~ place.id) }}"
                                            data-place-title="{{ place.title|e('html_attr') }}"
                                            class="rounded-xl bg-rose-600 px-4 py-2 text-xs font-bold text-white"
                                        >
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </article>
                        {% else %}
                            <div class="rounded-[2rem] border border-dashed border-border bg-slate-50 p-10 text-center">
                                <p class="text-lg font-heading font-bold text-slate-950">No places yet.</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="host-place-edit-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-slate-950/60 px-4 py-8 backdrop-blur-sm">
    <div class="w-full max-w-4xl rounded-[2rem] border border-border bg-background shadow-2xl">
        <div class="flex items-start justify-between border-b border-border px-6 py-5">
            <div>
                <p class="text-xs font-bold uppercase tracking-[0.28em] text-primary">Hosting</p>
                <h3 class="mt-1 text-2xl font-heading font-bold text-foreground">Edit Place</h3>
                <p class="mt-1 text-sm text-muted-foreground">Update your place details and add more images.</p>
            </div>
            <button type="button" onclick="closeEditHostPlaceModal()" class="rounded-full p-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
            </button>
        </div>

        <form id="host-place-edit-form" method="post" action="" enctype="multipart/form-data" data-validate-form novalidate class="grid max-h-[75vh] grid-cols-1 gap-3 overflow-y-auto px-6 py-6 md:grid-cols-2">
            <input id="host-place-edit-token" type="hidden" name="_token" value="">
            <div class="space-y-1 md:col-span-2">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Title</label>
                <input id="host-place-edit-title" type="text" name="title" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1 md:col-span-2">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Description</label>
                <textarea id="host-place-edit-description" name="description" rows="3" class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm"></textarea>
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">City</label>
                <input id="host-place-edit-city" type="text" name="city" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Category</label>
                <input id="host-place-edit-category" type="text" name="category" class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Price / day</label>
                <input id="host-place-edit-price" type="number" min="0.01" step="0.01" name="price_per_day" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Capacity</label>
                <input id="host-place-edit-capacity" type="number" min="1" name="capacity" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Max Guests</label>
                <input id="host-place-edit-max-guests" type="number" min="1" name="max_guests" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1 md:col-span-2">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Address</label>
                <input id="host-place-edit-address" type="text" name="address" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Latitude</label>
                <input id="host-place-edit-latitude" type="text" name="latitude" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Longitude</label>
                <input id="host-place-edit-longitude" type="text" name="longitude" required class="w-full rounded-xl border border-border bg-background px-3 py-2 text-sm">
            </div>
            <div class="space-y-2 md:col-span-2" data-image-uploader>
                <label class="text-xs font-bold uppercase tracking-wider text-muted-foreground">Add More Images</label>
                <div class="flex items-center gap-3">
                    <button type="button" class="js-upload-trigger rounded-xl border border-border bg-background px-4 py-2 text-xs font-bold">Upload images</button>
                    <span class="text-xs text-muted-foreground">Select one or many images</span>
                </div>
                <input type="file" name="images[]" accept="image/*" multiple class="js-image-input hidden">
                <div class="js-image-preview-grid grid grid-cols-3 gap-2 md:grid-cols-6"></div>
            </div>
            <div class="md:col-span-2 flex flex-wrap items-center justify-end gap-3 pt-2">
                <button type="button" onclick="closeEditHostPlaceModal()" class="rounded-xl border border-border px-5 py-2.5 text-sm font-bold text-foreground transition-colors hover:bg-secondary/50">Cancel</button>
                <button type="submit" class="rounded-xl bg-primary px-5 py-2.5 text-sm font-bold text-white transition-colors hover:bg-primary/90">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<div id="host-place-delete-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-slate-950/60 px-4 py-8 backdrop-blur-sm">
    <div class="w-full max-w-lg rounded-[2rem] border border-border bg-background p-6 shadow-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.28em] text-destructive">Danger Zone</p>
        <h3 class="mt-2 text-2xl font-heading font-bold text-foreground">Delete Place</h3>
        <p class="mt-2 text-sm text-muted-foreground">This action cannot be undone.</p>
        <p class="mt-2 text-sm font-semibold text-foreground" id="host-place-delete-name"></p>

        <form id="host-place-delete-form" method="post" action="" class="mt-6 flex flex-wrap items-center justify-end gap-3">
            <input id="host-place-delete-token" type="hidden" name="_token" value="">
            <button type="button" onclick="closeDeleteHostPlaceModal()" class="rounded-xl border border-border px-5 py-2.5 text-sm font-bold text-foreground transition-colors hover:bg-secondary/50">Cancel</button>
            <button type="submit" class="rounded-xl bg-destructive px-5 py-2.5 text-sm font-bold text-white">Delete</button>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const bookingStatusChartData = {{ bookingStatusChartData|json_encode|raw }};
    const earningsChartData = {{ earningsChartData|json_encode|raw }};

    const hostPlaceEditModal = document.getElementById('host-place-edit-modal');
    const hostPlaceEditForm = document.getElementById('host-place-edit-form');
    const hostPlaceEditToken = document.getElementById('host-place-edit-token');
    const hostPlaceDeleteModal = document.getElementById('host-place-delete-modal');
    const hostPlaceDeleteForm = document.getElementById('host-place-delete-form');
    const hostPlaceDeleteToken = document.getElementById('host-place-delete-token');
    const hostPlaceDeleteName = document.getElementById('host-place-delete-name');

    function initHostCharts() {
        if (typeof Chart === 'undefined') {
            return;
        }

        const statusCanvas = document.getElementById('bookingStatusChart');
        if (statusCanvas) {
            new Chart(statusCanvas, {
                type: 'doughnut',
                data: {
                    labels: bookingStatusChartData.map((item) => item.label),
                    datasets: [{
                        data: bookingStatusChartData.map((item) => item.count),
                        backgroundColor: ['#f59e0b', '#10b981', '#ef4444', '#94a3b8', '#0f172a'],
                        borderWidth: 0,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { usePointStyle: true } } },
                },
            });
        }

        const earningsCanvas = document.getElementById('earningsChart');
        if (earningsCanvas) {
            new Chart(earningsCanvas, {
                type: 'line',
                data: {
                    labels: earningsChartData.labels,
                    datasets: [{
                        label: 'Earnings',
                        data: earningsChartData.values,
                        borderColor: '#0f172a',
                        backgroundColor: 'rgba(15, 23, 42, 0.12)',
                        fill: true,
                        tension: 0.35,
                    }],
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                },
            });
        }
    }

    function initHostImageUploaders() {
        document.querySelectorAll('[data-image-uploader]').forEach((uploader) => {
            if (uploader.dataset.initialized === '1') {
                return;
            }

            const trigger = uploader.querySelector('.js-upload-trigger');
            const input = uploader.querySelector('.js-image-input');
            const grid = uploader.querySelector('.js-image-preview-grid');
            if (!trigger || !input || !grid) {
                return;
            }

            uploader.dataset.initialized = '1';
            let selectedFiles = [];

            const syncInputFiles = () => {
                const dataTransfer = new DataTransfer();
                selectedFiles.forEach((file) => dataTransfer.items.add(file));
                input.files = dataTransfer.files;
            };

            const appendSelectedFiles = (newFiles) => {
                const existingKeys = new Set(selectedFiles.map((file) => file.name + '|' + file.size + '|' + file.lastModified));
                newFiles.forEach((file) => {
                    const key = file.name + '|' + file.size + '|' + file.lastModified;
                    if (!existingKeys.has(key)) {
                        selectedFiles.push(file);
                        existingKeys.add(key);
                    }
                });
            };

            const renderSelectedFiles = () => {
                grid.innerHTML = '';

                selectedFiles.forEach((file, index) => {
                    const url = URL.createObjectURL(file);
                    const card = document.createElement('div');
                    card.className = 'relative';
                    card.innerHTML = '<img src="' + url + '" alt="selected image" class="h-14 w-full rounded-lg object-cover"><button type="button" class="js-remove-selected-image absolute -right-1 -top-1 h-5 w-5 rounded-full bg-destructive text-[11px] font-bold text-white">x</button>';

                    const removeButton = card.querySelector('.js-remove-selected-image');
                    removeButton.addEventListener('click', () => {
                        selectedFiles.splice(index, 1);
                        syncInputFiles();
                        renderSelectedFiles();
                    });

                    grid.appendChild(card);
                });
            };

            trigger.addEventListener('click', () => input.click());
            input.addEventListener('change', () => {
                appendSelectedFiles(Array.from(input.files || []));
                syncInputFiles();
                renderSelectedFiles();
            });

            uploader.__resetUploader = () => {
                selectedFiles = [];
                syncInputFiles();
                renderSelectedFiles();
            };
        });
    }

    function resetHostUploadersInContainer(container) {
        if (!container) {
            return;
        }

        container.querySelectorAll('[data-image-uploader]').forEach((uploader) => {
            if (typeof uploader.__resetUploader === 'function') {
                uploader.__resetUploader();
            }
        });
    }

    function initHostValidation() {
        document.querySelectorAll('form[data-validate-form]').forEach((form) => {
            if (form.dataset.validationInitialized === '1') {
                return;
            }

            form.dataset.validationInitialized = '1';
            const fields = form.querySelectorAll('input, textarea, select');

            fields.forEach((field) => {
                if (field.type === 'hidden') {
                    return;
                }

                const eventName = field.type === 'file' || field.tagName === 'SELECT' ? 'change' : 'input';
                field.addEventListener(eventName, () => field.setCustomValidity(''));
                field.addEventListener('blur', () => field.setCustomValidity(''));
            });

            form.addEventListener('submit', (event) => {
                let firstInvalid = null;

                fields.forEach((field) => {
                    if (field.type === 'hidden') {
                        return;
                    }

                    if (!field.checkValidity() && !firstInvalid) {
                        firstInvalid = field;
                    }
                });

                if (firstInvalid) {
                    event.preventDefault();
                    firstInvalid.reportValidity();
                }
            });
        });
    }

    function openEditHostPlaceModal(button) {
        if (!hostPlaceEditModal || !hostPlaceEditForm || !hostPlaceEditToken) {
            return;
        }

        const data = button.dataset;
        hostPlaceEditForm.action = data.updateUrl || '';
        hostPlaceEditToken.value = data.updateToken || '';

        document.getElementById('host-place-edit-title').value = data.title || '';
        document.getElementById('host-place-edit-description').value = data.description || '';
        document.getElementById('host-place-edit-city').value = data.city || '';
        document.getElementById('host-place-edit-category').value = data.category || '';
        document.getElementById('host-place-edit-price').value = data.pricePerDay || '';
        document.getElementById('host-place-edit-capacity').value = data.capacity || '';
        document.getElementById('host-place-edit-max-guests').value = data.maxGuests || '';
        document.getElementById('host-place-edit-address').value = data.address || '';
        document.getElementById('host-place-edit-latitude').value = data.latitude || '36.80650000';
        document.getElementById('host-place-edit-longitude').value = data.longitude || '10.18150000';

        resetHostUploadersInContainer(hostPlaceEditModal);
        hostPlaceEditModal.classList.remove('hidden');
        hostPlaceEditModal.classList.add('flex');
    }

    function closeEditHostPlaceModal() {
        if (!hostPlaceEditModal) {
            return;
        }

        hostPlaceEditModal.classList.add('hidden');
        hostPlaceEditModal.classList.remove('flex');
    }

    function openDeleteHostPlaceModal(button) {
        if (!hostPlaceDeleteModal || !hostPlaceDeleteForm || !hostPlaceDeleteToken || !hostPlaceDeleteName) {
            return;
        }

        const data = button.dataset;
        hostPlaceDeleteForm.action = data.deleteUrl || '';
        hostPlaceDeleteToken.value = data.deleteToken || '';
        hostPlaceDeleteName.textContent = data.placeTitle ? 'Place: ' + data.placeTitle : '';

        hostPlaceDeleteModal.classList.remove('hidden');
        hostPlaceDeleteModal.classList.add('flex');
    }

    function closeDeleteHostPlaceModal() {
        if (!hostPlaceDeleteModal) {
            return;
        }

        hostPlaceDeleteModal.classList.add('hidden');
        hostPlaceDeleteModal.classList.remove('flex');
    }

    if (hostPlaceEditModal) {
        hostPlaceEditModal.addEventListener('click', function (event) {
            if (event.target === hostPlaceEditModal) {
                closeEditHostPlaceModal();
            }
        });
    }

    if (hostPlaceDeleteModal) {
        hostPlaceDeleteModal.addEventListener('click', function (event) {
            if (event.target === hostPlaceDeleteModal) {
                closeDeleteHostPlaceModal();
            }
        });
    }

    document.addEventListener('keydown', function (event) {
        if (event.key !== 'Escape') {
            return;
        }

        if (hostPlaceEditModal && !hostPlaceEditModal.classList.contains('hidden')) {
            closeEditHostPlaceModal();
        }

        if (hostPlaceDeleteModal && !hostPlaceDeleteModal.classList.contains('hidden')) {
            closeDeleteHostPlaceModal();
        }
    });

    initHostCharts();
    initHostImageUploaders();
    initHostValidation();
</script>
{% endblock %}
