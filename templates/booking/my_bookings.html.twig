{% extends 'base.html.twig' %}

{% block title %}My Bookings — Wanderlust{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .bookings-shell { background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%); padding: 36px 0 72px; }
        .bookings-header { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-end; gap: 12px; margin-bottom: 24px; }
        .eyebrow { margin: 0; font-size: 11px; font-weight: 700; letter-spacing: .22em; text-transform: uppercase; color: #94a3b8; }
        .page-title { margin: 10px 0 8px; font-size: clamp(2rem, 3.4vw, 2.7rem); line-height: 1.1; color: #020617; font-weight: 700; }
        .page-subtitle { margin: 0; color: #64748b; font-size: 14px; }
        .browse-link { display: inline-flex; align-items: center; justify-content: center; border-radius: 12px; background: #020617; color: #fff; font-size: 13px; font-weight: 700; padding: 10px 14px; }
        .browse-link:hover { background: #1e293b; color: #fff; }

        .flash { margin-bottom: 10px; border-radius: 14px; padding: 10px 14px; font-size: 14px; font-weight: 600; border: 1px solid transparent; }
        .flash-success { border-color: #a7f3d0; background: #ecfdf5; color: #047857; }
        .flash-error { border-color: #fecdd3; background: #fff1f2; color: #be123c; }

        .booking-list { display: grid; gap: 18px; }
        .booking-card { border-radius: 24px; border: 1px solid #e2e8f0; background: #fff; padding: 22px; box-shadow: 0 12px 28px rgba(15, 23, 42, .07); }
        .booking-top { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; gap: 12px; }
        .booking-title { margin: 0; color: #020617; font-size: 1.5rem; font-weight: 700; }
        .booking-address { margin: 7px 0 2px; color: #64748b; font-size: 14px; }
        .booking-date { margin: 0; font-size: 11px; color: #94a3b8; text-transform: uppercase; letter-spacing: .16em; font-weight: 700; }
        .status-pill { border-radius: 999px; background: #f1f5f9; color: #475569; padding: 6px 10px; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }

        .booking-meta { margin-top: 16px; display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .meta-label { margin: 0; font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #94a3b8; }
        .meta-value { margin-top: 5px; margin-bottom: 0; color: #0f172a; font-weight: 600; font-size: 14px; }

        .refund-box { margin-top: 14px; border-radius: 14px; border: 1px solid #a7f3d0; background: #ecfdf5; color: #065f46; padding: 10px 12px; font-size: 14px; }
        .refund-box p { margin: 0; }
        .refund-box p + p { margin-top: 4px; font-size: 12px; }

        .cancel-form { margin-top: 14px; }
        .cancel-btn { border: 0; border-radius: 12px; background: #e11d48; color: #fff; font-size: 13px; font-weight: 700; padding: 9px 14px; transition: .2s ease; }
        .cancel-btn:hover { background: #be123c; }
        .policy-text { margin: 8px 0 0; font-size: 12px; color: #64748b; }

        .edit-panel { margin-top: 16px; border-radius: 18px; border: 1px solid #cbd5e1; background: #f8fafc; padding: 14px; }
        .edit-top { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; align-items: center; }
        .edit-title { margin: 0; color: #0f172a; font-size: 15px; font-weight: 700; }
        .edit-subtitle { margin: 2px 0 0; color: #64748b; font-size: 12px; }
        .edit-pill { border-radius: 999px; background: #fef3c7; color: #92400e; padding: 5px 10px; font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; }
        .edit-grid { margin-top: 12px; display: grid; gap: 10px; grid-template-columns: 1fr; }
        .edit-field label { display: block; margin-bottom: 5px; font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #94a3b8; }
        .edit-field input { width: 100%; border: 1px solid #cbd5e1; border-radius: 12px; padding: 10px 11px; font-size: 14px; color: #0f172a; }
        .edit-field input:focus { outline: none; border-color: #0ea5e9; }
        .save-btn { width: 100%; border: 0; border-radius: 12px; background: #020617; color: #fff; font-size: 13px; font-weight: 700; padding: 10px 12px; }
        .save-btn:hover { background: #1e293b; }

        .panel { margin-top: 30px; border-radius: 24px; border: 1px solid #e2e8f0; background: #fff; padding: 20px; box-shadow: 0 12px 28px rgba(15, 23, 42, .07); }
        .panel h2 { margin: 0; font-size: 1.55rem; color: #020617; }
        .panel p { margin: 6px 0 0; color: #64748b; font-size: 14px; }
        .places-grid { margin-top: 16px; display: grid; gap: 14px; grid-template-columns: repeat(1, minmax(0, 1fr)); }
        .place-card { overflow: hidden; border-radius: 20px; border: 1px solid #e2e8f0; background: #f8fafc; }
        .place-cover { height: 190px; background: #e2e8f0; }
        .place-cover img { width: 100%; height: 100%; object-fit: cover; }
        .place-body { padding: 14px; }
        .place-title { margin: 0; font-size: 1.15rem; font-weight: 700; color: #020617; }
        .place-info { margin: 5px 0 0; color: #64748b; font-size: 13px; }
        .place-link { display: inline-flex; margin-top: 8px; font-size: 13px; font-weight: 700; color: #0f172a; }
        .place-link:hover { color: #0369a1; }

        .empty-box { border: 1px dashed #cbd5e1; border-radius: 20px; background: #fff; text-align: center; padding: 36px 20px; }
        .empty-box h3 { margin: 0 0 6px; font-size: 1.05rem; color: #0f172a; }
        .empty-box p { margin: 0; color: #64748b; font-size: 14px; }

        @media (min-width: 768px) {
            .booking-meta { grid-template-columns: repeat(4, minmax(0, 1fr)); }
            .edit-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); align-items: end; }
            .places-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @media (min-width: 1200px) {
            .places-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        }
    </style>
{% endblock %}

{% block content %}
<section class="bookings-shell">
    <div class="container px-4">
        {% for message in app.flashes('success') %}
            <div class="flash flash-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="flash flash-error">{{ message }}</div>
        {% endfor %}

        <div class="bookings-header">
            <div>
                <p class="eyebrow">Trips</p>
                <h1 class="page-title">My bookings</h1>
                <p class="page-subtitle">Edit dates while a booking is still pending, then review the places you've booked below.</p>
            </div>
            <a href="{{ path('app_booking') }}" class="browse-link">Browse stays</a>
        </div>

        <div class="booking-list">
            {% for booking in bookings %}
                <article class="booking-card">
                    <div class="booking-top">
                        <div>
                            <h2 class="booking-title">{{ booking.place.title }}</h2>
                            <p class="booking-address">{{ booking.place.city }} · {{ booking.place.address }}</p>
                            <p class="booking-date">Booked on {{ booking.createdAt|date('M d, Y') }}</p>
                        </div>
                        <span class="status-pill">{{ booking.status }}</span>
                    </div>

                    <div class="booking-meta">
                        <div>
                            <p class="meta-label">Start</p>
                            <p class="meta-value">{{ booking.startDate|date('M d, Y') }}</p>
                        </div>
                        <div>
                            <p class="meta-label">End</p>
                            <p class="meta-value">{{ booking.endDate|date('M d, Y') }}</p>
                        </div>
                        <div>
                            <p class="meta-label">Guests</p>
                            <p class="meta-value">{{ booking.guestsCount }}</p>
                        </div>
                        <div>
                            <p class="meta-label">Total</p>
                            <p class="meta-value">{{ booking.totalPrice|number_format(2, '.', ' ') }}</p>
                        </div>
                    </div>

                    {% if booking.status == 'CANCELLED' %}
                        {% set totalPriceValue = booking.totalPrice + 0 %}
                        {% set refundAmountValue = booking.refundAmount + 0 %}
                        <div class="refund-box">
                            <p class="font-bold">Refund amount: {{ booking.refundAmount|number_format(2, '.', ' ') }}</p>
                            {% if totalPriceValue > 0 %}
                                <p>
                                    Refund rate: {{ ((refundAmountValue / totalPriceValue) * 100)|number_format(0, '.', ' ') }}%
                                </p>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if booking.status in ['PENDING', 'CONFIRMED'] %}
                        <form method="post" action="{{ path('app_booking_my_booking_cancel', { id: booking.id }) }}" class="cancel-form" onsubmit="return confirm('Cancel this booking?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('booking_cancel_' ~ booking.id) }}">
                            <button type="submit" class="cancel-btn">Cancel booking</button>
                            {% if booking.status == 'CONFIRMED' %}
                                <p class="policy-text">Refund policy: 100% (>=7 days), 50% (3-6 days), 0% (<3 days before start).</p>
                            {% endif %}
                        </form>
                    {% endif %}

                    {% if booking.status == 'PENDING' %}
                        <form method="post" action="{{ path('app_booking_my_booking_edit', { id: booking.id }) }}" class="edit-panel">
                            <div class="edit-top">
                                <div>
                                    <p class="edit-title">Edit pending dates</p>
                                    <p class="edit-subtitle">You can only change a booking while it is still pending.</p>
                                </div>
                                <span class="edit-pill">Pending editable</span>
                            </div>
                            <input type="hidden" name="_token" value="{{ csrf_token('booking_edit_' ~ booking.id) }}">
                            <div class="edit-grid">
                                <div class="edit-field">
                                    <label>Start date</label>
                                    <input type="date" name="start_date" value="{{ booking.startDate|date('Y-m-d') }}" min="{{ 'now'|date('Y-m-d') }}" required>
                                </div>
                                <div class="edit-field">
                                    <label>End date</label>
                                    <input type="date" name="end_date" value="{{ booking.endDate|date('Y-m-d') }}" min="{{ 'now'|date('Y-m-d') }}" required>
                                </div>
                                <div>
                                    <button type="submit" class="save-btn">Save dates</button>
                                </div>
                            </div>
                        </form>
                    {% endif %}
                </article>
            {% else %}
                <div class="empty-box">
                    <h3>No bookings yet.</h3>
                    <p>Book a stay to see your trips here.</p>
                </div>
            {% endfor %}
        </div>

        <div class="panel">
            <div>
                <div>
                    <h2>Places you visited</h2>
                    <p>The places tied to your bookings appear here underneath your trips.</p>
                </div>
            </div>

            <div class="places-grid">
                {% for place in visitedPlaces %}
                    {% set previewImage = place.imageUrl %}
                    {% if place.images is not empty %}
                        {% set previewImage = place.images|first.url %}
                    {% endif %}
                    <article class="place-card">
                        <div class="place-cover">
                            {% if previewImage %}
                                <img src="{{ previewImage starts with('http') ? previewImage : asset('uploads/places/' ~ previewImage) }}" alt="{{ place.title }}">
                            {% endif %}
                        </div>
                        <div class="place-body">
                            <h3 class="place-title">{{ place.title }}</h3>
                            <p class="place-info">{{ place.city }} · {{ place.address }}</p>
                            <a href="{{ path('app_booking_place', { id: place.id }) }}" class="place-link">View place</a>
                        </div>
                    </article>
                {% else %}
                    <p class="page-subtitle">No booked places yet.</p>
                {% endfor %}
            </div>
        </div>
    </div>
</section>
{% endblock %}