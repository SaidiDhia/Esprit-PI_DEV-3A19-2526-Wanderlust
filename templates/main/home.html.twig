{% extends 'base.html.twig' %}

{% block title %}Wanderlust - Home{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .home-banner {
            min-height: calc(78vh + 96px);
            padding-top: 96px;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
            isolation: isolate;
            background: #0f172a;
        }

        .home-banner-video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -2;
        }

        .home-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(rgba(0, 0, 0, 0.36), rgba(0, 0, 0, 0.52)),
                radial-gradient(circle at 22% 30%, rgba(246, 33, 75, 0.24), transparent 44%);
            pointer-events: none;
            z-index: -1;
        }

        .home-banner .container {
            position: relative;
            z-index: 1;
        }

        .home-banner h1 {
            color: #fff;
            font-size: 54px;
            font-weight: 700;
            margin-bottom: 16px;
            line-height: 1.1;
        }

        .home-banner p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 18px;
            max-width: 680px;
            margin-bottom: 30px;
        }

        .module-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: transform .25s ease, box-shadow .25s ease;
            height: 100%;
        }

        .module-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
        }

        .module-card .thumb {
            height: 220px;
            object-fit: cover;
            width: 100%;
        }

        .module-card .body {
            padding: 20px;
        }

        .module-card h4 {
            margin-bottom: 10px;
        }

        .facts-wrap {
            background: #f9f9ff;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 28px;
            text-align: center;
            margin-bottom: 20px;
        }

        .facts-wrap h2 {
            margin-bottom: 8px;
            color: #f6214b;
        }

        .testimonials-section {
            background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
        }

        .testimonial-track {
            display: flex;
            gap: 16px;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            padding-bottom: 8px;
            scroll-behavior: smooth;
        }

        .testimonial-track::-webkit-scrollbar {
            height: 8px;
        }

        .testimonial-track::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

        .testimonial-card {
            min-width: min(360px, 90vw);
            scroll-snap-align: start;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            padding: 18px;
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.08);
        }

        .testimonial-avatar {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            object-fit: cover;
            border: 2px solid #e2e8f0;
        }

        .testimonial-form {
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            padding: 22px;
            margin-top: 20px;
        }

        .testimonial-nav button {
            border: 1px solid #d1d5db;
            background: #fff;
            width: 42px;
            height: 42px;
            border-radius: 999px;
            font-weight: 700;
        }

        .testimonial-nav button:hover {
            background: #f8fafc;
        }
    </style>
{% endblock %}

{% block content %}
<section class="home-banner">
    <video class="home-banner-video" autoplay muted loop playsinline preload="metadata" poster="{{ asset('adventure/img/slider1.jpg') }}">
        <source src="{{ asset('adventure/Mountains, Fog, Clouds. Free Stock Video_2.mp4') }}" type="video/mp4">
    </video>
    <div class="container">
        <h1>Start Your Next Adventure</h1>
        <p>Explore events, activities, reservations and stories in one platform inspired by the Adventure travel theme.</p>
        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase mr-2">Explore Events</a>
        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Explore Activities</a>
    </div>
</section>

{% for message in app.flashes('success') %}
    <div class="container mt-4">
        <div class="alert alert-success mb-0">{{ message }}</div>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="container mt-4">
        <div class="alert alert-danger mb-0">{{ message }}</div>
    </div>
{% endfor %}

<section class="section-gap">
    <div class="container">
        <div class="row d-flex justify-content-center mb-40">
            <div class="menu-content pb-20 col-lg-8">
                <div class="title text-center">
                    <h1 class="mb-10">Browse Main Modules</h1>
                    <p>All core pages now share the Adventure visual language.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g1.jpg') }}" alt="Events">
                    <div class="body">
                        <h4>Events</h4>
                        <p>Create and manage event experiences.</p>
                        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g2.jpg') }}" alt="Activities">
                    <div class="body">
                        <h4>Activities</h4>
                        <p>Discover or publish local activities.</p>
                        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g3.jpg') }}" alt="Reservations">
                    <div class="body">
                        <h4>Reservations</h4>
                        <p>Track your reservation lifecycle quickly.</p>
                        <a href="{{ path('app_reservations_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g4.jpg') }}" alt="Marketplace">
                    <div class="body">
                        <h4>Marketplace</h4>
                        <p>Browse and publish travel items.</p>
                        <a href="{{ path('app_marketplace') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-gap testimonials-section pt-0">
    <div class="container">
        <div class="row d-flex justify-content-center mb-40">
            <div class="menu-content pb-20 col-lg-8">
                <div class="title text-center">
                    <h1 class="mb-10">Traveler Testimonials</h1>
                    <p>Real testimonials published by your community, with newest entries first.</p>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end testimonial-nav mb-3" style="gap: 8px;">
            <button type="button" id="testimonial-prev" aria-label="Previous testimonial">&#8592;</button>
            <button type="button" id="testimonial-next" aria-label="Next testimonial">&#8594;</button>
        </div>

        <div id="testimonial-track" class="testimonial-track">
            {% for item in testimonialFeed|default([]) %}
                {% set testimonialUser = item.user %}
                {% set testimonialName = testimonialUser ? (testimonialUser.fullName ?: testimonialUser.email) : 'Unknown traveler' %}
                {% set avatar = (testimonialUser and testimonialUser.profilePicture) ? asset('uploads/profiles/' ~ testimonialUser.profilePicture) : ('https://api.dicebear.com/7.x/avataaars/svg?seed=' ~ testimonialName|url_encode) %}
                <article class="testimonial-card">
                    <div class="d-flex align-items-center mb-3" style="gap: 12px;">
                        <img class="testimonial-avatar" src="{{ avatar }}" alt="{{ testimonialName }}">
                        <div>
                            <p class="mb-0" style="font-weight: 700; color: #0f172a;">{{ testimonialName }}</p>
                            <p class="mb-0" style="font-size: 12px; color: #64748b;">{{ item.createdAt|date('Y-m-d H:i') }}</p>
                            {% if item.moderationSeverity == 'mild' %}
                                <span style="display: inline-flex; margin-top: 4px; border-radius: 999px; background: #fff7ed; color: #c2410c; border: 1px solid #fdba74; padding: 2px 8px; font-size: 10px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;">Filtered</span>
                            {% endif %}
                        </div>
                    </div>
                    {% if item.hiddenByModeration %}
                        <p class="mb-0" style="font-size: 15px; color: #be123c; line-height: 1.55; font-weight: 600;">This testimonial was removed from public view due to policy violation.</p>
                    {% else %}
                        <p class="mb-0" style="font-size: 15px; color: #0f172a; line-height: 1.55;">{{ item.displayContent|slice(0, 300) }}</p>
                    {% endif %}
                </article>
            {% else %}
                <article class="testimonial-card">
                    <p class="mb-0" style="color: #475569;">No testimonials yet. Be the first to share your experience.</p>
                </article>
            {% endfor %}
        </div>

        <div class="testimonial-form">
            <h4 class="mb-3">Share your testimonial</h4>
            <p class="mb-3" style="color: #64748b;">Your profile picture, name, timestamp, and message will appear in the testimonial slider.</p>
            <form method="post" action="{{ path('app_home') }}">
                <input type="hidden" name="action" value="submit_testimonial">
                <input type="hidden" name="_token" value="{{ csrf_token('submit_home_testimonial') }}">
                <div class="form-group mb-3">
                    <textarea name="testimonialContent" rows="4" class="form-control" maxlength="1200" placeholder="Tell us about your stay, activities, or messages experience..." required></textarea>
                </div>
                {% if app.user %}
                    <button type="submit" class="primary-btn text-uppercase">Publish Testimonial</button>
                {% else %}
                    <a href="{{ path('app_login') }}" class="primary-btn text-uppercase">Login To Publish</a>
                {% endif %}
            </form>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>100%</h2>
                    <p>Symfony-integrated theme migration</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Auth-safe</h2>
                    <p>Ownership and access rules preserved</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Responsive</h2>
                    <p>Desktop and mobile friendly layout</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        const track = document.getElementById('testimonial-track');
        const prevBtn = document.getElementById('testimonial-prev');
        const nextBtn = document.getElementById('testimonial-next');
        if (!track || !prevBtn || !nextBtn) {
            return;
        }

        const scrollStep = 380;
        prevBtn.addEventListener('click', function () {
            track.scrollBy({ left: -scrollStep, behavior: 'smooth' });
        });
        nextBtn.addEventListener('click', function () {
            track.scrollBy({ left: scrollStep, behavior: 'smooth' });
        });
    })();
</script>

{% endblock %}
