{% extends 'base.html.twig' %}

{% block title %}WanderLust — Votre Compagnon de Voyage{% endblock %}

{% block content %}

<!-- HERO -->
<section class="hero-section fullscreen">
    <div class="hero-bg-shapes">
        <div class="hero-shape hero-shape-1"></div>
        <div class="hero-shape hero-shape-2"></div>
        <div class="hero-shape hero-shape-3"></div>
    </div>
    <div class="hero-content">
        <div class="hero-tag">✈️ Votre Compagnon de Voyage</div>
        <h1 class="hero-title">
            Découvrez les Merveilles<br>
            <em>Cachées du Monde</em>
        </h1>
        <p class="hero-subtitle">Planifiez, réservez et vivez des aventures inoubliables avec WanderLust — tous vos besoins de voyage au même endroit.</p>
        <div class="hero-cta-group">
            <a href="{{ path('app_activities_index') }}" class="btn-hero-primary">🗺️ Explorer les Activités</a>
            <a href="{{ path('app_events_index') }}" class="btn-hero-outline">🎉 Parcourir les Événements</a>
        </div>
    </div>
</section>

<!-- STATS BAR -->
<div class="stats-bar">
    <div class="stats-bar-inner">
        <div class="stat-item">
            <div class="stat-number counter">12K+</div>
            <div class="stat-label">Voyageurs Heureux</div>
        </div>
        <div class="stat-item">
            <div class="stat-number counter">480+</div>
            <div class="stat-label">Destinations</div>
        </div>
        <div class="stat-item">
            <div class="stat-number counter">98%</div>
            <div class="stat-label">Taux de Satisfaction</div>
        </div>
        <div class="stat-item">
            <div class="stat-number counter">24/7</div>
            <div class="stat-label">Support Client</div>
        </div>
    </div>
</div>

<!-- MODULES GRID -->
<section class="modules-section">
    <div class="section-header">
        <div class="section-label">Tout ce dont vous avez besoin</div>
        <h2 class="section-title">Votre Plateforme de Voyage Complète</h2>
    </div>

    <div class="modules-grid">

        <!-- Activities -->
        <a href="{{ path('app_activities_index') }}" class="module-card card-activities">
            <div class="module-card-visual">
                <span class="card-emoji">📅</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Activités</div>
                <p class="module-card-desc">Parcourez des centaines d'activités organisées, de visites et d'expériences locales. Filtrez par date, lieu et centres d'intérêt.</p>
                <span class="module-card-arrow">Explorer les activités →</span>
            </div>
        </a>

        <!-- Events -->
        <a href="{{ path('app_events_index') }}" class="module-card card-events">
            <div class="module-card-visual">
                <span class="card-emoji">🎉</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Événements</div>
                <p class="module-card-desc">Parcourez et gérez les événements, activités et expériences. Créez de nouveaux événements et suivez les inscriptions.</p>
                <span class="module-card-arrow">Explorer les événements →</span>
            </div>
        </a>

        <!-- Booking -->
        <a href="{{ path('app_booking') }}" class="module-card card-booking">
            <div class="module-card-visual">
                <span class="card-emoji">🏨</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Réservation d'Hôtels</div>
                <p class="module-card-desc">Trouvez et réservez des hôtels, resorts et séjours uniques aux meilleurs prix. Comparez les avis et équipements instantanément.</p>
                <span class="module-card-arrow">Réserver votre séjour →</span>
            </div>
        </a>

        <!-- Messaging -->
        <a href="{{ path('app_messaging') }}" class="module-card card-messaging">
            <div class="module-card-visual">
                <span class="card-emoji">💬</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Messaging</div>
                <p class="module-card-desc">Chat directly with guides, hosts, and fellow travelers. Get real-time answers and personalized recommendations.</p>
                <span class="module-card-arrow">Open messages →</span>
            </div>
        </a>

        <!-- Blog -->
        <a href="{{ path('app_blog') }}" class="module-card card-blog">
            <div class="module-card-visual">
                <span class="card-emoji">📝</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Travel Blog</div>
                <p class="module-card-desc">Read inspiring travel stories, destination guides, and expert tips from seasoned explorers around the globe.</p>
                <span class="module-card-arrow">Read stories →</span>
            </div>
        </a>

        <!-- Marketplace -->
        <a href="{{ path('app_marketplace') }}" class="module-card card-marketplace">
            <div class="module-card-visual">
                <span class="card-emoji">🛒</span>
            </div>
            <div class="module-card-body">
                <div class="module-card-title">Marketplace</div>
                <p class="module-card-desc">Shop travel gear, souvenirs, and local crafts. Support local artisans and equip yourself for any adventure.</p>
                <span class="module-card-arrow">Shop now →</span>
            </div>
        </a>

    </div>
</section>

{% endblock %}
