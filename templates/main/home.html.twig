{% extends 'base.html.twig' %}

{% block title %}Wanderlust - Home{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .home-banner {
            min-height: calc(78vh + 96px);
            padding-top: 96px;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
            isolation: isolate;
            background: #0f172a;
        }

        .home-banner-video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -2;
        }

        .home-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(rgba(0, 0, 0, 0.36), rgba(0, 0, 0, 0.52)),
                radial-gradient(circle at 22% 30%, rgba(246, 33, 75, 0.24), transparent 44%);
            pointer-events: none;
            z-index: -1;
        }

        .home-banner .container {
            position: relative;
            z-index: 1;
        }

        .home-banner h1 {
            color: #fff;
            font-size: 54px;
            font-weight: 700;
            margin-bottom: 16px;
            line-height: 1.1;
        }

        .home-banner p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 18px;
            max-width: 680px;
            margin-bottom: 30px;
        }

        .module-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: transform .25s ease, box-shadow .25s ease;
            height: 100%;
        }

        .module-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
        }

        .module-card .thumb {
            height: 220px;
            object-fit: cover;
            width: 100%;
        }

        .module-card .body {
            padding: 20px;
        }

        .module-card h4 {
            margin-bottom: 10px;
        }

        .facts-wrap {
            background: #f9f9ff;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 28px;
            text-align: center;
            margin-bottom: 20px;
        }

        .facts-wrap h2 {
            margin-bottom: 8px;
            color: #f6214b;
        }
    </style>
{% endblock %}

{% block content %}
<section class="home-banner">
    <video class="home-banner-video" autoplay muted loop playsinline preload="metadata" poster="{{ asset('adventure/img/slider1.jpg') }}">
        <source src="{{ asset('adventure/Mountains, Fog, Clouds. Free Stock Video_2.mp4') }}" type="video/mp4">
    </video>
    <div class="container">
        <h1>Start Your Next Adventure</h1>
        <p>Explore events, activities, reservations and stories in one platform inspired by the Adventure travel theme.</p>
        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase mr-2">Explore Events</a>
        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Explore Activities</a>
    </div>
</section>

<section class="section-gap">
    <div class="container">
        <div class="row d-flex justify-content-center mb-40">
            <div class="menu-content pb-20 col-lg-8">
                <div class="title text-center">
                    <h1 class="mb-10">Browse Main Modules</h1>
                    <p>All core pages now share the Adventure visual language.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g1.jpg') }}" alt="Events">
                    <div class="body">
                        <h4>Events</h4>
                        <p>Create and manage event experiences.</p>
                        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g2.jpg') }}" alt="Activities">
                    <div class="body">
                        <h4>Activities</h4>
                        <p>Discover or publish local activities.</p>
                        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g3.jpg') }}" alt="Reservations">
                    <div class="body">
                        <h4>Reservations</h4>
                        <p>Track your reservation lifecycle quickly.</p>
                        <a href="{{ path('app_reservations_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g4.jpg') }}" alt="Marketplace">
                    <div class="body">
                        <h4>Marketplace</h4>
                        <p>Browse and publish travel items.</p>
                        <a href="{{ path('app_marketplace') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>100%</h2>
                    <p>Symfony-integrated theme migration</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Auth-safe</h2>
                    <p>Ownership and access rules preserved</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Responsive</h2>
                    <p>Desktop and mobile friendly layout</p>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}
