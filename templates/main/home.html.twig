{% extends 'base.html.twig' %}

{% block title %}WanderLust — Explore the World{% endblock %}

{% block content %}

<!-- Hero Section -->
<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&q=80&w=2000"
        alt="Stunning mountain landscape"
        class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-foreground/40 via-foreground/20 to-foreground/60"></div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-heading font-bold text-white mb-4 leading-tight">
            Your Next Adventure
            <br />
            <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">
                Starts Here
            </span>
        </h1>
        <p class="text-lg md:text-xl text-white/80 mb-8 max-w-2xl mx-auto">
            Discover unique stays, vibrant experiences, and a global community of travelers.
        </p>

        <!-- Search Bar -->
        <div class="glass-strong rounded-2xl p-2 max-w-3xl mx-auto">
            <div class="flex flex-col sm:flex-row gap-2">
                <div class="flex-1 flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-secondary/50 transition-colors cursor-pointer">
                    <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    <div class="text-left">
                        <p class="text-xs font-medium text-muted-foreground uppercase">Where</p>
                        <p class="text-sm text-foreground font-semibold">Search destinations</p>
                    </div>
                </div>
                <div class="hidden sm:block w-px bg-border my-2"></div>
                <div class="flex-1 flex items-center gap-2 px-4 py-3 rounded-xl hover:bg-secondary/50 transition-colors cursor-pointer">
                    <svg class="w-5 h-5 text-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                    <div class="text-left">
                        <p class="text-xs font-medium text-muted-foreground uppercase">When</p>
                        <p class="text-sm text-foreground font-semibold">Add dates</p>
                    </div>
                </div>
                <button class="bg-primary hover:bg-primary/90 text-white px-8 py-3 rounded-xl font-bold flex items-center justify-center gap-2 transition-all">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    <span>Search</span>
                </button>
            </div>
        </div>
    </div>
</section>

<!-- Featured Stays -->
<section class="py-20 px-4 bg-background">
    <div class="container mx-auto">
        <div class="flex items-end justify-between mb-10">
            <div>
                <p class="text-sm font-bold text-primary mb-1 uppercase tracking-wider">Featured Stays</p>
                <h2 class="text-3xl md:text-4xl font-heading font-bold text-foreground">
                    Places to stay
                </h2>
            </div>
            <a href="{{ path('app_booking') }}" class="text-sm font-semibold text-primary hover:underline hidden sm:block">
                View all →
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            <!-- Property 1 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/3] overflow-hidden rounded-2xl mb-4">
                    <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground shadow-sm">Villa</div>
                </div>
                <div class="flex justify-between items-start mb-1">
                    <h3 class="font-heading font-bold text-lg group-hover:text-primary transition-colors">Oceanview Infinity Villa</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>4.9</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-2">Bali, Indonesia</p>
                <p class="text-foreground"><span class="font-bold text-lg">$285</span> <span class="text-muted-foreground text-sm">/ night</span></p>
            </div>

            <!-- Property 2 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/3] overflow-hidden rounded-2xl mb-4">
                    <img src="https://images.unsplash.com/photo-1510798831971-661eb04b3739?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground shadow-sm">Cabin</div>
                </div>
                <div class="flex justify-between items-start mb-1">
                    <h3 class="font-heading font-bold text-lg group-hover:text-primary transition-colors">Alpine Pine Lodge</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>4.8</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-2">Zermatt, Switzerland</p>
                <p class="text-foreground"><span class="font-bold text-lg">$195</span> <span class="text-muted-foreground text-sm">/ night</span></p>
            </div>

            <!-- Property 3 -->
            <div class="group cursor-pointer">
                <div class="relative aspect-[4/3] overflow-hidden rounded-2xl mb-4">
                    <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
                    <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-foreground shadow-sm">Loft</div>
                </div>
                <div class="flex justify-between items-start mb-1">
                    <h3 class="font-heading font-bold text-lg group-hover:text-primary transition-colors">Manhattan Skyline Loft</h3>
                    <div class="flex items-center gap-1 text-sm font-bold">
                        <svg class="w-4 h-4 text-accent fill-accent" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                        <span>4.7</span>
                    </div>
                </div>
                <p class="text-muted-foreground text-sm mb-2">New York, USA</p>
                <p class="text-foreground"><span class="font-bold text-lg">$320</span> <span class="text-muted-foreground text-sm">/ night</span></p>
            </div>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="py-20 bg-secondary/20">
    <div class="container mx-auto px-4">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4 text-foreground">Why choose Wanderlust?</h2>
            <p class="text-muted-foreground">We provide everything you need for an unforgettable journey.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
            <div class="text-center">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">Safe & Secure</h3>
                <p class="text-muted-foreground text-sm">Your safety is our top priority. We verify every host and property.</p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">24/7 Support</h3>
                <p class="text-muted-foreground text-sm">Our team is always here to help you, no matter where you are in the world.</p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-6 text-primary">
                    <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <h3 class="text-xl font-bold mb-3">Global Community</h3>
                <p class="text-muted-foreground text-sm">Connect with millions of travelers and share your experiences.</p>
            </div>
        </div>
    </div>
</section>

{% endblock %}
