{% extends 'base.html.twig' %}

{% block title %}Wanderlust - Home{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .home-banner {
            min-height: calc(78vh + 96px);
            padding-top: 96px;
            position: relative;
            display: flex;
            align-items: center;
            overflow: hidden;
            isolation: isolate;
            background: #0f172a;
        }

        .home-banner-video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -2;
        }

        .home-banner::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(rgba(0, 0, 0, 0.36), rgba(0, 0, 0, 0.52)),
                radial-gradient(circle at 22% 30%, rgba(246, 33, 75, 0.24), transparent 44%);
            pointer-events: none;
            z-index: -1;
        }

        .home-banner .container {
            position: relative;
            z-index: 1;
        }

        .home-banner h1 {
            color: #fff;
            font-size: 54px;
            font-weight: 700;
            margin-bottom: 16px;
            line-height: 1.1;
        }

        .home-banner p {
            color: rgba(255, 255, 255, 0.9);
            font-size: 18px;
            max-width: 680px;
            margin-bottom: 30px;
        }

        .module-card {
            border: 1px solid #eee;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: transform .25s ease, box-shadow .25s ease;
            height: 100%;
        }

        .module-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.12);
        }

        .module-card .thumb {
            height: 220px;
            object-fit: cover;
            width: 100%;
        }

        .module-card .body {
            padding: 20px;
        }

        .module-card h4 {
            margin-bottom: 10px;
        }

        .facts-wrap {
            background: #f9f9ff;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 28px;
            text-align: center;
            margin-bottom: 20px;
        }

        .facts-wrap h2 {
            margin-bottom: 8px;
            color: #f6214b;
        }

        .testimonials-section {
            background: linear-gradient(180deg, #fff 0%, #f8fafc 100%);
        }

        .testimonial-track {
            display: flex;
            gap: 16px;
            overflow-x: auto;
            scroll-snap-type: x mandatory;
            padding-bottom: 8px;
            scroll-behavior: smooth;
        }

        .testimonial-track::-webkit-scrollbar {
            height: 8px;
        }

        .testimonial-track::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 999px;
        }

        .testimonial-card {
            min-width: min(360px, 90vw);
            scroll-snap-align: start;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            padding: 18px;
            box-shadow: 0 8px 30px rgba(15, 23, 42, 0.08);
        }

        .testimonial-avatar {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            object-fit: cover;
            border: 2px solid #e2e8f0;
        }

        .testimonial-form {
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            padding: 22px;
            margin-top: 20px;
        }

        .testimonial-nav button {
            border: 1px solid #d1d5db;
            background: #fff;
            width: 42px;
            height: 42px;
            border-radius: 999px;
            font-weight: 700;
        }

        .testimonial-nav button:hover {
            background: #f8fafc;
        }

        /* Carousel Styles */
        .carousel-container {
            position: relative;
            max-width: 600px;
            margin: 0 auto;
        }

        .carousel-wrapper {
            overflow: hidden;
            border-radius: 16px;
        }

        .carousel-inner {
            display: flex;
            position: relative;
        }

        .carousel-item {
            min-width: 100%;
            opacity: 0;
            transition: opacity 0.7s ease-in-out;
        }

        .carousel-item.active {
            opacity: 1;
        }

        .testimonial-card {
            min-width: 100%;
        }

        .carousel-indicators {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 20px;
            padding: 0;
        }

        .carousel-indicators button {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            border: none;
            background: #cbd5e1;
            cursor: pointer;
            transition: background-color 0.3s ease, transform 0.3s ease;
        }

        .carousel-indicators button.active {
            background: #1D4ED8;
            transform: scale(1.2);
        }

        .carousel-indicators button:hover {
            background: #94a3b8;
        }

        .no-testimonials {
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            background: #fff;
            padding: 40px;
            text-align: center;
            color: #475569;
        }
    </style>
{% endblock %}

{% block content %}
<section class="home-banner">
    <video class="home-banner-video" autoplay muted loop playsinline preload="metadata" poster="{{ asset('adventure/img/slider1.jpg') }}">
        <source src="{{ asset('adventure/Mountains, Fog, Clouds. Free Stock Video_2.mp4') }}" type="video/mp4">
    </video>
    <div class="container">
        <h1>Start Your Next Adventure</h1>
        <p>Explore events, activities, reservations and stories in one platform inspired by the Adventure travel theme.</p>
        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase mr-2">Explore Events</a>
        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Explore Activities</a>
    </div>
</section>

{% for message in app.flashes('success') %}
    <div class="container mt-4">
        <div class="alert alert-success mb-0">{{ message }}</div>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="container mt-4">
        <div class="alert alert-danger mb-0">{{ message }}</div>
    </div>
{% endfor %}

<section class="section-gap">
    <div class="container">
        <div class="row d-flex justify-content-center mb-40">
            <div class="menu-content pb-20 col-lg-8">
                <div class="title text-center">
                    <h1 class="mb-10">Browse Main Modules</h1>
                    <p>All core pages now share the Adventure visual language.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g1.jpg') }}" alt="Events">
                    <div class="body">
                        <h4>Events</h4>
                        <p>Create and manage event experiences.</p>
                        <a href="{{ path('app_events_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g2.jpg') }}" alt="Activities">
                    <div class="body">
                        <h4>Activities</h4>
                        <p>Discover or publish local activities.</p>
                        <a href="{{ path('app_activities_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g3.jpg') }}" alt="Reservations">
                    <div class="body">
                        <h4>Reservations</h4>
                        <p>Track your reservation lifecycle quickly.</p>
                        <a href="{{ path('app_reservations_index') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="module-card">
                    <img class="thumb" src="{{ asset('adventure/img/g4.jpg') }}" alt="Marketplace">
                    <div class="body">
                        <h4>Marketplace</h4>
                        <p>Browse and publish travel items.</p>
                        <a href="{{ path('app_marketplace') }}" class="primary-btn text-uppercase">Open</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-gap testimonials-section pt-0">
    <div class="container">
        <div class="row d-flex justify-content-center mb-40">
            <div class="menu-content pb-20 col-lg-8">
                <div class="title text-center">
                    <h1 class="mb-10">Traveler Testimonials</h1>
                    <p>Real testimonials published by your community, with newest entries first.</p>
                </div>
            </div>
        </div>

        {% if testimonialFeed|default([]) is not empty %}
            <div class="carousel-container">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div style="flex: 1;"></div>
                    <div class="testimonial-nav d-flex" style="gap: 8px;">
                        <button type="button" id="carousel-prev" aria-label="Previous testimonial">&#8592;</button>
                        <button type="button" id="carousel-next" aria-label="Next testimonial">&#8594;</button>
                    </div>
                </div>

                <div class="carousel-wrapper">
                    <div class="carousel-inner" id="carousel-inner">
                        {% for item in testimonialFeed|default([]) %}
                            {% set testimonialUser = item.user %}
                            {% set testimonialName = testimonialUser ? (testimonialUser.fullName ?: testimonialUser.email) : 'Unknown traveler' %}
                            {% set avatar = (testimonialUser and testimonialUser.profilePicture) ? asset('uploads/profiles/' ~ testimonialUser.profilePicture) : ('https://api.dicebear.com/7.x/avataaars/svg?seed=' ~ testimonialName|url_encode) %}
                            <article class="carousel-item{% if loop.first %} active{% endif %}" data-testimonial-id="{{ item.id }}">
                                <div class="testimonial-card">
                                    <div class="d-flex align-items-center mb-3" style="gap: 12px;">
                                        <img class="testimonial-avatar" src="{{ avatar }}" alt="{{ testimonialName }}">
                                        <div style="flex: 1;">
                                            <p class="mb-0" style="font-weight: 700; color: #0f172a;">{{ testimonialName }}</p>
                                            <p class="mb-0" style="font-size: 12px; color: #64748b;">
                                                {% if item.updatedAt %}
                                                    Updated {{ item.updatedAt|date('Y-m-d H:i') }}
                                                {% else %}
                                                    {{ item.createdAt|date('Y-m-d H:i') }}
                                                {% endif %}
                                            </p>
                                            {% if item.moderationSeverity == 'mild' %}
                                                <span style="display: inline-flex; margin-top: 4px; border-radius: 999px; background: #fff7ed; color: #c2410c; border: 1px solid #fdba74; padding: 2px 8px; font-size: 10px; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;">Filtered</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if item.hiddenByModeration %}
                                        <p class="mb-0" style="font-size: 15px; color: #be123c; line-height: 1.55; font-weight: 600;">This testimonial was removed from public view due to policy violation.</p>
                                    {% else %}
                                        <p class="mb-0" style="font-size: 15px; color: #0f172a; line-height: 1.55;">{{ item.displayContent|slice(0, 300) }}</p>
                                    {% endif %}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </div>

                {% if testimonialFeed|length > 1 %}
                    <div class="carousel-indicators" id="carousel-indicators">
                        {% for item in testimonialFeed %}
                            <button type="button" class="{% if loop.first %}active{% endif %}" aria-label="Go to testimonial {{ loop.index }}" data-slide-index="{{ loop.index0 }}"></button>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div class="no-testimonials">
                <p class="mb-0">No testimonials yet. Be the first to share your experience.</p>
            </div>
        {% endif %}

        <div class="testimonial-form">
            {% if app.user and userTestimonial %}
                <h4 class="mb-3">Update your testimonial</h4>
                <p class="mb-3" style="color: #64748b;">Edit your existing testimonial to keep it fresh and up-to-date.</p>
            {% else %}
                <h4 class="mb-3">Share your testimonial</h4>
                <p class="mb-3" style="color: #64748b;">Your profile picture, name, timestamp, and message will appear in the testimonial carousel.</p>
            {% endif %}
            <form method="post" action="{{ path('app_home') }}">
                <input type="hidden" name="action" value="submit_testimonial">
                <input type="hidden" name="_token" value="{{ csrf_token('submit_home_testimonial') }}">
                <div class="form-group mb-3">
                    <textarea name="testimonialContent" rows="4" class="form-control" maxlength="1200" placeholder="Tell us about your stay, activities, or experience..." required>{% if userTestimonial %}{{ userTestimonial.content }}{% endif %}</textarea>
                </div>
                {% if app.user %}
                    <button type="submit" class="primary-btn text-uppercase">
                        {% if userTestimonial %}Update Testimonial{% else %}Publish Testimonial{% endif %}
                    </button>
                {% else %}
                    <a href="{{ path('app_login') }}" class="primary-btn text-uppercase">Login To Publish</a>
                {% endif %}
            </form>
        </div>
    </div>
</section>

<section class="section-gap pt-0">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>100%</h2>
                    <p>Symfony-integrated theme migration</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Auth-safe</h2>
                    <p>Ownership and access rules preserved</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="facts-wrap">
                    <h2>Responsive</h2>
                    <p>Desktop and mobile friendly layout</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        const carousel = document.getElementById('carousel-inner');
        const items = carousel ? Array.from(carousel.querySelectorAll('.carousel-item')) : [];
        const prevBtn = document.getElementById('carousel-prev');
        const nextBtn = document.getElementById('carousel-next');
        const indicators = document.querySelectorAll('.carousel-indicators button');
        
        if (items.length === 0) return;

        let currentIndex = 0;
        let autoPlayTimer = null;
        const AUTO_PLAY_INTERVAL = 5000; // 5 seconds

        // Show slide at given index
        function showSlide(index) {
            // Ensure index is within bounds
            currentIndex = (index + items.length) % items.length;

            // Update items
            items.forEach((item, i) => {
                item.classList.remove('active');
                if (i === currentIndex) {
                    item.classList.add('active');
                }
            });

            // Update indicators
            indicators.forEach((indicator, i) => {
                indicator.classList.remove('active');
                if (i === currentIndex) {
                    indicator.classList.add('active');
                }
            });
        }

        // Next slide
        function nextSlide() {
            showSlide(currentIndex + 1);
            resetAutoPlay();
        }

        // Previous slide
        function prevSlide() {
            showSlide(currentIndex - 1);
            resetAutoPlay();
        }

        // Go to specific slide
        function goToSlide(index) {
            showSlide(index);
            resetAutoPlay();
        }

        // Auto-play functionality
        function startAutoPlay() {
            autoPlayTimer = setInterval(() => {
                nextSlide();
            }, AUTO_PLAY_INTERVAL);
        }

        function resetAutoPlay() {
            if (autoPlayTimer) {
                clearInterval(autoPlayTimer);
            }
            startAutoPlay();
        }

        // Event listeners
        if (prevBtn) {
            prevBtn.addEventListener('click', prevSlide);
        }
        if (nextBtn) {
            nextBtn.addEventListener('click', nextSlide);
        }

        indicators.forEach((indicator) => {
            indicator.addEventListener('click', function () {
                const slideIndex = parseInt(this.dataset.slideIndex, 10);
                goToSlide(slideIndex);
            });
        });

        // Start auto-play
        startAutoPlay();

        // Optional: Pause on hover
        const carouselWrapper = document.querySelector('.carousel-wrapper');
        if (carouselWrapper) {
            carouselWrapper.addEventListener('mouseenter', () => {
                if (autoPlayTimer) {
                    clearInterval(autoPlayTimer);
                }
            });

            carouselWrapper.addEventListener('mouseleave', () => {
                startAutoPlay();
            });
        }
    })();
</script>

{% endblock %}
