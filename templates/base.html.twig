<!DOCTYPE html>
<html lang="en">
<head>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}WanderLust{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- HEADER -->
<header class="site-header">
    <!-- Top bar: contacts + logo + profile -->
    <div class="header-top">
        <!-- Contact Info -->
        <div class="contact-info">
            <div class="logo-wrap">
            <a href="{{ path('app_home') }}" class="logo-link">
                <div class="logo-icon">
                    <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="30" cy="30" r="28" fill="#1D4ED8" opacity="0.1" stroke="#1D4ED8" stroke-width="2"/>
                        <path d="M15 38 C20 25 25 20 30 18 C35 20 40 25 45 38" stroke="#1D4ED8" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                        <path d="M22 38 C24 30 27 26 30 24 C33 26 36 30 38 38" stroke="#1D4ED8" stroke-width="2" fill="none" stroke-linecap="round"/>
                        <circle cx="30" cy="20" r="3" fill="#1D4ED8"/>
                        <path d="M14 38 H46" stroke="#1D4ED8" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="logo-text">WanderLust</span>
            </a>
        </div>
        </div>

        <!-- Logo Center -->
        <div class="logo-wrap">
        <!-- Nav Bar -->
    <nav class="nav-bar">
        <a href="{{ path('app_activities') }}" class="nav-btn {% if app.request.attributes.get('_route') starts with 'app_activities' %}active{% endif %}">
            <span class="nav-icon">📅</span> ACTIVITÉS
        </a>
        <a href="{{ path('app_booking') }}" class="nav-btn {% if app.request.attributes.get('_route') starts with 'app_booking' %}active{% endif %}">
            <span class="nav-icon">🏨</span> BOOKING
        </a>
        <a href="{{ path('app_messaging') }}" class="nav-btn {% if app.request.attributes.get('_route') starts with 'app_messaging' %}active{% endif %}">
            <span class="nav-icon">💬</span> MESSAGING
        </a>
        <a href="{{ path('app_blog') }}" class="nav-btn {% if app.request.attributes.get('_route') starts with 'app_blog' %}active{% endif %}">
            <span class="nav-icon">📝</span> BLOG
        </a>
        <a href="{{ path('app_marketplace') }}" class="nav-btn {% if app.request.attributes.get('_route') starts with 'app_marketplace' %}active{% endif %}">
            <span class="nav-icon">🛒</span> MARKETPLACE
        </a>
    </nav>
            
        </div>

        <!-- Profile -->
        <div class="profile-area">
            <span class="user-name">Guest</span>
            <div class="avatar-menu">
                <div class="avatar-circle">
                    <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="20" cy="16" r="7" fill="#1D4ED8" opacity="0.7"/>
                        <path d="M6 36 C6 28 13 22 20 22 C27 22 34 28 34 36" fill="#1D4ED8" opacity="0.5"/>
                    </svg>
                </div>
                <div class="dropdown-menu-custom">
                    <a href="{{ path('app_settings') }}" class="dropdown-item-custom">⚙️ Settings</a>
                    <a href="{{ path('app_logout') }}" class="dropdown-item-custom">🚪 Logout</a>
                </div>
            </div>
        </div>
    </div>

    
    <div class="header-separator"></div>
</header>

<!-- CONTENT AREA -->
<main class="content-area">
    {% block content %}{% endblock %}
</main>

<script src="{{ asset('js/main.js') }}"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
