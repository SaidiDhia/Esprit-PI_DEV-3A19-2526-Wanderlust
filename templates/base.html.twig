<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>{% block title %}Wanderlust{% endblock %}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,200,300,400,500,600,700" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('adventure/css/linearicons.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/font-awesome.min.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/bootstrap.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/magnific-popup.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/animate.min.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/owl.carousel.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/nice-select.css') }}">
    <link rel="stylesheet" href="{{ asset('adventure/css/main.css') }}">

    <style>
        body {
            margin: 0;
        }

        .default-header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            z-index: 1000;
            background: #0f172a;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.24);
        }

        .default-header .navbar {
            background: transparent;
            min-height: 72px;
        }

        .default-header .navbar-nav a,
        .default-header .navbar-brand {
            color: #fff !important;
        }

        .default-header .navbar-nav a:hover {
            color: #f6214b !important;
        }

        main {
            min-height: 70vh;
            padding-top: 96px;
        }

        main > .module-hero {
            margin-top: -96px;
            padding-top: 216px !important;
        }

        main > .home-banner {
            margin-top: -96px;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<header class="default-header">
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}" style="font-size:26px;font-weight:700;color:#fff;">
                Wanderlust
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="fa fa-bars" style="color:#fff;"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end align-items-center" id="navbarNav">
                <ul class="navbar-nav">
                    <li><a href="{{ path('app_home') }}">Home</a></li>
                    <li><a href="{{ path('app_booking') }}">Stays</a></li>
                    <li><a href="{{ path('app_activities_index') }}">Activities</a></li>
                    <li><a href="{{ path('app_events_index') }}">Events</a></li>
                    <li><a href="{{ path('app_reservations_index') }}">Reservations</a></li>
                    <li><a href="{{ path('app_messaging') }}">Chat</a></li>
                    <li><a href="{{ path('app_blog') }}">Blog</a></li>
                    <li><a href="{{ path('app_marketplace') }}">Marketplace</a></li>
                    {% if app.user and app.user.isAdmin %}
                        <li><a href="{{ path('app_admin_dashboard') }}">Admin</a></li>
                    {% endif %}
                    {% if app.user %}
                        <li><a href="{{ path('app_logout') }}">Logout</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}">Login</a></li>
                        <li><a href="{{ path('app_signup') }}">Sign up</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    {% block content %}{% endblock %}
</main>

<footer class="footer-area section-gap" style="padding-top:50px; padding-bottom:30px;">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="single-footer-widget">
                    <h6>About Wanderlust</h6>
                    <p>Discover events, activities, stays and stories in one place.</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 col-sm-6 social-widget">
                <div class="single-footer-widget">
                    <h6>Quick Links</h6>
                    <p>
                        <a href="{{ path('app_events_index') }}">Events</a> |
                        <a href="{{ path('app_activities_index') }}">Activities</a> |
                        <a href="{{ path('app_reservations_index') }}">Reservations</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="{{ asset('adventure/js/vendor/jquery-2.2.4.min.js') }}"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.11.0/umd/popper.min.js" crossorigin="anonymous"></script>
<script src="{{ asset('adventure/js/vendor/bootstrap.min.js') }}"></script>
<script src="{{ asset('adventure/js/jquery.sticky.js') }}"></script>
<script src="{{ asset('adventure/js/owl.carousel.min.js') }}"></script>
<script src="{{ asset('adventure/js/jquery.nice-select.min.js') }}"></script>
<script src="{{ asset('adventure/js/jquery.magnific-popup.min.js') }}"></script>
<script src="{{ asset('adventure/js/main.js') }}"></script>

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
/* Premium SweetAlert2 Styling */
.swal2-popup.premium-swal {
    border-radius: 20px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    font-family: 'Outfit', 'Poppins', sans-serif;
    border: 1px solid #e2e8f0;
}
.swal2-popup.premium-swal .swal2-header {
    border-top: 8px solid #0f375b; /* Top blue border */
    padding-top: 35px;
    background: #ffffff;
}
.swal2-popup.premium-swal .swal2-icon {
    border: none !important;
    background: #0f375b !important;
    color: white !important;
    font-size: 1.2rem;
    width: 70px;
    height: 70px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.swal2-popup.premium-swal .swal2-icon.swal2-success .swal2-success-ring {
    border: none;
}
.swal2-popup.premium-swal .swal2-icon.swal2-success [class^="swal2-success-line"] {
    background-color: white !important;
}
/* For warnings / errors */
.swal2-popup.premium-swal .swal2-icon.swal2-warning, 
.swal2-popup.premium-swal .swal2-icon.swal2-error {
    background: #f87171 !important;
    color: white !important;
}
.swal2-popup.premium-swal .swal2-title {
    color: #0f375b;
    font-weight: 700;
    font-size: 1.8rem;
    padding-bottom: 5px;
}
.swal2-popup.premium-swal .swal2-html-container {
    color: #64748b;
    font-size: 1.05rem;
    font-weight: 400;
    margin: 15px 30px 30px;
    line-height: 1.5;
}
.swal2-popup.premium-swal .swal2-actions {
    background: #ffffff;
    padding-bottom: 30px;
    width: 100%;
}
.swal2-popup.premium-swal .swal2-confirm {
    background-color: #0f375b !important;
    color: white !important;
    border-radius: 50px !important;
    padding: 14px 35px !important;
    font-size: 1.05rem !important;
    font-weight: 600 !important;
    width: 85%;
    margin: 0 auto 15px !important;
    box-shadow: 0 4px 15px rgba(15, 55, 91, 0.2);
    transition: all 0.3s ease;
}
.swal2-popup.premium-swal .swal2-confirm:hover {
    background-color: #092440 !important;
    transform: translateY(-2px);
}
.swal2-popup.premium-swal .swal2-cancel {
    background-color: #f1f5f9 !important;
    color: #475569 !important;
    border-radius: 50px !important;
    padding: 14px 35px !important;
    font-size: 1.05rem !important;
    font-weight: 600 !important;
    width: 85%;
    margin: 0 auto !important;
    transition: all 0.3s ease;
}
.swal2-popup.premium-swal .swal2-cancel:hover {
    background-color: #e2e8f0 !important;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Transform basic Bootstrap flashes into Premium SweetAlerts
    const flashes = document.querySelectorAll('.alert-success, .alert-danger, .alert-warning, .alert-info');
    let hasShownGlobalAlert = false;

    flashes.forEach(flash => {
        const text = flash.innerText.trim();
        flash.style.display = 'none'; // Hide the boring native alert
        
        let type = 'info';
        if (flash.classList.contains('alert-success')) type = 'success';
        if (flash.classList.contains('alert-danger')) type = 'error';
        if (flash.classList.contains('alert-warning')) type = 'warning';
        
        if (!hasShownGlobalAlert) {
            Swal.fire({
                icon: type,
                title: type === 'success' ? 'Success' : 'Notification',
                text: text,
                customClass: { popup: 'premium-swal' },
                confirmButtonText: 'Continue',
                buttonsStyling: false
            });
            hasShownGlobalAlert = true;
        }
    });

    // 2. Intercept Default Deletion Forms
    const forms = document.querySelectorAll('form');
    forms.forEach(form => {
        const onsubmitStr = form.getAttribute('onsubmit');
        // Check if it's using the standard JS confirm dialog
        if (onsubmitStr && onsubmitStr.includes('confirm(')) {
            // Remove native confirm
            form.removeAttribute('onsubmit');
            
            // Add modern SweetAlert interception
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Êtes-vous sûr ?',
                    text: 'Cette action est irréversible.',
                    showCancelButton: true,
                    confirmButtonText: 'Oui, continuer',
                    cancelButtonText: 'Annuler',
                    customClass: { popup: 'premium-swal' },
                    buttonsStyling: false,
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        }
    });
});
</script>
{% endblock %}
{% block importmap %}{{ importmap('app') }}{% endblock %}
</body>
</html>
