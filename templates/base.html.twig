<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Wanderlust Blog{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/style.css') }}">
    <style>
        body { background: #EFF6FF; font-family: 'Segoe UI', Arial, sans-serif; }
        .navbar-custom { background: #1E40AF; box-shadow: 0 4px 10px rgba(30,64,175,0.2); }
        .navbar-custom .navbar-brand, .navbar-custom .nav-link { color: #fff; }
        .navbar-custom .nav-link:hover { background: rgba(255,255,255,0.1); border-radius: 8px; }
        .card-post { background: #fff; border-radius: 14px; box-shadow: 0 8px 20px rgba(0,0,0,0.05); transition: all 0.2s; }
        .card-post:hover { box-shadow: 0 12px 28px rgba(30,64,175,0.12); transform: translateY(-2px); }
        .btn-primary-custom { background: #1E40AF; border: none; border-radius: 9px; padding: 6px 18px; font-weight: bold; }
        .btn-primary-custom:hover { background: #2D59C7; }
        .comment-bubble { background: #F8FAFF; border-radius: 14px; padding: 12px; border-left: 4px solid #3B82F6; }
        .reaction-btn { background: transparent; border: none; color: #6B7280; font-size: 14px; transition: 0.1s; }
        .reaction-btn.active { color: #EF4444; font-weight: bold; }
        .admin-sidebar { background: #1E3A8A; min-height: 100vh; }
        .admin-sidebar .nav-link { color: #BFDBFE; border-radius: 0; padding: 12px 20px; border-left: 3px solid transparent; }
        .admin-sidebar .nav-link.active { background: #2D59C7; color: white; border-left-color: #60A5FA; }
        .admin-table-header { background: #F8FAFF; font-size: 0.75rem; font-weight: bold; color: #6B7280; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom px-4">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="{{ path('blog_index') }}">✦ Wanderlust Blog</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('blog_index') }}">Accueil</a></li>
                    {% if userResolver.currentUser is defined and userResolver.currentUser %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('blog_post_new') }}">✎ Nouveau post</a></li>
                        {% if userResolver.isAdmin is defined and userResolver.isAdmin %}
                            <li class="nav-item"><a class="nav-link" href="{{ path('admin_dashboard') }}">🛡 Admin</a></li>
                        {% endif %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('logout') }}">🚪 Déconnexion</a></li>
                    {% else %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('login_switch') }}">🔑 Connexion</a></li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $('.react-btn').click(function(e) {
            e.preventDefault();
            let btn = $(this);
            let url = btn.data('url');
            $.post(url, {}, function(data) {
                btn.html('♥ ' + data.count);
                if (data.added) btn.addClass('active'); else btn.removeClass('active');
            });
        });
        $('.react-comment-btn').click(function(e) {
            e.preventDefault();
            let btn = $(this);
            let url = btn.data('url');
            $.post(url, {}, function(data) {
                btn.html('♥ ' + data.count);
                if (data.added) btn.addClass('active'); else btn.removeClass('active');
            });
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>